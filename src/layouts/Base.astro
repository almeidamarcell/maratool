---
import { lastmodBySlug } from '../data/lastmod-generated'
import { tools } from '../data/tools'

interface Props {
  title: string
  description: string
  canonical: string
  schema: Record<string, unknown>
  faqSchema?: Record<string, unknown>
  breadcrumbSchema?: Record<string, unknown>
  ogImage?: string
  noindex?: boolean
  // 'tool' = individual tool pages. Anything else loads the heavier
  // discovery.css with hub/all/home-specific styles.
  scope?: 'tool' | 'hub' | 'home' | 'all' | 'subcategory' | 'page'
}

const { title, description, canonical, schema, faqSchema, breadcrumbSchema, ogImage, noindex, scope = 'tool' } = Astro.props
const loadDiscoveryCSS = scope !== 'tool'

// Inject dateModified into the page schema if we can match this page's URL
// to a known tool slug. Schema can opt out by setting dateModified themselves.
const canonicalSlug = canonical.replace(/^https?:\/\/maratool\.com\//, '').replace(/\/$/, '')
const inferredLastmod = lastmodBySlug[canonicalSlug]
const enrichedSchema = (
  inferredLastmod && !('dateModified' in schema)
    ? { ...schema, dateModified: inferredLastmod }
    : schema
)

// Resolve OG image: explicit prop wins. Otherwise pick a per-vertical OG
// image based on the canonical URL — covers hub pages, subcategory pages,
// and individual tool pages (looked up via tools.ts).
const VERTICAL_OG = [
  'developer', 'health', 'image', 'text', 'color',
  'converter', 'marketing', 'mockup', 'pdf',
]
function ogImageForCanonical(): string {
  const path = canonicalSlug
  // /developer, /developer/foo, /health, /health/bar, etc.
  const first = path.split('/')[0]?.toLowerCase()
  if (first && VERTICAL_OG.includes(first)) {
    return `https://maratool.com/og/${first}.svg`
  }
  // Tool slug — look up category.
  const tool = tools.find(t => t.slug === path)
  if (tool) {
    const cat = tool.category.toLowerCase()
    if (VERTICAL_OG.includes(cat)) {
      return `https://maratool.com/og/${cat}.svg`
    }
  }
  return 'https://maratool.com/og-image.png'
}
const resolvedOgImage = ogImage ?? ogImageForCanonical()

const canonicalURL = new URL(
  canonical.endsWith('/') ? canonical : canonical + '/',
  Astro.site
)

const orgSchema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'maratool',
  url: 'https://maratool.com',
  logo: 'https://maratool.com/favicon.svg',
  sameAs: [
    'https://marcell.com.br',
    'https://github.com/almeidamarcell/maratool',
  ],
  founder: {
    '@type': 'Person',
    name: 'Marcell Almeida',
    url: 'https://marcell.com.br',
  },
  contactPoint: {
    '@type': 'ContactPoint',
    email: 'maratool@marcell.com.br',
    contactType: 'customer support',
  },
}

const normalizedBreadcrumb = breadcrumbSchema
  ? {
      ...breadcrumbSchema,
      itemListElement: (breadcrumbSchema.itemListElement as Array<Record<string, unknown>>).map((item) => ({
        ...item,
        item: typeof item.item === 'string' && !item.item.endsWith('/') ? item.item + '/' : item.item,
      })),
    }
  : undefined
---
<!DOCTYPE html>
<html lang="en">
  <head>
    <script is:inline>if(new URLSearchParams(window.location.search).get('embed')==='1'){document.documentElement.classList.add('embed')}</script>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    {noindex && <meta name="robots" content="noindex,follow" />}

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="en_US" />
    <meta property="og:url" content={canonicalURL.toString()} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={resolvedOgImage} />
    <meta property="og:site_name" content="maratool" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={resolvedOgImage} />

    <link rel="canonical" href={canonicalURL.toString()} />
    <link rel="icon" href="/favicon.ico" />
    <link rel="author" href="/humans.txt" />

    <!-- Google Fonts preconnect -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&family=Inter:wght@400;500;600&display=swap" rel="stylesheet" />

    <!-- Stylesheets -->
    <link rel="stylesheet" href="/styles/global.css" />
    <link rel="stylesheet" href="/styles/layout.css" />
    <link rel="stylesheet" href="/styles/tools.css" />
    <link rel="stylesheet" href="/styles/health-tools.css" />
    <link rel="stylesheet" href="/styles/discovery-shared.css" />
    {loadDiscoveryCSS && <link rel="stylesheet" href="/styles/discovery.css" />}

    <!-- Organization JSON-LD (site-wide) -->
    <script type="application/ld+json" set:html={JSON.stringify(orgSchema)} />

    <!-- WebApplication JSON-LD -->
    <script type="application/ld+json" set:html={JSON.stringify(enrichedSchema)} />

    <!-- FAQPage JSON-LD (optional) -->
    {faqSchema && <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />}

    <!-- BreadcrumbList JSON-LD (optional) -->
    {normalizedBreadcrumb && <script type="application/ld+json" set:html={JSON.stringify(normalizedBreadcrumb)} />}

    <meta name="theme-color" content="#ffffff" />
  </head>
  <body>
    <slot />
    <script is:inline>
      if (new URLSearchParams(window.location.search).get('embed') !== '1') {
        var s = document.createElement('script')
        s.src = 'https://marapulse.com/widget.js'
        s.setAttribute('data-board', '218bd8fb-7300-47c3-8c62-6a1746688729')
        s.setAttribute('data-color', '#2563eb')
        document.body.appendChild(s)
      }
    </script>
  </body>
</html>
