---
import Base from '../layouts/Base.astro'
import Layout from '../components/Layout.astro'
import ToolShell from '../components/ToolShell.astro'

const seo = {
  title: 'Rotate Video Online — Free Video Rotator | maratool',
  description: 'Rotate videos online for free — 90°, 180°, or 270° on MP4, WebM, and MOV. Runs in your browser, no upload, no watermark, no signup.',
  canonical: 'https://maratool.com/rotate-video',
  schema: {
    '@context': 'https://schema.org',
    '@type': 'WebApplication',
    name: 'Rotate Video Online',
    url: 'https://maratool.com/rotate-video',
    applicationCategory: 'UtilitiesApplication',
    operatingSystem: 'Any',
    offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
    description: 'Rotate MP4, WebM, and MOV videos by 90, 180, or 270 degrees directly in your browser. No upload, no watermark.',
  },
  breadcrumbSchema: {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://maratool.com' },
      { '@type': 'ListItem', position: 2, name: 'Converter', item: 'https://maratool.com/converter' },
      { '@type': 'ListItem', position: 3, name: 'Video', item: 'https://maratool.com/converter/video' },
      { '@type': 'ListItem', position: 4, name: 'Rotate Video', item: 'https://maratool.com/rotate-video' },
    ],
  },
  faqSchema: {
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: [
      {
        '@type': 'Question',
        name: 'How do I rotate a video that was filmed sideways?',
        acceptedAnswer: { '@type': 'Answer', text: 'Upload the video, pick "90° CW" or "90° CCW" depending on which way it is tilted, then click "Rotate video". The corrected video downloads in seconds — all in your browser, no upload required.' }
      },
      {
        '@type': 'Question',
        name: 'Will rotating the video reduce quality?',
        acceptedAnswer: { '@type': 'Answer', text: 'Rotation requires re-encoding the video frames (unlike trimming), so there is a small quality pass. We use high-quality settings (CRF 18 with libx264) so the difference is not visible to the naked eye. The audio stream is always copied losslessly.' }
      },
      {
        '@type': 'Question',
        name: 'Is this video rotator free?',
        acceptedAnswer: { '@type': 'Answer', text: '100% free, no signup, no watermark, no file-size limits beyond what your browser can handle. Your video never leaves your device — everything runs locally using FFmpeg compiled to WebAssembly.' }
      },
      {
        '@type': 'Question',
        name: 'What is the maximum file size?',
        acceptedAnswer: { '@type': 'Answer', text: 'Up to 2 GB on desktop; mobile browsers may struggle above 500 MB. Because nothing is uploaded to a server, the only limit is your device memory.' }
      }
    ]
  }
}

const howTo = [
  'Drop a video file or click to select an MP4, WebM, or MOV.',
  'Choose the rotation — 90° clockwise, 180°, or 90° counter-clockwise.',
  'Click "Rotate video" and download the corrected file.'
]

const faq = [
  { q: 'How do I rotate a video that was filmed sideways?', a: 'Upload the video, pick "90° CW" or "90° CCW" depending on which way it is tilted, then click "Rotate video". The corrected video downloads in seconds — all in your browser, no upload required.' },
  { q: 'Will rotating the video reduce quality?', a: 'Rotation requires re-encoding the video frames (unlike trimming), so there is a small quality pass. We use high-quality settings so the difference is not visible to the naked eye. The audio stream is always copied losslessly.' },
  { q: 'Is this video rotator free?', a: '100% free, no signup, no watermark, no file-size limits beyond what your browser can handle. Your video never leaves your device — everything runs locally using FFmpeg compiled to WebAssembly.' },
  { q: 'What is the maximum file size?', a: 'Up to 2 GB on desktop; mobile browsers may struggle above 500 MB. Because nothing is uploaded to a server, the only limit is your device memory.' },
]

const relatedTools = [
  { slug: 'trim-video', name: 'Trim Video Online' },
  { slug: 'mute-video', name: 'Mute Video Online' },
  { slug: 'video-to-gif', name: 'Video to GIF Converter' },
]

const breadcrumbs = [
  { label: 'Home', href: '/' },
  { label: 'Converter', href: '/converter' },
  { label: 'Video', href: '/converter/video' },
  { label: 'Rotate Video' },
]
---
<Base {...seo}>
  <Layout>
    <ToolShell slug="rotate-video" name="Rotate Video Online" description="Rotate MP4, WebM, and MOV videos by 90, 180, or 270 degrees in your browser. No upload, no watermark, no signup." howTo={howTo} faq={faq} relatedTools={relatedTools} breadcrumbs={breadcrumbs}>
      <div class="tool-container" style="min-height:400px;">
        <!-- Mobile banner -->
        <div class="rv-mobile-banner" id="rv-mobile-banner" style="display:none;">
          <span>This works on mobile but is faster on desktop. Files above 500 MB may fail on phones.</span>
          <button type="button" class="rv-mobile-banner-dismiss" id="rv-mobile-banner-dismiss" aria-label="Dismiss">&times;</button>
        </div>

        <!-- Drop zone -->
        <div class="rv-dropzone" id="rv-dropzone">
          <input type="file" id="rv-file-input" accept="video/mp4,video/webm,video/quicktime" hidden />
          <div class="rv-dropzone-inner">
            <svg class="rv-upload-icon" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
              <polyline points="17 8 12 3 7 8"/>
              <line x1="12" y1="3" x2="12" y2="15"/>
            </svg>
            <p class="rv-dropzone-title">Drop a video here</p>
            <p class="rv-dropzone-sub">or click to select a file</p>
            <p class="rv-dropzone-formats">MP4, WebM, MOV — up to 2 GB</p>
          </div>
        </div>

        <div class="rv-info" id="rv-info">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="16" x2="12" y2="12"/><line x1="12" y1="8" x2="12.01" y2="8"/></svg>
          <span>The FFmpeg engine (~25 MB) downloads on first use and is cached by your browser. Rotation re-encodes the video; audio is always copied losslessly.</span>
        </div>

        <!-- Settings / editor -->
        <div class="rv-settings" id="rv-settings" style="display:none;">
          <div class="rv-preview-row">
            <div class="rv-video-wrap">
              <video id="rv-video" controls preload="metadata"></video>
            </div>
            <div class="rv-metadata">
              <div class="rv-stat">
                <span class="rv-stat-value" id="rv-duration">—</span>
                <span class="rv-stat-label">Duration</span>
              </div>
              <div class="rv-stat">
                <span class="rv-stat-value" id="rv-dimensions">—</span>
                <span class="rv-stat-label">Resolution</span>
              </div>
              <div class="rv-stat">
                <span class="rv-stat-value" id="rv-filesize">—</span>
                <span class="rv-stat-label">File size</span>
              </div>
            </div>
          </div>

          <!-- Rotation selector -->
          <div class="rv-section">
            <span class="rv-section-label">Rotation</span>
            <div class="rv-rotation-row">
              <button type="button" class="rv-rotation-btn" data-rotation="90ccw" aria-label="Rotate 90 degrees counter-clockwise">
                <span class="rv-rotation-icon">&#8634;</span>
                <span class="rv-rotation-label">90° CCW</span>
              </button>
              <button type="button" class="rv-rotation-btn" data-rotation="180" aria-label="Rotate 180 degrees">
                <span class="rv-rotation-icon">&#8635;</span>
                <span class="rv-rotation-label">180°</span>
              </button>
              <button type="button" class="rv-rotation-btn" data-rotation="90cw" aria-label="Rotate 90 degrees clockwise">
                <span class="rv-rotation-icon">&#8635;</span>
                <span class="rv-rotation-label">90° CW</span>
              </button>
            </div>
          </div>

          <div class="rv-actions">
            <button class="tool-button" id="rv-rotate" disabled>Rotate video</button>
            <button class="copy-btn" id="rv-change">Change video</button>
          </div>
        </div>

        <!-- Progress -->
        <div class="rv-progress" id="rv-progress" style="display:none;">
          <div class="rv-progress-text" id="rv-progress-text">Loading FFmpeg...</div>
          <div class="rv-progress-track">
            <div class="rv-progress-fill" id="rv-progress-fill"></div>
          </div>
          <div class="rv-progress-detail" id="rv-progress-detail"></div>
        </div>

        <!-- Error -->
        <div class="rv-error" id="rv-error" style="display:none;">
          <span class="rv-error-text" id="rv-error-text"></span>
          <button class="rv-error-retry" id="rv-error-retry">Try again</button>
        </div>

        <!-- Result -->
        <div class="rv-result" id="rv-result" style="display:none;">
          <div class="rv-result-preview">
            <video id="rv-result-video" controls></video>
          </div>
          <div class="rv-result-stats" id="rv-result-stats"></div>
          <div class="rv-result-actions">
            <button class="tool-button" id="rv-download">Download rotated video</button>
            <button class="copy-btn" id="rv-new">Rotate another</button>
          </div>
        </div>
      </div>
    </ToolShell>
  </Layout>
</Base>
<style is:global>
  /* Mobile banner */
  .rv-mobile-banner {
    display: flex; align-items: center; justify-content: space-between; gap: 0.75rem;
    padding: 0.625rem 0.875rem; margin-bottom: 1rem;
    background: var(--bg-soft); border: 1px solid var(--border); border-radius: var(--radius);
    font-size: 0.8125rem; color: var(--text-2);
  }
  .rv-mobile-banner-dismiss {
    background: none; border: none; font-size: 1.25rem; line-height: 1; cursor: pointer;
    color: var(--text-3); padding: 0 0.25rem;
  }
  .rv-mobile-banner-dismiss:hover { color: var(--text); }

  /* Dropzone */
  .rv-dropzone {
    border: 2px dashed var(--border);
    border-radius: var(--radius);
    padding: 3rem 2rem;
    text-align: center;
    cursor: pointer;
    transition: border-color 0.2s, background 0.2s;
  }
  .rv-dropzone:hover, .rv-dropzone.drag-over {
    border-color: var(--accent);
    background: var(--bg-soft);
  }
  .rv-dropzone-inner {
    display: flex; flex-direction: column; align-items: center; gap: 0.5rem;
  }
  .rv-upload-icon { color: var(--text-3); margin-bottom: 0.5rem; }
  .rv-dropzone-title { font-size: 1.125rem; font-weight: 600; color: var(--text); margin: 0; }
  .rv-dropzone-sub { font-size: 0.875rem; color: var(--text-2); margin: 0; }
  .rv-dropzone-formats { font-size: 0.75rem; color: var(--text-3); margin: 0.25rem 0 0; }

  .rv-info {
    display: flex; align-items: flex-start; gap: 0.5rem;
    padding: 0.75rem 1rem; background: var(--bg-soft);
    border: 1px solid var(--border); border-radius: var(--radius);
    margin-top: 1rem; font-size: 0.8125rem; color: var(--text-2); line-height: 1.5;
  }
  .rv-info svg { flex-shrink: 0; margin-top: 1px; color: var(--text-3); }

  /* Editor */
  .rv-preview-row {
    display: flex; gap: 1.5rem; margin-bottom: 1.25rem;
  }
  .rv-video-wrap { flex: 1; min-width: 0; }
  .rv-video-wrap video {
    width: 100%; border-radius: var(--radius);
    border: 1px solid var(--border); background: #000;
  }
  .rv-metadata {
    display: flex; flex-direction: column; gap: 1rem; min-width: 130px;
  }
  .rv-stat { display: flex; flex-direction: column; gap: 0.125rem; }
  .rv-stat-value {
    font-size: 1.125rem; font-weight: 600; color: var(--text);
    font-family: var(--font-mono);
  }
  .rv-stat-label {
    font-size: 0.75rem; color: var(--text-3);
    text-transform: uppercase; letter-spacing: 0.05em;
  }

  .rv-section {
    background: var(--bg-soft); border: 1px solid var(--border);
    border-radius: var(--radius); padding: 1rem; margin-bottom: 1rem;
  }
  .rv-section-label {
    display: block; font-size: 0.8125rem; font-weight: 600;
    color: var(--text-2); text-transform: uppercase;
    letter-spacing: 0.05em; margin-bottom: 0.75rem;
  }

  /* Rotation buttons */
  .rv-rotation-row {
    display: flex; gap: 0.75rem;
  }
  .rv-rotation-btn {
    flex: 1; display: flex; flex-direction: column; align-items: center; gap: 0.375rem;
    padding: 0.875rem 1rem;
    background: var(--bg); border: 2px solid var(--border);
    border-radius: var(--radius); cursor: pointer;
    transition: border-color 0.15s, background 0.15s;
    color: var(--text-2);
  }
  .rv-rotation-btn:hover {
    border-color: var(--accent); color: var(--accent); background: var(--bg-soft);
  }
  .rv-rotation-btn.active {
    border-color: var(--accent); background: var(--bg-soft); color: var(--accent);
  }
  .rv-rotation-icon {
    font-size: 1.75rem; line-height: 1;
  }
  .rv-rotation-label {
    font-size: 0.8125rem; font-weight: 600;
  }

  .rv-actions {
    display: flex; gap: 0.75rem; align-items: center; margin-top: 0.25rem;
  }

  /* Progress */
  .rv-progress { text-align: center; padding: 2rem; }
  .rv-progress-text {
    font-size: 0.9375rem; font-weight: 600; color: var(--text); margin-bottom: 1rem;
  }
  .rv-progress-track {
    width: 100%; max-width: 400px; height: 8px; background: var(--bg-hover);
    border-radius: 4px; margin: 0 auto; overflow: hidden;
  }
  .rv-progress-fill {
    height: 100%; background: var(--accent); border-radius: 4px;
    width: 0%; transition: width 0.3s;
  }
  .rv-progress-detail {
    font-size: 0.75rem; color: var(--text-3); margin-top: 0.5rem;
  }

  /* Error */
  .rv-error {
    background: var(--error-bg); border: 1px solid var(--error-border);
    border-radius: var(--radius); padding: 1rem;
    display: flex; align-items: center; justify-content: space-between; gap: 1rem;
  }
  .rv-error-text { color: #c53030; font-size: 0.875rem; }
  .rv-error-retry {
    padding: 6px 14px; background: var(--bg); border: 1px solid var(--border);
    border-radius: 6px; font-size: 0.8125rem; cursor: pointer; white-space: nowrap;
    color: var(--text);
  }
  .rv-error-retry:hover { background: var(--bg-hover); }

  /* Result */
  .rv-result-preview {
    text-align: center; margin-bottom: 0.75rem;
    border: 1px solid var(--border); border-radius: var(--radius);
    padding: 0.5rem; min-height: 100px;
    display: flex; align-items: center; justify-content: center;
    background: var(--bg-soft);
  }
  .rv-result-preview video { max-width: 100%; max-height: 500px; border-radius: 6px; background: #000; }
  .rv-result-stats {
    font-size: 0.875rem; color: var(--text-2); margin-bottom: 0.75rem;
    text-align: center; line-height: 1.6;
  }
  .rv-result-actions {
    display: flex; gap: 0.75rem; align-items: center; justify-content: center;
  }

  @media (max-width: 768px) {
    .rv-preview-row { flex-direction: column; }
    .rv-metadata { flex-direction: row; min-width: 0; flex-wrap: wrap; }
    .rv-rotation-row { flex-direction: column; }
  }
</style>
<script src="../tools/rotate-video.js"></script>
