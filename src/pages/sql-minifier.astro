---
import Base from '../layouts/Base.astro'
import Layout from '../components/Layout.astro'
import ToolShell from '../components/ToolShell.astro'

const seo = {
  title: 'SQL Minifier — Minify SQL Online | maratool',
  description: 'Minify SQL online by removing comments and extra whitespace. Paste messy queries and copy compact output instantly. Free tool, runs in your browser.',
  canonical: 'https://maratool.com/sql-minifier',
  schema: {
    '@context': 'https://schema.org',
    '@type': 'WebApplication',
    name: 'SQL Minifier — Minify SQL Online',
    url: 'https://maratool.com/sql-minifier',
    applicationCategory: 'DeveloperApplication',
    operatingSystem: 'Any',
    offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
    description: 'Minify SQL online by removing comments and extra whitespace. Paste messy queries and copy compact output instantly. Free tool, runs in your browser.',
  },
  breadcrumbSchema: {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://maratool.com' },
      { '@type': 'ListItem', position: 2, name: 'Developer', item: 'https://maratool.com/developer' },
      { '@type': 'ListItem', position: 3, name: 'SQL', item: 'https://maratool.com/developer/sql' },
      { '@type': 'ListItem', position: 4, name: 'SQL Minifier — Minify SQL Online', item: 'https://maratool.com/sql-minifier' },
    ],
  },
  faqSchema: {
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: [
      { '@type': 'Question', name: 'What does SQL minification remove?', acceptedAnswer: { '@type': 'Answer', text: 'Line and block comments, extra spaces, and line breaks while keeping the query executable.' } },
      { '@type': 'Question', name: 'Does minification change SQL meaning?', acceptedAnswer: { '@type': 'Answer', text: 'No. It only removes comments and redundant whitespace outside string literals.' } },
      { '@type': 'Question', name: 'Which SQL dialects are supported?', acceptedAnswer: { '@type': 'Answer', text: 'Standard SQL comment syntax (-- and /* */) is handled for most databases.' } },
      { '@type': 'Question', name: 'Is my SQL sent to a server?', acceptedAnswer: { '@type': 'Answer', text: 'No. Minification happens entirely in your browser.' } }
    ]
  }
}

const howTo = [
  'Paste your SQL query in the input box.',
  'Minified output updates automatically as you type.',
  'Click Copy to copy the compact SQL.'
]

const faq = [
  { q: 'What does SQL minification remove?', a: 'Line and block comments, extra spaces, and line breaks while keeping the query executable.' },
  { q: 'Does minification change SQL meaning?', a: 'No. It only removes comments and redundant whitespace outside string literals.' },
  { q: 'Which SQL dialects are supported?', a: 'Standard SQL comment syntax (-- and /* */) is handled for most databases.' },
  { q: 'Is my SQL sent to a server?', a: 'No. Minification happens entirely in your browser.' }
]

const relatedTools = [
  { slug: 'sql-formatter', name: 'SQL Formatter' },
  { slug: 'sql-insert-generator', name: 'SQL INSERT Generator' },
  { slug: 'sql-create-table-generator', name: 'CREATE TABLE Generator' }
]

const breadcrumbs = [
  { label: 'Home', href: '/' },
  { label: 'Developer', href: '/developer' },
  { label: 'SQL', href: '/developer/sql' },
  { label: 'SQL Minifier' }
]
---
<Base {...seo}>
  <Layout>
    <ToolShell slug="sql-minifier" name="SQL Minifier — Minify SQL Online" description="Paste SQL to strip comments and collapse whitespace. Minified output updates automatically with a one-click copy button." howTo={howTo} faq={faq} relatedTools={relatedTools} breadcrumbs={breadcrumbs}>
      <div class="tool-container" style="min-height:480px;">
        <label class="tool-label" for="sm-input">SQL input</label>
        <textarea id="sm-input" class="tool-textarea" rows="8" placeholder="SELECT id, name FROM users WHERE active = 1"></textarea>
        <div style="display:flex;justify-content:space-between;align-items:center;margin:1rem 0 0.5rem;">
          <label class="tool-label" style="margin:0;">Minified output</label>
          <button type="button" id="sm-copy" class="copy-btn">Copy</button>
        </div>
        <pre id="sm-output" class="tool-output" style="min-height:120px;white-space:pre-wrap;"></pre>
      </div>
    </ToolShell>
  </Layout>
</Base>

<script src="../tools/sql-minifier.js"></script>
