---
import Base from '../../layouts/Base.astro'
import Layout from '../../components/Layout.astro'
import Breadcrumb from '../../components/Breadcrumb.astro'
import { comparePairs } from '../../data/compare-pairs'
import { tools } from '../../data/tools'

export function getStaticPaths() {
  return comparePairs.map(pair => ({
    params: { pair: pair.slug },
    props: { pair },
  }))
}

const { pair } = Astro.props

const toolA = tools.find(t => t.slug === pair.toolA)
const toolB = tools.find(t => t.slug === pair.toolB)

if (!toolA || !toolB) {
  throw new Error(`compare-pair "${pair.slug}" references missing tool: ${pair.toolA} or ${pair.toolB}`)
}

const canonical = `https://maratool.com/compare/${pair.slug}`

const seo = {
  title: pair.metaTitle,
  description: pair.metaDescription,
  canonical,
  scope: 'page' as const,
  schema: {
    '@context': 'https://schema.org',
    '@type': 'WebPage',
    name: pair.title,
    url: canonical,
    description: pair.metaDescription,
    about: [
      { '@type': 'Thing', name: toolA.name, url: `https://maratool.com/${toolA.slug}` },
      { '@type': 'Thing', name: toolB.name, url: `https://maratool.com/${toolB.slug}` },
    ],
  },
  breadcrumbSchema: {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://maratool.com' },
      { '@type': 'ListItem', position: 2, name: 'Compare', item: 'https://maratool.com/compare' },
      { '@type': 'ListItem', position: 3, name: pair.title, item: canonical },
    ],
  },
  faqSchema: {
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: pair.faq.map(item => ({
      '@type': 'Question',
      name: item.q,
      acceptedAnswer: { '@type': 'Answer', text: item.a },
    })),
  },
}

const breadcrumbs = [
  { label: 'Home', href: '/' },
  { label: pair.title },
]
---
<Base {...seo}>
  <Layout scope="page">
    <article class="compare-page">
      <Breadcrumb crumbs={breadcrumbs} />
      <h1>{pair.title}</h1>
      <p class="compare-deck">
        A side-by-side comparison of <a href={`/${toolA.slug}`}>{toolA.name}</a> and <a href={`/${toolB.slug}`}>{toolB.name}</a>.
      </p>

      <section class="compare-intro" set:html={pair.intro} />

      <h2>When to use {toolA.name}</h2>
      <div set:html={pair.whenToUseA} />

      <h2>When to use {toolB.name}</h2>
      <div set:html={pair.whenToUseB} />

      <h2>Side-by-side comparison</h2>
      <div class="compare-table-wrap">
        <table class="compare-table">
          <thead>
            <tr>
              <th></th>
              <th><a href={`/${toolA.slug}`}>{toolA.name.replace(/\s+(Calculator|Score|Tool)\s*$/i, '')}</a></th>
              <th><a href={`/${toolB.slug}`}>{toolB.name.replace(/\s+(Calculator|Score|Tool)\s*$/i, '')}</a></th>
            </tr>
          </thead>
          <tbody>
            {pair.comparison.map(row => (
              <tr>
                <th scope="row">{row.feature}</th>
                <td>{row.a}</td>
                <td>{row.b}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>

      <h2>Bottom line</h2>
      <p class="compare-bottom-line">{pair.bottomLine}</p>

      <h2>Frequently asked questions</h2>
      {pair.faq.map(item => (
        <div class="faq-item">
          <h3 class="faq-question">{item.q}</h3>
          <p class="faq-answer">{item.a}</p>
        </div>
      ))}

      <h2>Use the calculators</h2>
      <div class="compare-cta-row">
        <a class="compare-cta" href={`/${toolA.slug}`}>
          <strong>{toolA.name}</strong>
          <span>{toolA.description}</span>
        </a>
        <a class="compare-cta" href={`/${toolB.slug}`}>
          <strong>{toolB.name}</strong>
          <span>{toolB.description}</span>
        </a>
      </div>
    </article>
  </Layout>
</Base>

<style is:global>
  .compare-page {
    max-width: 760px;
    padding: 1.5rem 0 3rem;
  }
  .compare-page h1 {
    font-size: 2rem;
    margin: 0.5rem 0 0.5rem;
    font-weight: 700;
    line-height: 1.2;
  }
  .compare-deck {
    font-size: 16px;
    color: var(--text-2);
    margin: 0 0 1.5rem;
    line-height: 1.6;
  }
  .compare-page h2 {
    font-family: var(--font-heading);
    font-style: italic;
    font-weight: 400;
    font-size: 1.5rem;
    margin: 2.25rem 0 0.625rem;
    color: var(--text);
  }
  .compare-page h3 {
    font-size: 1rem;
    font-weight: 600;
    margin: 1.25rem 0 0.375rem;
    color: var(--text);
  }
  .compare-page p {
    font-size: 15px;
    line-height: 1.7;
    color: var(--text);
    margin: 0 0 1rem;
  }
  .compare-page a {
    color: var(--accent);
    text-decoration: none;
  }
  .compare-page a:hover {
    text-decoration: underline;
  }
  .compare-table-wrap {
    overflow-x: auto;
    margin: 0.5rem 0 1.5rem;
    border: 1px solid var(--border);
    border-radius: var(--radius);
  }
  .compare-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 14px;
  }
  .compare-table th,
  .compare-table td {
    text-align: left;
    padding: 10px 14px;
    border-bottom: 1px solid var(--border);
    vertical-align: top;
  }
  .compare-table thead th {
    background: var(--bg-soft);
    font-weight: 600;
    font-size: 14px;
    color: var(--text);
  }
  .compare-table tbody tr:last-child th,
  .compare-table tbody tr:last-child td {
    border-bottom: 0;
  }
  .compare-table tbody th {
    background: var(--bg-soft);
    font-weight: 500;
    color: var(--text-2);
    width: 30%;
  }
  .compare-table tbody td {
    color: var(--text);
  }
  .compare-bottom-line {
    background: var(--bg-soft);
    border-left: 3px solid var(--accent);
    padding: 0.875rem 1.125rem;
    border-radius: 0 var(--radius) var(--radius) 0;
    font-size: 15px;
  }
  .compare-cta-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 12px;
    margin: 0.75rem 0 1rem;
  }
  .compare-cta {
    display: block;
    padding: 1rem 1.125rem;
    border: 1px solid var(--border);
    border-radius: var(--radius);
    background: var(--bg);
    text-decoration: none;
    color: var(--text);
    transition: border-color 0.1s, background 0.1s;
  }
  .compare-cta:hover {
    border-color: var(--accent);
    background: var(--bg-soft);
    text-decoration: none;
  }
  .compare-cta strong {
    display: block;
    font-size: 14.5px;
    margin-bottom: 4px;
    color: var(--text);
  }
  .compare-cta span {
    font-size: 13px;
    color: var(--text-2);
    line-height: 1.5;
  }
  @media (max-width: 600px) {
    .compare-cta-row {
      grid-template-columns: 1fr;
    }
    .compare-table tbody th {
      width: 40%;
    }
  }
</style>
