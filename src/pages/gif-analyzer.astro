---
import Base from '../layouts/Base.astro'
import Layout from '../components/Layout.astro'
import ToolShell from '../components/ToolShell.astro'

const seo = {
  title: 'GIF Analyzer — Inspect Animated GIF Structure | maratool',
  description: 'Inspect animated GIF internals: dimensions, frame count, delays, palettes, and disposal methods. Export metadata as JSON.',
  canonical: 'https://maratool.com/gif-analyzer',
  schema: {
    '@context': 'https://schema.org',
    '@type': 'WebApplication',
    name: 'GIF Analyzer',
    url: 'https://maratool.com/gif-analyzer',
    applicationCategory: 'MultimediaApplication',
    operatingSystem: 'Any',
    offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
    description: 'Inspect animated GIF internals: dimensions, frame count, delays, palettes, and disposal methods. Export metadata as JSON.',
  },
  breadcrumbSchema: {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://maratool.com' },
      { '@type': 'ListItem', position: 2, name: 'Image', item: 'https://maratool.com/image' },
      { '@type': 'ListItem', position: 3, name: 'Inspect', item: 'https://maratool.com/image/inspect' },
      { '@type': 'ListItem', position: 4, name: 'GIF Analyzer', item: 'https://maratool.com/gif-analyzer' },
    ],
  },
  faqSchema: {
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: [
      {
        '@type': 'Question',
        name: 'What can I learn from the analyzer?',
        acceptedAnswer: { '@type': 'Answer', text: 'Dimensions, file size, frame count, loop count, per-frame delays, offsets, disposal methods, and color palettes.' }
      },
      {
        '@type': 'Question',
        name: 'Why inspect GIF structure?',
        acceptedAnswer: { '@type': 'Answer', text: 'Debug broken animations, optimize file size, or understand how a GIF was built.' }
      },
      {
        '@type': 'Question',
        name: 'Color table visualization?',
        acceptedAnswer: { '@type': 'Answer', text: 'Yes — see the actual colors in global and local palettes.' }
      },
      {
        '@type': 'Question',
        name: 'Upload required?',
        acceptedAnswer: { '@type': 'Answer', text: 'No server upload. Parsing happens in your browser.' }
      }
    ]
  }
}

const howTo = [
  'Upload a GIF file.',
  'Review summary stats and per-frame details.',
  'Export the metadata as JSON if needed.'
]
const faq = [
  {
    'q': 'What can I learn from the analyzer?',
    'a': 'Dimensions, file size, frame count, loop count, per-frame delays, offsets, disposal methods, and color palettes.'
  },
  {
    'q': 'Why inspect GIF structure?',
    'a': 'Debug broken animations, optimize file size, or understand how a GIF was built.'
  },
  {
    'q': 'Color table visualization?',
    'a': 'Yes — see the actual colors in global and local palettes.'
  },
  {
    'q': 'Upload required?',
    'a': 'No server upload. Parsing happens in your browser.'
  }
]
const relatedTools = [
  { slug: 'gif-compressor', name: 'Gif Compressor' },
  { slug: 'gif-maker', name: 'Gif Maker' },
  { slug: 'image-compressor', name: 'Image Compressor' },
]
const breadcrumbs = [
  { label: 'Home', href: '/' },
  { label: 'Image', href: '/image' },
  { label: 'Inspect', href: '/image/inspect' },
  { label: 'GIF Analyzer' },
]
---
<Base {...seo}>
  <Layout>
    <ToolShell slug="gif-analyzer" name="GIF Analyzer — Inspect GIF Structure" description="Inspect animated GIF internals: dimensions, frame count, delays, palettes, and disposal methods. Export metadata as JSON." howTo={howTo} faq={faq} relatedTools={relatedTools} breadcrumbs={breadcrumbs}>
      <div class="tool-container gan-root" style="min-height:480px;">
        <div class="gan-dropzone" id="gan-dropzone">
          <input type="file" id="gan-file" hidden />
          <p class="gan-drop-title">Drop a file here</p>
          <p class="gan-drop-sub">or click to select</p>
        </div>
        <div id="gan-workspace" style="display:none;"></div>
        <div id="gan-progress" class="gan-progress" style="display:none;">
          <div id="gan-progress-text">Processing...</div>
          <div class="gan-progress-track"><div id="gan-progress-fill" class="gan-progress-fill"></div></div>
        </div>
        <div id="gan-error" class="gan-error" style="display:none;"><span id="gan-error-text"></span></div>
        <div id="gan-result" style="display:none;"></div>
      </div>
    </ToolShell>
  </Layout>
</Base>
<style is:global>
  .gan-dropzone {
    border: 2px dashed var(--border); border-radius: var(--radius);
    padding: 3rem 2rem; text-align: center; cursor: pointer;
    transition: border-color 0.2s, background 0.2s;
  }
  .gan-dropzone:hover, .gan-dropzone.drag-over { border-color: var(--accent); background: var(--bg-soft); }
  .gan-drop-title { font-size: 1.125rem; font-weight: 600; margin: 0; }
  .gan-drop-sub { font-size: 0.875rem; color: var(--text-2); margin: 0.5rem 0 0; }
  .gan-progress { text-align: center; padding: 2rem; }
  .gan-progress-track { width: 100%; max-width: 400px; height: 8px; background: var(--bg-hover); border-radius: 4px; margin: 1rem auto; overflow: hidden; }
  .gan-progress-fill { height: 100%; background: var(--accent); width: 0%; transition: width 0.3s; }
  .gan-error { background: var(--error-bg); border: 1px solid var(--error-border); border-radius: var(--radius); padding: 1rem; color: #c53030; font-size: 0.875rem; }
  .gan-preview-wrap {
    background: repeating-conic-gradient(#e0e0e0 0% 25%, #fff 0% 50%) 0 0 / 16px 16px;
    border: 1px solid var(--border); border-radius: var(--radius); padding: 0.5rem;
    display: flex; align-items: center; justify-content: center; margin-bottom: 1rem;
  }
  .gan-preview-wrap canvas, .gan-preview-wrap img { max-width: 100%; max-height: 360px; display: block; }
  .gan-controls { display: flex; flex-direction: column; gap: 0.75rem; margin-bottom: 1rem; }
  .gan-row { display: flex; flex-wrap: wrap; gap: 0.75rem; align-items: center; }
  .gan-actions { display: flex; gap: 0.75rem; flex-wrap: wrap; margin-top: 0.5rem; }
</style>
<script src="../tools/gif-analyzer.js"></script>
