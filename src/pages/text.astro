---
import Base from '../layouts/Base.astro'
import Layout from '../components/Layout.astro'
import HubPage from '../components/HubPage.astro'
import { toolsFlatByCategory, subcategoryOrderByCategory } from '../data/tools'

const categoryTools = toolsFlatByCategory.Text ?? []
const subcategories = subcategoryOrderByCategory.Text ?? []

const seo = {
  title: 'Text Tools — maratool',
  description: 'Free browser-based text tools. Compare text, test regex, edit Markdown, format JSON, generate placeholder text — no sign-up, runs in your browser.',
  canonical: 'https://maratool.com/text',
  schema: {
    '@context': 'https://schema.org',
    '@type': 'CollectionPage',
    name: 'Text Tools',
    url: 'https://maratool.com/text',
    description: 'Free browser-based text tools. Compare text, test regex, edit Markdown, format JSON, generate placeholder text — no sign-up, runs in your browser.',
    hasPart: categoryTools.filter(t => t.live).map(tool => ({
      '@type': 'SoftwareApplication',
      name: tool.name,
      url: `https://maratool.com/${tool.slug}`,
      applicationCategory: 'UtilitiesApplication',
    })),
  },
  breadcrumbSchema: {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://maratool.com' },
      { '@type': 'ListItem', position: 2, name: 'Text', item: 'https://maratool.com/text' },
    ],
  },
}

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: 'How to compare two texts side by side?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Paste your two texts into the diff checker and click Compare. maratool highlights added and removed lines with color coding, showing you exactly what changed between the two versions.'
      }
    },
    {
      '@type': 'Question',
      name: 'Can I format JSON without installing a tool?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Yes. Paste your raw JSON into maratool\'s JSON formatter and get properly indented, syntax-highlighted output instantly. It runs in your browser — no extensions, no installs, no sign-up needed.'
      }
    },
    {
      '@type': 'Question',
      name: 'What text tools are available for free?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'maratool offers free text comparison (diff checker), regex testing, Markdown editing with live preview, JSON formatting, Lorem Ipsum generation, reading time calculation, and more — all browser-based with no limits.'
      }
    },
    {
      '@type': 'Question',
      name: 'Is my text data safe when using online text tools?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Yes. All maratool text tools run entirely in your browser using client-side JavaScript. Your text is never sent to any server, making it safe for sensitive content like code, contracts, or personal writing.'
      }
    },
  ]
}
---
<Base {...seo} faqSchema={faqSchema}>
  <Layout scope="hub">
    <HubPage
      category="Text"
      categorySlug="text"
      title="Text tools"
      subtitle="Compare, analyze, edit, format, and generate text — all running locally in your browser."
      tools={categoryTools}
      subcategories={subcategories}
      basePath="/text"
    />
  </Layout>
</Base>
