---
import Base from '../layouts/Base.astro'
import Layout from '../components/Layout.astro'
import ToolShell from '../components/ToolShell.astro'

const seo = {
  title: 'PX to REM Converter — Convert pixels to rem instantly | maratool',
  description: 'Convert px to rem and rem to px instantly with a configurable base font size. Includes a common conversions reference table. Free, no sign-up.',
  canonical: 'https://maratool.com/px-to-rem',
  schema: {
    '@context': 'https://schema.org',
    '@type': 'WebApplication',
    name: 'PX to REM Converter',
    url: 'https://maratool.com/px-to-rem',
    applicationCategory: 'UtilitiesApplication',
    operatingSystem: 'Any',
    offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
    description: 'Convert px to rem and rem to px instantly with a configurable base font size.',
  },
  breadcrumbSchema: {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://maratool.com' },
      { '@type': 'ListItem', position: 2, name: 'Converter', item: 'https://maratool.com/converter' },
      { '@type': 'ListItem', position: 3, name: 'Unit', item: 'https://maratool.com/converter/unit' },
      { '@type': 'ListItem', position: 4, name: 'PX to REM Converter', item: 'https://maratool.com/px-to-rem' },
    ],
  },
  faqSchema: {
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: [
      {
        '@type': 'Question',
        name: 'How do I convert px to rem?',
        acceptedAnswer: { '@type': 'Answer', text: 'Divide the pixel value by the base font size (usually 16px). For example, 24px / 16 = 1.5rem. This tool does it automatically — just enter a pixel value and the rem equivalent appears instantly.' }
      },
      {
        '@type': 'Question',
        name: 'What is the default base font size for rem?',
        acceptedAnswer: { '@type': 'Answer', text: 'The default base font size in all browsers is 16px. This means 1rem = 16px unless you change the font-size on the html element. You can adjust the base size in this tool to match your project.' }
      },
      {
        '@type': 'Question',
        name: 'Why should I use rem instead of px?',
        acceptedAnswer: { '@type': 'Answer', text: 'rem units are relative to the root font size, making your layouts more accessible. Users who change their browser font size will see your design scale proportionally. px values are fixed and ignore user preferences.' }
      },
      {
        '@type': 'Question',
        name: 'How do I convert rem back to px?',
        acceptedAnswer: { '@type': 'Answer', text: 'Multiply the rem value by the base font size. For example, 1.5rem × 16 = 24px. Enter a rem value in the REM field and this tool shows the pixel equivalent instantly.' }
      }
    ]
  }
}

const howTo = [
  'Set your base font size (default is 16px).',
  'Enter a pixel value to get rem, or a rem value to get pixels.',
  'Click any value in the reference table to copy it.'
]

const faq = [
  { q: 'How do I convert px to rem?', a: 'Divide the pixel value by the base font size (usually 16px). For example, 24px / 16 = 1.5rem. This tool does it automatically.' },
  { q: 'What is the default base font size for rem?', a: 'The default base font size in all browsers is 16px. This means 1rem = 16px unless you change the font-size on the html element.' },
  { q: 'Why should I use rem instead of px?', a: 'rem units are relative to the root font size, making your layouts more accessible. Users who change their browser font size will see your design scale proportionally.' },
  { q: 'How do I convert rem back to px?', a: 'Multiply the rem value by the base font size. For example, 1.5rem × 16 = 24px.' }
]

const relatedTools = [
  { slug: 'typography-calculator', name: 'Typography Size Converter — PX, PT, EM, %' },
  { slug: 'line-height-calculator', name: 'Line Height Calculator' },
  { slug: 'unit-converter', name: 'Unit Converter — Length, Weight, Temperature & More' },
]

const breadcrumbs = [
  { label: 'Home', href: '/' },
  { label: 'Converter', href: '/converter' },
  { label: 'Unit', href: '/converter/unit' },
  { label: 'PX to REM Converter' },
]
---
<Base {...seo}>
  <Layout>
    <ToolShell slug="px-to-rem" name="PX to REM Converter" description="Convert pixels to rem and rem to pixels with a configurable base font size." howTo={howTo} faq={faq} relatedTools={relatedTools} breadcrumbs={breadcrumbs}>
      <div class="tool-container">
        <div class="pr-base-row">
          <label class="tool-label" for="pr-base">Base font size</label>
          <div class="pr-base-input-wrap">
            <input type="number" id="pr-base" class="pr-base-input" value="16" min="1" max="200" />
            <span class="pr-unit">px</span>
          </div>
        </div>

        <div class="pr-panels">
          <div class="pr-panel">
            <label class="tool-label" for="pr-px-input">Pixels</label>
            <input type="number" id="pr-px-input" class="tool-input pr-input" placeholder="16" step="any" />
            <div class="pr-result" id="pr-rem-result">&mdash;</div>
            <button class="copy-btn" id="pr-copy-rem">Copy</button>
          </div>
          <div class="pr-panel">
            <label class="tool-label" for="pr-rem-input">REM</label>
            <input type="number" id="pr-rem-input" class="tool-input pr-input" placeholder="1" step="any" />
            <div class="pr-result" id="pr-px-result">&mdash;</div>
            <button class="copy-btn" id="pr-copy-px">Copy</button>
          </div>
        </div>

        <div class="pr-table-wrap">
          <span class="tool-label">Common conversions</span>
          <table class="pr-table">
            <thead><tr><th>Pixels</th><th>REM</th></tr></thead>
            <tbody id="pr-table-body"></tbody>
          </table>
        </div>
      </div>
    </ToolShell>
  </Layout>
</Base>
<style>
  .pr-base-row {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 1.25rem;
  }
  .pr-base-input-wrap {
    display: flex;
    align-items: center;
    gap: 0.375rem;
  }
  .pr-base-input {
    width: 72px;
    font-size: 16px;
    font-weight: 600;
    text-align: center;
    border: 1px solid var(--border);
    border-radius: var(--radius);
    background: var(--bg);
    color: var(--text);
    padding: 6px 8px;
  }
  .pr-unit { font-size: 13px; color: var(--text-3); }

  .pr-panels {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
    margin-bottom: 1.5rem;
  }
  .pr-panel {
    background: var(--bg-soft);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 1rem;
  }
  .pr-input {
    width: 100%;
    font-size: 18px;
    font-family: var(--font-mono);
    margin-bottom: 0.5rem;
  }
  .pr-result {
    font-size: 28px;
    font-weight: 700;
    font-family: var(--font-mono);
    color: var(--text);
    margin-bottom: 0.5rem;
    min-height: 40px;
  }

  .pr-table-wrap { margin-top: 0.5rem; }
  .pr-table {
    width: 100%;
    border-collapse: collapse;
    margin-top: 0.5rem;
  }
  .pr-table th {
    text-align: left;
    font-size: 11px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--text-3);
    padding: 6px 12px;
    border-bottom: 1px solid var(--border);
  }
  .pr-table td {
    padding: 8px 12px;
    font-family: var(--font-mono);
    font-size: 13px;
    color: var(--text);
    border-bottom: 1px solid var(--border);
    cursor: pointer;
    transition: background 0.1s;
  }
  .pr-table tr:hover td { background: var(--bg-soft); }
  .pr-table td.copied { color: var(--accent); }

  @media (max-width: 768px) {
    .pr-panels { grid-template-columns: 1fr; }
  }
</style>
<script src="../tools/px-to-rem.js"></script>
