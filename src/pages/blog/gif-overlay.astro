---
import Base from '../../layouts/Base.astro'
import Layout from '../../components/Layout.astro'

const seo = {
  title: 'How to overlay an image or logo on a GIF | maratool',
  description: 'Overlay a static image or another GIF on top of an animated GIF. Drag to position, resize, set opacity, and download.',
  canonical: 'https://maratool.com/blog/gif-overlay',
  schema: {
    '@context': 'https://schema.org',
    '@type': 'BlogPosting',
    headline: 'How to overlay an image or logo on a GIF',
    image: 'https://maratool.com/og/image.svg',
    datePublished: '2026-06-28',
    dateModified: '2026-06-28',
    author: { '@type': 'Person', name: 'Marcell Almeida', url: 'https://marcell.com.br' },
    publisher: {
      '@type': 'Organization',
      name: 'maratool',
      url: 'https://maratool.com',
      logo: { '@type': 'ImageObject', url: 'https://maratool.com/favicon.svg' },
    },
    mainEntityOfPage: { '@type': 'WebPage', '@id': 'https://maratool.com/blog/gif-overlay' },
    url: 'https://maratool.com/blog/gif-overlay',
    description: 'Overlay a static image or another GIF on top of an animated GIF. Drag to position, resize, set opacity, and download.',
  },
}
---
<Base {...seo}>
  <Layout>
    <article class="blog-post">
      <header class="blog-post-header">
        <div class="blog-post-meta">
          <a href="/blog" class="blog-back">← Blog</a>
          <time datetime="2026-06-28" class="blog-post-date">June 28, 2026</time>
        </div>
        <h1 class="blog-post-title">How to overlay an image or logo on a GIF</h1>
        <p class="blog-post-lead">Add a watermark or logo on top of any animated GIF.</p>
      </header>
      <div class="blog-body">
        <p>The <a href="/gif-overlay">GIF Overlay</a> tool runs entirely in your browser — no upload, no watermark.</p>
        <h2>How it works</h2>
        <ol>
          <li>Upload the base GIF and an overlay image or GIF.</li>
          <li>Drag, resize, and set overlay opacity.</li>
          <li>Apply to all frames or a range, then download.</li>
        </ol>
        <p>Overlay a static image or another GIF on top of an animated GIF. Drag to position, resize, set opacity, and download.</p>
        <hr class="blog-divider" />
        <p class="blog-footer-note">Try the <a href="/gif-overlay">GIF Overlay</a> free at <a href="/image">maratool.com/image</a>.</p>
      </div>
    </article>
  </Layout>
</Base>
