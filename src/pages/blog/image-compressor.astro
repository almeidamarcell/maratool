---
import Base from '../../layouts/Base.astro'
import Layout from '../../components/Layout.astro'

const seo = {
  title: 'How to compress images online — reduce JPG, PNG & WebP size | maratool',
  description: 'Compress JPG, PNG, and WebP images in your browser. Side-by-side preview, savings percentage, and EXIF strip.',
  canonical: 'https://maratool.com/blog/image-compressor',
  schema: {
    '@context': 'https://schema.org',
    '@type': 'BlogPosting',
    headline: 'How to compress JPG, PNG, and WebP images in your browser',
    image: 'https://maratool.com/og/image.svg',
    datePublished: '2026-06-28',
    dateModified: '2026-06-28',
    author: { '@type': 'Person', name: 'Marcell Almeida', url: 'https://marcell.com.br' },
    publisher: {
      '@type': 'Organization',
      name: 'maratool',
      url: 'https://maratool.com',
      logo: { '@type': 'ImageObject', url: 'https://maratool.com/favicon.svg' },
    },
    mainEntityOfPage: { '@type': 'WebPage', '@id': 'https://maratool.com/blog/image-compressor' },
    url: 'https://maratool.com/blog/image-compressor',
    description: 'How the maratool image compressor reduces JPG, PNG, and WebP file size in the browser.',
  },
}
---
<Base {...seo}>
  <Layout>
    <article class="blog-post">
      <header class="blog-post-header">
        <div class="blog-post-meta">
          <a href="/blog" class="blog-back">← Blog</a>
          <time datetime="2026-06-28" class="blog-post-date">June 28, 2026</time>
        </div>
        <h1 class="blog-post-title">How to compress JPG, PNG, and WebP images in your browser</h1>
        <p class="blog-post-lead">Drop an image, adjust quality and scale, compare side by side, download a smaller file.</p>
      </header>
      <div class="blog-body">
        <p>The <a href="/image-compressor">Image Compressor</a> shrinks JPG, PNG, and WebP files using the Canvas API — with side-by-side preview, savings percentage, and optional EXIF stripping.</p>
        <h2>How it works</h2>
        <ol>
          <li>Drop or select an image — JPEG, PNG, WebP, GIF, or BMP.</li>
          <li>Adjust quality, scale, output format, and EXIF strip option.</li>
          <li>Compress, compare original vs result, see savings %, download.</li>
        </ol>
        <hr class="blog-divider" />
        <p class="blog-footer-note">Try the <a href="/image-compressor">Image Compressor</a> free at <a href="/image">maratool.com/image</a>.</p>
      </div>
    </article>
  </Layout>
</Base>
