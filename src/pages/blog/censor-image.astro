---
import Base from '../../layouts/Base.astro'
import Layout from '../../components/Layout.astro'

const seo = {
  title: 'How to pixelate or blur areas in an image | maratool',
  description: 'Pixelate or blur specific areas of images and GIFs. Draw rectangles over faces or sensitive content, then download.',
  canonical: 'https://maratool.com/blog/censor-image',
  schema: {
    '@context': 'https://schema.org',
    '@type': 'BlogPosting',
    headline: 'How to pixelate or blur areas in an image',
    image: 'https://maratool.com/og/image.svg',
    datePublished: '2026-06-28',
    dateModified: '2026-06-28',
    author: { '@type': 'Person', name: 'Marcell Almeida', url: 'https://marcell.com.br' },
    publisher: {
      '@type': 'Organization',
      name: 'maratool',
      url: 'https://maratool.com',
      logo: { '@type': 'ImageObject', url: 'https://maratool.com/favicon.svg' },
    },
    mainEntityOfPage: { '@type': 'WebPage', '@id': 'https://maratool.com/blog/censor-image' },
    url: 'https://maratool.com/blog/censor-image',
    description: 'Pixelate or blur specific areas of images and GIFs. Draw rectangles over faces or sensitive content, then download.',
  },
}
---
<Base {...seo}>
  <Layout>
    <article class="blog-post">
      <header class="blog-post-header">
        <div class="blog-post-meta">
          <a href="/blog" class="blog-back">← Blog</a>
          <time datetime="2026-06-28" class="blog-post-date">June 28, 2026</time>
        </div>
        <h1 class="blog-post-title">How to pixelate or blur areas in an image</h1>
        <p class="blog-post-lead">Draw rectangles over sensitive areas and censor them with pixelate or blur.</p>
      </header>
      <div class="blog-body">
        <p>The <a href="/censor-image">Censor Image</a> tool runs entirely in your browser — no upload, no watermark.</p>
        <h2>How it works</h2>
        <ol>
          <li>Upload an image or animated GIF.</li>
          <li>Draw rectangles over areas to censor and pick pixelate or blur.</li>
          <li>Apply and download the result.</li>
        </ol>
        <p>Pixelate or blur specific areas of images and GIFs. Draw rectangles over faces or sensitive content, then download.</p>
        <hr class="blog-divider" />
        <p class="blog-footer-note">Try the <a href="/censor-image">Censor Image</a> free at <a href="/image">maratool.com/image</a>.</p>
      </div>
    </article>
  </Layout>
</Base>
