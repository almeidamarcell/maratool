---
import Base from '../../layouts/Base.astro'
import Layout from '../../components/Layout.astro'
import BlogPostShell from '../../components/BlogPostShell.astro'
import BlogToolEmbed from '../../components/BlogToolEmbed.astro'

const slug = 'stock-average-calculator'
const seo = {
  title: 'Stock average price calculator — cost basis | maratool',
  description: 'Calculate weighted average share price across multiple stock purchases. Free cost basis calculator in your browser.',
  canonical: `https://maratool.com/blog/${slug}`,
  schema: {
    '@context': 'https://schema.org',
    '@type': 'BlogPosting',
    headline: 'How to calculate average stock purchase price',
    image: 'https://maratool.com/og/marketing.svg',
    datePublished: '2026-06-28',
    dateModified: '2026-06-28',
    author: { '@type': 'Person', name: 'Marcell Almeida', url: 'https://marcell.com.br' },
    publisher: {
      '@type': 'Organization',
      name: 'maratool',
      url: 'https://maratool.com',
      logo: { '@type': 'ImageObject', url: 'https://maratool.com/favicon.svg' },
    },
    mainEntityOfPage: { '@type': 'WebPage', '@id': `https://maratool.com/blog/${slug}` },
    url: `https://maratool.com/blog/${slug}`,
    description: 'Calculate weighted average share price across multiple stock purchases. Free cost basis calculator in your browser.',
  },
  breadcrumbSchema: {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://maratool.com' },
      { '@type': 'ListItem', position: 2, name: 'Blog', item: 'https://maratool.com/blog' },
      { '@type': 'ListItem', position: 3, name: 'How to calculate average stock purchase price', item: `https://maratool.com/blog/${slug}` },
    ],
  },
}
---
<Base {...seo}>
  <Layout>
    <BlogPostShell
      title="How to calculate average stock purchase price"
      lead="Add each buy lot — shares and price — to get your weighted average cost per share."
      date="June 28, 2026"
      dateIso="2026-06-28"
    >
      <p>After several buys at different prices, your true cost basis is a weighted average — not the last trade price. The <a href="/stock-average-calculator">Stock Average Price Calculator</a> totals shares and computes average cost instantly.</p>

      <BlogToolEmbed slug="stock-average-calculator" title="Try it — enter shares and price per lot" height={420} />

      <h2>How it works</h2>
      <ol>
        <li><strong>Add lots</strong> — shares purchased and price per share for each trade.</li>
        <li><strong>Review average</strong> — weighted average cost and total shares.</li>
        <li><strong>Compare to market</strong> — use average cost for gain/loss decisions.</li>
      </ol>

      <h2>Weighted average</h2>
      <p>Average cost = total amount paid ÷ total shares. A larger lot at a higher price pulls the average up more than a small lot.</p>

      <h2>DCA modeling</h2>
      <p>For recurring investments over time, try the <a href="/dca-calculator">Dollar Cost Averaging Calculator</a>.</p>

      <hr class="blog-divider" />
      <p class="blog-footer-note">The <a href="/stock-average-calculator">How to calculate average stock purchase price</a> is free, runs locally, and never sends your data to a server. More <a href="/finance">finance calculators</a> at <a href="/">maratool.com</a>.</p>
    </BlogPostShell>
  </Layout>
</Base>
