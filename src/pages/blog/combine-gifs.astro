---
import Base from '../../layouts/Base.astro'
import Layout from '../../components/Layout.astro'

const seo = {
  title: 'How to combine GIFs side by side | maratool',
  description: 'Merge two or more GIFs into one animation — side by side or stacked. Align timing and download the combined GIF.',
  canonical: 'https://maratool.com/blog/combine-gifs',
  schema: {
    '@context': 'https://schema.org',
    '@type': 'BlogPosting',
    headline: 'How to combine GIFs side by side',
    image: 'https://maratool.com/og/image.svg',
    datePublished: '2026-06-28',
    dateModified: '2026-06-28',
    author: { '@type': 'Person', name: 'Marcell Almeida', url: 'https://marcell.com.br' },
    publisher: {
      '@type': 'Organization',
      name: 'maratool',
      url: 'https://maratool.com',
      logo: { '@type': 'ImageObject', url: 'https://maratool.com/favicon.svg' },
    },
    mainEntityOfPage: { '@type': 'WebPage', '@id': 'https://maratool.com/blog/combine-gifs' },
    url: 'https://maratool.com/blog/combine-gifs',
    description: 'Merge two or more GIFs into one animation — side by side or stacked. Align timing and download the combined GIF.',
  },
}
---
<Base {...seo}>
  <Layout>
    <article class="blog-post">
      <header class="blog-post-header">
        <div class="blog-post-meta">
          <a href="/blog" class="blog-back">← Blog</a>
          <time datetime="2026-06-28" class="blog-post-date">June 28, 2026</time>
        </div>
        <h1 class="blog-post-title">How to combine GIFs side by side</h1>
        <p class="blog-post-lead">Merge multiple animated GIFs into one file — horizontal or vertical layout.</p>
      </header>
      <div class="blog-body">
        <p>The <a href="/combine-gifs">Combine GIFs</a> tool runs entirely in your browser — no upload, no watermark.</p>
        <h2>How it works</h2>
        <ol>
          <li>Upload two or more GIF files.</li>
          <li>Choose horizontal or vertical layout and alignment.</li>
          <li>Download the merged GIF.</li>
        </ol>
        <p>Merge two or more GIFs into one animation — side by side or stacked. Align timing and download the combined GIF.</p>
        <hr class="blog-divider" />
        <p class="blog-footer-note">Try the <a href="/combine-gifs">Combine GIFs</a> free at <a href="/image">maratool.com/image</a>.</p>
      </div>
    </article>
  </Layout>
</Base>
