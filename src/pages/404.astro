---
import Base from '../layouts/Base.astro'
import Layout from '../components/Layout.astro'
import { tools } from '../data/tools.ts'

const seo = {
  title: 'Page not found (404) | maratool',
  description: 'The page you were looking for does not exist. Try the search palette (⌘K) or browse all 235+ tools.',
  canonical: 'https://maratool.com/404',
  noindex: true,
  schema: {
    '@context': 'https://schema.org',
    '@type': 'WebPage',
    name: 'Page not found',
    url: 'https://maratool.com/404',
  },
}

const verticals = [
  { slug: 'health', label: 'Health', count: tools.filter(t => t.live && t.category === 'Health').length },
  { slug: 'developer', label: 'Developer', count: tools.filter(t => t.live && t.category === 'Developer').length },
  { slug: 'image', label: 'Image', count: tools.filter(t => t.live && t.category === 'Image').length },
  { slug: 'converter', label: 'Converter', count: tools.filter(t => t.live && t.category === 'Converter').length },
  { slug: 'text', label: 'Text', count: tools.filter(t => t.live && t.category === 'Text').length },
  { slug: 'color', label: 'Color', count: tools.filter(t => t.live && t.category === 'Color').length },
  { slug: 'pdf', label: 'PDF', count: tools.filter(t => t.live && t.category === 'PDF').length },
  { slug: 'mockup', label: 'Mockup', count: tools.filter(t => t.live && t.category === 'Mockup').length },
  { slug: 'marketing', label: 'Marketing', count: tools.filter(t => t.live && t.category === 'Marketing').length },
]
---
<Base {...seo}>
  <Layout scope="page">
    <div class="notfound">
      <p class="notfound-eyebrow">404</p>
      <h1 class="notfound-title">This page doesn’t exist (yet).</h1>
      <p class="notfound-lead">The URL you tried doesn’t match any tool, hub, or post on maratool. Either it moved, was renamed, or never existed.</p>

      <div class="notfound-actions">
        <a href="/" class="notfound-btn notfound-btn-primary">Go to homepage</a>
        <a href="/all/" class="notfound-btn">Browse all tools</a>
        <a href="/blog/" class="notfound-btn">Read the blog</a>
      </div>

      <h2 class="notfound-h2">Browse by vertical</h2>
      <ul class="notfound-verticals">
        {verticals.map(v => (
          <li><a href={`/${v.slug}/`}>{v.label} <span class="notfound-count">{v.count}</span></a></li>
        ))}
      </ul>

      <p class="notfound-tip">Tip: press <kbd>⌘K</kbd> (or <kbd>Ctrl K</kbd>) anywhere on the site to search across all 235+ tools.</p>
    </div>
  </Layout>
</Base>

<style is:global>
  .notfound {
    max-width: 640px;
    padding: 3rem 2rem;
  }
  .notfound-eyebrow {
    font-family: 'Instrument Serif', Georgia, serif;
    font-style: italic;
    font-size: 4rem;
    color: var(--text-3);
    margin: 0 0 0.25rem;
    line-height: 1;
  }
  .notfound-title {
    font-family: 'Instrument Serif', Georgia, serif;
    font-style: italic;
    font-size: 2rem;
    font-weight: 400;
    color: var(--text);
    margin: 0 0 1rem;
    letter-spacing: -0.01em;
  }
  .notfound-lead {
    font-size: 16px;
    color: var(--text-2);
    line-height: 1.6;
    margin: 0 0 1.75rem;
  }
  .notfound-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-bottom: 2.5rem;
  }
  .notfound-btn {
    display: inline-flex;
    align-items: center;
    padding: 0.5rem 0.875rem;
    font-size: 14px;
    color: var(--text);
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    text-decoration: none;
    transition: background 0.1s;
  }
  .notfound-btn:hover { background: var(--bg-hover); }
  .notfound-btn-primary {
    background: var(--text);
    color: var(--bg);
    border-color: var(--text);
  }
  .notfound-btn-primary:hover { background: var(--text); opacity: 0.9; }
  .notfound-h2 {
    font-size: 13px;
    font-weight: 500;
    color: var(--text-3);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin: 0 0 0.75rem;
  }
  .notfound-verticals {
    list-style: none;
    margin: 0 0 2.5rem;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(160px, 1fr));
    gap: 0.5rem;
  }
  .notfound-verticals li { margin: 0; }
  .notfound-verticals a {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.625rem 0.875rem;
    font-size: 14px;
    color: var(--text);
    background: var(--bg-soft);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    text-decoration: none;
    transition: background 0.1s;
  }
  .notfound-verticals a:hover { background: var(--bg-hover); }
  .notfound-count {
    font-size: 12px;
    color: var(--text-3);
    font-variant-numeric: tabular-nums;
  }
  .notfound-tip {
    font-size: 13px;
    color: var(--text-2);
    background: var(--bg-soft);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 0.75rem 1rem;
    margin: 0;
  }
  .notfound-tip kbd {
    font-family: var(--font-mono, 'Fira Mono', ui-monospace, monospace);
    font-size: 12px;
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: 4px;
    padding: 1px 5px;
  }
  @media (max-width: 600px) {
    .notfound { padding: 1.75rem 1rem; }
    .notfound-eyebrow { font-size: 3rem; }
    .notfound-title { font-size: 1.5rem; }
  }
</style>
