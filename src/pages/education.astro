---
import Base from '../layouts/Base.astro'
import Layout from '../components/Layout.astro'
import HubPage from '../components/HubPage.astro'
import { toolsFlatByCategory, subcategoryOrderByCategory, buildToolItemList } from '../data/tools'

const categoryTools = toolsFlatByCategory.Education ?? []
const subcategories = subcategoryOrderByCategory.Education ?? []
const liveCategoryTools = categoryTools.filter(t => t.live)

const seo = {
  title: 'Education Calculators — GPA, Grades & Reading Level | maratool',
  description: 'Free education calculators for GPA, weighted grades, final exam scores, and reading level. Runs in your browser — no sign-up required.',
  canonical: 'https://maratool.com/education',
  schema: {
    '@context': 'https://schema.org',
    '@type': 'CollectionPage',
    name: 'Education Calculators',
    url: 'https://maratool.com/education',
    description: 'Free education calculators for GPA, weighted grades, final exam scores, and reading level.',
    hasPart: liveCategoryTools.map(tool => ({
      '@type': 'SoftwareApplication',
      name: tool.name,
      url: `https://maratool.com/${tool.slug}`,
      applicationCategory: 'EducationApplication',
    })),
    mainEntity: buildToolItemList(liveCategoryTools, 'Education Calculators'),
  },
  breadcrumbSchema: {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://maratool.com' },
      { '@type': 'ListItem', position: 2, name: 'Education', item: 'https://maratool.com/education' },
    ],
  },
}

const editorial = `
<h2>About these education calculators</h2>
<p>Students and teachers need quick answers — weighted GPA, course grades, what score you need on the final, or the reading level of a passage. These calculators run instantly in your browser.</p>
<h3>What you can calculate</h3>
<p>Use the <a href="/gpa-calculator">GPA calculator</a> on a 4.0 scale, the <a href="/grade-calculator">grade calculator</a> for weighted assignments, the <a href="/final-grade-calculator">final grade calculator</a> to plan exam prep, and the <a href="/reading-level-calculator">reading level calculator</a> for Flesch-Kincaid estimates.</p>
<h3>Privacy</h3>
<p>Grades and text never leave your device.</p>
`
---
<Base {...seo} scope="hub">
  <Layout scope="hub">
    <HubPage
      category="Education"
      categorySlug="education"
      title="Education calculators"
      subtitle="GPA, grades, and reading level tools — everything runs locally in your browser."
      tools={categoryTools}
      subcategories={subcategories}
      basePath="/education"
      editorial={editorial}
    />
  </Layout>
</Base>
