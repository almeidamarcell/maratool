---
import Base from '../../layouts/Base.astro'
import Layout from '../../components/Layout.astro'
import HubPage from '../../components/HubPage.astro'
import { toolsByCategory, toolsFlatByCategory, subcategoryOrderByCategory } from '../../data/tools'

export function getStaticPaths() {
  const subs = subcategoryOrderByCategory.Color ?? []
  const catTools = toolsByCategory.Color ?? {}

  const descriptions: Record<string, { title: string; description: string; intro: string }> = {
    generate: {
      title: 'Color Generator Tools — maratool',
      description: 'Free browser-based color generators. Create CSS gradients, color shades, palettes, and Tailwind palettes — no sign-up, runs in your browser.',
      intro: 'Generate gradients, shades, and palettes for your projects instantly.',
    },
    check: {
      title: 'Color Check Tools — maratool',
      description: 'Free browser-based color checking tools. Check contrast ratios for WCAG AA and AAA compliance — no sign-up, runs in your browser.',
      intro: 'Verify color accessibility and contrast compliance directly in your browser.',
    },
  }

  return subs.map(sub => {
    const slug = sub.toLowerCase()
    const meta = descriptions[slug] ?? {
      title: `${sub} Color Tools — maratool`,
      description: `Free browser-based color ${sub.toLowerCase()} tools — no sign-up, runs entirely in your browser.`,
      intro: `Color ${sub.toLowerCase()} tools that run locally in your browser.`,
    }
    return {
      params: { subcategory: slug },
      props: { sub, subTools: catTools[sub] ?? [], ...meta },
    }
  })
}

const { subcategory } = Astro.params
const { sub, subTools, title, description, intro } = Astro.props
const allTools = toolsFlatByCategory.Color ?? []
const subcategories = subcategoryOrderByCategory.Color ?? []

const seo = {
  title,
  description,
  canonical: `https://maratool.com/color/${subcategory}`,
  schema: {
    '@context': 'https://schema.org',
    '@type': 'CollectionPage',
    name: `Color ${sub} Tools`,
    url: `https://maratool.com/color/${subcategory}`,
    description,
    hasPart: subTools.filter((tool: { live: boolean }) => tool.live).map((tool: { name: string; slug: string }) => ({
      '@type': 'SoftwareApplication',
      name: tool.name,
      url: `https://maratool.com/${tool.slug}`,
      applicationCategory: 'DesignApplication',
    })),
  },
  breadcrumbSchema: {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://maratool.com' },
      { '@type': 'ListItem', position: 2, name: 'Color', item: 'https://maratool.com/color' },
      { '@type': 'ListItem', position: 3, name: sub, item: `https://maratool.com/color/${subcategory}` },
    ],
  },
}
---
<Base {...seo}>
  <Layout scope="subcategory">
    <HubPage
      category="Color"
      categorySlug="color"
      title={`Color ${sub} tools`}
      subtitle={intro}
      tools={allTools}
      subcategories={subcategories}
      activeSubcategory={sub}
      basePath="/color"
    />
  </Layout>
</Base>
