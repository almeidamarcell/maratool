---
import Base from '../layouts/Base.astro'
import Layout from '../components/Layout.astro'
import ToolShell from '../components/ToolShell.astro'

const seo = {
  title: 'Cron Expression Generator — Build and decode cron jobs | maratool',
  description: 'Build cron expressions visually. Get plain-English descriptions and see the next 5 scheduled run times. Free, no sign-up.',
  canonical: 'https://maratool.com/cron-expression',
  schema: {
    '@context': 'https://schema.org',
    '@type': 'WebApplication',
    name: 'Cron Expression Generator',
    url: 'https://maratool.com/cron-expression',
    applicationCategory: 'DeveloperApplication',
    operatingSystem: 'Any',
    offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
    description: 'Build and decode cron expressions with a visual editor.',
  },
  breadcrumbSchema: {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://maratool.com' },
      { '@type': 'ListItem', position: 2, name: 'Developer', item: 'https://maratool.com/developer' },
      { '@type': 'ListItem', position: 3, name: 'Generate', item: 'https://maratool.com/developer/generate' },
      { '@type': 'ListItem', position: 4, name: 'Cron Expression', item: 'https://maratool.com/cron-expression' },
    ],
  },
  faqSchema: {
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: [
      {
        '@type': 'Question',
        name: 'What is a cron expression?',
        acceptedAnswer: { '@type': 'Answer', text: 'A cron expression is a string of five fields separated by spaces that defines a schedule for automated tasks. It is used by cron, a time-based job scheduler in Unix-like operating systems, to run commands or scripts at specified intervals.' }
      },
      {
        '@type': 'Question',
        name: 'What do the 5 fields mean?',
        acceptedAnswer: { '@type': 'Answer', text: 'The five fields are: Minute (0\u201359), Hour (0\u201323), Day of month (1\u201331), Month (1\u201312), and Day of week (0\u20136, where 0 is Sunday). An asterisk (*) means "every" value. You can also use ranges (1-5), lists (1,3,5), and steps (*/15).' }
      },
      {
        '@type': 'Question',
        name: 'How do I run a job every 15 minutes?',
        acceptedAnswer: { '@type': 'Answer', text: 'Use the expression */15 * * * * \u2014 the */15 in the minute field means "every 15 minutes". The asterisks in the remaining fields mean "every hour, every day, every month, every day of the week".' }
      },
      {
        '@type': 'Question',
        name: "What's the difference between cron and crontab?",
        acceptedAnswer: { '@type': 'Answer', text: 'Cron is the daemon (background service) that runs scheduled jobs. Crontab (cron table) is the file or command used to create, edit, and manage the schedule entries. You edit the crontab to tell cron what to run and when.' }
      }
    ]
  }
}

const howTo = [
  'Set values for each of the 5 cron fields (minute, hour, day, month, weekday) or use a preset.',
  'Read the plain-English description and check the next 5 scheduled run times.',
  'Click Copy to copy the cron expression to your clipboard.'
]

const faq = [
  { q: 'What is a cron expression?', a: 'A cron expression is a string of five fields separated by spaces that defines a schedule for automated tasks. It is used by cron, a time-based job scheduler in Unix-like operating systems, to run commands or scripts at specified intervals.' },
  { q: 'What do the 5 fields mean?', a: 'The five fields are: Minute (0\u201359), Hour (0\u201323), Day of month (1\u201331), Month (1\u201312), and Day of week (0\u20136, where 0 is Sunday). An asterisk (*) means "every" value. You can also use ranges (1-5), lists (1,3,5), and steps (*/15).' },
  { q: 'How do I run a job every 15 minutes?', a: 'Use the expression */15 * * * * \u2014 the */15 in the minute field means "every 15 minutes". The asterisks in the remaining fields mean "every hour, every day, every month, every day of the week".' },
  { q: "What's the difference between cron and crontab?", a: 'Cron is the daemon (background service) that runs scheduled jobs. Crontab (cron table) is the file or command used to create, edit, and manage the schedule entries. You edit the crontab to tell cron what to run and when.' }
]

const relatedTools = [
  { slug: 'unix-timestamp', name: 'Unix Timestamp Converter' },
  { slug: 'uuid-generator', name: 'UUID Generator' },
]

const breadcrumbs = [
  { label: 'Home', href: '/' },
  { label: 'Developer', href: '/developer' },
  { label: 'Generate', href: '/developer/generate' },
  { label: 'Cron Expression' },
]
---
<Base {...seo}>
  <Layout>
    <ToolShell slug="cron-expression" name="Cron Expression Generator" description="Build cron expressions visually. See a plain-English description and the next 5 scheduled run times." howTo={howTo} faq={faq} relatedTools={relatedTools} breadcrumbs={breadcrumbs}>
      <div class="tool-container">
        <div class="cron-fields">
          <div class="cron-field">
            <label class="tool-label" for="cron-min">Minute</label>
            <input type="text" id="cron-min" class="tool-input cron-input" value="*" spellcheck="false" />
            <span class="cron-range">0&ndash;59</span>
          </div>
          <div class="cron-field">
            <label class="tool-label" for="cron-hour">Hour</label>
            <input type="text" id="cron-hour" class="tool-input cron-input" value="*" spellcheck="false" />
            <span class="cron-range">0&ndash;23</span>
          </div>
          <div class="cron-field">
            <label class="tool-label" for="cron-dom">Day (month)</label>
            <input type="text" id="cron-dom" class="tool-input cron-input" value="*" spellcheck="false" />
            <span class="cron-range">1&ndash;31</span>
          </div>
          <div class="cron-field">
            <label class="tool-label" for="cron-month">Month</label>
            <input type="text" id="cron-month" class="tool-input cron-input" value="*" spellcheck="false" />
            <span class="cron-range">1&ndash;12</span>
          </div>
          <div class="cron-field">
            <label class="tool-label" for="cron-dow">Day (week)</label>
            <input type="text" id="cron-dow" class="tool-input cron-input" value="*" spellcheck="false" />
            <span class="cron-range">0&ndash;6 (Sun=0)</span>
          </div>
        </div>

        <div class="tool-panel">
          <div class="tool-panel-header">
            <span class="tool-label">Expression</span>
            <button class="copy-btn" id="cron-copy">Copy</button>
          </div>
          <pre id="cron-expr" class="tool-output" style="min-height:40px;font-size:1.1rem;" aria-label="Cron expression"></pre>
        </div>

        <div id="cron-error" class="cron-error" aria-live="polite"></div>

        <div class="tool-panel">
          <span class="tool-label">Description</span>
          <div id="cron-desc" class="cron-desc" aria-live="polite"></div>
        </div>

        <div class="tool-panel">
          <span class="tool-label">Next 5 runs</span>
          <ol id="cron-next" class="cron-next" aria-label="Next 5 run times"></ol>
        </div>

        <div class="cron-presets">
          <span class="tool-label">Presets</span>
          <div class="cron-preset-row">
            <button class="cron-preset" data-expr="* * * * *">Every minute</button>
            <button class="cron-preset" data-expr="0 * * * *">Every hour</button>
            <button class="cron-preset" data-expr="0 0 * * *">Daily at midnight</button>
            <button class="cron-preset" data-expr="0 0 * * 1">Every Monday</button>
            <button class="cron-preset" data-expr="0 0 * * 1-5">Every weekday</button>
            <button class="cron-preset" data-expr="0 0 1 * *">First of month</button>
          </div>
        </div>
      </div>
    </ToolShell>
  </Layout>
</Base>
<style>
  .cron-fields {
    display: flex;
    gap: 0.5rem;
    margin-bottom: 1rem;
    flex-wrap: wrap;
  }
  .cron-field {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    flex: 1;
    min-width: 80px;
  }
  .cron-input {
    text-align: center;
    font-family: var(--font-mono);
    font-size: 15px;
    font-weight: 600;
  }
  .cron-range {
    font-size: 11px;
    color: var(--text-3);
    text-align: center;
  }
  .cron-error {
    color: #c53030;
    font-size: 13px;
    margin-bottom: 0.5rem;
    min-height: 0;
  }
  .cron-error:empty { display: none; }
  .cron-desc {
    font-size: 15px;
    color: var(--text);
    padding: 10px 12px;
    border: 1px solid var(--border);
    border-radius: var(--radius);
    background: var(--bg-soft);
    min-height: 40px;
  }
  .cron-next {
    list-style: decimal;
    padding: 10px 12px 10px 2rem;
    border: 1px solid var(--border);
    border-radius: var(--radius);
    background: var(--bg-soft);
    min-height: 40px;
    font-family: var(--font-mono);
    font-size: 13px;
    color: var(--text);
  }
  .cron-next li { margin-bottom: 0.25rem; }
  .cron-presets { margin-top: 1rem; }
  .cron-preset-row {
    display: flex;
    gap: 0.375rem;
    flex-wrap: wrap;
    margin-top: 0.375rem;
  }
  .cron-preset {
    padding: 6px 12px;
    border: 1px solid var(--border);
    border-radius: 100px;
    background: var(--bg);
    font-family: var(--font);
    font-size: 12px;
    color: var(--text-2);
    cursor: pointer;
    transition: border-color 0.15s, color 0.15s, background 0.15s;
  }
  .cron-preset:hover {
    border-color: var(--accent);
    color: var(--accent);
    background: var(--bg-soft);
  }
</style>
<script src="../tools/cron-expression.js"></script>
