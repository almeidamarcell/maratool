---
import ScoreCalc from '../components/ScoreCalc.astro'

const spec = {
  items: [
    { id: 'age', label: 'Age', options: [
      { label: '< 60 years (0)', points: 0, default: true },
      { label: '60–79 years (1)', points: 1 },
      { label: '≥ 80 years (2)', points: 2 },
    ]},
    { id: 'shock', label: 'Shock', options: [
      { label: 'No shock — SBP ≥ 100, HR < 100 (0)', points: 0, default: true },
      { label: 'Tachycardia — SBP ≥ 100, HR ≥ 100 (1)', points: 1 },
      { label: 'Hypotension — SBP < 100 (2)', points: 2 },
    ]},
    { id: 'comorbidity', label: 'Comorbidity', options: [
      { label: 'None (0)', points: 0, default: true },
      { label: 'Cardiac failure, ischemic heart disease, other major comorbidity (2)', points: 2 },
      { label: 'Renal failure, liver failure, metastatic malignancy (3)', points: 3 },
    ]},
    { id: 'diagnosis', label: 'Endoscopic diagnosis', options: [
      { label: 'Mallory-Weiss tear / no lesion / no SRH (0)', points: 0, default: true },
      { label: 'All other diagnoses (1)', points: 1 },
      { label: 'Malignancy of upper GI tract (2)', points: 2 },
    ]},
    { id: 'srh', label: 'Stigmata of recent hemorrhage', options: [
      { label: 'None or dark spot only (0)', points: 0, default: true },
      { label: 'Blood in upper GI tract, adherent clot, visible or spurting vessel (2)', points: 2 },
    ]},
  ],
  bands: [
    { min: 0, max: 2, label: 'Score ≤ 2 — low risk (rebleeding ≈ 5%, mortality ≈ 0.1%)', cls: 'cls-normal' },
    { min: 3, max: 5, label: 'Score 3–5 — intermediate risk (mortality ≈ 5–11%)', cls: 'cls-warn' },
    { min: 6, max: 11, label: 'Score ≥ 6 — high risk (mortality ≈ 25–40%)', cls: 'cls-danger' },
  ],
  max: 11,
  cols: 2,
}

const faq = [
  { q: 'What is the Rockall score?', a: 'A score for upper GI bleeding that predicts rebleeding and mortality. The full (complete) Rockall score combines clinical and endoscopic variables (0–11).' },
  { q: 'What is the pre-endoscopy Rockall score?', a: 'Using only age, shock, and comorbidity (0–7), it stratifies risk before endoscopy. A score of 0 identifies very low-risk patients.' },
  { q: 'Rockall vs Glasgow-Blatchford?', a: 'Glasgow-Blatchford uses only pre-endoscopy data and best identifies patients safe for outpatient care; full Rockall requires endoscopy and best predicts mortality/rebleeding.' },
  { q: 'When is the full Rockall calculated?', a: 'After diagnostic endoscopy, once the bleeding source and stigmata of recent hemorrhage are known.' },
]
const references = [
  { citation: 'Rockall TA, Logan RF, Devlin HB, Northfield TC. Risk assessment after acute upper gastrointestinal haemorrhage. <em>Gut</em>. 1996;38(3):316-321.' },
]
const relatedTools = [
  { slug: 'aims65-score', name: 'AIMS65 Score' },
  { slug: 'child-pugh', name: 'Child-Pugh' },
  { slug: 'has-bled', name: 'HAS-BLED' },
]
---
<ScoreCalc
  slug="rockall-score"
  name="Rockall Score for Upper GI Bleed Calculator"
  schemaName="Rockall Score"
  shortDescription="Complete Rockall score for rebleeding and mortality risk in upper GI bleeding (0–11)."
  metaTitle="Rockall Score Calculator (Upper GI Bleed) | maratool"
  metaDescription="Free Rockall score calculator. Predict rebleeding and mortality in upper gastrointestinal bleeding from clinical and endoscopic variables."
  subcategory="Score"
  subcategorySlug="score"
  howTo={[
    'Select age, shock, and comorbidity for the pre-endoscopy component.',
    'Add the endoscopic diagnosis and stigmata of recent hemorrhage for the complete score.',
    'The total score (0–11) with rebleeding/mortality risk updates instantly.',
  ]}
  faq={faq}
  relatedTools={relatedTools}
  references={references}
  spec={spec}
/>
