---
import Base from '../../layouts/Base.astro'
import Layout from '../../components/Layout.astro'
import HubPage from '../../components/HubPage.astro'
import { toolsByCategory, toolsFlatByCategory, subcategoryOrderByCategory } from '../../data/tools'

export function getStaticPaths() {
  const subs = subcategoryOrderByCategory.PDF ?? []
  const catTools = toolsByCategory.PDF ?? {}

  const descriptions: Record<string, { title: string; description: string; intro: string }> = {
    extract: {
      title: 'PDF Extract Tools — maratool',
      description: 'Free browser-based PDF extraction tools. Extract text and convert PDFs to Markdown — no upload, runs entirely in your browser.',
      intro: 'Extract text and structured content from PDFs without uploading anything.',
    },
    edit: {
      title: 'PDF Edit Tools — maratool',
      description: 'Free browser-based PDF editing tools. Merge multiple PDFs and split pages — no upload, runs entirely in your browser.',
      intro: 'Merge, split, and reorganize PDF files directly in your browser.',
    },
    inspect: {
      title: 'PDF Inspect Tools — maratool',
      description: 'Free browser-based PDF inspection tools. View metadata, page count, and check accessibility — no upload, runs entirely in your browser.',
      intro: 'Inspect PDF properties, metadata, and accessibility compliance locally.',
    },
  }

  return subs.map(sub => {
    const slug = sub.toLowerCase()
    const meta = descriptions[slug] ?? {
      title: `${sub} PDF Tools — maratool`,
      description: `Free browser-based PDF ${sub.toLowerCase()} tools — no sign-up, runs entirely in your browser.`,
      intro: `PDF ${sub.toLowerCase()} tools that run locally in your browser.`,
    }
    return {
      params: { subcategory: slug },
      props: { sub, subTools: catTools[sub] ?? [], ...meta },
    }
  })
}

const { subcategory } = Astro.params
const { sub, subTools, title, description, intro } = Astro.props
const allTools = toolsFlatByCategory.PDF ?? []
const subcategories = subcategoryOrderByCategory.PDF ?? []

const seo = {
  title,
  description,
  canonical: `https://maratool.com/pdf/${subcategory}`,
  schema: {
    '@context': 'https://schema.org',
    '@type': 'CollectionPage',
    name: `PDF ${sub} Tools`,
    url: `https://maratool.com/pdf/${subcategory}`,
    description,
    hasPart: subTools.filter((tool: { live: boolean }) => tool.live).map((tool: { name: string; slug: string }) => ({
      '@type': 'SoftwareApplication',
      name: tool.name,
      url: `https://maratool.com/${tool.slug}`,
      applicationCategory: 'DeveloperApplication',
    })),
  },
  breadcrumbSchema: {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://maratool.com' },
      { '@type': 'ListItem', position: 2, name: 'PDF', item: 'https://maratool.com/pdf' },
      { '@type': 'ListItem', position: 3, name: sub, item: `https://maratool.com/pdf/${subcategory}` },
    ],
  },
}
---
<Base {...seo}>
  <Layout scope="subcategory">
    <HubPage
      category="PDF"
      categorySlug="pdf"
      title={`PDF ${sub} tools`}
      subtitle={intro}
      tools={allTools}
      subcategories={subcategories}
      activeSubcategory={sub}
      basePath="/pdf"
    />
  </Layout>
</Base>
