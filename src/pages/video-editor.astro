---
import Base from '../layouts/Base.astro'
import Layout from '../components/Layout.astro'
import ToolShell from '../components/ToolShell.astro'
import { tools } from '../data/tools.ts'

const videoTools = tools.filter(
  t => t.category === 'Converter' && t.subcategory === 'Video' && t.slug !== 'video-editor' && t.live
)

// Group by intent: Edit, Convert, Generate
const editTools = videoTools.filter(t =>
  ['trim-video', 'compress-video', 'crop-video', 'resize-video', 'rotate-video', 'mute-video'].includes(t.slug)
)
const convertTools = videoTools.filter(t =>
  ['mp4-to-mp3', 'mov-to-mp4', 'mp4-to-webm'].includes(t.slug)
)
const generateTools = videoTools.filter(t =>
  ['video-to-gif', 'fps-converter'].includes(t.slug)
)
// Any remaining tools not in the above groups
const knownSlugs = [...editTools, ...convertTools, ...generateTools].map(t => t.slug)
const otherTools = videoTools.filter(t => !knownSlugs.includes(t.slug))

const seo = {
  title: 'Online Video Editor — Free Browser Video Tools, No Upload | maratool',
  description: 'Free online video editor with 12 focused tools — trim, compress, convert, crop, rotate, mute, resize. Runs in your browser. No upload, no watermark.',
  canonical: 'https://maratool.com/video-editor',
  schema: {
    '@context': 'https://schema.org',
    '@type': 'WebApplication',
    name: 'Online Video Editor',
    url: 'https://maratool.com/video-editor',
    applicationCategory: 'UtilitiesApplication',
    operatingSystem: 'Any',
    offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
    description: 'Free online video editor — trim, compress, convert, rotate, mute, crop, and resize videos in your browser. No upload, no watermark, no signup.',
    featureList: [
      'Trim and cut video',
      'Compress video to reduce file size',
      'Crop video to any aspect ratio',
      'Resize video resolution',
      'Rotate and flip video',
      'Mute or remove audio',
      'Convert MP4, WebM, MOV formats',
      'Extract MP3 audio from video',
      'Convert video to GIF',
      'Change video frame rate',
    ],
  },
  breadcrumbSchema: {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://maratool.com' },
      { '@type': 'ListItem', position: 2, name: 'Converter', item: 'https://maratool.com/converter' },
      { '@type': 'ListItem', position: 3, name: 'Video', item: 'https://maratool.com/converter/video' },
      { '@type': 'ListItem', position: 4, name: 'Online Video Editor', item: 'https://maratool.com/video-editor' },
    ],
  },
  faqSchema: {
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: [
      {
        '@type': 'Question',
        name: 'Is this online video editor really free?',
        acceptedAnswer: {
          '@type': 'Answer',
          text: 'Yes, completely free. No signup, no subscription, no watermark on any output. Every tool runs in your browser using open-source libraries — there is no server processing your files.',
        },
      },
      {
        '@type': 'Question',
        name: 'Can I edit large videos like 4K or files bigger than 2 GB?',
        acceptedAnswer: {
          '@type': 'Answer',
          text: 'Large files work on desktop browsers — most tools handle up to 2 GB comfortably. 4K files are supported but require a modern CPU and at least 8 GB of RAM because FFmpeg.wasm processes the video in your browser memory. Mobile devices may struggle with files above 500 MB.',
        },
      },
      {
        '@type': 'Question',
        name: 'Does this video editor work on mobile?',
        acceptedAnswer: {
          '@type': 'Answer',
          text: 'Yes, the tools open and run on iOS and Android browsers. For small files (under 200 MB) the experience is smooth. Larger files are slower on mobile because processing happens on the device CPU — desktop is faster for anything above 500 MB.',
        },
      },
      {
        '@type': 'Question',
        name: 'Do you store or upload my videos?',
        acceptedAnswer: {
          '@type': 'Answer',
          text: 'No. Your video files never leave your device. All processing is done locally in your browser using FFmpeg.wasm, a WebAssembly build of FFmpeg. Nothing is uploaded to any server, logged, or stored remotely.',
        },
      },
    ],
  },
}

const howTo = [
  'Pick the tool that matches your task from the grid below.',
  'Drop your video file into the dropzone on that tool\'s page.',
  'Adjust settings, click the action button, and download your result.',
]

const faq = [
  {
    q: 'Is this online video editor really free?',
    a: 'Yes, completely free. No signup, no subscription, no watermark on any output. Every tool runs in your browser using open-source libraries — there is no server processing your files.',
  },
  {
    q: 'Can I edit large videos like 4K or files bigger than 2 GB?',
    a: 'Large files work on desktop browsers — most tools handle up to 2 GB comfortably. 4K files are supported but require a modern CPU and at least 8 GB of RAM because FFmpeg.wasm processes the video in your browser memory. Mobile devices may struggle with files above 500 MB.',
  },
  {
    q: 'Does this video editor work on mobile?',
    a: 'Yes, the tools open and run on iOS and Android browsers. For small files (under 200 MB) the experience is smooth. Larger files are slower on mobile because processing happens on the device CPU — desktop is faster for anything above 500 MB.',
  },
  {
    q: 'Do you store or upload my videos?',
    a: 'No. Your video files never leave your device. All processing is done locally in your browser using FFmpeg.wasm, a WebAssembly build of FFmpeg. Nothing is uploaded to any server, logged, or stored remotely.',
  },
]

const relatedTools = [
  { slug: 'trim-video', name: 'Trim Video Online' },
  { slug: 'mp4-to-mp3', name: 'Convert MP4 to MP3' },
  { slug: 'compress-video', name: 'Compress Video Online' },
]

const breadcrumbs = [
  { label: 'Home', href: '/' },
  { label: 'Converter', href: '/converter' },
  { label: 'Video', href: '/converter/video' },
  { label: 'Online Video Editor' },
]
---
<Base {...seo} faqSchema={seo.faqSchema} breadcrumbSchema={seo.breadcrumbSchema} scope="tool">
  <Layout>
    <ToolShell
      slug="video-editor"
      name="Online Video Editor"
      description="Trim, compress, convert, crop, rotate, mute, and resize videos in your browser. 12 focused video tools — no upload, no watermark, no signup."
      howTo={howTo}
      faq={faq}
      relatedTools={relatedTools}
      breadcrumbs={breadcrumbs}
    >
      <div class="ve-container" style="min-height:400px;">

        <!-- Hero lede -->
        <p class="ve-lede">
          Trim, compress, convert, rotate, mute, crop, and resize videos directly in your browser.
          12 focused tools, zero upload, zero watermark, zero signup.
        </p>

        <!-- Value prop badges -->
        <div class="ve-badges">
          <span class="ve-badge">Free forever</span>
          <span class="ve-badge">No upload — files stay on your device</span>
          <span class="ve-badge">No watermark</span>
          <span class="ve-badge">Works on MP4, WebM, MOV</span>
        </div>

        <!-- Tool grid: Edit -->
        <section class="ve-group" aria-labelledby="ve-group-edit">
          <h2 class="ve-group-heading" id="ve-group-edit">Edit</h2>
          <div class="ve-tool-grid">
            {editTools.map(tool => (
              <a class="ve-card" href={`/${tool.slug}`}>
                <span class="ve-card-emoji" aria-hidden="true">{tool.emoji}</span>
                <div class="ve-card-body">
                  <span class="ve-card-name">{tool.name.replace(/\s*—.*$/, '')}</span>
                  <span class="ve-card-desc">
                    {tool.description.length > 80
                      ? tool.description.slice(0, 77) + '…'
                      : tool.description}
                  </span>
                </div>
                <span class="ve-card-arrow" aria-hidden="true">→</span>
              </a>
            ))}
          </div>
        </section>

        <!-- Tool grid: Convert -->
        <section class="ve-group" aria-labelledby="ve-group-convert">
          <h2 class="ve-group-heading" id="ve-group-convert">Convert</h2>
          <div class="ve-tool-grid">
            {convertTools.map(tool => (
              <a class="ve-card" href={`/${tool.slug}`}>
                <span class="ve-card-emoji" aria-hidden="true">{tool.emoji}</span>
                <div class="ve-card-body">
                  <span class="ve-card-name">{tool.name.replace(/\s*—.*$/, '')}</span>
                  <span class="ve-card-desc">
                    {tool.description.length > 80
                      ? tool.description.slice(0, 77) + '…'
                      : tool.description}
                  </span>
                </div>
                <span class="ve-card-arrow" aria-hidden="true">→</span>
              </a>
            ))}
          </div>
        </section>

        <!-- Tool grid: Generate -->
        <section class="ve-group" aria-labelledby="ve-group-generate">
          <h2 class="ve-group-heading" id="ve-group-generate">Generate</h2>
          <div class="ve-tool-grid">
            {generateTools.map(tool => (
              <a class="ve-card" href={`/${tool.slug}`}>
                <span class="ve-card-emoji" aria-hidden="true">{tool.emoji}</span>
                <div class="ve-card-body">
                  <span class="ve-card-name">{tool.name.replace(/\s*—.*$/, '')}</span>
                  <span class="ve-card-desc">
                    {tool.description.length > 80
                      ? tool.description.slice(0, 77) + '…'
                      : tool.description}
                  </span>
                </div>
                <span class="ve-card-arrow" aria-hidden="true">→</span>
              </a>
            ))}
          </div>
        </section>

        {otherTools.length > 0 && (
          <section class="ve-group" aria-labelledby="ve-group-other">
            <h2 class="ve-group-heading" id="ve-group-other">More tools</h2>
            <div class="ve-tool-grid">
              {otherTools.map(tool => (
                <a class="ve-card" href={`/${tool.slug}`}>
                  <span class="ve-card-emoji" aria-hidden="true">{tool.emoji}</span>
                  <div class="ve-card-body">
                    <span class="ve-card-name">{tool.name.replace(/\s*—.*$/, '')}</span>
                    <span class="ve-card-desc">
                      {tool.description.length > 80
                        ? tool.description.slice(0, 77) + '…'
                        : tool.description}
                    </span>
                  </div>
                  <span class="ve-card-arrow" aria-hidden="true">→</span>
                </a>
              ))}
            </div>
          </section>
        )}

        <!-- Capability comparison -->
        <section class="ve-compare" aria-labelledby="ve-compare-heading">
          <h2 class="ve-compare-heading" id="ve-compare-heading">Why use maratool?</h2>
          <div class="ve-table-wrap">
            <table class="ve-table">
              <thead>
                <tr>
                  <th>Feature</th>
                  <th>maratool</th>
                  <th>Typical SaaS editor</th>
                </tr>
              </thead>
              <tbody>
                <tr>
                  <td>Free to use</td>
                  <td class="ve-check">✓</td>
                  <td class="ve-cross">Free tier with limits</td>
                </tr>
                <tr>
                  <td>No file upload to servers</td>
                  <td class="ve-check">✓ — runs in your browser</td>
                  <td class="ve-cross">Files uploaded to cloud</td>
                </tr>
                <tr>
                  <td>No watermark on output</td>
                  <td class="ve-check">✓</td>
                  <td class="ve-cross">Watermark on free tier</td>
                </tr>
                <tr>
                  <td>No file-size paywall</td>
                  <td class="ve-check">✓ — up to 2 GB</td>
                  <td class="ve-cross">Size limit on free tier</td>
                </tr>
                <tr>
                  <td>Works offline after first load</td>
                  <td class="ve-check">✓</td>
                  <td class="ve-cross">Requires internet connection</td>
                </tr>
              </tbody>
            </table>
          </div>
        </section>

        <!-- How it works (supplemental — ToolShell renders a separate How-to) -->
        <section class="ve-how" aria-labelledby="ve-how-heading">
          <h2 class="ve-how-heading" id="ve-how-heading">How it works</h2>
          <div class="ve-how-steps">
            <div class="ve-how-step">
              <span class="ve-how-num">1</span>
              <div>
                <strong>Pick a focused tool.</strong> Each tool does one job well — trim, compress, convert, and so on. Select the one that matches your task from the grid above.
              </div>
            </div>
            <div class="ve-how-step">
              <span class="ve-how-num">2</span>
              <div>
                <strong>Drop your video file.</strong> No account, no upload form — just drag your file into the dropzone. Your video stays on your device the entire time.
              </div>
            </div>
            <div class="ve-how-step">
              <span class="ve-how-num">3</span>
              <div>
                <strong>Processing happens in your browser.</strong> FFmpeg.wasm — a WebAssembly port of the industry-standard FFmpeg — runs entirely in your browser tab. There is no server. The first run downloads the ~25 MB engine once; after that it is cached.
              </div>
            </div>
          </div>
        </section>

        <!-- Bottom internal nav cluster for crawlability -->
        <nav class="ve-nav-cluster" aria-label="All video tools">
          <h2 class="ve-nav-heading">All video tools</h2>
          <ul class="ve-nav-list">
            {videoTools.map(tool => (
              <li><a href={`/${tool.slug}`}>{tool.name.replace(/\s*—.*$/, '')}</a></li>
            ))}
          </ul>
        </nav>

      </div>
    </ToolShell>
  </Layout>
</Base>

<style is:global>
  /* ── Container ── */
  .ve-container {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  /* ── Hero lede ── */
  .ve-lede {
    font-size: 1.0625rem;
    line-height: 1.65;
    color: var(--text-2);
    margin: 0;
    max-width: 680px;
  }

  /* ── Value prop badges ── */
  .ve-badges {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }
  .ve-badge {
    display: inline-flex;
    align-items: center;
    padding: 0.25rem 0.75rem;
    background: var(--bg-soft);
    border: 1px solid var(--border);
    border-radius: 999px;
    font-size: 0.8125rem;
    color: var(--text-2);
    white-space: nowrap;
  }

  /* ── Group heading ── */
  .ve-group { display: flex; flex-direction: column; gap: 0.75rem; }
  .ve-group-heading {
    font-size: 0.875rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--text-3);
    margin: 0;
  }

  /* ── Tool grid ── */
  .ve-tool-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0.75rem;
  }

  /* ── Tool card ── */
  .ve-card {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.875rem 1rem;
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    text-decoration: none;
    color: inherit;
    transition: border-color 0.15s, background 0.15s, box-shadow 0.15s;
  }
  .ve-card:hover {
    border-color: var(--accent);
    background: var(--bg-soft);
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.06);
  }
  .ve-card-emoji {
    font-size: 1.375rem;
    flex-shrink: 0;
    line-height: 1;
  }
  .ve-card-body {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
    flex: 1;
    min-width: 0;
  }
  .ve-card-name {
    font-size: 0.9375rem;
    font-weight: 600;
    color: var(--text);
    line-height: 1.3;
  }
  .ve-card-desc {
    font-size: 0.75rem;
    color: var(--text-2);
    line-height: 1.45;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .ve-card-arrow {
    font-size: 0.875rem;
    color: var(--text-3);
    flex-shrink: 0;
    transition: color 0.15s, transform 0.15s;
  }
  .ve-card:hover .ve-card-arrow {
    color: var(--accent);
    transform: translateX(2px);
  }

  /* ── Comparison table ── */
  .ve-compare { display: flex; flex-direction: column; gap: 0.75rem; }
  .ve-compare-heading {
    font-size: 1.125rem;
    font-weight: 600;
    color: var(--text);
    margin: 0;
  }
  .ve-table-wrap {
    overflow-x: auto;
    border: 1px solid var(--border);
    border-radius: var(--radius);
  }
  .ve-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.875rem;
  }
  .ve-table th,
  .ve-table td {
    padding: 0.625rem 1rem;
    text-align: left;
    border-bottom: 1px solid var(--border);
    color: var(--text);
  }
  .ve-table tr:last-child td { border-bottom: none; }
  .ve-table thead th {
    background: var(--bg-soft);
    font-weight: 600;
    font-size: 0.8125rem;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: var(--text-2);
  }
  .ve-table tbody tr:hover { background: var(--bg-soft); }
  .ve-check { color: #16a34a; font-weight: 500; }
  .ve-cross { color: var(--text-2); }

  /* ── How it works ── */
  .ve-how { display: flex; flex-direction: column; gap: 0.75rem; }
  .ve-how-heading {
    font-size: 1.125rem;
    font-weight: 600;
    color: var(--text);
    margin: 0;
  }
  .ve-how-steps {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }
  .ve-how-step {
    display: flex;
    gap: 0.875rem;
    align-items: flex-start;
    padding: 0.875rem 1rem;
    background: var(--bg-soft);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    font-size: 0.875rem;
    line-height: 1.6;
    color: var(--text);
  }
  .ve-how-num {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 1.625rem;
    height: 1.625rem;
    border-radius: 50%;
    background: var(--accent);
    color: #fff;
    font-size: 0.8125rem;
    font-weight: 700;
    flex-shrink: 0;
    margin-top: 0.1rem;
  }

  /* ── Bottom nav cluster ── */
  .ve-nav-cluster {
    padding: 1.25rem 1.5rem;
    background: var(--bg-soft);
    border: 1px solid var(--border);
    border-radius: var(--radius);
  }
  .ve-nav-heading {
    font-size: 0.8125rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--text-3);
    margin: 0 0 0.75rem;
  }
  .ve-nav-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem 1.5rem;
  }
  .ve-nav-list li a {
    font-size: 0.875rem;
    color: var(--accent);
    text-decoration: none;
  }
  .ve-nav-list li a:hover { text-decoration: underline; }

  /* ── Responsive ── */
  @media (max-width: 900px) {
    .ve-tool-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 540px) {
    .ve-tool-grid { grid-template-columns: 1fr; }
    .ve-badges { gap: 0.375rem; }
    .ve-table th:last-child,
    .ve-table td:last-child { display: none; }
  }
</style>
