---
import Base from '../layouts/Base.astro'
import Layout from '../components/Layout.astro'
import Breadcrumb from '../components/Breadcrumb.astro'
import { toolsFlatByCategory } from '../data/tools'

const tools = toolsFlatByCategory.Image ?? []

const seo = {
  title: 'Image Tools — maratool',
  description: 'Free browser-based image tools. Remove backgrounds, optimize SVGs, generate favicons, preview Base64 images, and generate alt text — no upload required.',
  canonical: 'https://maratool.com/image',
  schema: {
    '@context': 'https://schema.org',
    '@type': 'CollectionPage',
    name: 'Image Tools',
    url: 'https://maratool.com/image',
    description: 'Free browser-based image tools. Remove backgrounds, optimize SVGs, generate favicons, preview Base64 images, and generate alt text — no upload required.',
    hasPart: tools.map(tool => ({
      '@type': 'SoftwareApplication',
      name: tool.name,
      url: `https://maratool.com/${tool.slug}`,
      applicationCategory: 'MultimediaApplication',
    })),
  },
  breadcrumbSchema: {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://maratool.com' },
      { '@type': 'ListItem', position: 2, name: 'Image', item: 'https://maratool.com/image' },
    ],
  },
}

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: 'How to remove image background without Photoshop?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Use maratool\'s background remover — upload your image and get a transparent PNG in seconds. It runs entirely in your browser using AI-powered processing, with no Photoshop or any other software required.'
      }
    },
    {
      '@type': 'Question',
      name: 'Can I convert images without uploading to a server?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Yes. All maratool image tools process files locally in your browser. Your images never leave your device — no uploads, no cloud processing, no privacy concerns.'
      }
    },
    {
      '@type': 'Question',
      name: 'What image formats are supported?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'maratool supports PNG, JPEG, WebP, SVG, GIF, and ICO formats. You can convert between formats, optimize SVGs, generate favicons from any image, and preview Base64-encoded images.'
      }
    },
    {
      '@type': 'Question',
      name: 'Are these image tools free to use?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Yes, all image tools on maratool are completely free with no sign-up, no watermarks, and no usage limits. Process as many images as you need directly in your browser.'
      }
    },
  ]
}

const breadcrumbs = [
  { label: 'Home', href: '/' },
  { label: 'Image' },
]
---
<Base {...seo} faqSchema={faqSchema}>
  <Layout>
    <Breadcrumb crumbs={breadcrumbs} />
    <div class="hero">
      <h1>Image Tools</h1>
      <p>Free, browser-based image tools — remove backgrounds, optimize SVGs, generate favicons, and more, all running locally.</p>
    </div>

    <div class="tools-grid">
      {tools.map(tool => (
        tool.live
          ? (
            <a href={`/${tool.slug}`} class="tool-card">
              <span class="tool-card-emoji">{tool.emoji}</span>
              <div class="tool-card-name">{tool.name}</div>
              <div class="tool-card-desc">{tool.description}</div>
            </a>
          )
          : (
            <div class="tool-card" style="opacity:0.5;cursor:default;">
              <span class="tool-card-emoji">{tool.emoji}</span>
              <div class="tool-card-name">{tool.name}</div>
              <div class="tool-card-desc">{tool.description}</div>
              <span class="tool-card-badge">Coming Soon</span>
            </div>
          )
      ))}
    </div>
  </Layout>
</Base>
