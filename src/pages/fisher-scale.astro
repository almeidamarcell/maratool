---
import ScoreCalc from '../components/ScoreCalc.astro'

const spec = {
  items: [
    {
      id: 'fisher',
      label: 'CT appearance (modified Fisher)',
      options: [
        { label: '0 — No SAH on CT, no IVH', points: 0, default: true },
        { label: '1 — Thin focal or diffuse SAH, no IVH', points: 1 },
        { label: '2 — Thin SAH with IVH in both lateral ventricles', points: 2 },
        { label: '3 — Thick SAH (≥ 1 mm in any cistern), no IVH', points: 3 },
        { label: '4 — Thick SAH with IVH in both lateral ventricles', points: 4 },
      ],
    },
  ],
  bands: [
    { min: 0, max: 0, label: 'Grade 0 — minimal vasospasm risk', cls: 'cls-normal' },
    { min: 1, max: 2, label: 'Low vasospasm risk', cls: 'cls-warn' },
    { min: 3, max: 4, label: 'High vasospasm risk', cls: 'cls-danger' },
  ],
  max: 4,
}

const faq = [
  { q: 'What is the modified Fisher scale used for?', a: 'It grades aneurysmal subarachnoid hemorrhage on CT to predict the risk of symptomatic vasospasm and delayed cerebral ischemia.' },
  { q: 'Modified vs original Fisher scale?', a: 'The modified Fisher (Frontera 2006) is the current standard and adds the presence of IVH as a separate dimension, improving predictive performance.' },
  { q: 'When should the CT be obtained?', a: 'Within 24–72 hours of ictus, before significant blood breakdown alters the appearance.' },
  { q: 'Does Fisher grade dictate treatment?', a: 'Higher grades prompt closer monitoring (transcranial Doppler, neuro checks) and a low threshold for vasospasm prophylaxis with nimodipine and euvolemia.' },
]
const references = [
  { citation: 'Frontera JA, Claassen J, Schmidt JM, et al. Prediction of symptomatic vasospasm after subarachnoid hemorrhage: the modified Fisher scale. <em>Neurosurgery</em>. 2006;59(1):21-27.' },
  { citation: 'Fisher CM, Kistler JP, Davis JM. Relation of cerebral vasospasm to subarachnoid hemorrhage visualized by CT scanning. <em>Neurosurgery</em>. 1980;6(1):1-9.' },
]
const relatedTools = [
  { slug: 'glasgow-coma-pupil', name: 'Glasgow Coma Scale (GCS-P)' },
  { slug: 'four-coma-scale', name: 'FOUR Score Coma Scale' },
  { slug: 'nihss-stroke', name: 'NIHSS Stroke Scale' },
]
---
<ScoreCalc
  slug="fisher-scale"
  name="Fisher Scale Calculator (Subarachnoid Hemorrhage)"
  schemaName="Fisher Scale"
  shortDescription="Modified Fisher scale (0–4) for vasospasm risk after subarachnoid hemorrhage."
  metaTitle="Modified Fisher Scale Calculator (SAH) | maratool"
  metaDescription="Free modified Fisher scale calculator for subarachnoid hemorrhage. Grade CT findings to predict vasospasm risk."
  subcategory="Scale"
  subcategorySlug="scale"
  howTo={[
    'Select the CT appearance that best describes the subarachnoid blood.',
    'The grade and vasospasm risk update instantly.',
    'Use the grade alongside clinical exam to guide vasospasm monitoring.',
  ]}
  faq={faq}
  relatedTools={relatedTools}
  references={references}
  spec={spec}
/>
