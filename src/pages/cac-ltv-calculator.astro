---
import Base from '../layouts/Base.astro'
import Layout from '../components/Layout.astro'
import ToolShell from '../components/ToolShell.astro'

const seo = {
  title: 'CAC / LTV Calculator — Customer acquisition & lifetime value | maratool',
  description: 'Calculate customer acquisition cost (CAC), lifetime value (LTV), LTV:CAC ratio, and payback period. Free marketing calculator, runs in your browser.',
  canonical: 'https://maratool.com/cac-ltv-calculator',
  schema: {
    '@context': 'https://schema.org',
    '@type': 'WebApplication',
    name: 'CAC / LTV Calculator',
    url: 'https://maratool.com/cac-ltv-calculator',
    applicationCategory: 'BusinessApplication',
    operatingSystem: 'Any',
    offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
    description: 'Calculate CAC, LTV, ratio, and payback period.',
  },
  breadcrumbSchema: {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://maratool.com' },
      { '@type': 'ListItem', position: 2, name: 'Marketing', item: 'https://maratool.com/marketing' },
      { '@type': 'ListItem', position: 3, name: 'Calculator', item: 'https://maratool.com/marketing/calculator' },
      { '@type': 'ListItem', position: 4, name: 'CAC / LTV Calculator', item: 'https://maratool.com/cac-ltv-calculator' },
    ],
  },
  faqSchema: {
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: [
      { '@type': 'Question', name: 'How do you calculate CAC?', acceptedAnswer: { '@type': 'Answer', text: 'CAC (Customer Acquisition Cost) = Total marketing spend ÷ Number of new customers acquired. For example, $10,000 spend acquiring 100 customers = $100 CAC.' } },
      { '@type': 'Question', name: 'How do you calculate LTV?', acceptedAnswer: { '@type': 'Answer', text: 'LTV (Lifetime Value) = Average monthly revenue per customer × Customer lifespan in months × Gross margin %. This tool uses monthly revenue and lifespan to estimate total customer value.' } },
      { '@type': 'Question', name: 'What is a good LTV:CAC ratio?', acceptedAnswer: { '@type': 'Answer', text: 'A ratio of 3:1 or higher is generally considered healthy — each dollar spent acquiring a customer returns at least three dollars in lifetime value. Below 1:1 means you are losing money on acquisition.' } },
      { '@type': 'Question', name: 'What is CAC payback period?', acceptedAnswer: { '@type': 'Answer', text: 'Payback period is how many months it takes for a customer to generate enough revenue to cover their acquisition cost. Shorter is better — SaaS companies often target under 12 months.' } },
    ]
  }
}

const howTo = ['Enter marketing spend and number of new customers.', 'Enter average monthly revenue per customer and expected lifespan.', 'See CAC, LTV, ratio, and payback period instantly.']
const faq = [
  { q: 'How do you calculate CAC?', a: 'CAC = Total marketing spend ÷ New customers acquired.' },
  { q: 'How do you calculate LTV?', a: 'LTV = Average monthly revenue × Lifespan (months) × Gross margin %.' },
  { q: 'What is a good LTV:CAC ratio?', a: '3:1 or higher is generally healthy. Below 1:1 means you lose money on acquisition.' },
  { q: 'What is CAC payback period?', a: 'Months until customer revenue covers acquisition cost. SaaS often targets under 12 months.' },
]
const relatedTools = [
  { slug: 'campaign-roi-calculator', name: 'Campaign ROI Calculator' },
  { slug: 'ab-test-calculator', name: 'A/B Test Significance Calculator' },
  { slug: 'utm-builder', name: 'UTM Builder' },
]
const breadcrumbs = [
  { label: 'Home', href: '/' },
  { label: 'Marketing', href: '/marketing' },
  { label: 'Calculator', href: '/marketing/calculator' },
  { label: 'CAC / LTV Calculator' },
]
---
<Base {...seo}>
  <Layout>
    <ToolShell slug="cac-ltv-calculator" name="Calculate CAC and LTV Online" description="Calculate customer acquisition cost, lifetime value, LTV:CAC ratio, and payback period. Updates instantly as you type." howTo={howTo} faq={faq} relatedTools={relatedTools} breadcrumbs={breadcrumbs}>
      <div class="tool-container" style="min-height:420px;">
        <div class="calc-row">
          <div class="calc-field"><label class="tool-label" for="cl-spend">Marketing spend ($)</label><input type="number" id="cl-spend" class="tool-input" min="0" step="any" placeholder="10000" /></div>
          <div class="calc-field"><label class="tool-label" for="cl-customers">New customers</label><input type="number" id="cl-customers" class="tool-input" min="1" step="1" placeholder="100" /></div>
        </div>
        <div class="calc-row">
          <div class="calc-field"><label class="tool-label" for="cl-revenue">Avg monthly revenue / customer ($)</label><input type="number" id="cl-revenue" class="tool-input" min="0" step="any" placeholder="50" /></div>
          <div class="calc-field"><label class="tool-label" for="cl-lifespan">Customer lifespan (months)</label><input type="number" id="cl-lifespan" class="tool-input" min="1" step="1" placeholder="24" /></div>
        </div>
        <div class="calc-field">
          <label class="tool-label" for="cl-margin">Gross margin (%)</label>
          <input type="number" id="cl-margin" class="tool-input" min="1" max="100" step="any" placeholder="80" style="max-width:120px;" />
        </div>
        <p class="calc-error" id="cl-error" style="display:none;"></p>
        <div id="cl-results">
          <div class="tool-stats">
            <div class="tool-stat"><span class="tool-stat-value" id="cl-cac">—</span><span class="tool-stat-label">CAC</span></div>
            <div class="tool-stat"><span class="tool-stat-value" id="cl-ltv">—</span><span class="tool-stat-label">LTV</span></div>
            <div class="tool-stat"><span class="tool-stat-value" id="cl-ratio">—</span><span class="tool-stat-label">LTV:CAC</span></div>
            <div class="tool-stat"><span class="tool-stat-value" id="cl-payback">—</span><span class="tool-stat-label">Payback</span></div>
          </div>
        </div>
      </div>
    </ToolShell>
  </Layout>
</Base>
<style is:global>
  .calc-row { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; margin-bottom: 1rem; }
  .calc-field { margin-bottom: 0.5rem; }
  .calc-error { color: var(--error, #c4553a); font-size: 0.875rem; }
  @media (max-width: 600px) { .calc-row { grid-template-columns: 1fr; } }
</style>
<script src="../tools/cac-ltv-calculator.js"></script>
