---
import Base from '../layouts/Base.astro'
import Layout from '../components/Layout.astro'
import ToolShell from '../components/ToolShell.astro'

const seo = {
  title: 'FPS Converter — Change Video Frame Rate Online Free | maratool',
  description: 'Change video frame rate (FPS) online for free. Convert between 24, 25, 30, 50, 60 fps and custom values. Runs entirely in your browser — no upload needed.',
  canonical: 'https://maratool.com/fps-converter',
  schema: {
    '@context': 'https://schema.org',
    '@type': 'WebApplication',
    name: 'FPS Converter',
    url: 'https://maratool.com/fps-converter',
    applicationCategory: 'UtilitiesApplication',
    operatingSystem: 'Any',
    offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
    description: 'Change video frame rate (FPS) online. Convert between 24, 30, 60 fps and more.',
  },
  breadcrumbSchema: {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://maratool.com' },
      { '@type': 'ListItem', position: 2, name: 'Converter', item: 'https://maratool.com/converter' },
      { '@type': 'ListItem', position: 3, name: 'Video', item: 'https://maratool.com/converter/video' },
      { '@type': 'ListItem', position: 4, name: 'FPS Converter', item: 'https://maratool.com/fps-converter' },
    ],
  },
  faqSchema: {
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: [
      {
        '@type': 'Question',
        name: 'Is my video uploaded to a server?',
        acceptedAnswer: { '@type': 'Answer', text: 'No. The entire conversion runs in your browser using WebAssembly. Your video never leaves your device.' }
      },
      {
        '@type': 'Question',
        name: 'Why does it download ~25 MB on first use?',
        acceptedAnswer: { '@type': 'Answer', text: 'The FFmpeg processing engine needs to be loaded as a WebAssembly module. After the first use, your browser caches it so subsequent conversions start instantly.' }
      },
      {
        '@type': 'Question',
        name: 'What video formats are supported?',
        acceptedAnswer: { '@type': 'Answer', text: 'You can upload MP4, WebM, and MOV files. The output is always MP4 with the original audio track preserved.' }
      },
      {
        '@type': 'Question',
        name: 'What FPS values can I convert to?',
        acceptedAnswer: { '@type': 'Answer', text: 'Presets include 24 (cinema), 25 (PAL), 30 (NTSC), 50, and 60 fps. You can also enter any custom value between 1 and 240.' }
      }
    ]
  }
}

const howTo = [
  'Drop a video file or click to select an MP4, WebM, or MOV file.',
  'Choose a target frame rate from the presets or enter a custom value.',
  'Click Convert and download the result when processing completes.'
]

const faq = [
  { q: 'Is my video uploaded to a server?', a: 'No. The entire conversion runs in your browser using WebAssembly. Your video never leaves your device.' },
  { q: 'Why does it download ~25 MB on first use?', a: 'The FFmpeg processing engine needs to be loaded as a WebAssembly module. After the first use, your browser caches it so subsequent conversions start instantly.' },
  { q: 'What video formats are supported?', a: 'You can upload MP4, WebM, and MOV files. The output is always MP4 with the original audio track preserved.' },
  { q: 'What FPS values can I convert to?', a: 'Presets include 24 (cinema), 25 (PAL), 30 (NTSC), 50, and 60 fps. You can also enter any custom value between 1 and 240.' }
]

const relatedTools = [
  { slug: 'video-to-gif', name: 'Video to GIF Converter — MP4 to GIF Online' },
  { slug: 'gif-maker', name: 'GIF Maker — Create Animated GIFs from Images' },
  { slug: 'image-converter', name: 'Image Format Converter — PNG, JPEG, WebP' },
]

const breadcrumbs = [
  { label: 'Home', href: '/' },
  { label: 'Converter', href: '/converter' },
  { label: 'Video', href: '/converter/video' },
  { label: 'FPS Converter' },
]
---
<Base {...seo}>
  <Layout>
    <ToolShell slug="fps-converter" name="FPS Converter — Change Video Frame Rate" description="Change the frame rate of your videos directly in the browser. Supports presets and custom FPS. Free, fast, and private." howTo={howTo} faq={faq} relatedTools={relatedTools} breadcrumbs={breadcrumbs}>
      <div class="tool-container" style="min-height:400px;">
        <!-- Drop zone -->
        <div class="fps-dropzone" id="fps-dropzone">
          <input type="file" id="fps-file-input" accept="video/mp4,video/webm,video/quicktime" hidden />
          <div class="fps-dropzone-inner">
            <svg class="fps-upload-icon" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
              <polyline points="17 8 12 3 7 8"/>
              <line x1="12" y1="3" x2="12" y2="15"/>
            </svg>
            <p class="fps-dropzone-title">Drop a video here</p>
            <p class="fps-dropzone-sub">or click to select a file</p>
            <p class="fps-dropzone-formats">MP4, WebM, MOV</p>
          </div>
        </div>

        <!-- Info banner -->
        <div class="fps-info" id="fps-info">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="16" x2="12" y2="12"/><line x1="12" y1="8" x2="12.01" y2="8"/></svg>
          <span>The FFmpeg engine (~25 MB) downloads on first use and is cached by your browser. Max file size: 1 GB.</span>
        </div>

        <!-- Settings (after file selected) -->
        <div class="fps-settings" id="fps-settings" style="display:none;">
          <div class="fps-preview-row">
            <div class="fps-video-wrap">
              <video id="fps-video-preview" controls></video>
            </div>
            <div class="fps-metadata">
              <div class="fps-stat">
                <span class="fps-stat-value" id="fps-original-fps">—</span>
                <span class="fps-stat-label">Original FPS</span>
              </div>
              <div class="fps-stat">
                <span class="fps-stat-value" id="fps-duration">—</span>
                <span class="fps-stat-label">Duration</span>
              </div>
              <div class="fps-stat">
                <span class="fps-stat-value" id="fps-file-size">—</span>
                <span class="fps-stat-label">File size</span>
              </div>
            </div>
          </div>
          <div class="fps-controls">
            <span class="fps-controls-label">Target FPS</span>
            <div class="fps-presets" id="fps-presets">
              <button class="fps-preset" data-fps="24">24</button>
              <button class="fps-preset" data-fps="25">25</button>
              <button class="fps-preset active" data-fps="30">30</button>
              <button class="fps-preset" data-fps="50">50</button>
              <button class="fps-preset" data-fps="60">60</button>
              <input type="number" class="fps-custom" id="fps-custom" placeholder="Custom" min="1" max="240" />
            </div>
            <div class="fps-actions">
              <button class="tool-button" id="fps-convert">Convert FPS</button>
              <button class="copy-btn" id="fps-change-file">Change file</button>
            </div>
          </div>
        </div>

        <!-- Progress -->
        <div class="fps-progress" id="fps-progress" style="display:none;">
          <div class="fps-progress-text" id="fps-progress-text">Loading FFmpeg...</div>
          <div class="fps-progress-bar-track">
            <div class="fps-progress-bar-fill" id="fps-progress-bar"></div>
          </div>
          <div class="fps-progress-detail" id="fps-progress-detail"></div>
        </div>

        <!-- Error -->
        <div class="fps-error" id="fps-error" style="display:none;">
          <span class="fps-error-text" id="fps-error-text"></span>
          <button class="fps-error-retry" id="fps-error-retry">Try again</button>
        </div>

        <!-- Result -->
        <div class="fps-result" id="fps-result" style="display:none;">
          <div class="fps-result-stats" id="fps-result-stats"></div>
          <video id="fps-result-preview" controls></video>
          <div class="fps-result-actions">
            <button class="tool-button" id="fps-download">Download converted video</button>
            <button class="copy-btn" id="fps-new">Convert another</button>
          </div>
        </div>
      </div>
    </ToolShell>
  </Layout>
</Base>
<style is:global>
  .fps-dropzone {
    border: 2px dashed var(--border);
    border-radius: var(--radius);
    padding: 3rem 2rem;
    text-align: center;
    cursor: pointer;
    transition: border-color 0.2s, background 0.2s;
  }
  .fps-dropzone:hover,
  .fps-dropzone.drag-over {
    border-color: var(--accent);
    background: var(--bg-soft);
  }
  .fps-dropzone-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
  }
  .fps-upload-icon {
    color: var(--text-3);
    margin-bottom: 0.5rem;
  }
  .fps-dropzone-title {
    font-size: 1.125rem;
    font-weight: 600;
    color: var(--text);
    margin: 0;
  }
  .fps-dropzone-sub {
    font-size: 0.875rem;
    color: var(--text-2);
    margin: 0;
  }
  .fps-dropzone-formats {
    font-size: 0.75rem;
    color: var(--text-3);
    margin: 0.25rem 0 0;
  }

  .fps-info {
    display: flex;
    align-items: flex-start;
    gap: 0.5rem;
    padding: 0.75rem 1rem;
    background: var(--bg-soft);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    margin-top: 1rem;
    font-size: 0.8125rem;
    color: var(--text-2);
    line-height: 1.5;
  }
  .fps-info svg {
    flex-shrink: 0;
    margin-top: 1px;
    color: var(--text-3);
  }

  /* Settings */
  .fps-preview-row {
    display: flex;
    gap: 1.5rem;
    margin-bottom: 1.5rem;
  }
  .fps-video-wrap {
    flex: 1;
    min-width: 0;
  }
  .fps-video-wrap video {
    width: 100%;
    border-radius: var(--radius);
    border: 1px solid var(--border);
    background: #000;
  }
  .fps-metadata {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    min-width: 140px;
  }
  .fps-stat {
    display: flex;
    flex-direction: column;
    gap: 0.125rem;
  }
  .fps-stat-value {
    font-size: 1.25rem;
    font-weight: 600;
    color: var(--text);
    font-family: var(--font-mono);
  }
  .fps-stat-label {
    font-size: 0.75rem;
    color: var(--text-3);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .fps-controls {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }
  .fps-controls-label {
    font-size: 0.8125rem;
    font-weight: 600;
    color: var(--text-2);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
  .fps-presets {
    display: flex;
    gap: 0.5rem;
    align-items: center;
    flex-wrap: wrap;
  }
  .fps-preset {
    padding: 6px 16px;
    border: 1px solid var(--border);
    border-radius: 20px;
    background: var(--bg);
    color: var(--text);
    font-size: 0.875rem;
    cursor: pointer;
    transition: all 0.15s;
  }
  .fps-preset:hover {
    border-color: var(--accent);
    color: var(--accent);
  }
  .fps-preset.active {
    background: var(--accent);
    border-color: var(--accent);
    color: #fff;
  }
  .fps-custom {
    width: 80px;
    padding: 6px 10px;
    border: 1px solid var(--border);
    border-radius: var(--radius);
    background: var(--bg);
    color: var(--text);
    font-size: 0.875rem;
    font-family: var(--font-mono);
  }
  .fps-custom:focus {
    outline: none;
    border-color: var(--accent);
  }
  .fps-actions {
    display: flex;
    gap: 0.75rem;
    align-items: center;
    margin-top: 0.5rem;
  }

  /* Progress */
  .fps-progress {
    text-align: center;
    padding: 2rem;
  }
  .fps-progress-text {
    font-size: 0.9375rem;
    font-weight: 600;
    color: var(--text);
    margin-bottom: 1rem;
  }
  .fps-progress-bar-track {
    width: 100%;
    max-width: 400px;
    height: 8px;
    background: var(--bg-hover);
    border-radius: 4px;
    margin: 0 auto;
    overflow: hidden;
  }
  .fps-progress-bar-fill {
    height: 100%;
    background: var(--accent);
    border-radius: 4px;
    width: 0%;
    transition: width 0.3s;
  }
  .fps-progress-detail {
    font-size: 0.75rem;
    color: var(--text-3);
    margin-top: 0.5rem;
  }

  /* Error */
  .fps-error {
    background: var(--error-bg);
    border: 1px solid var(--error-border);
    border-radius: var(--radius);
    padding: 1rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
  }
  .fps-error-text {
    color: #c53030;
    font-size: 0.875rem;
  }
  .fps-error-retry {
    padding: 6px 14px;
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: 6px;
    font-size: 0.8125rem;
    cursor: pointer;
    white-space: nowrap;
    color: var(--text);
  }
  .fps-error-retry:hover {
    background: var(--bg-hover);
  }

  /* Result */
  .fps-result-stats {
    font-size: 0.875rem;
    color: var(--text-2);
    margin-bottom: 1rem;
    line-height: 1.6;
  }
  .fps-result video {
    width: 100%;
    max-height: 400px;
    border-radius: var(--radius);
    border: 1px solid var(--border);
    background: #000;
    margin-bottom: 1rem;
  }
  .fps-result-actions {
    display: flex;
    gap: 0.75rem;
    align-items: center;
  }

  @media (max-width: 768px) {
    .fps-preview-row {
      flex-direction: column;
    }
    .fps-metadata {
      flex-direction: row;
      min-width: 0;
      flex-wrap: wrap;
    }
    .fps-dropzone { padding: 2rem 1rem; }
  }
</style>
<script src="../tools/fps-converter.js"></script>
