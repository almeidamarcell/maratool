---
import Base from '../../layouts/Base.astro'
import Layout from '../../components/Layout.astro'
import HubPage from '../../components/HubPage.astro'
import { toolsByCategory, toolsFlatByCategory, subcategoryOrderByCategory, buildToolItemList } from '../../data/tools'

export function getStaticPaths() {
  const subs = subcategoryOrderByCategory.Marketing ?? []
  const catTools = toolsByCategory.Marketing ?? {}

  const descriptions: Record<string, { title: string; description: string; intro: string }> = {
    builder: {
      title: 'Marketing Builder Tools — maratool',
      description: 'Free browser-based marketing builder tools. Generate QR codes, create UTM-tagged URLs for campaign tracking — no sign-up, runs in your browser.',
      intro: 'Build QR codes, campaign URLs, and marketing assets directly in your browser.',
    },
    calculator: {
      title: 'Marketing Calculator Tools — maratool',
      description: 'Free marketing calculators for A/B test significance, campaign ROI, CAC, and LTV. Instant results, no sign-up, runs entirely in your browser.',
      intro: 'Calculate ROI, statistical significance, and unit economics for your campaigns.',
    },
  }

  return subs.map(sub => {
    const slug = sub.toLowerCase()
    const meta = descriptions[slug] ?? {
      title: `${sub} Tools — maratool`,
      description: `Free browser-based ${sub.toLowerCase()} tools — no sign-up, runs entirely in your browser.`,
      intro: `${sub} tools that run locally in your browser.`,
    }
    return {
      params: { subcategory: slug },
      props: {
        sub,
        subTools: catTools[sub] ?? [],
        ...meta,
      },
    }
  })
}

const { subcategory } = Astro.params
const { sub, subTools, title, description, intro } = Astro.props
const allTools = toolsFlatByCategory.Marketing ?? []
const subcategories = subcategoryOrderByCategory.Marketing ?? []
const liveSubTools = subTools.filter((tool: { live: boolean }) => tool.live)

const seo = {
  title,
  description,
  canonical: `https://maratool.com/marketing/${subcategory}`,
  schema: {
    '@context': 'https://schema.org',
    '@type': 'CollectionPage',
    name: `${sub} Tools`,
    url: `https://maratool.com/marketing/${subcategory}`,
    description,
    hasPart: liveSubTools.map((tool: { name: string; slug: string }) => ({
      '@type': 'SoftwareApplication',
      name: tool.name,
      url: `https://maratool.com/${tool.slug}`,
      applicationCategory: 'BusinessApplication',
    })),
    mainEntity: buildToolItemList(liveSubTools, `${sub} Tools`),
  },
  breadcrumbSchema: {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://maratool.com' },
      { '@type': 'ListItem', position: 2, name: 'Marketing', item: 'https://maratool.com/marketing' },
      { '@type': 'ListItem', position: 3, name: sub, item: `https://maratool.com/marketing/${subcategory}` },
    ],
  },
}
---
<Base {...seo} scope="subcategory">
  <Layout scope="subcategory">
    <HubPage
      category="Marketing"
      categorySlug="marketing"
      title={`${sub} tools`}
      subtitle={intro}
      tools={allTools}
      subcategories={subcategories}
      activeSubcategory={sub}
      basePath="/marketing"
    />
  </Layout>
</Base>
