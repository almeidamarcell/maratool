---
import Base from '../../layouts/Base.astro'
import Layout from '../../components/Layout.astro'
import Breadcrumb from '../../components/Breadcrumb.astro'
import { toolsByCategory, subcategoryOrderByCategory } from '../../data/tools'

export function getStaticPaths() {
  const subs = subcategoryOrderByCategory.Marketing ?? []
  const catTools = toolsByCategory.Marketing ?? {}

  const descriptions: Record<string, { title: string; description: string; intro: string }> = {
    builder: {
      title: 'Marketing Builder Tools — maratool',
      description: 'Free browser-based marketing builder tools. Create UTM-tagged URLs for campaign tracking — no sign-up, runs entirely in your browser.',
      intro: 'Build campaign URLs and marketing assets directly in your browser.',
    },
  }

  return subs.map(sub => {
    const slug = sub.toLowerCase()
    const meta = descriptions[slug] ?? {
      title: `${sub} Tools — maratool`,
      description: `Free browser-based ${sub.toLowerCase()} tools — no sign-up, runs entirely in your browser.`,
      intro: `${sub} tools that run locally in your browser.`,
    }
    return {
      params: { subcategory: slug },
      props: {
        sub,
        tools: catTools[sub] ?? [],
        ...meta,
      },
    }
  })
}

const { subcategory } = Astro.params
const { sub, tools, title, description, intro } = Astro.props

const seo = {
  title,
  description,
  canonical: `https://maratool.com/marketing/${subcategory}`,
  schema: {
    '@context': 'https://schema.org',
    '@type': 'CollectionPage',
    name: `${sub} Tools`,
    url: `https://maratool.com/marketing/${subcategory}`,
    description,
    hasPart: tools.map((tool: { name: string; slug: string }) => ({
      '@type': 'SoftwareApplication',
      name: tool.name,
      url: `https://maratool.com/${tool.slug}`,
      applicationCategory: 'BusinessApplication',
    })),
  },
  breadcrumbSchema: {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://maratool.com' },
      { '@type': 'ListItem', position: 2, name: 'Marketing', item: 'https://maratool.com/marketing' },
      { '@type': 'ListItem', position: 3, name: sub, item: `https://maratool.com/marketing/${subcategory}` },
    ],
  },
}

const breadcrumbs = [
  { label: 'Home', href: '/' },
  { label: 'Marketing', href: '/marketing' },
  { label: sub },
]
---
<Base {...seo}>
  <Layout>
    <Breadcrumb crumbs={breadcrumbs} />
    <div class="hero">
      <h1>{sub} Tools</h1>
      <p>{intro}</p>
    </div>

    <div class="tools-grid">
      {tools.map((tool: { live: boolean; slug: string; emoji: string; name: string; description: string }) => (
        tool.live
          ? (
            <a href={`/${tool.slug}`} class="tool-card">
              <span class="tool-card-emoji">{tool.emoji}</span>
              <div class="tool-card-name">{tool.name}</div>
              <div class="tool-card-desc">{tool.description}</div>
            </a>
          )
          : (
            <div class="tool-card" style="opacity:0.5;cursor:default;">
              <span class="tool-card-emoji">{tool.emoji}</span>
              <div class="tool-card-name">{tool.name}</div>
              <div class="tool-card-desc">{tool.description}</div>
              <span class="tool-card-badge">Coming Soon</span>
            </div>
          )
      ))}
    </div>
  </Layout>
</Base>
