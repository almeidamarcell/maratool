---
import Base from '../layouts/Base.astro'
import Layout from '../components/Layout.astro'
import ToolShell from '../components/ToolShell.astro'

const seo = {
  title: 'Curated Color Palettes — Browse 70+ beautiful palettes | maratool',
  description: 'Browse a curated collection of beautiful color palettes. Filter by mood, search by name or tag, and copy hex values instantly. Free, no sign-up.',
  canonical: 'https://maratool.com/palette-collection',
  schema: {
    '@context': 'https://schema.org',
    '@type': 'WebApplication',
    name: 'Curated Color Palettes',
    url: 'https://maratool.com/palette-collection',
    applicationCategory: 'DeveloperApplication',
    operatingSystem: 'Any',
    offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
    description: 'Browse a curated collection of beautiful color palettes for design and development.',
  },
  breadcrumbSchema: {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://maratool.com' },
      { '@type': 'ListItem', position: 2, name: 'Color', item: 'https://maratool.com/color' },
      { '@type': 'ListItem', position: 3, name: 'Generate', item: 'https://maratool.com/color/generate' },
      { '@type': 'ListItem', position: 4, name: 'Curated Color Palettes', item: 'https://maratool.com/palette-collection' },
    ],
  },
  faqSchema: {
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: [
      {
        '@type': 'Question',
        name: 'How do I copy a color from a palette?',
        acceptedAnswer: { '@type': 'Answer', text: 'Click any color swatch within a palette to copy its hex value to your clipboard. You\'ll see a brief "Copied!" confirmation.' }
      },
      {
        '@type': 'Question',
        name: 'Can I copy an entire palette as CSS variables?',
        acceptedAnswer: { '@type': 'Answer', text: 'Yes. Click the palette name to copy all colors as CSS custom properties (e.g., --palette-1: #2d6ef6; --palette-2: #e74c3c;). You can paste them directly into your stylesheet.' }
      },
      {
        '@type': 'Question',
        name: 'How are the palettes organized?',
        acceptedAnswer: { '@type': 'Answer', text: 'Palettes are tagged by mood and style (e.g., warm, cool, pastel, dark, vibrant, nature, retro). Use the filter buttons or search bar to find palettes matching your design needs.' }
      },
      {
        '@type': 'Question',
        name: 'Can I use these palettes in my projects?',
        acceptedAnswer: { '@type': 'Answer', text: 'Yes. All palettes in this collection are free to use in personal and commercial projects. Simply copy the hex values and apply them in your design tool or code.' }
      }
    ]
  }
}

const howTo = [
  'Browse palettes or use the search bar and filter buttons to narrow down.',
  'Click any color swatch to copy its hex value.',
  'Click a palette name to copy all colors as CSS variables.'
]

const faq = [
  { q: 'How do I copy a color from a palette?', a: 'Click any color swatch to copy its hex value. You\'ll see a "Copied!" confirmation.' },
  { q: 'Can I copy an entire palette as CSS variables?', a: 'Yes. Click the palette name to copy all colors as CSS custom properties that you can paste directly into your stylesheet.' },
  { q: 'How are the palettes organized?', a: 'Palettes are tagged by mood and style (warm, cool, pastel, dark, vibrant, etc.). Use the filter buttons or search bar to find what you need.' },
  { q: 'Can I use these palettes in my projects?', a: 'Yes. All palettes are free to use in personal and commercial projects.' }
]

const relatedTools = [
  { slug: 'color-harmony-generator', name: 'Color Harmony Generator' },
  { slug: 'color-shades', name: 'Color Shades Generator' },
  { slug: 'palette-generator', name: 'Palette Generator' },
]

const breadcrumbs = [
  { label: 'Home', href: '/' },
  { label: 'Color', href: '/color' },
  { label: 'Generate', href: '/color/generate' },
  { label: 'Curated Color Palettes' },
]
---
<Base {...seo}>
  <Layout>
    <ToolShell slug="palette-collection" name="Browse Curated Color Palettes" description="A curated collection of beautiful color palettes. Filter by mood, search by name or tag, copy hex values instantly." howTo={howTo} faq={faq} relatedTools={relatedTools} breadcrumbs={breadcrumbs}>
      <div class="tool-container">
        <!-- Search and filters -->
        <div class="pc-controls">
          <input type="text" id="pc-search" class="tool-input pc-search" placeholder="Search palettes by name or tag..." spellcheck="false" aria-label="Search palettes" />
          <div class="pc-tags" id="pc-tags"></div>
        </div>

        <!-- Palette count -->
        <div class="pc-count" id="pc-count"></div>

        <!-- Palette grid -->
        <div class="pc-grid" id="pc-grid"></div>
      </div>
    </ToolShell>
  </Layout>
</Base>
<style is:global>
  .pc-controls {
    margin-bottom: 1rem;
  }
  .pc-search {
    width: 100%;
    font-size: 15px;
    margin-bottom: 0.75rem;
  }
  .pc-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.375rem;
  }
  .pc-tag {
    font-size: 12px;
    font-weight: 500;
    color: var(--text-2);
    background: var(--bg-soft);
    border: 1px solid var(--border);
    border-radius: 20px;
    padding: 4px 12px;
    cursor: pointer;
    transition: background 0.1s, color 0.1s, border-color 0.1s;
    white-space: nowrap;
  }
  .pc-tag:hover { background: var(--bg-hover); }
  .pc-tag.active {
    background: var(--accent);
    color: #fff;
    border-color: var(--accent);
  }

  .pc-count {
    font-size: 12px;
    color: var(--text-3);
    margin-bottom: 0.75rem;
  }

  .pc-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1rem;
    min-height: 300px;
  }

  .pc-card {
    border: 1px solid var(--border);
    border-radius: var(--radius);
    overflow: hidden;
    background: var(--bg);
    transition: box-shadow 0.15s;
  }
  .pc-card:hover {
    box-shadow: 0 2px 8px rgba(0,0,0,0.06);
  }

  .pc-colors {
    display: flex;
    height: 80px;
  }
  .pc-color-swatch {
    flex: 1;
    cursor: pointer;
    position: relative;
    transition: flex 0.15s;
  }
  .pc-color-swatch:hover {
    flex: 1.5;
  }
  .pc-color-swatch .pc-swatch-hex {
    position: absolute;
    bottom: 4px;
    left: 50%;
    transform: translateX(-50%);
    font-size: 9px;
    font-family: var(--font-mono);
    background: rgba(0,0,0,0.45);
    color: #fff;
    padding: 1px 5px;
    border-radius: 3px;
    opacity: 0;
    transition: opacity 0.15s;
    white-space: nowrap;
    pointer-events: none;
  }
  .pc-color-swatch:hover .pc-swatch-hex {
    opacity: 1;
  }
  .pc-color-swatch.copied .pc-swatch-hex {
    opacity: 1;
    background: var(--accent);
  }

  .pc-card-info {
    padding: 10px 12px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.5rem;
  }
  .pc-card-name {
    font-size: 13px;
    font-weight: 600;
    color: var(--text);
    cursor: pointer;
    border: none;
    background: none;
    padding: 0;
    text-align: left;
    transition: color 0.1s;
  }
  .pc-card-name:hover { color: var(--accent); }
  .pc-card-name.copied { color: var(--accent); }

  .pc-card-tags {
    display: flex;
    gap: 0.25rem;
    flex-wrap: wrap;
    justify-content: flex-end;
  }
  .pc-card-tag {
    font-size: 10px;
    color: var(--text-3);
    background: var(--bg-soft);
    border-radius: 10px;
    padding: 2px 7px;
  }

  @media (max-width: 768px) {
    .pc-grid { grid-template-columns: 1fr; }
  }
</style>
<script src="../tools/palette-collection.js"></script>
