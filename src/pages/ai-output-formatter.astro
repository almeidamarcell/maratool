---
import Base from '../layouts/Base.astro'
import Layout from '../components/Layout.astro'
import ToolShell from '../components/ToolShell.astro'

const seo = {
  title: 'Format AI Output — JSON & Markdown | maratool',
  description: 'Format AI Output — JSON & Markdown. Free, instant, runs in your browser — no upload to server.',
  canonical: 'https://maratool.com/ai-output-formatter',
  schema: {
    '@context': 'https://schema.org',
    '@type': 'WebApplication',
    name: 'Format AI Output — JSON & Markdown',
    url: 'https://maratool.com/ai-output-formatter',
    applicationCategory: 'DeveloperApplication',
    operatingSystem: 'Any',
    offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
    description: 'Format AI Output — JSON & Markdown. Free, instant, runs in your browser — no upload to server.',
  },
  breadcrumbSchema: {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://maratool.com' },
      { '@type': 'ListItem', position: 2, name: 'Developer', item: 'https://maratool.com/developer' },
      { '@type': 'ListItem', position: 3, name: 'AI', item: 'https://maratool.com/developer/ai' },
      { '@type': 'ListItem', position: 4, name: 'Format AI Output — JSON & Markdown', item: 'https://maratool.com/ai-output-formatter' },
    ],
  },
  faqSchema: {
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: [
      { '@type': 'Question', name: 'Does this tool send data to a server?', acceptedAnswer: { '@type': 'Answer', text: 'No. Everything runs locally in your browser. Your data never leaves your device.' } },
      { '@type': 'Question', name: 'Do I need an account?', acceptedAnswer: { '@type': 'Answer', text: 'No sign-up, no limits, no paywall.' } },
      { '@type': 'Question', name: 'Can I use this offline?', acceptedAnswer: { '@type': 'Answer', text: 'Yes, after the page loads once, the tool works without a network connection.' } },
      { '@type': 'Question', name: 'Is this tool free?', acceptedAnswer: { '@type': 'Answer', text: 'Yes, completely free with no usage limits.' } }
    ]
  }
}

const howTo = ['Enter or paste your input in the fields below.', 'Results update instantly as you type.', 'Use Copy to grab the output.']
const faq = [{ q: 'Does this tool send data to a server?', a: 'No. Everything runs locally in your browser. Your data never leaves your device.' }, { q: 'Do I need an account?', a: 'No sign-up, no limits, no paywall.' }, { q: 'Can I use this offline?', a: 'Yes, after the page loads once, the tool works without a network connection.' }, { q: 'Is this tool free?', a: 'Yes, completely free with no usage limits.' }]
const relatedTools = [{ slug: 'llm-json-extractor', name: 'llm-json-extractor' }, { slug: 'json-formatter', name: 'json-formatter' }, { slug: 'markdown-cleanup', name: 'Clean Up Markdown Text Online' }]
const breadcrumbs = [
  { label: 'Home', href: '/' },
  { label: 'Developer', href: '/developer' },
  { label: 'AI', href: '/developer/ai' },
  { label: 'Format AI Output' },
]
---
<Base {...seo}>
  <Layout>
    <ToolShell slug="ai-output-formatter" name="Format AI Output — JSON & Markdown" description="Format AI Output — JSON & Markdown. Free, instant, runs in your browser — no upload to server." howTo={howTo} faq={faq} relatedTools={relatedTools} breadcrumbs={breadcrumbs}>
      <div class="tool-container" style="min-height:480px;">
        <div id="w4-root"></div>
        <label class="tool-label" for="w4-in">AI output</label>
        <textarea id="w4-in" class="tool-textarea" rows="8" placeholder="Paste raw LLM output"></textarea>
        <pre id="w4-out" class="tool-output" style="min-height:120px;white-space:pre-wrap;margin-top:1rem;"></pre>
      </div>
    </ToolShell>
  </Layout>
</Base>

<style is:global>
  .calc-row { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; margin-bottom: 1rem; }
  .calc-field { margin-bottom: 0.75rem; }
  .calc-select { max-width: 100%; }
  .diff-add { background: #e6ffed; }
  .diff-remove { background: #ffeef0; }
  @media (max-width: 600px) { .calc-row { grid-template-columns: 1fr; } }
</style>
<script src="../tools/ai-output-formatter.js"></script>
