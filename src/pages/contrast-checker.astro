---
import Base from '../layouts/Base.astro'
import Layout from '../components/Layout.astro'
import ToolShell from '../components/ToolShell.astro'

const seo = {
  title: 'Contrast Checker — WCAG color contrast ratio checker | maratool',
  description: 'Check color contrast ratios for WCAG AA and AAA compliance. Test foreground and background colors for accessibility instantly. Free, no sign-up.',
  canonical: 'https://maratool.com/contrast-checker',
  schema: {
    '@context': 'https://schema.org',
    '@type': 'WebApplication',
    name: 'Contrast Checker',
    url: 'https://maratool.com/contrast-checker',
    applicationCategory: 'DesignApplication',
    operatingSystem: 'Any',
    offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
    description: 'Check color contrast ratios for WCAG AA and AAA compliance.',
  },
  breadcrumbSchema: {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://maratool.com' },
      { '@type': 'ListItem', position: 2, name: 'Color', item: 'https://maratool.com/color' },
      { '@type': 'ListItem', position: 3, name: 'Check', item: 'https://maratool.com/color/check' },
      { '@type': 'ListItem', position: 4, name: 'Contrast Checker', item: 'https://maratool.com/contrast-checker' },
    ],
  },
  faqSchema: {
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: [
      {
        '@type': 'Question',
        name: 'What is a good contrast ratio for accessibility?',
        acceptedAnswer: { '@type': 'Answer', text: 'WCAG 2.1 requires a minimum contrast ratio of 4.5:1 for normal text (AA level) and 7:1 for enhanced contrast (AAA level). Large text (18px bold or 24px regular) needs at least 3:1 for AA.' }
      },
      {
        '@type': 'Question',
        name: 'What is the difference between WCAG AA and AAA?',
        acceptedAnswer: { '@type': 'Answer', text: 'AA is the minimum recommended level for web accessibility. AAA is the enhanced level with stricter contrast requirements. AA requires 4.5:1 for normal text, while AAA requires 7:1. Most sites target AA compliance.' }
      },
      {
        '@type': 'Question',
        name: 'How is color contrast ratio calculated?',
        acceptedAnswer: { '@type': 'Answer', text: 'The contrast ratio is calculated using the relative luminance of two colors. The formula is (L1 + 0.05) / (L2 + 0.05), where L1 is the lighter color luminance and L2 is the darker. Luminance is derived from the sRGB color values using a gamma correction formula.' }
      },
      {
        '@type': 'Question',
        name: 'What counts as large text in WCAG?',
        acceptedAnswer: { '@type': 'Answer', text: 'Large text is defined as 18pt (24px) or larger for regular weight, or 14pt (18.66px) or larger for bold weight. Large text has a lower contrast requirement of 3:1 for AA compliance.' }
      }
    ]
  }
}

const howTo = [
  'Enter a foreground (text) color using the picker or hex input.',
  'Enter a background color. The preview updates in real time.',
  'Check the WCAG results below — green means pass, red means fail.'
]

const faq = [
  { q: 'What is a good contrast ratio for accessibility?', a: 'WCAG 2.1 requires a minimum of 4.5:1 for normal text (AA) and 7:1 for enhanced contrast (AAA). Large text needs at least 3:1 for AA.' },
  { q: 'What is the difference between WCAG AA and AAA?', a: 'AA is the minimum recommended level. AAA is stricter. AA requires 4.5:1 for normal text, AAA requires 7:1. Most sites target AA.' },
  { q: 'How is color contrast ratio calculated?', a: 'Using relative luminance: (L1 + 0.05) / (L2 + 0.05) where L1 is the lighter color. Luminance comes from sRGB values with gamma correction.' },
  { q: 'What counts as large text in WCAG?', a: 'Large text is 18pt (24px) regular or 14pt (18.66px) bold. It has a lower contrast requirement of 3:1 for AA.' }
]

const relatedTools = [
  { slug: 'color-shades', name: 'Color Shades Generator' },
  { slug: 'css-gradient', name: 'CSS Gradient Generator' },
]

const breadcrumbs = [
  { label: 'Home', href: '/' },
  { label: 'Color', href: '/color' },
  { label: 'Check', href: '/color/check' },
  { label: 'Contrast Checker' },
]
---
<Base {...seo}>
  <Layout>
    <ToolShell slug="contrast-checker" name="Contrast Checker" description="Check color contrast ratios against WCAG AA and AAA standards." howTo={howTo} faq={faq} relatedTools={relatedTools} breadcrumbs={breadcrumbs}>
      <div class="tool-container">
        <div class="cc-inputs">
          <div class="cc-color-block">
            <label class="tool-label">Foreground</label>
            <div class="cc-color-row">
              <input type="color" id="cc-fg-picker" value="#1a1a18" class="cc-picker" />
              <input type="text" id="cc-fg-hex" value="#1a1a18" class="cc-hex-input" spellcheck="false" />
            </div>
          </div>
          <button class="cc-swap-btn" id="cc-swap" aria-label="Swap colors" type="button">&lrarr;</button>
          <div class="cc-color-block">
            <label class="tool-label">Background</label>
            <div class="cc-color-row">
              <input type="color" id="cc-bg-picker" value="#ffffff" class="cc-picker" />
              <input type="text" id="cc-bg-hex" value="#ffffff" class="cc-hex-input" spellcheck="false" />
            </div>
          </div>
        </div>

        <div class="cc-preview" id="cc-preview">
          <p class="cc-preview-large">Large text (18px bold)</p>
          <p class="cc-preview-normal">Normal body text (16px regular)</p>
          <p class="cc-preview-small">Small text (12px regular)</p>
        </div>

        <div class="cc-ratio-display">
          <span class="cc-ratio-value" id="cc-ratio">&mdash;</span>
          <span class="cc-ratio-label">contrast ratio</span>
        </div>

        <div class="cc-wcag-grid">
          <div class="cc-wcag-card">
            <div class="cc-wcag-level">AA Normal</div>
            <div class="cc-wcag-threshold">&ge; 4.5:1</div>
            <span class="tool-badge" id="cc-aa-normal">&mdash;</span>
          </div>
          <div class="cc-wcag-card">
            <div class="cc-wcag-level">AA Large</div>
            <div class="cc-wcag-threshold">&ge; 3:1</div>
            <span class="tool-badge" id="cc-aa-large">&mdash;</span>
          </div>
          <div class="cc-wcag-card">
            <div class="cc-wcag-level">AAA Normal</div>
            <div class="cc-wcag-threshold">&ge; 7:1</div>
            <span class="tool-badge" id="cc-aaa-normal">&mdash;</span>
          </div>
          <div class="cc-wcag-card">
            <div class="cc-wcag-level">AAA Large</div>
            <div class="cc-wcag-threshold">&ge; 4.5:1</div>
            <span class="tool-badge" id="cc-aaa-large">&mdash;</span>
          </div>
          <div class="cc-wcag-card">
            <div class="cc-wcag-level">UI Components</div>
            <div class="cc-wcag-threshold">&ge; 3:1</div>
            <span class="tool-badge" id="cc-ui">&mdash;</span>
          </div>
        </div>
      </div>
    </ToolShell>
  </Layout>
</Base>
<style>
  .cc-inputs {
    display: flex;
    align-items: flex-end;
    gap: 1rem;
    margin-bottom: 1.25rem;
  }
  .cc-color-block { flex: 1; }
  .cc-color-row {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-top: 0.375rem;
  }
  .cc-picker {
    width: 44px;
    height: 44px;
    border: 1px solid var(--border);
    border-radius: 50%;
    cursor: pointer;
    padding: 2px;
    background: var(--bg);
    flex-shrink: 0;
  }
  .cc-hex-input {
    font-family: var(--font-mono);
    font-size: 16px;
    font-weight: 600;
    color: var(--text);
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 8px 10px;
    width: 120px;
  }
  .cc-swap-btn {
    width: 40px;
    height: 40px;
    border: 1px solid var(--border);
    border-radius: var(--radius);
    background: var(--bg-soft);
    color: var(--text-2);
    font-size: 18px;
    cursor: pointer;
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.1s;
    margin-bottom: 2px;
  }
  .cc-swap-btn:hover { background: var(--bg-hover); }

  .cc-preview {
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 1.5rem;
    margin-bottom: 1.25rem;
  }
  .cc-preview-large { font-size: 18px; font-weight: 700; margin-bottom: 0.5rem; }
  .cc-preview-normal { font-size: 16px; margin-bottom: 0.5rem; }
  .cc-preview-small { font-size: 12px; }
  .cc-preview p { color: inherit; }

  .cc-ratio-display {
    text-align: center;
    margin-bottom: 1.25rem;
  }
  .cc-ratio-value {
    display: block;
    font-size: 48px;
    font-weight: 700;
    font-family: var(--font-mono);
    color: var(--text);
    line-height: 1.1;
  }
  .cc-ratio-label {
    font-size: 13px;
    color: var(--text-3);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .cc-wcag-grid {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 0.75rem;
  }
  .cc-wcag-card {
    background: var(--bg-soft);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 0.75rem;
    text-align: center;
  }
  .cc-wcag-level {
    font-size: 12px;
    font-weight: 600;
    color: var(--text);
    margin-bottom: 0.25rem;
  }
  .cc-wcag-threshold {
    font-size: 11px;
    color: var(--text-3);
    margin-bottom: 0.5rem;
  }

  @media (max-width: 768px) {
    .cc-inputs { flex-direction: column; align-items: stretch; }
    .cc-swap-btn { align-self: center; transform: rotate(90deg); }
    .cc-wcag-grid { grid-template-columns: repeat(2, 1fr); }
  }
</style>
<script src="../tools/contrast-checker.js"></script>
