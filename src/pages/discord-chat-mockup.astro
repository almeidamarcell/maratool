---
import Base from '../layouts/Base.astro'
import { styleHref } from '../lib/css-version'
import Layout from '../components/Layout.astro'
import ToolShell from '../components/ToolShell.astro'
import { discord } from '../data/mockup-platforms'

const platformConfig = discord

const seo = {
  title: 'Discord Chat Mockup Generator — Create Fake Discord Messages | maratool',
  description: 'Create realistic Discord chat screenshots online. Full-width message rows with avatars, role colors, dark and light themes. Download as PNG, free.',
  canonical: 'https://maratool.com/discord-chat-mockup',
  schema: {
    '@context': 'https://schema.org',
    '@type': 'WebApplication',
    name: 'Discord Chat Mockup Generator',
    url: 'https://maratool.com/discord-chat-mockup',
    applicationCategory: 'DesignApplication',
    operatingSystem: 'Any',
    offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
    description: 'Create realistic Discord chat screenshots with role colors, inline editing, and PNG export.',
  },
  breadcrumbSchema: {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://maratool.com' },
      { '@type': 'ListItem', position: 2, name: 'Mockup', item: 'https://maratool.com/mockup' },
      { '@type': 'ListItem', position: 3, name: 'Chat', item: 'https://maratool.com/mockup/chat' },
      { '@type': 'ListItem', position: 4, name: 'Discord Chat Mockup Generator', item: 'https://maratool.com/discord-chat-mockup' },
    ],
  },
  faqSchema: {
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: [
      {
        '@type': 'Question',
        name: 'Is this Discord chat mockup generator free?',
        acceptedAnswer: { '@type': 'Answer', text: 'Yes, completely free. No sign-up, no watermark. Create unlimited Discord chat mockups and download them as PNG.' }
      },
      {
        '@type': 'Question',
        name: 'Can I customize user role colors?',
        acceptedAnswer: { '@type': 'Answer', text: 'Yes. Each user gets a role color automatically. You can add multiple users and each will have a distinct color, just like Discord server roles.' }
      },
      {
        '@type': 'Question',
        name: 'Does this support Discord light mode?',
        acceptedAnswer: { '@type': 'Answer', text: 'Yes. The mockup starts in dark mode (like real Discord) and you can toggle to light mode using the button above the preview.' }
      },
      {
        '@type': 'Question',
        name: 'Are consecutive messages from the same user grouped?',
        acceptedAnswer: { '@type': 'Answer', text: 'Yes. Just like real Discord, consecutive messages from the same user are collapsed — only the first message shows the avatar and username.' }
      }
    ]
  }
}

const howTo = [
  'Add users and type messages using the controls panel on the left.',
  'Click any message text in the preview to edit it inline.',
  'Toggle light mode or hide the phone frame, then click Download PNG.'
]

const faq = [
  { q: 'Is this Discord chat mockup generator free?', a: 'Yes, completely free. No sign-up, no watermark. Create unlimited mockups and download as PNG.' },
  { q: 'Can I customize user role colors?', a: 'Each user gets a role color automatically, just like Discord server roles.' },
  { q: 'Does this support Discord light mode?', a: 'Yes. Toggle between dark and light themes using the button above the preview.' },
  { q: 'Are consecutive messages grouped?', a: 'Yes. Same-user messages are collapsed just like real Discord.' }
]

const relatedTools = [
  { slug: 'whatsapp-chat-mockup', name: 'WhatsApp Chat Mockup' },
  { slug: 'imessage-chat-mockup', name: 'iMessage Chat Mockup' },
  { slug: 'instagram-chat-mockup', name: 'Instagram DM Mockup' },
]

const breadcrumbs = [
  { label: 'Home', href: '/' },
  { label: 'Mockup', href: '/mockup' },
  { label: 'Chat', href: '/mockup/chat' },
  { label: 'Discord Chat Mockup' },
]
---
<Base {...seo}>
  <Layout>
    <ToolShell slug="discord-chat-mockup" name="Discord Chat Mockup Generator" description="Create realistic Discord chat screenshots. Full-width message rows with avatars, role colors, dark and light themes. Download as PNG." howTo={howTo} faq={faq} relatedTools={relatedTools} breadcrumbs={breadcrumbs}>
      <div class="tool-container" style="min-height:600px;">
        <div class="mockup-workspace">
          <!-- Controls panel -->
          <div class="controls-panel">
            <div class="controls-section">
              <h3 class="controls-label">People</h3>
              <div id="people-list"></div>
              <div class="ctrl-row" style="margin-top:8px">
                <input type="text" class="ctrl-input" id="new-person-name" placeholder="Add person...">
                <button class="mockup-btn mockup-btn-primary" id="add-person-btn">Add</button>
              </div>
            </div>
            <div class="controls-section">
              <h3 class="controls-label">New Message</h3>
              <div class="dir-toggle">
                <button class="active" id="dir-outgoing">You</button>
                <button id="dir-incoming">Pick user</button>
              </div>
              <select class="ctrl-input" id="msg-sender-select" style="display:none;margin-bottom:6px"></select>
              <div class="ctrl-row">
                <input type="text" class="ctrl-input" id="new-msg-text" placeholder="Type a message...">
                <button class="mockup-btn mockup-btn-primary" id="add-msg-btn">Send</button>
              </div>
            </div>
            <div class="controls-section">
              <h3 class="controls-label">Messages</h3>
              <div id="msg-list" style="max-height:320px;overflow-y:auto"></div>
            </div>
          </div>

          <!-- Preview -->
          <div class="mockup-preview">
            <div class="mockup-action-bar">
              <button class="mockup-btn mockup-btn-outline" id="toggle-dark">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/></svg>
                Light mode
              </button>
              <button class="mockup-btn mockup-btn-outline" id="toggle-frame">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="5" y="2" width="14" height="20" rx="2" ry="2"/><line x1="12" y1="18" x2="12.01" y2="18"/></svg>
                Hide frame
              </button>
              <div style="flex:1"></div>
              <button class="mockup-btn mockup-btn-primary" id="download-btn">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
                Download PNG
              </button>
            </div>

            <div class="phone-frame" id="phone-frame">
              <div class="phone-notch"></div>
              <div class="phone-screen" id="phone-screen">
                <div class="dc-screen">
                  <div class="dc-statusbar">
                    <span class="dc-statusbar-time">3:42</span>
                    <span style="flex:1"></span>
                    <span class="dc-statusbar-icons">
                      <svg viewBox="0 0 18 12" fill="currentColor" width="16" height="11"><rect x="0" y="9" width="3" height="3" rx="1"/><rect x="5" y="6" width="3" height="6" rx="1"/><rect x="10" y="3" width="3" height="9" rx="1"/><rect x="15" y="0" width="3" height="12" rx="1"/></svg>
                      <svg viewBox="0 0 16 12" fill="currentColor" width="15" height="11"><path d="M8.5 1.5C10.4 1.5 12.1 2.3 13.3 3.5L14.7 2.1C13.1 0.5 10.9 -0.5 8.5 -0.5C6.1 -0.5 3.9 0.5 2.3 2.1L3.7 3.5C4.9 2.3 6.6 1.5 8.5 1.5Z M5.1 5C5.9 4.2 7.1 3.7 8.5 3.7C9.9 3.7 11.1 4.2 11.9 5L8.5 8.5L5.1 5Z"/></svg>
                      <svg viewBox="0 0 25 12" fill="none" width="25" height="12"><rect x="0.5" y="0.5" width="21" height="11" rx="3.5" stroke="currentColor" stroke-width="1"/><rect x="2" y="2" width="18" height="8" rx="2" fill="currentColor"/><path d="M23 4.5C23.5523 4.5 24 4.94772 24 5.5V6.5C24 7.05228 23.5523 7.5 23 7.5" fill="currentColor"/></svg>
                    </span>
                  </div>
                  <div class="dc-header">
                    <span class="dc-header-hash">#</span>
                    <span class="dc-header-name">dev-general</span>
                    <span class="dc-header-divider"></span>
                    <span class="dc-header-topic">General development discussion</span>
                    <div class="dc-header-actions">
                      <!-- Bell icon -->
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M18 8A6 6 0 006 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 01-3.46 0"/></svg>
                      <!-- Pin icon -->
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="17" x2="12" y2="22"/><path d="M5 17h14v-1.76a2 2 0 00-1.11-1.79l-1.78-.9A2 2 0 0115 10.76V6h1V2H8v4h1v4.76a2 2 0 01-1.11 1.79l-1.78.9A2 2 0 005 15.24V17z"/></svg>
                      <!-- Members icon -->
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 00-3-3.87"/><path d="M16 3.13a4 4 0 010 7.75"/></svg>
                    </div>
                  </div>
                  <div class="dc-chat" id="dc-chat"></div>
                  <div class="dc-input-bar">
                    <div class="dc-input-wrap">
                      <span class="dc-input-btn">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="16"/><line x1="8" y1="12" x2="16" y2="12"/></svg>
                      </span>
                      <input type="text" class="dc-input-field" placeholder="Message #dev-general" disabled>
                      <div class="dc-input-actions">
                        <!-- Gift icon -->
                        <span class="dc-input-btn">
                          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 12 20 22 4 22 4 12"/><rect x="2" y="7" width="20" height="5"/><line x1="12" y1="22" x2="12" y2="7"/><path d="M12 7H7.5a2.5 2.5 0 010-5C11 2 12 7 12 7z"/><path d="M12 7h4.5a2.5 2.5 0 000-5C13 2 12 7 12 7z"/></svg>
                        </span>
                        <!-- Sticker icon -->
                        <span class="dc-input-btn">
                          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="3"/><path d="M15 3v6a3 3 0 003 3h3"/><circle cx="9" cy="10" r="1" fill="currentColor" stroke="none"/><circle cx="14" cy="10" r="1" fill="currentColor" stroke="none"/><path d="M9 15c.83.95 1.91 1.5 3 1.5s2.17-.55 3-1.5"/></svg>
                        </span>
                        <!-- Emoji icon -->
                        <span class="dc-input-btn">
                          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M8 14s1.5 2 4 2 4-2 4-2"/><line x1="9" y1="9" x2="9.01" y2="9"/><line x1="15" y1="9" x2="15.01" y2="9"/></svg>
                        </span>
                      </div>
                    </div>
                  </div>
                  <div class="dc-home-indicator"></div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </ToolShell>
  </Layout>
</Base>

<link rel="stylesheet" href={styleHref('mockup.css')} />

<script define:vars={{ platformConfig }}>
  window.__mockupPlatform = platformConfig
</script>
<script is:inline src="https://cdn.jsdelivr.net/npm/html2canvas@1.4.1/dist/html2canvas.min.js"></script>
<script src="../tools/mockup/mockup-common.js"></script>
<script src="../tools/mockup/discord-engine.js"></script>

<style is:global>
/* Ensure the mockup phone is centered in the preview area */
.mockup-preview {
  display: flex;
  flex-direction: column;
  align-items: center;
}
</style>
