---
import Base from '../layouts/Base.astro'
import Layout from '../components/Layout.astro'
import ToolShell from '../components/ToolShell.astro'

const seo = {
  title: 'JWT Decoder — Decode JSON Web Tokens instantly | maratool',
  description: 'Paste a JWT and instantly see the decoded header, payload, and signature. Works with any JWT — no keys required, no data sent to a server. Free, no sign-up.',
  canonical: 'https://maratool.com/jwt-decoder',
  schema: {
    '@context': 'https://schema.org',
    '@type': 'WebApplication',
    name: 'JWT Decoder',
    url: 'https://maratool.com/jwt-decoder',
    applicationCategory: 'DeveloperApplication',
    operatingSystem: 'Any',
    offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
    description: 'Decode JWT tokens and inspect header, payload, and signature in your browser.',
  },
  breadcrumbSchema: {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://maratool.com' },
      { '@type': 'ListItem', position: 2, name: 'Developer', item: 'https://maratool.com/developer' },
      { '@type': 'ListItem', position: 3, name: 'Encoding', item: 'https://maratool.com/developer/encoding' },
      { '@type': 'ListItem', position: 4, name: 'JWT Decoder', item: 'https://maratool.com/jwt-decoder' },
    ],
  },
  faqSchema: {
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: [
      {
        '@type': 'Question',
        name: 'Is it safe to paste my JWT into this tool?',
        acceptedAnswer: { '@type': 'Answer', text: 'Yes. All decoding happens in your browser. Your JWT is never sent to a server. The tool uses only JavaScript\'s built-in atob() function to decode the Base64url-encoded parts.' }
      },
      {
        '@type': 'Question',
        name: 'What is a JWT?',
        acceptedAnswer: { '@type': 'Answer', text: 'A JWT (JSON Web Token) is a compact, URL-safe token format used to transmit claims between parties. It consists of three Base64url-encoded parts: header, payload, and signature, separated by dots.' }
      },
      {
        '@type': 'Question',
        name: 'Can this tool verify the JWT signature?',
        acceptedAnswer: { '@type': 'Answer', text: 'No. Signature verification requires the secret key or public key used to sign the JWT. This tool only decodes the header and payload — it does not validate or verify the signature.' }
      },
      {
        '@type': 'Question',
        name: 'What does the exp claim mean in a JWT payload?',
        acceptedAnswer: { '@type': 'Answer', text: 'The exp claim is the expiration time, expressed as a Unix timestamp. If the current time is past the exp value, the token is expired. You can use the Unix Timestamp Converter tool to convert it to a human-readable date.' }
      }
    ]
  }
}

const howTo = [
  'Paste your JWT token into the input field.',
  'The header and payload are decoded and pretty-printed automatically.',
  'Click Copy on any panel to copy that section to your clipboard.'
]

const faq = [
  { q: 'Is it safe to paste my JWT into this tool?', a: 'Yes. All decoding happens in your browser. Your JWT is never sent to a server. The tool uses only JavaScript\'s built-in atob() function to decode the Base64url-encoded parts.' },
  { q: 'What is a JWT?', a: 'A JWT (JSON Web Token) is a compact, URL-safe token format used to transmit claims between parties. It consists of three Base64url-encoded parts: header, payload, and signature, separated by dots.' },
  { q: 'Can this tool verify the JWT signature?', a: 'No. Signature verification requires the secret key or public key used to sign the JWT. This tool only decodes the header and payload — it does not validate or verify the signature.' },
  { q: 'What does the exp claim mean in a JWT payload?', a: 'The exp claim is the expiration time, expressed as a Unix timestamp. If the current time is past the exp value, the token is expired. You can use the Unix Timestamp Converter tool to convert it to a human-readable date.' }
]

const relatedTools = [
  { slug: 'hash-generator', name: 'Hash Generator' },
  { slug: 'base64', name: 'Base64 Encode / Decode' },
  { slug: 'unix-timestamp', name: 'Unix Timestamp Converter' },
]

const breadcrumbs = [
  { label: 'Home', href: '/' },
  { label: 'Developer', href: '/developer' },
  { label: 'Encoding', href: '/developer/encoding' },
  { label: 'JWT Decoder' },
]
---
<Base {...seo}>
  <Layout>
    <ToolShell slug="jwt-decoder" name="JWT Decoder" description="Paste a JWT token to instantly decode and inspect the header, payload, and signature. Runs entirely in your browser — nothing is sent to a server." howTo={howTo} faq={faq} relatedTools={relatedTools} breadcrumbs={breadcrumbs}>
      <div class="tool-container">
        <div class="tool-panel">
          <label class="tool-label" for="jwt-input">JWT Token</label>
          <textarea id="jwt-input" class="tool-textarea" rows="5" placeholder="Paste your JWT here... e.g. eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..." aria-label="JWT token input"></textarea>
        </div>

        <div class="tool-panel">
          <div class="tool-panel-header">
            <span class="tool-label">Header</span>
            <button class="copy-btn" data-copy-from="jwt-header">Copy</button>
          </div>
          <pre id="jwt-header" class="tool-output" aria-label="Decoded header" style="min-height:80px;"></pre>
        </div>

        <div class="tool-panel">
          <div class="tool-panel-header">
            <span class="tool-label">Payload</span>
            <button class="copy-btn" data-copy-from="jwt-payload">Copy</button>
          </div>
          <pre id="jwt-payload" class="tool-output" aria-label="Decoded payload" style="min-height:80px;"></pre>
        </div>

        <div class="tool-panel">
          <div class="tool-panel-header">
            <span class="tool-label">Signature (raw)</span>
            <button class="copy-btn" data-copy-from="jwt-signature">Copy</button>
          </div>
          <pre id="jwt-signature" class="tool-output" aria-label="Signature" style="min-height:48px;word-break:break-all;"></pre>
        </div>
      </div>
    </ToolShell>
  </Layout>
</Base>
<script src="../tools/jwt.js"></script>
