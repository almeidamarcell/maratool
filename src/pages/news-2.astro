---
import ScoreCalc from '../components/ScoreCalc.astro'

const spec = {
  items: [
    { id: 'rr', label: 'Respiratory rate (breaths/min)', options: [
      { label: '≤ 8 (+3)', points: 3 },
      { label: '9–11 (+1)', points: 1 },
      { label: '12–20 (0)', points: 0, default: true },
      { label: '21–24 (+2)', points: 2 },
      { label: '≥ 25 (+3)', points: 3 },
    ]},
    { id: 'spo2', label: 'SpO₂ — Scale 1 (no hypercapnic risk)', options: [
      { label: '≤ 91% (+3)', points: 3 },
      { label: '92–93% (+2)', points: 2 },
      { label: '94–95% (+1)', points: 1 },
      { label: '≥ 96% (0)', points: 0, default: true },
    ]},
    { id: 'air', label: 'Air or supplemental O₂', options: [
      { label: 'Room air (0)', points: 0, default: true },
      { label: 'Supplemental O₂ (+2)', points: 2 },
    ]},
    { id: 'sbp', label: 'Systolic BP (mmHg)', options: [
      { label: '≤ 90 (+3)', points: 3 },
      { label: '91–100 (+2)', points: 2 },
      { label: '101–110 (+1)', points: 1 },
      { label: '111–219 (0)', points: 0, default: true },
      { label: '≥ 220 (+3)', points: 3 },
    ]},
    { id: 'hr', label: 'Heart rate (bpm)', options: [
      { label: '≤ 40 (+3)', points: 3 },
      { label: '41–50 (+1)', points: 1 },
      { label: '51–90 (0)', points: 0, default: true },
      { label: '91–110 (+1)', points: 1 },
      { label: '111–130 (+2)', points: 2 },
      { label: '≥ 131 (+3)', points: 3 },
    ]},
    { id: 'cons', label: 'Consciousness (ACVPU)', options: [
      { label: 'Alert (0)', points: 0, default: true },
      { label: 'New confusion / V / P / U (+3)', points: 3 },
    ]},
    { id: 'temp', label: 'Temperature (°C)', options: [
      { label: '≤ 35.0 (+3)', points: 3 },
      { label: '35.1–36.0 (+1)', points: 1 },
      { label: '36.1–38.0 (0)', points: 0, default: true },
      { label: '38.1–39.0 (+1)', points: 1 },
      { label: '≥ 39.1 (+2)', points: 2 },
    ]},
  ],
  bands: [
    { min: 0, max: 4, label: 'Low risk — routine ward observations', cls: 'cls-normal' },
    { min: 5, max: 6, label: 'Medium — urgent senior review, consider HDU', cls: 'cls-warn' },
    { min: 7, max: 20, label: 'High — emergency response, critical care input', cls: 'cls-danger' },
  ],
  cols: 2,
}

const faq = [
  { q: 'What is NEWS-2?', a: 'The National Early Warning Score 2 — UK Royal College of Physicians’ updated track-and-trigger system for detecting clinical deterioration in adult inpatients.' },
  { q: 'What is the recommended response?', a: 'NEWS 0–4: routine observation. NEWS 5–6 (or any single parameter scoring 3): urgent senior review. NEWS ≥ 7: emergency response team / critical care input.' },
  { q: 'Should I use Scale 1 or Scale 2 for SpO₂?', a: 'Scale 1 for most patients. Scale 2 is reserved for patients with confirmed hypercapnic respiratory failure (e.g., COPD with documented target SpO₂ 88–92%).' },
  { q: 'NEWS-2 vs qSOFA?', a: 'NEWS-2 is broader (any deterioration) and a stronger early warning. qSOFA is specific to suspected infection / sepsis. They are complementary.' },
]
const references = [
  { citation: 'Royal College of Physicians. National Early Warning Score (NEWS) 2: Standardising the assessment of acute-illness severity in the NHS. London: RCP, 2017.' },
]
const relatedTools = [
  { slug: 'qsofa', name: 'qSOFA' },
  { slug: 'sofa-score', name: 'SOFA Score' },
  { slug: 'curb-65', name: 'CURB-65' },
]
---
<ScoreCalc
  slug="news-2"
  name="NEWS 2 Score Calculator"
  schemaName="NEWS 2"
  shortDescription="National Early Warning Score 2 (NEWS-2) for clinical deterioration detection."
  metaTitle="NEWS 2 Score Calculator (Clinical Deterioration) | maratool"
  metaDescription="Free NEWS-2 calculator. National Early Warning Score 2 with response thresholds for clinical deterioration."
  subcategory="Score"
  subcategorySlug="score"
  howTo={[
    'Enter the patient’s vital signs and consciousness.',
    'The NEWS-2 total and recommended response update instantly.',
    'Re-assess at the frequency dictated by the score band.',
  ]}
  faq={faq}
  relatedTools={relatedTools}
  references={references}
  spec={spec}
/>
