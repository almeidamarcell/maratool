---
import ScoreCalc from '../components/ScoreCalc.astro'

const spec = {
  items: [
    { id: 'age', label: 'Age > 70 years', options: [
      { label: 'No (0)', points: 0, default: true }, { label: 'Yes (5)', points: 5 },
    ]},
    { id: 'mi', label: 'Myocardial infarction in the past 6 months', options: [
      { label: 'No (0)', points: 0, default: true }, { label: 'Yes (10)', points: 10 },
    ]},
    { id: 'chf', label: 'S3 gallop or jugular venous distension', options: [
      { label: 'No (0)', points: 0, default: true }, { label: 'Yes (11)', points: 11 },
    ]},
    { id: 'as', label: 'Significant aortic stenosis', options: [
      { label: 'No (0)', points: 0, default: true }, { label: 'Yes (3)', points: 3 },
    ]},
    { id: 'rhythm', label: 'Rhythm other than sinus, or premature atrial contractions on last preop ECG', options: [
      { label: 'No (0)', points: 0, default: true }, { label: 'Yes (7)', points: 7 },
    ]},
    { id: 'pvc', label: '> 5 premature ventricular contractions/min documented at any time', options: [
      { label: 'No (0)', points: 0, default: true }, { label: 'Yes (7)', points: 7 },
    ]},
    { id: 'status', label: 'Poor general medical status (metabolic, renal, hepatic, or bedridden)', options: [
      { label: 'No (0)', points: 0, default: true }, { label: 'Yes (3)', points: 3 },
    ]},
    { id: 'surgery', label: 'Intraperitoneal, intrathoracic, or aortic surgery', options: [
      { label: 'No (0)', points: 0, default: true }, { label: 'Yes (3)', points: 3 },
    ]},
    { id: 'emergency', label: 'Emergency operation', options: [
      { label: 'No (0)', points: 0, default: true }, { label: 'Yes (4)', points: 4 },
    ]},
  ],
  bands: [
    { min: 0, max: 5, label: 'Class I (0–5) — cardiac complications ≈ 1%, cardiac death ≈ 0.2%', cls: 'cls-normal' },
    { min: 6, max: 12, label: 'Class II (6–12) — complications ≈ 7%, cardiac death ≈ 2%', cls: 'cls-warn' },
    { min: 13, max: 25, label: 'Class III (13–25) — complications ≈ 14%, cardiac death ≈ 2%', cls: 'cls-danger' },
    { min: 26, max: 53, label: 'Class IV (≥ 26) — complications ≈ 78%, cardiac death ≈ 56%', cls: 'cls-danger' },
  ],
  max: 53,
  cols: 2,
}

const faq = [
  { q: 'What is the Goldman Cardiac Risk Index?', a: 'The original (1977) multifactorial index estimating perioperative cardiac complications in non-cardiac surgery from 9 weighted clinical factors.' },
  { q: 'How are the Goldman classes interpreted?', a: 'Class I (0–5 points) is low risk; risk rises through Class II–III to Class IV (≥ 26 points), which carries very high cardiac mortality.' },
  { q: 'Goldman vs RCRI?', a: 'The Lee Revised Cardiac Risk Index superseded Goldman for most contemporary preoperative risk assessment; Goldman remains of historical and educational value.' },
  { q: 'Is the index still valid?', a: 'It identifies high-risk patients but modern perioperative care has lowered absolute event rates; use it alongside current ACC/AHA or ESC algorithms.' },
]
const references = [
  { citation: 'Goldman L, Caldera DL, Nussbaum SR, et al. Multifactorial index of cardiac risk in noncardiac surgical procedures. <em>N Engl J Med</em>. 1977;297(16):845-850.' },
]
const relatedTools = [
  { slug: 'lee-rcri', name: 'Revised Cardiac Risk Index' },
  { slug: 'detsky-cardiac-risk', name: 'Detsky Cardiac Risk Index' },
  { slug: 'heart-score', name: 'HEART Score' },
]
---
<ScoreCalc
  slug="goldman-cardiac-risk"
  name="Goldman Cardiac Risk Index Calculator"
  schemaName="Goldman Cardiac Risk Index"
  shortDescription="Original Goldman multifactorial cardiac risk index for non-cardiac surgery (0–53)."
  metaTitle="Goldman Cardiac Risk Index Calculator | maratool"
  metaDescription="Free Goldman Cardiac Risk Index calculator. Estimate perioperative cardiac complication risk in non-cardiac surgery from 9 weighted factors."
  subcategory="Score"
  subcategorySlug="score"
  howTo={[
    'Select each of the nine Goldman factors that applies.',
    'The weighted total and Goldman class (I–IV) update instantly.',
    'Use alongside the RCRI and current guideline algorithms for preoperative assessment.',
  ]}
  faq={faq}
  relatedTools={relatedTools}
  references={references}
  spec={spec}
/>
