---
import Base from '../layouts/Base.astro'
import Layout from '../components/Layout.astro'
import ToolShell from '../components/ToolShell.astro'

const seo = {
  title: 'Grade Calculator — Weighted Course Grade | maratool',
  description: 'Calculate weighted course grade from assignments. Enter scores and weights to see your overall percentage. Free grade calculator, runs in your browser.',
  canonical: 'https://maratool.com/grade-calculator',
  schema: {
    '@context': 'https://schema.org',
    '@type': 'WebApplication',
    name: 'Grade Calculator — Weighted Course Grade',
    url: 'https://maratool.com/grade-calculator',
    applicationCategory: 'EducationApplication',
    operatingSystem: 'Any',
    offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
    description: 'Calculate weighted course grade from assignments. Enter scores and weights to see your overall percentage. Free grade calculator, runs in your browser.',
  },
  breadcrumbSchema: {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://maratool.com' },
      { '@type': 'ListItem', position: 2, name: 'Education', item: 'https://maratool.com/education' },
      { '@type': 'ListItem', position: 3, name: 'Calculator', item: 'https://maratool.com/education/calculator' },
      { '@type': 'ListItem', position: 4, name: 'Grade Calculator — Weighted Course Grade', item: 'https://maratool.com/grade-calculator' },
    ],
  },
  faqSchema: {
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: [
      { '@type': 'Question', name: 'How is weighted grade calculated?', acceptedAnswer: { '@type': 'Answer', text: 'Sum of (score × weight) divided by total weight. Weights do not need to sum to 100.' } },
      { '@type': 'Question', name: 'What score format is used?', acceptedAnswer: { '@type': 'Answer', text: 'Percentages 0–100 for each assignment score.' } },
      { '@type': 'Question', name: 'Can weights be uneven?', acceptedAnswer: { '@type': 'Answer', text: 'Yes. Enter each assignment weight as a percentage of the total grade.' } },
      { '@type': 'Question', name: 'Is my data sent to a server?', acceptedAnswer: { '@type': 'Answer', text: 'No. All calculations happen in your browser.' } }
    ]
  }
}

const howTo = [
  'Add each assignment with a name, score, and weight percentage.',
  'Click Add assignment for more rows.',
  'See your weighted course grade percentage instantly.'
]

const faq = [
  { q: 'How is weighted grade calculated?', a: 'Sum of (score × weight) divided by total weight. Weights do not need to sum to 100.' },
  { q: 'What score format is used?', a: 'Percentages 0–100 for each assignment score.' },
  { q: 'Can weights be uneven?', a: 'Yes. Enter each assignment weight as a percentage of the total grade.' },
  { q: 'Is my data sent to a server?', a: 'No. All calculations happen in your browser.' }
]

const relatedTools = [
  { slug: 'final-grade-calculator', name: 'Final Grade Calculator' },
  { slug: 'gpa-calculator', name: 'GPA Calculator' },
  { slug: 'percentage-calculator', name: 'Percentage Calculator' }
]

const breadcrumbs = [
  { label: 'Home', href: '/' },
  { label: 'Education', href: '/education' },
  { label: 'Calculator', href: '/education/calculator' },
  { label: 'Grade Calculator' }
]
---
<Base {...seo}>
  <Layout>
    <ToolShell slug="grade-calculator" name="Grade Calculator — Weighted Course Grade" description="Add weighted assignments with scores and weights to calculate your overall course percentage." howTo={howTo} faq={faq} relatedTools={relatedTools} breadcrumbs={breadcrumbs}>
      <div class="tool-container" style="min-height:360px;">
        <div id="gc-rows"></div>
        <button type="button" id="gc-add" class="tool-button" style="margin-bottom:1rem;">Add assignment</button>
        <div class="tool-stats">
          <div class="tool-stat"><span class="tool-stat-value" id="gc-percent">—</span><span class="tool-stat-label">Course grade</span></div>
        </div>
      </div>
    </ToolShell>
  </Layout>
</Base>

<style is:global>
  .calc-row { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; margin-bottom: 1rem; }
  .calc-field { margin-bottom: 0.75rem; }
  .calc-select { max-width: 100%; }
  @media (max-width: 600px) { .calc-row { grid-template-columns: 1fr; } }
</style>
<script src="../tools/grade-calculator.js"></script>
