---
import ScoreCalc from '../components/ScoreCalc.astro'

const spec = {
  items: [
    { id: 'surgery', label: 'High-risk surgery (intraperitoneal, intrathoracic, or suprainguinal vascular)', options: [
      { label: 'No (0)', points: 0, default: true }, { label: 'Yes (1)', points: 1 },
    ]},
    { id: 'ihd', label: 'History of ischemic heart disease', options: [
      { label: 'No (0)', points: 0, default: true }, { label: 'Yes (1)', points: 1 },
    ]},
    { id: 'chf', label: 'History of congestive heart failure', options: [
      { label: 'No (0)', points: 0, default: true }, { label: 'Yes (1)', points: 1 },
    ]},
    { id: 'cvd', label: 'History of cerebrovascular disease (stroke or TIA)', options: [
      { label: 'No (0)', points: 0, default: true }, { label: 'Yes (1)', points: 1 },
    ]},
    { id: 'insulin', label: 'Preoperative insulin therapy for diabetes', options: [
      { label: 'No (0)', points: 0, default: true }, { label: 'Yes (1)', points: 1 },
    ]},
    { id: 'creat', label: 'Preoperative creatinine > 2.0 mg/dL', options: [
      { label: 'No (0)', points: 0, default: true }, { label: 'Yes (1)', points: 1 },
    ]},
  ],
  bands: [
    { min: 0, max: 0, label: 'Class I — major cardiac event risk ≈ 0.4%', cls: 'cls-normal' },
    { min: 1, max: 1, label: 'Class II — risk ≈ 0.9%', cls: 'cls-normal' },
    { min: 2, max: 2, label: 'Class III — risk ≈ 6.6%', cls: 'cls-warn' },
    { min: 3, max: 6, label: 'Class IV — risk ≈ 11%', cls: 'cls-danger' },
  ],
  max: 6,
  cols: 2,
}

const faq = [
  { q: 'What is the Revised Cardiac Risk Index?', a: 'The Lee RCRI is a 6-factor index that estimates the risk of major perioperative cardiac complications in patients undergoing non-cardiac surgery.' },
  { q: 'What outcome does the RCRI predict?', a: 'Major cardiac complications: myocardial infarction, pulmonary edema, ventricular fibrillation or cardiac arrest, and complete heart block.' },
  { q: 'How is the RCRI used in preoperative assessment?', a: 'An RCRI ≥ 2 (elevated risk) prompts consideration of functional capacity assessment and, in selected cases, biomarkers or further cardiac evaluation per ACC/AHA and ESC guidelines.' },
  { q: 'Does a low RCRI guarantee a safe operation?', a: 'No — RCRI estimates population risk; individual factors (frailty, anemia, surgery urgency) and intraoperative events also matter.' },
]
const references = [
  { citation: 'Lee TH, Marcantonio ER, Mangione CM, et al. Derivation and prospective validation of a simple index for prediction of cardiac risk of major noncardiac surgery. <em>Circulation</em>. 1999;100(10):1043-1049.' },
]
const relatedTools = [
  { slug: 'goldman-cardiac-risk', name: 'Goldman Cardiac Risk Index' },
  { slug: 'detsky-cardiac-risk', name: 'Detsky Cardiac Risk Index' },
  { slug: 'heart-score', name: 'HEART Score' },
]
---
<ScoreCalc
  slug="lee-rcri"
  name="Lee Revised Cardiac Risk Index (RCRI) Calculator"
  schemaName="Revised Cardiac Risk Index"
  shortDescription="Lee Revised Cardiac Risk Index (RCRI) for perioperative cardiac risk in non-cardiac surgery (0–6)."
  metaTitle="Revised Cardiac Risk Index Calculator (RCRI) | maratool"
  metaDescription="Free Lee RCRI calculator. Estimate major perioperative cardiac complication risk before non-cardiac surgery from 6 clinical predictors."
  subcategory="Score"
  subcategorySlug="score"
  howTo={[
    'Select each of the six RCRI predictors that applies to the patient.',
    'The total index (0–6) and major cardiac event risk update instantly.',
    'Use in preoperative evaluation to guide further cardiac work-up.',
  ]}
  faq={faq}
  relatedTools={relatedTools}
  references={references}
  spec={spec}
/>
