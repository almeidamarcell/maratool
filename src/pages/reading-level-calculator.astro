---
import Base from '../layouts/Base.astro'
import Layout from '../components/Layout.astro'
import ToolShell from '../components/ToolShell.astro'

const seo = {
  title: 'Reading Level Calculator — Flesch-Kincaid Grade | maratool',
  description: 'Calculate reading level and Flesch-Kincaid grade from pasted text. See word count, sentences, and readability score. Free, runs in your browser.',
  canonical: 'https://maratool.com/reading-level-calculator',
  schema: {
    '@context': 'https://schema.org',
    '@type': 'WebApplication',
    name: 'Reading Level Calculator — Flesch-Kincaid Grade',
    url: 'https://maratool.com/reading-level-calculator',
    applicationCategory: 'EducationApplication',
    operatingSystem: 'Any',
    offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
    description: 'Calculate reading level and Flesch-Kincaid grade from pasted text. See word count, sentences, and readability score. Free, runs in your browser.',
  },
  breadcrumbSchema: {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://maratool.com' },
      { '@type': 'ListItem', position: 2, name: 'Education', item: 'https://maratool.com/education' },
      { '@type': 'ListItem', position: 3, name: 'Calculator', item: 'https://maratool.com/education/calculator' },
      { '@type': 'ListItem', position: 4, name: 'Reading Level Calculator — Flesch-Kincaid Grade', item: 'https://maratool.com/reading-level-calculator' },
    ],
  },
  faqSchema: {
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: [
      { '@type': 'Question', name: 'What is Flesch-Kincaid grade level?', acceptedAnswer: { '@type': 'Answer', text: 'A US school-grade estimate based on average sentence length and syllables per word.' } },
      { '@type': 'Question', name: 'What is reading ease?', acceptedAnswer: { '@type': 'Answer', text: 'Flesch Reading Ease: higher scores (up to ~100) mean easier text; lower scores mean harder text.' } },
      { '@type': 'Question', name: 'How are syllables counted?', acceptedAnswer: { '@type': 'Answer', text: 'Heuristic vowel-group counting — accurate for most English prose.' } },
      { '@type': 'Question', name: 'Is my text sent to a server?', acceptedAnswer: { '@type': 'Answer', text: 'No. Analysis happens entirely in your browser.' } }
    ]
  }
}

const howTo = [
  'Paste or type your text in the textarea.',
  'Reading level stats update automatically.',
  'Use grade level and reading ease to target your audience.'
]

const faq = [
  { q: 'What is Flesch-Kincaid grade level?', a: 'A US school-grade estimate based on average sentence length and syllables per word.' },
  { q: 'What is reading ease?', a: 'Flesch Reading Ease: higher scores (up to ~100) mean easier text; lower scores mean harder text.' },
  { q: 'How are syllables counted?', a: 'Heuristic vowel-group counting — accurate for most English prose.' },
  { q: 'Is my text sent to a server?', a: 'No. Analysis happens entirely in your browser.' }
]

const relatedTools = [
  { slug: 'reading-time', name: 'Reading Time Calculator' },
  { slug: 'word-counter', name: 'Word Counter' },
  { slug: 'grade-calculator', name: 'Grade Calculator' }
]

const breadcrumbs = [
  { label: 'Home', href: '/' },
  { label: 'Education', href: '/education' },
  { label: 'Calculator', href: '/education/calculator' },
  { label: 'Reading Level Calculator' }
]
---
<Base {...seo}>
  <Layout>
    <ToolShell slug="reading-level-calculator" name="Reading Level Calculator — Flesch-Kincaid Grade" description="Paste text to see Flesch-Kincaid grade level, reading ease score, word count, and sentence count." howTo={howTo} faq={faq} relatedTools={relatedTools} breadcrumbs={breadcrumbs}>
      <div class="tool-container" style="min-height:400px;">
        <label class="tool-label" for="rl-input">Text</label>
        <textarea id="rl-input" class="tool-textarea" rows="8" placeholder="Paste text to analyze reading level…"></textarea>
        <div class="tool-stats" style="margin-top:1rem;">
          <div class="tool-stat"><span class="tool-stat-value" id="rl-grade">—</span><span class="tool-stat-label">Grade level</span></div>
          <div class="tool-stat"><span class="tool-stat-value" id="rl-ease">—</span><span class="tool-stat-label">Reading ease</span></div>
          <div class="tool-stat"><span class="tool-stat-value" id="rl-words">—</span><span class="tool-stat-label">Words</span></div>
          <div class="tool-stat"><span class="tool-stat-value" id="rl-sentences">—</span><span class="tool-stat-label">Sentences</span></div>
        </div>
      </div>
    </ToolShell>
  </Layout>
</Base>

<script src="../tools/reading-level-calculator.js"></script>
