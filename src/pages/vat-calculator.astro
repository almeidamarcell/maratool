---
import Base from '../layouts/Base.astro'
import Layout from '../components/Layout.astro'
import ToolShell from '../components/ToolShell.astro'

const seo = {
  title: 'VAT / Sales Tax Calculator — Add or Remove Tax | maratool',
  description: 'Add or remove VAT and sales tax from any amount. Preset rates for US, UK, EU. Free tax calculator, runs in your browser.',
  canonical: 'https://maratool.com/vat-calculator',
  schema: {
    '@context': 'https://schema.org',
    '@type': 'WebApplication',
    name: 'VAT / Sales Tax Calculator',
    url: 'https://maratool.com/vat-calculator',
    applicationCategory: 'BusinessApplication',
    operatingSystem: 'Any',
    offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
    description: 'Add or remove VAT and sales tax from any amount. Preset rates for US, UK, EU. Free tax calculator, runs in your browser.',
  },
  breadcrumbSchema: {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://maratool.com' },
      { '@type': 'ListItem', position: 2, name: 'Business', item: 'https://maratool.com/business' },
      { '@type': 'ListItem', position: 3, name: 'Tax', item: 'https://maratool.com/business/tax' },
      { '@type': 'ListItem', position: 4, name: 'VAT / Sales Tax Calculator', item: 'https://maratool.com/vat-calculator' },
    ],
  },
  faqSchema: {
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: [
      { '@type': 'Question', name: 'How do I add VAT to a price?', acceptedAnswer: { '@type': 'Answer', text: 'Gross = Net × (1 + rate/100). A $100 net price at 20% VAT = $120 gross.' } },
      { '@type': 'Question', name: 'How do I remove VAT from a price?', acceptedAnswer: { '@type': 'Answer', text: 'Net = Gross / (1 + rate/100). A $120 gross price at 20% VAT = $100 net.' } },
      { '@type': 'Question', name: 'What is the standard UK VAT rate?', acceptedAnswer: { '@type': 'Answer', text: '20% standard rate. Reduced rate is 5% for some goods. Always verify current rates.' } },
      { '@type': 'Question', name: 'Is my data sent to a server?', acceptedAnswer: { '@type': 'Answer', text: 'No. All calculations happen in your browser.' } }
    ]
  }
}

const howTo = [
  'Choose whether to add tax to a net amount or remove tax from a gross amount.',
  'Enter the amount and tax rate percentage.',
  'See net, tax, and gross amounts instantly.'
]

const faq = [
  { q: 'How do I add VAT to a price?', a: 'Gross = Net × (1 + rate/100). A $100 net price at 20% VAT = $120 gross.' },
  { q: 'How do I remove VAT from a price?', a: 'Net = Gross / (1 + rate/100). A $120 gross price at 20% VAT = $100 net.' },
  { q: 'What is the standard UK VAT rate?', a: '20% standard rate. Reduced rate is 5% for some goods. Always verify current rates.' },
  { q: 'Is my data sent to a server?', a: 'No. All calculations happen in your browser.' }
]

const relatedTools = [
  { slug: 'profit-margin-calculator', name: 'Profit Margin Calculator' },
  { slug: 'salary-converter', name: 'Salary Converter' },
  { slug: 'percentage-calculator', name: 'Percentage Calculator' }
]

const breadcrumbs = [
  { label: 'Home', href: '/' },
  { label: 'Business', href: '/business' },
  { label: 'Tax', href: '/business/tax' },
  { label: 'VAT Calculator' }
]
---
<Base {...seo}>
  <Layout>
    <ToolShell slug="vat-calculator" name="VAT / Sales Tax Calculator" description="Add or remove VAT/sales tax from any amount. Choose add or remove mode and set the tax rate." howTo={howTo} faq={faq} relatedTools={relatedTools} breadcrumbs={breadcrumbs}>
      <div class="tool-container" style="min-height:280px;">
        <div class="calc-row">
          <div class="calc-field"><label class="tool-label" for="vat-mode">Mode</label><select id="vat-mode" class="tool-input calc-select"><option value="add">Add tax to net amount</option><option value="remove">Remove tax from gross</option></select></div>
          <div class="calc-field"><label class="tool-label" for="vat-rate">Tax rate (%)</label><input type="number" id="vat-rate" class="tool-input" placeholder="20" min="0" step="any" /></div>
        </div>
        <div class="calc-field"><label class="tool-label" for="vat-amount">Amount ($)</label><input type="number" id="vat-amount" class="tool-input" placeholder="100" min="0" step="any" style="max-width:240px;" /></div>
        <div class="tool-stats">
          <div class="tool-stat"><span class="tool-stat-value" id="vat-net">—</span><span class="tool-stat-label">Net amount</span></div>
          <div class="tool-stat"><span class="tool-stat-value" id="vat-tax">—</span><span class="tool-stat-label">Tax amount</span></div>
          <div class="tool-stat"><span class="tool-stat-value" id="vat-gross">—</span><span class="tool-stat-label">Gross amount</span></div>
        </div>
      </div>
    </ToolShell>
  </Layout>
</Base>

<style is:global>
  .calc-row { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; margin-bottom: 1rem; }
  .calc-field { margin-bottom: 0.75rem; }
  .calc-select { max-width: 100%; }
  @media (max-width: 600px) { .calc-row { grid-template-columns: 1fr; } }
</style>
<script src="../tools/vat-calculator.js"></script>
