---
import Base from '../layouts/Base.astro'
import Layout from '../components/Layout.astro'
import ToolShell from '../components/ToolShell.astro'

const seo = {
  title: 'Image Format Converter — PNG, JPEG, WebP Online | maratool',
  description: 'Convert images between PNG, JPEG, WebP, and AVIF formats. Resize, adjust quality, and download instantly — runs entirely in your browser.',
  canonical: 'https://maratool.com/image-converter',
  schema: {
    '@context': 'https://schema.org',
    '@type': 'WebApplication',
    name: 'Image Format Converter',
    url: 'https://maratool.com/image-converter',
    applicationCategory: 'DesignApplication',
    operatingSystem: 'Any',
    offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
    description: 'Convert images between PNG, JPEG, WebP, and AVIF formats.',
  },
  breadcrumbSchema: {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://maratool.com' },
      { '@type': 'ListItem', position: 2, name: 'Image', item: 'https://maratool.com/image' },
      { '@type': 'ListItem', position: 3, name: 'Transform', item: 'https://maratool.com/image/transform' },
      { '@type': 'ListItem', position: 4, name: 'Image Format Converter', item: 'https://maratool.com/image-converter' },
    ],
  },
  faqSchema: {
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: [
      {
        '@type': 'Question',
        name: 'How do I convert PNG to JPEG online?',
        acceptedAnswer: { '@type': 'Answer', text: 'Upload or drop your PNG image into the converter. Select JPEG as the target format, adjust the quality slider if needed, and click "Convert & Download". The conversion runs entirely in your browser.' }
      },
      {
        '@type': 'Question',
        name: 'Does converting to WebP reduce file size?',
        acceptedAnswer: { '@type': 'Answer', text: 'Yes. WebP typically produces 25-35% smaller files than JPEG at equivalent visual quality. Use the quality slider to fine-tune the balance between file size and image quality.' }
      },
      {
        '@type': 'Question',
        name: 'Can I resize the image while converting?',
        acceptedAnswer: { '@type': 'Answer', text: 'Yes. Enter a new width or height and the tool will scale the image proportionally if the aspect ratio lock is enabled. You can also unlock it to set custom dimensions.' }
      },
      {
        '@type': 'Question',
        name: 'Does this tool upload my image to a server?',
        acceptedAnswer: { '@type': 'Answer', text: 'No. All image processing uses the Canvas API in your browser. Your image never leaves your device.' }
      }
    ]
  }
}

const howTo = [
  'Upload or drop an image (PNG, JPEG, WebP, GIF, or BMP).',
  'Choose the target format and adjust quality or dimensions.',
  'Click "Convert & Download" to save the converted image.'
]

const faq = [
  { q: 'How do I convert PNG to JPEG online?', a: 'Upload your PNG, select JPEG as the target, adjust quality, and click "Convert & Download". It runs in your browser.' },
  { q: 'Does converting to WebP reduce file size?', a: 'Yes. WebP typically produces 25-35% smaller files than JPEG at equivalent quality.' },
  { q: 'Can I resize the image while converting?', a: 'Yes. Enter new dimensions with the aspect ratio lock on to scale proportionally, or unlock it for custom sizes.' },
  { q: 'Does this tool upload my image to a server?', a: 'No. All processing uses the Canvas API in your browser. Your image never leaves your device.' }
]

const relatedTools = [
  { slug: 'image-splitter', name: 'Split Image Into Grid Tiles' },
  { slug: 'favicon-generator', name: 'Favicon Generator' },
  { slug: 'background-remover', name: 'Background Remover' },
]

const breadcrumbs = [
  { label: 'Home', href: '/' },
  { label: 'Image', href: '/image' },
  { label: 'Transform', href: '/image/transform' },
  { label: 'Image Format Converter' },
]
---
<Base {...seo}>
  <Layout>
    <ToolShell slug="image-converter" name="Image Format Converter — PNG, JPEG, WebP" description="Convert images between PNG, JPEG, WebP, and AVIF formats. Resize, adjust quality, and download." howTo={howTo} faq={faq} relatedTools={relatedTools} breadcrumbs={breadcrumbs}>
      <div class="tool-container" style="min-height:300px;">
        <div class="ic-upload" id="ic-upload">
          <input type="file" id="ic-file" accept="image/*" hidden />
          <div class="ic-upload-content">
            <div class="ic-upload-icon">🖼️</div>
            <p class="ic-upload-text">Drop an image here or <button type="button" class="ic-upload-btn" id="ic-browse">browse</button></p>
            <p class="ic-upload-hint">PNG, JPEG, WebP, GIF, BMP — any image format</p>
          </div>
        </div>

        <div class="ic-source" id="ic-source" style="display:none;">
          <div class="ic-source-preview">
            <img id="ic-source-img" alt="Source image" />
            <span class="ic-source-info" id="ic-source-info"></span>
          </div>
          <button class="ic-change-btn" id="ic-change" type="button">Change image</button>
        </div>

        <div class="ic-options" id="ic-options" style="display:none;">
          <div class="ic-option-row">
            <label class="tool-label" for="ic-format">Output format</label>
            <select id="ic-format" class="ic-select">
              <option value="image/png">PNG</option>
              <option value="image/jpeg">JPEG</option>
              <option value="image/webp">WebP</option>
            </select>
          </div>

          <div class="ic-option-row" id="ic-quality-row">
            <label class="tool-label" for="ic-quality">Quality: <span id="ic-quality-val">85</span>%</label>
            <input type="range" id="ic-quality" min="1" max="100" value="85" class="ic-slider" />
          </div>

          <div class="ic-option-row">
            <label class="tool-label">Resize (optional)</label>
            <div class="ic-resize-inputs">
              <input type="number" id="ic-width" class="ic-dim-input" placeholder="Width" min="1" />
              <button type="button" id="ic-lock" class="ic-lock-btn" title="Lock aspect ratio">🔗</button>
              <input type="number" id="ic-height" class="ic-dim-input" placeholder="Height" min="1" />
              <button type="button" id="ic-reset-size" class="ic-reset-btn" title="Reset to original size">↩</button>
            </div>
          </div>

          <button type="button" id="ic-convert" class="ic-convert-btn">Convert & Download</button>
        </div>
      </div>
    </ToolShell>
  </Layout>
</Base>
<style is:global>
  .ic-upload {
    border: 2px dashed var(--border);
    border-radius: var(--radius);
    padding: 3rem 2rem;
    text-align: center;
    cursor: pointer;
    transition: border-color 0.15s, background 0.15s;
    margin-bottom: 1.25rem;
  }
  .ic-upload:hover, .ic-upload.dragover {
    border-color: var(--accent);
    background: var(--bg-soft);
  }
  .ic-upload-icon { font-size: 36px; margin-bottom: 0.75rem; }
  .ic-upload-text { color: var(--text-2); font-size: 14px; }
  .ic-upload-btn {
    background: none;
    border: none;
    color: var(--accent);
    font-weight: 600;
    cursor: pointer;
    font-size: 14px;
    text-decoration: underline;
    padding: 0;
  }
  .ic-upload-hint { color: var(--text-3); font-size: 12px; margin-top: 0.375rem; }

  .ic-source {
    display: flex;
    align-items: center;
    gap: 1rem;
    background: var(--bg-soft);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 1rem;
    margin-bottom: 1.25rem;
  }
  .ic-source-preview {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    flex: 1;
    min-width: 0;
  }
  .ic-source-preview img {
    width: 64px;
    height: 64px;
    object-fit: contain;
    border: 1px solid var(--border);
    border-radius: 6px;
    background: #fff;
  }
  .ic-source-info { font-size: 13px; color: var(--text-2); }
  .ic-change-btn {
    font-size: 13px;
    color: var(--accent);
    background: none;
    border: 1px solid var(--accent);
    border-radius: var(--radius);
    padding: 6px 12px;
    cursor: pointer;
    flex-shrink: 0;
  }
  .ic-change-btn:hover { background: var(--accent); color: #fff; }

  .ic-options {
    background: var(--bg-soft);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 1.25rem;
  }
  .ic-option-row {
    margin-bottom: 1rem;
  }
  .ic-option-row:last-of-type {
    margin-bottom: 1.25rem;
  }
  .ic-select {
    display: block;
    width: 100%;
    max-width: 240px;
    padding: 8px 12px;
    font-size: 14px;
    border: 1px solid var(--border);
    border-radius: var(--radius);
    background: var(--bg);
    color: var(--text);
    margin-top: 0.375rem;
  }
  .ic-slider {
    display: block;
    width: 100%;
    max-width: 320px;
    margin-top: 0.375rem;
    accent-color: var(--accent);
  }
  .ic-resize-inputs {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-top: 0.375rem;
  }
  .ic-dim-input {
    width: 100px;
    padding: 8px 10px;
    font-size: 14px;
    border: 1px solid var(--border);
    border-radius: var(--radius);
    background: var(--bg);
    color: var(--text);
    font-family: var(--font-mono);
  }
  .ic-lock-btn, .ic-reset-btn {
    background: none;
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 6px 8px;
    cursor: pointer;
    font-size: 14px;
    line-height: 1;
    color: var(--text-2);
  }
  .ic-lock-btn.unlocked { opacity: 0.4; }
  .ic-lock-btn:hover, .ic-reset-btn:hover { background: var(--bg-hover); }

  .ic-convert-btn {
    display: inline-block;
    padding: 10px 24px;
    font-size: 14px;
    font-weight: 600;
    border: none;
    border-radius: var(--radius);
    background: var(--accent);
    color: #fff;
    cursor: pointer;
    transition: background 0.15s;
  }
  .ic-convert-btn:hover { opacity: 0.9; }

  @media (max-width: 768px) {
    .ic-source { flex-direction: column; }
    .ic-resize-inputs { flex-wrap: wrap; }
  }
</style>
<script src="../tools/image-converter.js"></script>
