---
import ScoreCalc from '../components/ScoreCalc.astro'

const spec = {
  items: [
    { id: 'resp', label: 'Respiration — PaO₂/FiO₂ (mmHg)', options: [
      { label: '≥ 400 (0)', points: 0, default: true },
      { label: '< 400 (1)', points: 1 },
      { label: '< 300 (2)', points: 2 },
      { label: '< 200 with respiratory support (3)', points: 3 },
      { label: '< 100 with respiratory support (4)', points: 4 },
    ]},
    { id: 'coag', label: 'Coagulation — Platelets (×10³/µL)', options: [
      { label: '≥ 150 (0)', points: 0, default: true },
      { label: '< 150 (1)', points: 1 },
      { label: '< 100 (2)', points: 2 },
      { label: '< 50 (3)', points: 3 },
      { label: '< 20 (4)', points: 4 },
    ]},
    { id: 'liver', label: 'Liver — Bilirubin (mg/dL)', options: [
      { label: '< 1.2 (0)', points: 0, default: true },
      { label: '1.2–1.9 (1)', points: 1 },
      { label: '2.0–5.9 (2)', points: 2 },
      { label: '6.0–11.9 (3)', points: 3 },
      { label: '≥ 12.0 (4)', points: 4 },
    ]},
    { id: 'cardio', label: 'Cardiovascular', options: [
      { label: 'MAP ≥ 70 mmHg (0)', points: 0, default: true },
      { label: 'MAP < 70 mmHg (1)', points: 1 },
      { label: 'Dopamine ≤ 5 or dobutamine any dose (2)', points: 2 },
      { label: 'Dopamine > 5, epi ≤ 0.1 or norepi ≤ 0.1 (3)', points: 3 },
      { label: 'Dopamine > 15, epi > 0.1 or norepi > 0.1 (4)', points: 4 },
    ]},
    { id: 'cns', label: 'CNS — Glasgow Coma Scale', options: [
      { label: '15 (0)', points: 0, default: true },
      { label: '13–14 (1)', points: 1 },
      { label: '10–12 (2)', points: 2 },
      { label: '6–9 (3)', points: 3 },
      { label: '< 6 (4)', points: 4 },
    ]},
    { id: 'renal', label: 'Renal — Creatinine (mg/dL) or urine output', options: [
      { label: '< 1.2 (0)', points: 0, default: true },
      { label: '1.2–1.9 (1)', points: 1 },
      { label: '2.0–3.4 (2)', points: 2 },
      { label: '3.5–4.9 or UO < 500 mL/d (3)', points: 3 },
      { label: '≥ 5.0 or UO < 200 mL/d (4)', points: 4 },
    ]},
  ],
  bands: [
    { min: 0, max: 6, label: 'Score 0–6 — mortality ≈ < 10%', cls: 'cls-normal' },
    { min: 7, max: 9, label: 'Score 7–9 — mortality ≈ 15–20%', cls: 'cls-warn' },
    { min: 10, max: 12, label: 'Score 10–12 — mortality ≈ 40–50%', cls: 'cls-danger' },
    { min: 13, max: 14, label: 'Score 13–14 — mortality ≈ 50–60%', cls: 'cls-danger' },
    { min: 15, max: 24, label: 'Score ≥ 15 — mortality ≈ > 80%', cls: 'cls-danger' },
  ],
  max: 24,
  cols: 2,
}

const faq = [
  { q: 'What is the SOFA score?', a: 'The Sequential Organ Failure Assessment grades dysfunction in six organ systems (respiratory, coagulation, liver, cardiovascular, CNS, renal) from 0–4 each, total 0–24.' },
  { q: 'How is SOFA used in Sepsis-3?', a: 'An acute rise in SOFA of ≥ 2 points in a patient with suspected infection defines sepsis under the Sepsis-3 consensus.' },
  { q: 'SOFA vs qSOFA?', a: 'qSOFA is a 3-item bedside surrogate for screening; full SOFA requires labs and ventilator/vasopressor data and is used for ICU organ-dysfunction quantification.' },
  { q: 'Is mortality linear with SOFA?', a: 'Mortality rises steeply — total scores > 11–15 or persistently rising scores are associated with mortality exceeding 80%.' },
]
const references = [
  { citation: 'Vincent JL, Moreno R, Takala J, et al. The SOFA (Sepsis-related Organ Failure Assessment) score to describe organ dysfunction/failure. <em>Intensive Care Med</em>. 1996;22(7):707-710.' },
  { citation: 'Singer M, Deutschman CS, Seymour CW, et al. The Third International Consensus Definitions for Sepsis and Septic Shock (Sepsis-3). <em>JAMA</em>. 2016;315(8):801-810.' },
]
const relatedTools = [
  { slug: 'qsofa', name: 'qSOFA' },
  { slug: 'apache-ii', name: 'APACHE II' },
  { slug: 'news-2', name: 'NEWS-2' },
]
---
<ScoreCalc
  slug="sofa-score"
  name="SOFA Score Calculator"
  schemaName="SOFA Score"
  shortDescription="Sequential Organ Failure Assessment (SOFA) — six-organ dysfunction score (0–24)."
  metaTitle="SOFA Score Calculator (Organ Failure) | maratool"
  metaDescription="Free SOFA score calculator. Quantify ICU organ dysfunction across respiratory, coagulation, liver, cardiovascular, CNS, and renal systems (Sepsis-3)."
  subcategory="Score"
  subcategorySlug="score"
  howTo={[
    'Select the worst value in each of the six organ systems for the period.',
    'The total SOFA score (0–24) and mortality estimate update instantly.',
    'A ≥ 2-point acute rise with suspected infection defines sepsis (Sepsis-3).',
  ]}
  faq={faq}
  relatedTools={relatedTools}
  references={references}
  whatIs="The Sequential Organ Failure Assessment (SOFA) score quantifies the degree of organ dysfunction in critically ill patients and is central to the Sepsis-3 definition. Developed by Vincent et al. in 1996 for the European Society of Intensive Care Medicine, it grades six organ systems on a 0–4 scale: respiratory (PaO2/FiO2), coagulation (platelets), liver (bilirubin), cardiovascular (MAP and vasopressors), central nervous system (Glasgow Coma Scale), and renal (creatinine or urine output). The total ranges 0–24, with higher scores predicting greater ICU mortality. Per Sepsis-3, an acute rise of ≥2 points from baseline in a patient with suspected infection defines sepsis."
  spec={spec}
/>
