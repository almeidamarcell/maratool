---
import ScoreCalc from '../components/ScoreCalc.astro'

const region = (label) => ({
  label,
  options: [
    { label: 'Normal (0)', points: 0, default: true },
    { label: 'Early ischemic change (−1)', points: -1 },
  ],
})

const spec = {
  items: [
    { id: 'c', ...region('Caudate (C)') },
    { id: 'l', ...region('Lentiform nucleus (L)') },
    { id: 'ic', ...region('Internal capsule (IC)') },
    { id: 'i', ...region('Insular ribbon (I)') },
    { id: 'm1', ...region('M1 — anterior MCA cortex') },
    { id: 'm2', ...region('M2 — MCA cortex lateral to insula') },
    { id: 'm3', ...region('M3 — posterior MCA cortex') },
    { id: 'm4', ...region('M4 — anterior MCA, superior to M1') },
    { id: 'm5', ...region('M5 — lateral MCA, superior to M2') },
    { id: 'm6', ...region('M6 — posterior MCA, superior to M3') },
  ],
  bands: [
    { min: 0, max: 7, label: 'ASPECTS ≤ 7 — large infarct; worse functional outcome and higher hemorrhagic risk', cls: 'cls-danger' },
    { min: 8, max: 10, label: 'ASPECTS 8–10 — limited early ischemic change; more favorable outcome', cls: 'cls-normal' },
  ],
  bonus: 10,
  max: 10,
  cols: 2,
}

const faq = [
  { q: 'What is the ASPECTS score?', a: 'The Alberta Stroke Program Early CT Score is a 10-point quantitative topographic score of early ischemic change in the middle cerebral artery territory on non-contrast CT.' },
  { q: 'How is ASPECTS calculated?', a: 'Start from 10 and subtract 1 point for each of the 10 defined MCA regions showing early ischemic change. A normal scan scores 10.' },
  { q: 'What ASPECTS supports thrombectomy?', a: 'In most trials and guidelines, ASPECTS ≥ 6 favours mechanical thrombectomy in the early window; lower scores indicate a larger established core and less benefit (evolving with imaging selection).' },
  { q: 'Why does a low ASPECTS matter?', a: 'A low score reflects a larger infarct core, predicting worse functional recovery and a higher risk of symptomatic intracerebral hemorrhage after reperfusion.' },
]
const references = [
  { citation: 'Barber PA, Demchuk AM, Zhang J, Buchan AM. Validity and reliability of a quantitative computed tomography score in predicting outcome of hyperacute stroke before thrombolytic therapy (ASPECTS). <em>Lancet</em>. 2000;355(9216):1670-1674.' },
]
const relatedTools = [
  { slug: 'nihss-stroke', name: 'NIHSS' },
  { slug: 'abcd2-tia', name: 'ABCD2 Score' },
  { slug: 'fisher-scale', name: 'Fisher Scale' },
]
---
<ScoreCalc
  slug="aspects-score"
  name="ASPECTS Score Calculator (Stroke CT)"
  schemaName="ASPECTS Score"
  shortDescription="Alberta Stroke Program Early CT Score (ASPECTS) for early MCA ischemic change (0–10)."
  metaTitle="ASPECTS Score Calculator (Stroke CT) | maratool"
  metaDescription="Free ASPECTS calculator. Quantify early ischemic change in the MCA territory on non-contrast CT to support acute stroke treatment decisions."
  subcategory="Score"
  subcategorySlug="score"
  howTo={[
    'For each of the 10 MCA regions, mark whether early ischemic change is present.',
    'The ASPECTS (10 minus affected regions) and interpretation update instantly.',
    'Use with NIHSS and vascular imaging for acute reperfusion decisions.',
  ]}
  faq={faq}
  relatedTools={relatedTools}
  references={references}
  spec={spec}
/>
