---
import Base from '../layouts/Base.astro'
import Layout from '../components/Layout.astro'
import ToolShell from '../components/ToolShell.astro'

const seo = {
  title: 'Word Counter & Character Counter Online | maratool',
  description: 'Count words, characters, sentences, and paragraphs in real time. Paste or type any text. Free word counter online.',
  canonical: 'https://maratool.com/word-counter',
  schema: {
    '@context': 'https://schema.org',
    '@type': 'WebApplication',
    name: 'Word Counter & Character Counter',
    url: 'https://maratool.com/word-counter',
    applicationCategory: 'UtilitiesApplication',
    operatingSystem: 'Any',
    offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
    description: 'Count words, characters, sentences, and paragraphs in real time. Paste or type any text. Free word counter online.',
  },
  breadcrumbSchema: {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://maratool.com' },
      { '@type': 'ListItem', position: 2, name: 'Text', item: 'https://maratool.com/text' },
      { '@type': 'ListItem', position: 3, name: 'Analyze', item: 'https://maratool.com/text/analyze' },
      { '@type': 'ListItem', position: 4, name: 'Word Counter & Character Counter', item: 'https://maratool.com/word-counter' },
    ],
  },
  faqSchema: {
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: [
      { '@type': 'Question', name: 'How are words counted?', acceptedAnswer: { '@type': 'Answer', text: 'Words are separated by whitespace. "Hello world" = 2 words. Hyphenated words count as one.' } },
      { '@type': 'Question', name: 'What is the difference between characters and characters without spaces?', acceptedAnswer: { '@type': 'Answer', text: 'Characters includes spaces and punctuation. Without spaces excludes all whitespace.' } },
      { '@type': 'Question', name: 'How are sentences counted?', acceptedAnswer: { '@type': 'Answer', text: 'Split on sentence-ending punctuation (. ! ?). Imperfect for abbreviations but useful for estimates.' } },
      { '@type': 'Question', name: 'Is my text sent to a server?', acceptedAnswer: { '@type': 'Answer', text: 'No. Counting happens entirely in your browser.' } }
    ]
  }
}

const howTo = [
  'Paste or type your text in the input area.',
  'Counts update automatically as you type.',
  'Use counts for essays, tweets, meta descriptions, or SEO content.'
]

const faq = [
  { q: 'How are words counted?', a: 'Words are separated by whitespace. "Hello world" = 2 words. Hyphenated words count as one.' },
  { q: 'What is the difference between characters and characters without spaces?', a: 'Characters includes spaces and punctuation. Without spaces excludes all whitespace.' },
  { q: 'How are sentences counted?', a: 'Split on sentence-ending punctuation (. ! ?). Imperfect for abbreviations but useful for estimates.' },
  { q: 'Is my text sent to a server?', a: 'No. Counting happens entirely in your browser.' }
]

const relatedTools = [
  { slug: 'reading-time', name: 'Reading Time Calculator' },
  { slug: 'diff-checker', name: 'Diff Checker' },
  { slug: 'lorem-ipsum', name: 'Lorem Ipsum Generator' }
]

const breadcrumbs = [
  { label: 'Home', href: '/' },
  { label: 'Text', href: '/text' },
  { label: 'Analyze', href: '/text/analyze' },
  { label: 'Word Counter' }
]
---
<Base {...seo}>
  <Layout>
    <ToolShell slug="word-counter" name="Word Counter & Character Counter" description="Paste or type text to see word count, character count, sentences, and paragraphs update in real time." howTo={howTo} faq={faq} relatedTools={relatedTools} breadcrumbs={breadcrumbs}>
      <div class="tool-container" style="min-height:360px;">
        <textarea id="wc-input" class="tool-textarea" rows="10" placeholder="Paste or type your text here..."></textarea>
        <div class="tool-stats" style="margin-top:1rem;">
          <div class="tool-stat"><span class="tool-stat-value" id="wc-words">0</span><span class="tool-stat-label">Words</span></div>
          <div class="tool-stat"><span class="tool-stat-value" id="wc-chars">0</span><span class="tool-stat-label">Characters</span></div>
          <div class="tool-stat"><span class="tool-stat-value" id="wc-chars-ns">0</span><span class="tool-stat-label">Chars (no spaces)</span></div>
          <div class="tool-stat"><span class="tool-stat-value" id="wc-sentences">0</span><span class="tool-stat-label">Sentences</span></div>
          <div class="tool-stat"><span class="tool-stat-value" id="wc-paragraphs">0</span><span class="tool-stat-label">Paragraphs</span></div>
        </div>
      </div>
    </ToolShell>
  </Layout>
</Base>

<script src="../tools/word-counter.js"></script>
