---
import Base from '../layouts/Base.astro'
import Layout from '../components/Layout.astro'
import ToolShell from '../components/ToolShell.astro'

const seo = {
  title: 'GIF Maker — Create Animated GIFs from Images Online | maratool',
  description: 'Upload images and create animated GIFs instantly in your browser. Reorder frames, set speed, adjust size — no upload to servers, no sign-up.',
  canonical: 'https://maratool.com/gif-maker',
  schema: {
    '@context': 'https://schema.org',
    '@type': 'WebApplication',
    name: 'GIF Maker',
    url: 'https://maratool.com/gif-maker',
    applicationCategory: 'MultimediaApplication',
    operatingSystem: 'Any',
    offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
    description: 'Create animated GIFs from images in your browser.',
  },
  breadcrumbSchema: {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://maratool.com' },
      { '@type': 'ListItem', position: 2, name: 'Image', item: 'https://maratool.com/image' },
      { '@type': 'ListItem', position: 3, name: 'Transform', item: 'https://maratool.com/image/transform' },
      { '@type': 'ListItem', position: 4, name: 'GIF Maker', item: 'https://maratool.com/gif-maker' },
    ],
  },
  faqSchema: {
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: [
      {
        '@type': 'Question',
        name: 'Is this GIF maker free?',
        acceptedAnswer: { '@type': 'Answer', text: 'Yes. This animated GIF maker is 100% free with no watermarks, no sign-up, and no limits on the number of GIFs you can create.' }
      },
      {
        '@type': 'Question',
        name: 'What image formats can I use?',
        acceptedAnswer: { '@type': 'Answer', text: 'You can upload PNG, JPEG, WebP, GIF, and BMP images. All formats are converted to GIF frames automatically.' }
      },
      {
        '@type': 'Question',
        name: 'What is the maximum image size?',
        acceptedAnswer: { '@type': 'Answer', text: 'Images larger than 1920 pixels wide or tall are automatically resized. The tool works best with images under 1000 pixels for optimal GIF file size.' }
      },
      {
        '@type': 'Question',
        name: 'Does this tool upload my images to a server?',
        acceptedAnswer: { '@type': 'Answer', text: 'No. All processing happens in your browser using the Canvas API and gifenc library. Your images never leave your device.' }
      }
    ]
  }
}

const howTo = [
  'Upload or drag multiple images into the drop zone.',
  'Reorder frames by dragging, adjust delay and size settings.',
  'Click "Make GIF!" to generate, then preview and download.'
]

const faq = [
  { q: 'Is this GIF maker free?', a: 'Yes. 100% free with no watermarks, no sign-up, and no limits.' },
  { q: 'What image formats can I use?', a: 'PNG, JPEG, WebP, GIF, and BMP. All formats are converted to GIF frames automatically.' },
  { q: 'What is the maximum image size?', a: 'Images over 1920px are auto-resized. For best results and smaller file sizes, keep images under 1000px.' },
  { q: 'Does this tool upload my images to a server?', a: 'No. Everything runs in your browser. Your images never leave your device.' }
]

const relatedTools = [
  { slug: 'image-converter', name: 'Image Format Converter' },
  { slug: 'image-splitter', name: 'Split Image Into Grid Tiles' },
  { slug: 'fps-converter', name: 'FPS Converter' },
]

const breadcrumbs = [
  { label: 'Home', href: '/' },
  { label: 'Image', href: '/image' },
  { label: 'Transform', href: '/image/transform' },
  { label: 'GIF Maker' },
]
---
<Base {...seo}>
  <Layout>
    <ToolShell slug="gif-maker" name="GIF Maker — Create Animated GIFs from Images" description="Upload images and create animated GIFs instantly in your browser. Drag to reorder frames, set speed, and download." howTo={howTo} faq={faq} relatedTools={relatedTools} breadcrumbs={breadcrumbs}>
      <div class="tool-container" style="min-height:400px;">
        <!-- Upload zone -->
        <div class="gm-upload" id="gm-upload">
          <input type="file" id="gm-file" accept="image/*" multiple hidden />
          <div class="gm-upload-content">
            <div class="gm-upload-icon">🎞️</div>
            <p class="gm-upload-text">Drop images here or <button type="button" class="gm-upload-btn" id="gm-browse">browse</button></p>
            <p class="gm-upload-hint">PNG, JPEG, WebP, GIF, BMP — select multiple files</p>
          </div>
        </div>

        <!-- Frames panel -->
        <div class="gm-frames-section" id="gm-frames-section" style="display:none;">
          <div class="gm-frames-header">
            <span class="tool-label">Frames <span id="gm-frame-count">(0)</span></span>
            <div class="gm-frames-actions">
              <button type="button" class="gm-add-btn" id="gm-add-more">+ Add more</button>
              <button type="button" class="gm-clear-btn" id="gm-clear">Clear all</button>
            </div>
          </div>
          <div class="gm-frames-grid" id="gm-frames-grid"></div>
        </div>

        <!-- GIF options -->
        <div class="gm-options" id="gm-options" style="display:none;">
          <div class="gm-options-title tool-label">GIF Options</div>
          <div class="gm-options-grid">
            <div class="gm-option">
              <label class="gm-label" for="gm-delay">Frame delay</label>
              <div class="gm-input-row">
                <input type="number" id="gm-delay" class="gm-input" value="100" min="20" max="5000" step="10" />
                <span class="gm-unit">ms</span>
              </div>
            </div>
            <div class="gm-option">
              <label class="gm-label" for="gm-fps">FPS</label>
              <div class="gm-input-row">
                <input type="number" id="gm-fps" class="gm-input" value="10" min="1" max="50" step="1" />
              </div>
            </div>
            <div class="gm-option">
              <label class="gm-label" for="gm-width">Width</label>
              <div class="gm-input-row">
                <input type="number" id="gm-width" class="gm-input" placeholder="auto" min="1" max="1920" />
                <span class="gm-unit">px</span>
              </div>
            </div>
            <div class="gm-option">
              <label class="gm-label" for="gm-height">Height</label>
              <div class="gm-input-row">
                <input type="number" id="gm-height" class="gm-input" placeholder="auto" min="1" max="1920" />
                <span class="gm-unit">px</span>
              </div>
            </div>
            <div class="gm-option">
              <label class="gm-label" for="gm-loop">Loop</label>
              <select id="gm-loop" class="gm-select">
                <option value="0">Forever</option>
                <option value="1">Once</option>
                <option value="2">Twice</option>
                <option value="3">3 times</option>
                <option value="5">5 times</option>
              </select>
            </div>
          </div>

          <button type="button" id="gm-make" class="gm-make-btn" disabled>Make GIF!</button>
          <div class="gm-progress" id="gm-progress" style="display:none;">
            <div class="gm-progress-bar"><div class="gm-progress-fill" id="gm-progress-fill"></div></div>
            <span class="gm-progress-text" id="gm-progress-text">Encoding...</span>
          </div>
        </div>

        <!-- Result -->
        <div class="gm-result" id="gm-result" style="display:none;">
          <div class="gm-result-title tool-label">Result</div>
          <div class="gm-preview-wrap">
            <img id="gm-preview" alt="Generated GIF preview" />
          </div>
          <div class="gm-result-info" id="gm-result-info"></div>
          <button type="button" id="gm-download" class="gm-download-btn">Download GIF</button>
        </div>
      </div>
    </ToolShell>
  </Layout>
</Base>
<style is:global>
  /* Upload zone */
  .gm-upload {
    border: 2px dashed var(--border);
    border-radius: var(--radius);
    padding: 3rem 2rem;
    text-align: center;
    cursor: pointer;
    transition: border-color 0.15s, background 0.15s;
    margin-bottom: 1.25rem;
  }
  .gm-upload:hover, .gm-upload.dragover {
    border-color: var(--accent);
    background: var(--bg-soft);
  }
  .gm-upload-icon { font-size: 36px; margin-bottom: 0.75rem; }
  .gm-upload-text { color: var(--text-2); font-size: 14px; }
  .gm-upload-btn {
    background: none; border: none; color: var(--accent);
    font-weight: 600; cursor: pointer; font-size: 14px;
    text-decoration: underline; padding: 0;
  }
  .gm-upload-hint { color: var(--text-3); font-size: 12px; margin-top: 0.375rem; }

  /* Frames */
  .gm-frames-section {
    background: var(--bg-soft);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 1rem;
    margin-bottom: 1.25rem;
  }
  .gm-frames-header {
    display: flex; align-items: center; justify-content: space-between;
    margin-bottom: 0.75rem;
  }
  .gm-frames-actions { display: flex; gap: 0.5rem; }
  .gm-add-btn, .gm-clear-btn {
    font-size: 12px; padding: 4px 10px; border-radius: var(--radius);
    cursor: pointer; border: 1px solid var(--border); background: var(--bg);
    color: var(--text-2);
  }
  .gm-add-btn:hover, .gm-clear-btn:hover { background: var(--bg-hover); }
  .gm-clear-btn { color: #e53e3e; border-color: #e53e3e; }
  .gm-clear-btn:hover { background: #fff5f5; }

  .gm-frames-grid {
    display: flex; flex-wrap: wrap; gap: 0.75rem;
    min-height: 100px;
  }

  .gm-frame {
    position: relative; width: 120px; border: 2px solid var(--border);
    border-radius: var(--radius); background: #fff; overflow: hidden;
    cursor: grab; user-select: none; transition: border-color 0.15s, box-shadow 0.15s;
  }
  .gm-frame:hover { border-color: var(--accent); }
  .gm-frame.dragging { opacity: 0.4; }
  .gm-frame.drag-over { border-color: var(--accent); box-shadow: 0 0 0 2px var(--accent); }

  .gm-frame-img {
    width: 120px; height: 90px; object-fit: contain;
    display: block; background: var(--bg-soft);
  }
  .gm-frame-info {
    padding: 4px 6px; font-size: 11px; color: var(--text-3);
    display: flex; align-items: center; justify-content: space-between;
  }
  .gm-frame-num { font-weight: 600; color: var(--text-2); }
  .gm-frame-del {
    background: none; border: none; color: var(--text-3);
    cursor: pointer; font-size: 14px; padding: 0 2px; line-height: 1;
  }
  .gm-frame-del:hover { color: #e53e3e; }

  .gm-frame-delay-row {
    padding: 0 6px 4px; display: flex; align-items: center; gap: 2px;
  }
  .gm-frame-delay {
    width: 50px; padding: 2px 4px; font-size: 11px;
    border: 1px solid var(--border); border-radius: 3px;
    font-family: var(--font-mono); text-align: center;
    background: var(--bg); color: var(--text);
  }
  .gm-frame-delay-unit { font-size: 10px; color: var(--text-3); }

  /* Options */
  .gm-options {
    background: var(--bg-soft);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 1.25rem;
    margin-bottom: 1.25rem;
  }
  .gm-options-title { margin-bottom: 0.75rem; }
  .gm-options-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(140px, 1fr));
    gap: 0.75rem;
    margin-bottom: 1rem;
  }
  .gm-option { display: flex; flex-direction: column; gap: 0.25rem; }
  .gm-label { font-size: 12px; color: var(--text-2); font-weight: 500; }
  .gm-input-row { display: flex; align-items: center; gap: 4px; }
  .gm-input {
    width: 80px; padding: 6px 8px; font-size: 13px;
    border: 1px solid var(--border); border-radius: var(--radius);
    background: var(--bg); color: var(--text); font-family: var(--font-mono);
  }
  .gm-select {
    padding: 6px 8px; font-size: 13px;
    border: 1px solid var(--border); border-radius: var(--radius);
    background: var(--bg); color: var(--text);
  }
  .gm-unit { font-size: 12px; color: var(--text-3); }

  .gm-make-btn {
    display: inline-block; padding: 10px 28px; font-size: 14px; font-weight: 600;
    border: none; border-radius: var(--radius); background: var(--accent);
    color: #fff; cursor: pointer; transition: opacity 0.15s;
  }
  .gm-make-btn:hover:not(:disabled) { opacity: 0.9; }
  .gm-make-btn:disabled { opacity: 0.5; cursor: not-allowed; }

  /* Progress */
  .gm-progress { margin-top: 0.75rem; }
  .gm-progress-bar {
    height: 6px; background: var(--border); border-radius: 3px; overflow: hidden;
  }
  .gm-progress-fill {
    height: 100%; width: 0%; background: var(--accent);
    transition: width 0.2s;
  }
  .gm-progress-text {
    font-size: 12px; color: var(--text-3); margin-top: 0.25rem; display: block;
  }

  /* Result */
  .gm-result {
    background: var(--bg-soft);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 1.25rem;
  }
  .gm-result-title { margin-bottom: 0.75rem; }
  .gm-preview-wrap {
    text-align: center; margin-bottom: 0.75rem;
    background: repeating-conic-gradient(#e0e0e0 0% 25%, #fff 0% 50%) 0 0 / 16px 16px;
    border: 1px solid var(--border); border-radius: var(--radius);
    padding: 1rem; min-height: 100px;
    display: flex; align-items: center; justify-content: center;
  }
  .gm-preview-wrap img {
    max-width: 100%; max-height: 500px; image-rendering: auto;
  }
  .gm-result-info {
    font-size: 13px; color: var(--text-2); margin-bottom: 0.75rem; text-align: center;
  }
  .gm-download-btn {
    display: block; width: 100%; padding: 10px; font-size: 14px; font-weight: 600;
    border: none; border-radius: var(--radius); background: var(--accent);
    color: #fff; cursor: pointer; transition: opacity 0.15s;
  }
  .gm-download-btn:hover { opacity: 0.9; }

  @media (max-width: 768px) {
    .gm-frame { width: 100px; }
    .gm-frame-img { width: 100px; height: 75px; }
    .gm-options-grid { grid-template-columns: repeat(2, 1fr); }
  }
</style>
<script src="../tools/gif-maker.js"></script>
