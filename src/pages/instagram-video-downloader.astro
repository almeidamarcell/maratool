---
import Base from '../layouts/Base.astro'
import Layout from '../components/Layout.astro'
import ToolShell from '../components/ToolShell.astro'

const seo = {
  title: 'Instagram Video Downloader — Save Reels & Videos Free | maratool',
  description: 'Download Instagram Reels and videos in MP4 format. Paste the link, click download — free, no login, no watermark. Works with public posts and reels.',
  canonical: 'https://maratool.com/instagram-video-downloader',
  schema: {
    '@context': 'https://schema.org',
    '@type': 'WebApplication',
    name: 'Instagram Video Downloader',
    url: 'https://maratool.com/instagram-video-downloader',
    applicationCategory: 'UtilitiesApplication',
    operatingSystem: 'Any',
    offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
    description: 'Download Instagram Reels and videos for free. No login required.',
  },
  breadcrumbSchema: {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://maratool.com' },
      { '@type': 'ListItem', position: 2, name: 'Converter', item: 'https://maratool.com/converter' },
      { '@type': 'ListItem', position: 3, name: 'Video', item: 'https://maratool.com/converter/video' },
      { '@type': 'ListItem', position: 4, name: 'Instagram Video Downloader', item: 'https://maratool.com/instagram-video-downloader' },
    ],
  },
  faqSchema: {
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: [
      {
        '@type': 'Question',
        name: 'Is this Instagram video downloader free?',
        acceptedAnswer: { '@type': 'Answer', text: 'Yes. It is 100% free with no watermarks, no sign-up, and no limits.' }
      },
      {
        '@type': 'Question',
        name: 'Can I download Instagram Reels?',
        acceptedAnswer: { '@type': 'Answer', text: 'Yes. Paste any public Reel URL and the video will be downloaded as an MP4 file.' }
      },
      {
        '@type': 'Question',
        name: 'Do I need to log in to Instagram?',
        acceptedAnswer: { '@type': 'Answer', text: 'No. This tool only works with public posts and reels. No Instagram login is required.' }
      },
      {
        '@type': 'Question',
        name: 'Can I download private Instagram videos?',
        acceptedAnswer: { '@type': 'Answer', text: 'No. Only public posts and reels can be downloaded. Private accounts require Instagram authentication which this tool does not use.' }
      }
    ]
  }
}

const howTo = [
  'Copy the Instagram Reel or video URL from the app or browser.',
  'Paste it into the input field above and click "Download".',
  'Click "Download Video" to save the MP4 file to your device.'
]

const faq = [
  { q: 'Is this Instagram video downloader free?', a: 'Yes. 100% free, no watermarks, no sign-up, no limits.' },
  { q: 'Can I download Instagram Reels?', a: 'Yes. Paste any public Reel URL and download it as MP4.' },
  { q: 'Do I need to log in to Instagram?', a: 'No. Works with public posts only — no Instagram login needed.' },
  { q: 'Can I download private Instagram videos?', a: 'No. Only public posts and reels can be downloaded.' }
]

const relatedTools = [
  { slug: 'instagram-photo-downloader', name: 'Instagram Photo Downloader' },
  { slug: 'video-to-gif', name: 'Video to GIF Converter' },
  { slug: 'social-media-cropper', name: 'Social Media Image Cropper' },
]

const breadcrumbs = [
  { label: 'Home', href: '/' },
  { label: 'Converter', href: '/converter' },
  { label: 'Video', href: '/converter/video' },
  { label: 'Instagram Video Downloader' },
]
---
<Base {...seo}>
  <Layout>
    <ToolShell slug="instagram-video-downloader" name="Instagram Video Downloader — Save Reels & Videos" description="Download Instagram Reels and videos in MP4. Paste the link, click download — free, no login, no watermark." howTo={howTo} faq={faq} relatedTools={relatedTools} breadcrumbs={breadcrumbs}>
      <div class="tool-container" style="min-height:300px;">

        <!-- Input form -->
        <form id="ig-form" class="ig-form">
          <div class="ig-input-row">
            <input
              type="url"
              id="ig-url"
              class="ig-url-input"
              placeholder="Paste Instagram Reel or video URL here..."
              autocomplete="off"
              spellcheck="false"
              required
            />
            <button type="button" id="ig-paste" class="ig-paste-btn" title="Paste from clipboard">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>
            </button>
            <button type="submit" id="ig-submit" class="tool-button ig-submit-btn">
              <span id="ig-spinner" class="ig-spinner" style="display:none;"></span>
              <span class="ig-btn-text">Download</span>
            </button>
          </div>
        </form>

        <!-- Error -->
        <div class="ig-error" id="ig-error" style="display:none;">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="15" y1="9" x2="9" y2="15"/><line x1="9" y1="9" x2="15" y2="15"/></svg>
          <span id="ig-error-text"></span>
        </div>

        <!-- Result -->
        <div class="ig-result" id="ig-result" style="display:none;">
          <div class="ig-preview-card">
            <div class="ig-thumb-wrap">
              <img id="ig-preview" alt="Instagram post preview" />
            </div>
            <div class="ig-meta">
              <span class="ig-username" id="ig-username"></span>
              <p class="ig-caption" id="ig-caption"></p>
            </div>
          </div>
          <div class="ig-result-actions">
            <button class="tool-button" id="ig-download">Download Video</button>
            <button class="copy-btn" id="ig-new">Download another</button>
          </div>
        </div>

        <!-- Limitations -->
        <div class="ig-limitations">
          <h3 class="ig-limitations-title">Limitations</h3>
          <ul class="ig-limitations-list">
            <li><strong>Private accounts</strong> — not supported. The post must be publicly accessible.</li>
            <li><strong>Stories</strong> — not supported. Stories require Instagram authentication.</li>
            <li><strong>Carousel posts</strong> — downloads the first item. Multi-slide support is planned.</li>
          </ul>
          <a href="/blog/instagram-video-downloader-launch" class="ig-blog-link">Learn more about how this tool works &rarr;</a>
        </div>
      </div>
    </ToolShell>
  </Layout>
</Base>
<style is:global>
  .ig-form { margin-bottom: 1rem; }
  .ig-input-row {
    display: flex; gap: 0.5rem; align-items: stretch;
  }
  .ig-url-input {
    flex: 1; padding: 0.75rem 1rem; font-size: 0.9375rem;
    border: 1px solid var(--border); border-radius: var(--radius);
    background: var(--bg); color: var(--text);
    font-family: var(--font);
    transition: border-color 0.15s;
  }
  .ig-url-input:focus {
    outline: none; border-color: var(--accent);
  }
  .ig-url-input::placeholder { color: var(--text-3); }
  .ig-paste-btn {
    padding: 0 0.75rem; border: 1px solid var(--border); border-radius: var(--radius);
    background: var(--bg); color: var(--text-2); cursor: pointer;
    display: flex; align-items: center; transition: all 0.15s;
  }
  .ig-paste-btn:hover { border-color: var(--accent); color: var(--accent); }
  .ig-submit-btn {
    display: flex; align-items: center; gap: 0.5rem;
    padding: 0 1.5rem; white-space: nowrap;
  }
  .ig-spinner {
    width: 14px; height: 14px; border: 2px solid rgba(255,255,255,0.3);
    border-top-color: #fff; border-radius: 50%;
    animation: ig-spin 0.6s linear infinite;
  }
  @keyframes ig-spin { to { transform: rotate(360deg); } }

  /* Error */
  .ig-error {
    display: flex; align-items: center; gap: 0.5rem;
    padding: 0.75rem 1rem; background: #fef2f2; border: 1px solid #fecaca;
    border-radius: var(--radius); margin-bottom: 1rem;
    font-size: 0.875rem; color: #dc2626;
  }
  .ig-error svg { flex-shrink: 0; color: #dc2626; }

  /* Result */
  .ig-preview-card {
    display: flex; gap: 1rem; padding: 1rem;
    background: var(--bg-soft); border: 1px solid var(--border);
    border-radius: var(--radius); margin-bottom: 1rem;
  }
  .ig-thumb-wrap {
    width: 180px; height: 180px; flex-shrink: 0;
    border-radius: 8px; overflow: hidden; background: #000;
  }
  .ig-thumb-wrap img {
    width: 100%; height: 100%; object-fit: cover;
  }
  .ig-meta {
    flex: 1; min-width: 0; display: flex; flex-direction: column; gap: 0.5rem;
  }
  .ig-username {
    font-size: 0.875rem; font-weight: 600; color: var(--accent);
  }
  .ig-caption {
    font-size: 0.8125rem; color: var(--text-2); line-height: 1.5;
    margin: 0; overflow: hidden;
    display: -webkit-box; -webkit-line-clamp: 5; -webkit-box-orient: vertical;
  }
  .ig-result-actions {
    display: flex; gap: 0.75rem; align-items: center;
  }

  /* Limitations */
  .ig-limitations {
    padding: 1rem;
    background: var(--bg-soft);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    margin-top: 1rem;
    font-size: 0.8125rem;
    color: var(--text-2);
    line-height: 1.6;
  }
  .ig-limitations-title {
    font-size: 0.8125rem;
    font-weight: 600;
    color: var(--text);
    margin: 0 0 0.5rem;
  }
  .ig-limitations-list {
    margin: 0 0 0.75rem 1.25rem;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }
  .ig-limitations-list strong { color: var(--text); }
  .ig-blog-link {
    font-size: 0.8125rem;
    color: var(--accent);
    text-decoration: none;
  }
  .ig-blog-link:hover { text-decoration: underline; }

  @media (max-width: 768px) {
    .ig-input-row { flex-direction: column; }
    .ig-submit-btn { width: 100%; justify-content: center; }
    .ig-preview-card { flex-direction: column; }
    .ig-thumb-wrap { width: 100%; height: 200px; }
  }
</style>
<script src="../tools/instagram-downloader.js"></script>
