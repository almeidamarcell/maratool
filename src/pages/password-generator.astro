---
import Base from '../layouts/Base.astro'
import Layout from '../components/Layout.astro'
import ToolShell from '../components/ToolShell.astro'

const seo = {
  title: 'Password Generator — Secure, offline, cryptographically random | maratool',
  description: 'Generate cryptographically secure passwords with custom length, character sets, and strength check. Fully offline — no data ever leaves your browser. Free.',
  canonical: 'https://maratool.com/password-generator',
  schema: {
    '@context': 'https://schema.org',
    '@type': 'WebApplication',
    name: 'Password Generator',
    url: 'https://maratool.com/password-generator',
    applicationCategory: 'DeveloperApplication',
    operatingSystem: 'Any',
    offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
    description: 'Generate cryptographically secure passwords with custom length and character sets.',
  },
  breadcrumbSchema: {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://maratool.com' },
      { '@type': 'ListItem', position: 2, name: 'Developer', item: 'https://maratool.com/developer' },
      { '@type': 'ListItem', position: 3, name: 'Generate', item: 'https://maratool.com/developer/generate' },
      { '@type': 'ListItem', position: 4, name: 'Password Generator', item: 'https://maratool.com/password-generator' },
    ],
  },
  faqSchema: {
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: [
      {
        '@type': 'Question',
        name: 'Is this password generator truly secure?',
        acceptedAnswer: { '@type': 'Answer', text: 'Yes. The tool uses the Web Crypto API (crypto.getRandomValues()), which is a cryptographically secure pseudo-random number generator (CSPRNG). This is the same source of entropy used by password managers. No data is sent to any server — generation happens entirely in your browser.' }
      },
      {
        '@type': 'Question',
        name: 'How long should my password be?',
        acceptedAnswer: { '@type': 'Answer', text: 'At minimum 12 characters for personal accounts, 16+ for sensitive accounts like email and banking, and 20+ for admin or root credentials. Length is the single most important factor in password strength — a 20-character password with only lowercase letters is stronger than a 10-character password with all character types.' }
      },
      {
        '@type': 'Question',
        name: 'What does "exclude ambiguous characters" do?',
        acceptedAnswer: { '@type': 'Answer', text: 'It removes characters that look similar in certain fonts: 0 (zero) and O (capital oh), 1 (one) and l (lowercase L) and I (capital i). Excluding them prevents transcription errors when you need to read or type the password manually.' }
      },
      {
        '@type': 'Question',
        name: 'Should I use a password manager?',
        acceptedAnswer: { '@type': 'Answer', text: 'Yes. A password manager stores unique passwords for every site so you only need to remember one master password. Use this generator to create the passwords, then store them in a manager like Bitwarden (free and open source), 1Password, or Dashlane.' }
      }
    ]
  }
}

const howTo = [
  'Set the desired length using the slider (8–64 characters).',
  'Choose which character sets to include: uppercase, lowercase, digits, and symbols.',
  'Click Generate or copy the password directly from the output field.'
]

const faq = [
  { q: 'Is this password generator truly secure?', a: 'Yes. Uses crypto.getRandomValues() — a CSPRNG, the same entropy source used by password managers. Everything runs in your browser; nothing is sent to a server.' },
  { q: 'How long should my password be?', a: 'At least 12 characters for personal accounts, 16+ for sensitive accounts, 20+ for admin credentials. Length matters more than complexity.' },
  { q: 'What does "exclude ambiguous characters" do?', a: 'Removes characters that look similar: 0/O, 1/l/I. Prevents transcription errors when typing passwords manually.' },
  { q: 'Should I use a password manager?', a: 'Yes. Generate unique passwords here, then store them in Bitwarden (free), 1Password, or Dashlane. Never reuse passwords.' }
]

const relatedTools = [
  { slug: 'hash-generator', name: 'Generate MD5 SHA-256 Hash Online' },
  { slug: 'uuid-generator', name: 'Generate UUID v4 Online' },
  { slug: 'bcrypt-generator', name: 'Bcrypt Generator' },
]

const breadcrumbs = [
  { label: 'Home', href: '/' },
  { label: 'Developer', href: '/developer' },
  { label: 'Generate', href: '/developer/generate' },
  { label: 'Password Generator' },
]
---
<Base {...seo}>
  <Layout>
    <ToolShell slug="password-generator" name="Password Generator" description="Generate cryptographically secure passwords. Runs entirely offline — nothing is ever sent to a server." howTo={howTo} faq={faq} relatedTools={relatedTools} breadcrumbs={breadcrumbs}>
      <div class="tool-container" style="min-height: 320px;">
        <!-- Length -->
        <div class="pwd-row">
          <label class="tool-label" for="pwd-length">Length: <span id="pwd-length-value">20</span></label>
          <input type="range" id="pwd-length" min="8" max="64" value="20" class="pwd-slider" />
        </div>

        <!-- Options -->
        <div class="pwd-options">
          <label class="pwd-option"><input type="checkbox" id="pwd-upper" checked /> Uppercase (A–Z)</label>
          <label class="pwd-option"><input type="checkbox" id="pwd-lower" checked /> Lowercase (a–z)</label>
          <label class="pwd-option"><input type="checkbox" id="pwd-digits" checked /> Digits (0–9)</label>
          <label class="pwd-option"><input type="checkbox" id="pwd-symbols" checked /> Symbols (!@#$…)</label>
          <label class="pwd-option"><input type="checkbox" id="pwd-ambiguous" /> Exclude ambiguous (0, O, I, l)</label>
        </div>

        <!-- Output -->
        <div class="pwd-output-row">
          <input type="text" id="pwd-output" class="tool-input pwd-output-input" readonly spellcheck="false" autocomplete="off" />
          <button class="pwd-btn pwd-btn-copy" id="pwd-copy" type="button">Copy</button>
        </div>

        <!-- Strength -->
        <div class="pwd-strength-section">
          <div class="pwd-strength-track">
            <div class="pwd-strength-fill" id="pwd-strength-bar" style="width:0%"></div>
          </div>
          <span class="pwd-strength-label" id="pwd-strength-label"></span>
        </div>

        <!-- Generate -->
        <button class="pwd-btn pwd-btn-primary" id="pwd-generate" type="button">Generate new password</button>
      </div>
    </ToolShell>
  </Layout>
</Base>
<style is:global>
  .pwd-row {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 1rem;
  }
  .pwd-row .tool-label { margin-bottom: 0; white-space: nowrap; }
  .pwd-slider {
    flex: 1;
    accent-color: var(--accent);
  }
  .pwd-options {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.5rem 1.5rem;
    margin-bottom: 1.25rem;
  }
  .pwd-option {
    font-size: 13px;
    color: var(--text-2);
    cursor: pointer;
    display: flex;
    align-items: center;
    gap: 0.4rem;
  }
  .pwd-output-row {
    display: flex;
    gap: 0.5rem;
    margin-bottom: 0.75rem;
  }
  .pwd-output-input {
    flex: 1;
    font-family: var(--font-mono, monospace);
    font-size: 15px;
    letter-spacing: 0.04em;
    background: var(--bg-soft);
  }
  .pwd-btn {
    padding: 8px 18px;
    font-size: 13px;
    font-weight: 600;
    border-radius: var(--radius);
    border: 1px solid var(--border);
    cursor: pointer;
    white-space: nowrap;
    transition: opacity 0.1s;
  }
  .pwd-btn-copy {
    background: var(--bg);
    color: var(--text);
  }
  .pwd-btn-copy:hover { background: var(--bg-soft); }
  .pwd-btn-primary {
    width: 100%;
    margin-top: 0.5rem;
    background: var(--accent);
    color: #fff;
    border-color: var(--accent);
    padding: 10px;
  }
  .pwd-btn-primary:hover { opacity: 0.9; }
  .pwd-strength-section {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 0.25rem;
  }
  .pwd-strength-track {
    flex: 1;
    height: 6px;
    border-radius: 3px;
    background: var(--border);
    overflow: hidden;
  }
  .pwd-strength-fill {
    height: 100%;
    border-radius: 3px;
    transition: width 0.2s, background-color 0.2s;
    background: var(--border);
  }
  .pwd-strength-weak { background: #f87171; }
  .pwd-strength-fair { background: #fbbf24; }
  .pwd-strength-good { background: #34d399; }
  .pwd-strength-strong { background: #10b981; }
  .pwd-strength-label {
    font-size: 12px;
    font-weight: 600;
    min-width: 48px;
    color: var(--text-2);
  }
  @media (max-width: 500px) {
    .pwd-options { grid-template-columns: 1fr; }
  }
</style>
<script src="../tools/password-generator.js"></script>
