---
import Base from '../layouts/Base.astro'
import Layout from '../components/Layout.astro'
import ToolShell from '../components/ToolShell.astro'

const seo = {
  title: 'JWT Security Checker — Audit JWT Issues | maratool',
  description: 'Audit JWT security issues from a pasted token. Flag alg none, missing exp, and weak claims instantly. Paste-only, free, runs in your browser.',
  canonical: 'https://maratool.com/jwt-security-checker',
  schema: {
    '@context': 'https://schema.org',
    '@type': 'WebApplication',
    name: 'JWT Security Checker — Audit JWT Issues',
    url: 'https://maratool.com/jwt-security-checker',
    applicationCategory: 'DeveloperApplication',
    operatingSystem: 'Any',
    offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
    description: 'Audit JWT security issues from a pasted token. Flag alg none, missing exp, and weak claims instantly. Paste-only, free, runs in your browser.',
  },
  breadcrumbSchema: {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://maratool.com' },
      { '@type': 'ListItem', position: 2, name: 'Developer', item: 'https://maratool.com/developer' },
      { '@type': 'ListItem', position: 3, name: 'Security', item: 'https://maratool.com/developer/security' },
      { '@type': 'ListItem', position: 4, name: 'JWT Security Checker — Audit JWT Issues', item: 'https://maratool.com/jwt-security-checker' },
    ],
  },
  faqSchema: {
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: [
      { '@type': 'Question', name: 'Does this verify the JWT signature?', acceptedAnswer: { '@type': 'Answer', text: 'No. It audits common security issues in header and payload claims — paste-only decode.' } },
      { '@type': 'Question', name: 'What issues are flagged?', acceptedAnswer: { '@type': 'Answer', text: 'alg none, missing exp, expired tokens, weak symmetric setup, and missing subject claims.' } },
      { '@type': 'Question', name: 'Is it safe to paste production JWTs?', acceptedAnswer: { '@type': 'Answer', text: 'Processing is local in your browser, but avoid pasting live secrets in shared environments.' } },
      { '@type': 'Question', name: 'Is my JWT sent to a server?', acceptedAnswer: { '@type': 'Answer', text: 'No. Auditing happens entirely in your browser.' } }
    ]
  }
}

const howTo = [
  'Paste the JWT token in the input field.',
  'Review decoded header, payload, and security issue list.',
  'Fix high-severity issues before deploying to production.'
]

const faq = [
  { q: 'Does this verify the JWT signature?', a: 'No. It audits common security issues in header and payload claims — paste-only decode.' },
  { q: 'What issues are flagged?', a: 'alg none, missing exp, expired tokens, weak symmetric setup, and missing subject claims.' },
  { q: 'Is it safe to paste production JWTs?', a: 'Processing is local in your browser, but avoid pasting live secrets in shared environments.' },
  { q: 'Is my JWT sent to a server?', a: 'No. Auditing happens entirely in your browser.' }
]

const relatedTools = [
  { slug: 'jwt-decoder', name: 'JWT Decoder' },
  { slug: 'hash-identifier', name: 'Hash Identifier' },
  { slug: 'password-strength-checker', name: 'Password Strength Checker' }
]

const breadcrumbs = [
  { label: 'Home', href: '/' },
  { label: 'Developer', href: '/developer' },
  { label: 'Security', href: '/developer/security' },
  { label: 'JWT Security Checker' }
]
---
<Base {...seo}>
  <Layout>
    <ToolShell slug="jwt-security-checker" name="JWT Security Checker — Audit JWT Issues" description="Paste a JWT to decode header and payload and list security issues by severity. Does not verify signatures — paste-only." howTo={howTo} faq={faq} relatedTools={relatedTools} breadcrumbs={breadcrumbs}>
      <div class="tool-container" style="min-height:400px;">
        <label class="tool-label" for="jws-input">JWT token</label>
        <textarea id="jws-input" class="tool-textarea" rows="4" placeholder="Paste JWT here…" spellcheck="false"></textarea>
        <div class="tool-stats" style="margin-top:1rem;">
          <div class="tool-stat"><span class="tool-stat-value" id="jws-risk">—</span><span class="tool-stat-label">Risk level</span></div>
        </div>
        <ul id="jws-issues" style="font-size:13px;color:var(--text-2);padding-left:1.25rem;margin:1rem 0;"></ul>
      </div>
    </ToolShell>
  </Layout>
</Base>

<script src="../tools/jwt-security-checker.js"></script>
