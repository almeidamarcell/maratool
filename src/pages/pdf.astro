---
import Base from '../layouts/Base.astro'
import Layout from '../components/Layout.astro'
import Breadcrumb from '../components/Breadcrumb.astro'
import { toolsFlatByCategory } from '../data/tools'

const tools = toolsFlatByCategory.PDF ?? []

const seo = {
  title: 'PDF Tools — maratool',
  description: 'Free browser-based PDF tools. Extract text, convert to Markdown, merge and split pages, check accessibility — no upload, runs in your browser.',
  canonical: 'https://maratool.com/pdf',
  schema: {
    '@context': 'https://schema.org',
    '@type': 'CollectionPage',
    name: 'PDF Tools',
    url: 'https://maratool.com/pdf',
    description: 'Free browser-based PDF tools. Extract text, convert to Markdown, merge and split pages, check accessibility — no upload, runs in your browser.',
    hasPart: tools.map(tool => ({
      '@type': 'SoftwareApplication',
      name: tool.name,
      url: `https://maratool.com/${tool.slug}`,
      applicationCategory: 'UtilitiesApplication',
    })),
  },
  breadcrumbSchema: {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://maratool.com' },
      { '@type': 'ListItem', position: 2, name: 'PDF', item: 'https://maratool.com/pdf' },
    ],
  },
}

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: 'How to extract text from a PDF without installing software?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Use maratool\'s PDF text extractor — open your PDF directly in the browser and get the full text content instantly. No software installation, no uploads to external servers. Everything runs locally in your browser.'
      }
    },
    {
      '@type': 'Question',
      name: 'Can I merge PDFs without uploading to a server?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Yes. maratool\'s PDF tools process files entirely in your browser using client-side JavaScript. Your documents never leave your device, making it safe for confidential and sensitive files.'
      }
    },
    {
      '@type': 'Question',
      name: 'Is it safe to use online PDF tools?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'With maratool, yes. Unlike most online PDF tools that upload your files to remote servers, maratool processes everything locally in your browser. No data is transmitted, stored, or accessible to anyone else.'
      }
    },
    {
      '@type': 'Question',
      name: 'What PDF tools are available for free?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'maratool offers free PDF text extraction, PDF to Markdown conversion, page merging and splitting, metadata viewing, and accessibility checking — all with no sign-up and no usage limits.'
      }
    },
  ]
}

const breadcrumbs = [
  { label: 'Home', href: '/' },
  { label: 'PDF' },
]
---
<Base {...seo} faqSchema={faqSchema}>
  <Layout>
    <Breadcrumb crumbs={breadcrumbs} />
    <div class="hero">
      <h1>PDF Tools</h1>
      <p>Free, browser-based PDF tools — extract text, view metadata, merge, split, and check accessibility, all running locally.</p>
    </div>

    <div class="tools-grid">
      {tools.map(tool => (
        tool.live
          ? (
            <a href={`/${tool.slug}`} class="tool-card">
              <span class="tool-card-emoji">{tool.emoji}</span>
              <div class="tool-card-name">{tool.name}</div>
              <div class="tool-card-desc">{tool.description}</div>
            </a>
          )
          : (
            <div class="tool-card" style="opacity:0.5;cursor:default;">
              <span class="tool-card-emoji">{tool.emoji}</span>
              <div class="tool-card-name">{tool.name}</div>
              <div class="tool-card-desc">{tool.description}</div>
              <span class="tool-card-badge">Coming Soon</span>
            </div>
          )
      ))}
    </div>
  </Layout>
</Base>
