const faq = [
  { q: 'What is APACHE II?', a: 'Acute Physiology and Chronic Health Evaluation II — an ICU severity-of-disease score (0–71) from 12 acute physiologic variables, age, and chronic health status.' },
  { q: 'When is APACHE II measured?', a: 'Using the worst values during the first 24 hours of ICU admission.' },
  { q: 'How is mortality estimated?', a: 'Higher scores predict higher hospital mortality; the precise prediction also incorporates the principal diagnosis via a disease-specific weight in the full model.' },
  { q: 'Why is creatinine sometimes doubled?', a: 'The creatinine point value is doubled in the presence of acute renal failure, reflecting its stronger prognostic weight.' },
]
const references = [
  { citation: 'Knaus WA, Draper EA, Wagner DP, Zimmerman JE. APACHE II: a severity of disease classification system. <em>Crit Care Med</em>. 1985;13(10):818-829.' },
]
const relatedTools = [
  { slug: 'sofa-score', name: 'SOFA Score' },
  { slug: 'saps-ii', name: 'SAPS II' },
  { slug: 'qsofa', name: 'qSOFA' },
]
---
<ScoreCalc
  slug="apache-ii"
  name="APACHE II Score Calculator"
  schemaName="APACHE II Score"
  shortDescription="APACHE II ICU severity-of-illness score with predicted mortality (0–71)."
  metaTitle="APACHE II Score Calculator (ICU Mortality) | maratool"
  metaDescription="Free APACHE II calculator. Compute ICU severity of illness and predicted mortality from 12 physiologic variables, age, and chronic health status."
  subcategory="Score"
  subcategorySlug="score"
  howTo={[
    'Select the worst value in the first 24 h for each physiologic variable.',
    'Add the GCS-derived points, age, and chronic-health category.',
    'The total APACHE II (0–71) and predicted mortality update instantly.',
  ]}
  faq={faq}
  relatedTools={relatedTools}
  references={references}
  spec={spec}
/>
