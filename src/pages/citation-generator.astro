---
import Base from '../layouts/Base.astro'
import Layout from '../components/Layout.astro'
import ToolShell from '../components/ToolShell.astro'

const seo = {
  title: 'Citation Generator — APA & MLA | maratool',
  description: 'Citation Generator — APA & MLA. Free, instant, runs in your browser — no upload to server.',
  canonical: 'https://maratool.com/citation-generator',
  schema: {
    '@context': 'https://schema.org',
    '@type': 'WebApplication',
    name: 'Citation Generator — APA & MLA',
    url: 'https://maratool.com/citation-generator',
    applicationCategory: 'EducationApplication',
    operatingSystem: 'Any',
    offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
    description: 'Citation Generator — APA & MLA. Free, instant, runs in your browser — no upload to server.',
  },
  breadcrumbSchema: {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://maratool.com' },
      { '@type': 'ListItem', position: 2, name: 'Education', item: 'https://maratool.com/education' },
      { '@type': 'ListItem', position: 3, name: 'Reference', item: 'https://maratool.com/education/reference' },
      { '@type': 'ListItem', position: 4, name: 'Citation Generator — APA & MLA', item: 'https://maratool.com/citation-generator' },
    ],
  },
  faqSchema: {
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: [
      { '@type': 'Question', name: 'Does this tool send data to a server?', acceptedAnswer: { '@type': 'Answer', text: 'No. Everything runs locally in your browser. Your data never leaves your device.' } },
      { '@type': 'Question', name: 'Do I need an account?', acceptedAnswer: { '@type': 'Answer', text: 'No sign-up, no limits, no paywall.' } },
      { '@type': 'Question', name: 'Can I use this offline?', acceptedAnswer: { '@type': 'Answer', text: 'Yes, after the page loads once, the tool works without a network connection.' } },
      { '@type': 'Question', name: 'Is this tool free?', acceptedAnswer: { '@type': 'Answer', text: 'Yes, completely free with no usage limits.' } }
    ]
  }
}

const howTo = ['Enter or paste your input in the fields below.', 'Results update instantly as you type.', 'Use Copy to grab the output.']
const faq = [{ q: 'Does this tool send data to a server?', a: 'No. Everything runs locally in your browser. Your data never leaves your device.' }, { q: 'Do I need an account?', a: 'No sign-up, no limits, no paywall.' }, { q: 'Can I use this offline?', a: 'Yes, after the page loads once, the tool works without a network connection.' }, { q: 'Is this tool free?', a: 'Yes, completely free with no usage limits.' }]
const relatedTools = [{ slug: 'apa-mla-converter', name: 'APA to MLA Citation Converter' }, { slug: 'reading-level-calculator', name: 'reading-level-calculator' }, { slug: 'grade-calculator', name: 'grade-calculator' }]
const breadcrumbs = [
  { label: 'Home', href: '/' },
  { label: 'Education', href: '/education' },
  { label: 'Reference', href: '/education/reference' },
  { label: 'Citation Generator' },
]
---
<Base {...seo}>
  <Layout>
    <ToolShell slug="citation-generator" name="Citation Generator — APA & MLA" description="Citation Generator — APA & MLA. Free, instant, runs in your browser — no upload to server." howTo={howTo} faq={faq} relatedTools={relatedTools} breadcrumbs={breadcrumbs}>
      <div class="tool-container" style="min-height:360px;" data-w4-ui="citation">
        <div id="w4-root"></div>
        <pre id="w4-out" class="tool-output" style="min-height:120px;white-space:pre-wrap;margin-top:1rem;"></pre>
        <p id="w4-err" class="tool-error" hidden></p>
      </div>
    </ToolShell>
  </Layout>
</Base>

<style is:global>
  .calc-row { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; margin-bottom: 1rem; }
  .calc-field { margin-bottom: 0.75rem; }
  .calc-select { max-width: 100%; }
  .diff-add { background: #e6ffed; }
  .diff-remove { background: #ffeef0; }
  @media (max-width: 600px) { .calc-row { grid-template-columns: 1fr; } }
</style>
<script src="../tools/citation-generator.js"></script>
