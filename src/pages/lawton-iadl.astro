---
import ScoreCalc from '../components/ScoreCalc.astro'

const spec = {
  items: [
    { id: 'phone', label: 'Ability to use telephone', options: [
      { label: '1 — Operates phone on own initiative', points: 1, default: true },
      { label: '1 — Dials a few well-known numbers', points: 1 },
      { label: '1 — Answers phone but does not dial', points: 1 },
      { label: '0 — Does not use phone at all', points: 0 },
    ]},
    { id: 'shopping', label: 'Shopping', options: [
      { label: '1 — Takes care of all shopping needs independently', points: 1, default: true },
      { label: '0 — Shops independently for small purchases', points: 0 },
      { label: '0 — Needs to be accompanied on any shopping trip', points: 0 },
      { label: '0 — Completely unable to shop', points: 0 },
    ]},
    { id: 'food', label: 'Food preparation', options: [
      { label: '1 — Plans, prepares, and serves adequate meals independently', points: 1, default: true },
      { label: '0 — Prepares adequate meals if supplied with ingredients', points: 0 },
      { label: '0 — Heats and serves prepared meals', points: 0 },
      { label: '0 — Needs meals prepared and served', points: 0 },
    ]},
    { id: 'housekeeping', label: 'Housekeeping', options: [
      { label: '1 — Maintains house alone or with occasional help', points: 1, default: true },
      { label: '1 — Performs light daily tasks (dishes, beds)', points: 1 },
      { label: '1 — Performs light tasks but cannot maintain cleanliness', points: 1 },
      { label: '1 — Needs help with all home maintenance', points: 1 },
      { label: '0 — Does not participate in any housekeeping', points: 0 },
    ]},
    { id: 'laundry', label: 'Laundry', options: [
      { label: '1 — Does personal laundry completely', points: 1, default: true },
      { label: '1 — Launders small items (socks, stockings)', points: 1 },
      { label: '0 — All laundry must be done by others', points: 0 },
    ]},
    { id: 'transport', label: 'Mode of transportation', options: [
      { label: '1 — Travels independently on public transport or drives own car', points: 1, default: true },
      { label: '1 — Arranges own travel via taxi but no public transport', points: 1 },
      { label: '1 — Travels on public transport when accompanied', points: 1 },
      { label: '0 — Travel limited to taxi or car with assistance', points: 0 },
      { label: '0 — Does not travel at all', points: 0 },
    ]},
    { id: 'meds', label: 'Responsibility for own medications', options: [
      { label: '1 — Responsible for taking medication in correct dose at correct time', points: 1, default: true },
      { label: '0 — Takes responsibility if medication is prepared in advance', points: 0 },
      { label: '0 — Not capable of dispensing own medication', points: 0 },
    ]},
    { id: 'finance', label: 'Ability to handle finances', options: [
      { label: '1 — Manages financial matters independently', points: 1, default: true },
      { label: '1 — Manages day-to-day purchases but needs help with banking', points: 1 },
      { label: '0 — Incapable of handling money', points: 0 },
    ]},
  ],
  bands: [
    { min: 0, max: 2, label: 'Severe functional dependence', cls: 'cls-danger' },
    { min: 3, max: 5, label: 'Moderate dependence', cls: 'cls-warn' },
    { min: 6, max: 8, label: 'Independent', cls: 'cls-normal' },
  ],
  max: 8,
}

const faq = [
  { q: 'What is the Lawton IADL scale?', a: 'A widely used instrument for assessing instrumental activities of daily living (cooking, shopping, finances, transport, etc.) in older adults — finer-grained than basic ADLs like bathing and dressing.' },
  { q: 'What range does it use?', a: '0–8 (originally scored 0 or 1 for each of 8 domains). Higher = more independent.' },
  { q: 'Are there sex-specific items?', a: 'Yes — historically housekeeping, food preparation, and laundry were scored only for women. Most modern use scores all 8 items for both sexes.' },
  { q: 'How does it differ from the Katz ADL?', a: 'Katz measures basic ADLs (bathing, dressing, feeding); Lawton measures higher-order tasks needed to live independently in the community.' },
]
const references = [
  { citation: 'Lawton MP, Brody EM. Assessment of older people: self-maintaining and instrumental activities of daily living. <em>Gerontologist</em>. 1969;9(3):179-186.' },
]
const relatedTools = [
  { slug: 'ecog-performance', name: 'ECOG Performance Status' },
  { slug: 'karnofsky-performance', name: 'Karnofsky Performance Scale' },
  { slug: 'palliative-performance-scale', name: 'Palliative Performance Scale' },
]
---
<ScoreCalc
  slug="lawton-iadl"
  name="Lawton IADL Scale Calculator"
  schemaName="Lawton IADL Scale"
  shortDescription="Lawton Instrumental Activities of Daily Living (IADL) scale (0–8)."
  metaTitle="Lawton IADL Scale Calculator | maratool"
  metaDescription="Free Lawton IADL scale calculator for instrumental activities of daily living in older adults. 8 domains, score 0–8."
  subcategory="Scale"
  subcategorySlug="scale"
  howTo={[
    'Score each of the 8 IADL domains.',
    'The total (0–8) and interpretation update instantly.',
    'Re-assess periodically — IADL decline often precedes ADL decline.',
  ]}
  faq={faq}
  relatedTools={relatedTools}
  references={references}
  spec={spec}
/>
