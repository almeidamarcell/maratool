---
import ScoreCalc from '../components/ScoreCalc.astro'

const yn1 = [
  { label: 'No (0)', points: 0, default: true },
  { label: 'Yes (1)', points: 1 },
]

const spec = {
  items: [
    { id: 'mass', label: 'Nodal or extranodal tumor mass > 7 cm', options: yn1 },
    { id: 'sites', label: '≥ 3 nodal sites, each > 3 cm', options: yn1 },
    { id: 'bsymptoms', label: 'Presence of B symptoms', options: yn1 },
    { id: 'spleen', label: 'Symptomatic splenomegaly (spleen below the umbilicus)', options: yn1 },
    { id: 'effusion', label: 'Pleural effusion or peritoneal ascites', options: yn1 },
    { id: 'cytopenia', label: 'Cytopenias (ANC < 1.0 ×10⁹/L and/or platelets < 100 ×10⁹/L)', options: yn1 },
    { id: 'leukemic', label: 'Leukemic phase (> 5.0 ×10⁹/L circulating malignant cells)', options: yn1 },
  ],
  bands: [
    { min: 0, max: 0, label: 'No GELF criterion met — low tumor burden; watchful waiting is reasonable', cls: 'cls-normal' },
    { min: 1, max: 7, label: '≥ 1 GELF criterion met — high tumor burden; treatment generally indicated', cls: 'cls-danger' },
  ],
  max: 7,
  cols: 2,
}

const faq = [
  { q: 'What are the GELF criteria?', a: 'The Groupe d’Etude des Lymphomes Folliculaires criteria define “high tumor burden” in follicular lymphoma. Meeting any single criterion indicates high burden.' },
  { q: 'How are GELF criteria used?', a: 'They help decide whether to initiate therapy: low-burden, asymptomatic patients may be observed (watchful waiting), whereas high-burden disease usually warrants treatment.' },
  { q: 'Are GELF criteria a prognostic score?', a: 'No — they assess tumor burden / treatment indication. Prognosis in follicular lymphoma is assessed with the FLIPI or FLIPI-2 indices.' },
  { q: 'Does meeting a criterion mandate treatment?', a: 'It strongly supports it, but the final decision integrates patient preference, symptoms, comorbidity, and goals of care.' },
]
const references = [
  { citation: 'Brice P, Bastion Y, Lepage E, et al. Comparison in low-tumor-burden follicular lymphomas between an initial no-treatment policy, prednimustine, or interferon alfa. <em>J Clin Oncol</em>. 1997;15(3):1110-1117.' },
]
const relatedTools = [
  { slug: 'r-iss-myeloma', name: 'R-ISS (Myeloma)' },
  { slug: 'ecog-performance', name: 'ECOG Performance Status' },
  { slug: 'karnofsky-performance', name: 'Karnofsky Performance Status' },
]
---
<ScoreCalc
  slug="gelf-criteria"
  name="GELF Criteria Calculator (Follicular Lymphoma)"
  schemaName="GELF Criteria"
  shortDescription="GELF criteria for high tumor burden in follicular lymphoma (treatment indication)."
  metaTitle="GELF Criteria Calculator (Follicular Lymphoma) | maratool"
  metaDescription="Free GELF criteria calculator. Determine high vs low tumor burden in follicular lymphoma to guide watchful waiting vs treatment."
  subcategory="Score"
  subcategorySlug="score"
  howTo={[
    'Select each GELF criterion that is present.',
    'Any single positive criterion classifies the patient as high tumor burden.',
    'Use to inform the watchful-waiting vs initiate-treatment decision.',
  ]}
  faq={faq}
  relatedTools={relatedTools}
  references={references}
  spec={spec}
/>
