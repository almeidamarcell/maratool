---
import Base from '../../layouts/Base.astro'
import Layout from '../../components/Layout.astro'
import HubPage from '../../components/HubPage.astro'
import { toolsByCategory, toolsFlatByCategory, subcategoryOrderByCategory, buildToolItemList } from '../../data/tools'

export function getStaticPaths() {
  const subs = subcategoryOrderByCategory.Developer ?? []
  const catTools = toolsByCategory.Developer ?? {}

  const descriptions: Record<string, { title: string; description: string; intro: string }> = {
    crypto: {
      title: 'Crypto Tools — maratool',
      description: 'Free browser-based cryptography tools. Generate hashes (MD5, SHA-256), decode JWT tokens — no sign-up, runs entirely in your browser.',
      intro: 'Hash, encode, and inspect cryptographic data without sending anything to a server.',
    },
    generate: {
      title: 'Developer Generator Tools — maratool',
      description: 'Free browser-based generator tools. Generate UUIDs (v1, v4, v5) and cron expressions — no sign-up, runs entirely in your browser.',
      intro: 'Generate unique identifiers, schedules, and random values instantly in your browser.',
    },
  }

  return subs.map(sub => {
    const slug = sub.toLowerCase()
    const meta = descriptions[slug] ?? {
      title: `${sub} Tools — maratool`,
      description: `Free browser-based ${sub.toLowerCase()} tools — no sign-up, runs entirely in your browser.`,
      intro: `${sub} tools that run locally in your browser.`,
    }
    return {
      params: { subcategory: slug },
      props: {
        sub,
        subTools: catTools[sub] ?? [],
        ...meta,
      },
    }
  })
}

const { subcategory } = Astro.params
const { sub, subTools, title, description, intro } = Astro.props
const allTools = toolsFlatByCategory.Developer ?? []
const subcategories = subcategoryOrderByCategory.Developer ?? []
const liveSubTools = subTools.filter((tool: { live: boolean }) => tool.live)

const seo = {
  title,
  description,
  canonical: `https://maratool.com/developer/${subcategory}`,
  schema: {
    '@context': 'https://schema.org',
    '@type': 'CollectionPage',
    name: `${sub} Tools`,
    url: `https://maratool.com/developer/${subcategory}`,
    description,
    hasPart: liveSubTools.map((tool: { name: string; slug: string }) => ({
      '@type': 'SoftwareApplication',
      name: tool.name,
      url: `https://maratool.com/${tool.slug}`,
      applicationCategory: 'DeveloperApplication',
    })),
    mainEntity: buildToolItemList(liveSubTools, `${sub} Tools`),
  },
  breadcrumbSchema: {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://maratool.com' },
      { '@type': 'ListItem', position: 2, name: 'Developer', item: 'https://maratool.com/developer' },
      { '@type': 'ListItem', position: 3, name: sub, item: `https://maratool.com/developer/${subcategory}` },
    ],
  },
}
---
<Base {...seo} scope="subcategory">
  <Layout scope="subcategory">
    <HubPage
      category="Developer"
      categorySlug="developer"
      title={`${sub} tools`}
      subtitle={intro}
      tools={allTools}
      subcategories={subcategories}
      activeSubcategory={sub}
      basePath="/developer"
    />
  </Layout>
</Base>
