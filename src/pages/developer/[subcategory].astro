---
import Base from '../../layouts/Base.astro'
import Layout from '../../components/Layout.astro'
import Breadcrumb from '../../components/Breadcrumb.astro'
import { toolsBySubcategory, subcategoryOrder } from '../../data/tools'

export function getStaticPaths() {
  const descriptions: Record<string, { title: string; description: string; intro: string }> = {
    encoding: {
      title: 'Encoding Tools — maratool',
      description: 'Free browser-based encoding tools. Encode and decode Base64, generate hashes (MD5, SHA-256), decode JWT tokens, and convert text to binary — all in your browser.',
      intro: 'Encode, decode, and inspect data formats without sending anything to a server.',
    },
    converter: {
      title: 'Converter Tools — maratool',
      description: 'Free browser-based converter tools. Convert Unix timestamps to human-readable dates with timezone support — no sign-up, runs entirely in your browser.',
      intro: 'Quickly convert between common data formats and representations.',
    },
    text: {
      title: 'Text Tools — maratool',
      description: 'Free browser-based text tools. Compare text with diff checker, estimate reading time — no sign-up, runs entirely in your browser.',
      intro: 'Analyse and compare text with fast, privacy-friendly tools that run locally.',
    },
    generator: {
      title: 'Generator Tools — maratool',
      description: 'Free browser-based generator tools. Generate UUIDs (v1, v4, v5) in bulk — no sign-up, runs entirely in your browser.',
      intro: 'Generate unique identifiers and random values instantly in your browser.',
    },
  }

  return subcategoryOrder.map(sub => {
    const slug = sub.toLowerCase()
    const meta = descriptions[slug]
    return {
      params: { subcategory: slug },
      props: {
        sub,
        tools: toolsBySubcategory[sub] ?? [],
        ...meta,
      },
    }
  })
}

const { subcategory } = Astro.params
const { sub, tools, title, description, intro } = Astro.props

const seo = {
  title,
  description,
  canonical: `https://maratool.com/developer/${subcategory}`,
  schema: {
    '@context': 'https://schema.org',
    '@type': 'CollectionPage',
    name: `${sub} Tools`,
    url: `https://maratool.com/developer/${subcategory}`,
    description,
    hasPart: tools.map((tool: { name: string; slug: string }) => ({
      '@type': 'SoftwareApplication',
      name: tool.name,
      url: `https://maratool.com/${tool.slug}`,
      applicationCategory: 'DeveloperApplication',
    })),
  },
  breadcrumbSchema: {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://maratool.com' },
      { '@type': 'ListItem', position: 2, name: 'Developer', item: 'https://maratool.com/developer' },
      { '@type': 'ListItem', position: 3, name: sub, item: `https://maratool.com/developer/${subcategory}` },
    ],
  },
}

const breadcrumbs = [
  { label: 'Home', href: '/' },
  { label: 'Developer', href: '/developer' },
  { label: sub },
]
---
<Base {...seo}>
  <Layout>
    <Breadcrumb crumbs={breadcrumbs} />
    <div class="hero">
      <h1>{sub} Tools</h1>
      <p>{intro}</p>
    </div>

    <div class="tools-grid">
      {tools.map((tool: { live: boolean; slug: string; emoji: string; name: string; description: string }) => (
        tool.live
          ? (
            <a href={`/${tool.slug}`} class="tool-card">
              <span class="tool-card-emoji">{tool.emoji}</span>
              <div class="tool-card-name">{tool.name}</div>
              <div class="tool-card-desc">{tool.description}</div>
            </a>
          )
          : (
            <div class="tool-card" style="opacity:0.5;cursor:default;">
              <span class="tool-card-emoji">{tool.emoji}</span>
              <div class="tool-card-name">{tool.name}</div>
              <div class="tool-card-desc">{tool.description}</div>
              <span class="tool-card-badge">Coming Soon</span>
            </div>
          )
      ))}
    </div>
  </Layout>
</Base>
