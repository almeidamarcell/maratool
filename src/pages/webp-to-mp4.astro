---
import Base from '../layouts/Base.astro'
import Layout from '../components/Layout.astro'
import ToolShell from '../components/ToolShell.astro'

const seo = {
  title: 'WebP to MP4 Converter — Animated WebP to Video | maratool',
  description: 'Convert animated WebP images to MP4 video in your browser. Adjust quality and resolution, then download — no upload required.',
  canonical: 'https://maratool.com/webp-to-mp4',
  schema: {
    '@context': 'https://schema.org',
    '@type': 'WebApplication',
    name: 'WebP to MP4 Converter',
    url: 'https://maratool.com/webp-to-mp4',
    applicationCategory: 'UtilitiesApplication',
    operatingSystem: 'Any',
    offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
    description: 'Convert animated WebP images to MP4 video in your browser. Adjust quality and resolution, then download — no upload required.',
  },
  breadcrumbSchema: {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://maratool.com' },
      { '@type': 'ListItem', position: 2, name: 'Converter', item: 'https://maratool.com/converter' },
      { '@type': 'ListItem', position: 3, name: 'Video', item: 'https://maratool.com/converter/video' },
      { '@type': 'ListItem', position: 4, name: 'WebP to MP4 Converter', item: 'https://maratool.com/webp-to-mp4' },
    ],
  },
  faqSchema: {
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: [
      {
        '@type': 'Question',
        name: 'Does this work with animated WebP?',
        acceptedAnswer: { '@type': 'Answer', text: 'Yes. Static WebP files also convert to a short MP4 with a single frame.' }
      },
      {
        '@type': 'Question',
        name: 'Is FFmpeg used?',
        acceptedAnswer: { '@type': 'Answer', text: 'Yes — FFmpeg runs as WebAssembly in your browser. Your file never leaves your device.' }
      },
      {
        '@type': 'Question',
        name: 'Can I convert multiple files?',
        acceptedAnswer: { '@type': 'Answer', text: 'Yes. Use batch mode to convert several WebP files and download them as a ZIP.' }
      },
      {
        '@type': 'Question',
        name: 'Why convert WebP to MP4?',
        acceptedAnswer: { '@type': 'Answer', text: 'MP4 plays everywhere — social platforms, editors, and older apps that do not support animated WebP.' }
      }
    ]
  }
}

const howTo = [
  'Upload an animated WebP file.',
  'Set quality and output resolution.',
  'Convert and download the MP4.'
]
const faq = [
  {
    'q': 'Does this work with animated WebP?',
    'a': 'Yes. Static WebP files also convert to a short MP4 with a single frame.'
  },
  {
    'q': 'Is FFmpeg used?',
    'a': 'Yes — FFmpeg runs as WebAssembly in your browser. Your file never leaves your device.'
  },
  {
    'q': 'Can I convert multiple files?',
    'a': 'Yes. Use batch mode to convert several WebP files and download them as a ZIP.'
  },
  {
    'q': 'Why convert WebP to MP4?',
    'a': 'MP4 plays everywhere — social platforms, editors, and older apps that do not support animated WebP.'
  }
]
const relatedTools = [
  { slug: 'video-to-gif', name: 'Video To Gif' },
  { slug: 'file-converter', name: 'File Converter' },
  { slug: 'mov-to-mp4', name: 'Mov To Mp4' },
]
const breadcrumbs = [
  { label: 'Home', href: '/' },
  { label: 'Converter', href: '/converter' },
  { label: 'Video', href: '/converter/video' },
  { label: 'WebP to MP4 Converter' },
]
---
<Base {...seo}>
  <Layout>
    <ToolShell slug="webp-to-mp4" name="Convert Animated WebP to MP4" description="Convert animated WebP images to MP4 video in your browser. Adjust quality and resolution, then download — no upload required." howTo={howTo} faq={faq} relatedTools={relatedTools} breadcrumbs={breadcrumbs}>
      <div class="tool-container w2m-root" style="min-height:420px;">
        <div class="w2m-dropzone" id="w2m-dropzone">
          <input type="file" id="w2m-file" hidden />
          <p class="w2m-drop-title">Drop a file here</p>
          <p class="w2m-drop-sub">or click to select</p>
        </div>
        <div id="w2m-workspace" style="display:none;"></div>
        <div id="w2m-progress" class="w2m-progress" style="display:none;">
          <div id="w2m-progress-text">Processing...</div>
          <div class="w2m-progress-track"><div id="w2m-progress-fill" class="w2m-progress-fill"></div></div>
        </div>
        <div id="w2m-error" class="w2m-error" style="display:none;"><span id="w2m-error-text"></span></div>
        <div id="w2m-result" style="display:none;"></div>
      </div>
    </ToolShell>
  </Layout>
</Base>
<style is:global>
  .w2m-dropzone {
    border: 2px dashed var(--border); border-radius: var(--radius);
    padding: 3rem 2rem; text-align: center; cursor: pointer;
    transition: border-color 0.2s, background 0.2s;
  }
  .w2m-dropzone:hover, .w2m-dropzone.drag-over { border-color: var(--accent); background: var(--bg-soft); }
  .w2m-drop-title { font-size: 1.125rem; font-weight: 600; margin: 0; }
  .w2m-drop-sub { font-size: 0.875rem; color: var(--text-2); margin: 0.5rem 0 0; }
  .w2m-progress { text-align: center; padding: 2rem; }
  .w2m-progress-track { width: 100%; max-width: 400px; height: 8px; background: var(--bg-hover); border-radius: 4px; margin: 1rem auto; overflow: hidden; }
  .w2m-progress-fill { height: 100%; background: var(--accent); width: 0%; transition: width 0.3s; }
  .w2m-error { background: var(--error-bg); border: 1px solid var(--error-border); border-radius: var(--radius); padding: 1rem; color: #c53030; font-size: 0.875rem; }
  .w2m-preview-wrap {
    background: repeating-conic-gradient(#e0e0e0 0% 25%, #fff 0% 50%) 0 0 / 16px 16px;
    border: 1px solid var(--border); border-radius: var(--radius); padding: 0.5rem;
    display: flex; align-items: center; justify-content: center; margin-bottom: 1rem;
  }
  .w2m-preview-wrap canvas, .w2m-preview-wrap img { max-width: 100%; max-height: 360px; display: block; }
  .w2m-controls { display: flex; flex-direction: column; gap: 0.75rem; margin-bottom: 1rem; }
  .w2m-row { display: flex; flex-wrap: wrap; gap: 0.75rem; align-items: center; }
  .w2m-actions { display: flex; gap: 0.75rem; flex-wrap: wrap; margin-top: 0.5rem; }
</style>
<script src="../tools/webp-to-mp4.js"></script>
