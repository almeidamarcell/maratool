---
import ScoreCalc from '../components/ScoreCalc.astro'

const yn = (pts) => [
  { label: 'No (0)', points: 0, default: true },
  { label: `Yes (${pts})`, points: pts },
]

const spec = {
  items: [
    { id: 'age', label: 'Age', options: [
      { label: '≤ 40 years (0)', points: 0, default: true },
      { label: '41–60 years (1)', points: 1 },
      { label: '61–74 years (2)', points: 2 },
      { label: '≥ 75 years (3)', points: 3 },
    ]},
    { id: 'surgery', label: 'Surgery type', options: [
      { label: 'None (0)', points: 0, default: true },
      { label: 'Minor surgery (1)', points: 1 },
      { label: 'Major surgery, laparoscopic or arthroscopic > 45 min (2)', points: 2 },
      { label: 'Elective major lower-extremity arthroplasty (5)', points: 5 },
    ]},
    { id: 'bmi', label: 'BMI > 25 kg/m²', options: yn(1) },
    { id: 'legs', label: 'Swollen legs', options: yn(1) },
    { id: 'varicose', label: 'Varicose veins', options: yn(1) },
    { id: 'sepsis', label: 'Sepsis (< 1 month)', options: yn(1) },
    { id: 'lung', label: 'Serious lung disease incl. pneumonia (< 1 month)', options: yn(1) },
    { id: 'ocp', label: 'Oral contraceptive or hormone replacement therapy', options: yn(1) },
    { id: 'pregnancy', label: 'Pregnancy or postpartum (< 1 month)', options: yn(1) },
    { id: 'abortion', label: 'History of unexplained or recurrent spontaneous abortion', options: yn(1) },
    { id: 'mi', label: 'Acute myocardial infarction', options: yn(1) },
    { id: 'chf', label: 'Congestive heart failure (< 1 month)', options: yn(1) },
    { id: 'ibd', label: 'History of inflammatory bowel disease', options: yn(1) },
    { id: 'bedrest', label: 'Medical patient currently at bed rest', options: yn(1) },
    { id: 'cast', label: 'Immobilizing plaster cast (< 1 month)', options: yn(2) },
    { id: 'cvc', label: 'Central venous access', options: yn(2) },
    { id: 'malignancy', label: 'Malignancy (present or previous)', options: yn(2) },
    { id: 'bedconfined', label: 'Confined to bed > 72 hours', options: yn(2) },
    { id: 'vte', label: 'History of DVT or PE', options: yn(3) },
    { id: 'famvte', label: 'Family history of thrombosis', options: yn(3) },
    { id: 'thrombophilia', label: 'Known thrombophilia (Factor V Leiden, prothrombin 20210A, lupus anticoagulant, antiphospholipid, hyperhomocysteinemia, HIT)', options: yn(3) },
    { id: 'stroke', label: 'Stroke (< 1 month)', options: yn(5) },
    { id: 'fracture', label: 'Hip, pelvis, or leg fracture', options: yn(5) },
    { id: 'sci', label: 'Acute spinal cord injury / paralysis (< 1 month)', options: yn(5) },
  ],
  bands: [
    { min: 0, max: 0, label: 'Score 0 — lowest risk (~0% VTE without prophylaxis)', cls: 'cls-normal' },
    { min: 1, max: 2, label: 'Score 1–2 — low risk (~1.5%); early ambulation', cls: 'cls-normal' },
    { min: 3, max: 4, label: 'Score 3–4 — moderate risk (~3%); mechanical or pharmacologic prophylaxis', cls: 'cls-warn' },
    { min: 5, max: 100, label: 'Score ≥ 5 — high risk (~6% or more); pharmacologic prophylaxis recommended', cls: 'cls-danger' },
  ],
  cols: 2,
}

const faq = [
  { q: 'What is the Caprini score?', a: 'A cumulative risk-factor score (2005 model) that stratifies surgical and medical patients for venous thromboembolism and guides prophylaxis intensity.' },
  { q: 'How is the Caprini score interpreted?', a: '0 = lowest risk, 1–2 = low, 3–4 = moderate, ≥ 5 = high risk. Pharmacologic prophylaxis is generally recommended for scores ≥ 5 (and considered at 3–4).' },
  { q: 'Which Caprini version is this?', a: 'This calculator uses the widely validated 2005 Caprini Risk Assessment Model. Later modified versions exist with slightly different point values.' },
  { q: 'Does the score replace bleeding-risk assessment?', a: 'No. Prophylaxis decisions weigh VTE risk (Caprini) against bleeding risk; high Caprini scores still require an individualized bleeding assessment.' },
]
const references = [
  { citation: 'Caprini JA. Thrombosis risk assessment as a guide to quality patient care. <em>Dis Mon</em>. 2005;51(2-3):70-78.' },
  { citation: 'Gould MK, Garcia DA, Wren SM, et al. Prevention of VTE in nonorthopedic surgical patients: ACCP guidelines. <em>Chest</em>. 2012;141(2 Suppl):e227S-e277S.' },
]
const relatedTools = [
  { slug: 'padua-prediction', name: 'Padua Prediction Score' },
  { slug: 'khorana-vte', name: 'Khorana Score' },
  { slug: 'wells-dvt', name: 'Wells Score (DVT)' },
]
---
<ScoreCalc
  slug="caprini-dvt-risk"
  name="Caprini VTE Risk Score Calculator"
  schemaName="Caprini Score"
  shortDescription="Caprini Risk Assessment Model (2005) for venous thromboembolism risk and prophylaxis guidance."
  metaTitle="Caprini Score Calculator (VTE / DVT Risk) | maratool"
  metaDescription="Free Caprini score calculator. Stratify surgical and medical patients for VTE risk and guide thromboprophylaxis using the 2005 Caprini model."
  subcategory="Score"
  subcategorySlug="score"
  howTo={[
    'Select age and surgery type, then mark each risk factor that applies.',
    'The cumulative Caprini score and risk band update instantly.',
    'Use the band to guide prophylaxis after assessing bleeding risk.',
  ]}
  faq={faq}
  relatedTools={relatedTools}
  references={references}
  spec={spec}
/>
