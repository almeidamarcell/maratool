---
import Base from '../layouts/Base.astro'
import Layout from '../components/Layout.astro'
import { tools, categoryOrder, toolsFlatByCategory, getPopularTools, getRecentlyAddedTools } from '../data/tools'

const liveTools = tools.filter(t => t.live)

// Per-vertical descriptions + popular tool slugs (manual curation)
const verticalMeta: Record<string, { description: string; popularSlugs: string[] }> = {
  Health: {
    description: 'Medical calculators, scores, scales, references',
    popularSlugs: ['bmi-calculator', 'mean-arterial-pressure', 'cha2ds2-vasc', 'corrected-qt-interval'],
  },
  Developer: {
    description: 'Inspect, decode, generate, hash, parse',
    popularSlugs: ['jwt-decoder', 'cron-expression', 'uuid-generator', 'hash-generator'],
  },
  Image: {
    description: 'Convert, compress, remove background, optimize',
    popularSlugs: ['background-remover', 'svg-optimizer', 'image-converter', 'favicon-generator'],
  },
  Converter: {
    description: 'CSV, JSON, YAML, XML, units, base',
    popularSlugs: ['csv-to-json', 'yaml-to-json', 'unit-converter', 'unix-timestamp'],
  },
  Text: {
    description: 'Diff, format, extract, transform, count',
    popularSlugs: ['diff-checker', 'json-formatter', 'reading-time', 'lorem-ipsum'],
  },
  Color: {
    description: 'Pick, convert, contrast, palette, harmony',
    popularSlugs: ['contrast-checker', 'color-converter', 'color-shades', 'color-harmony-generator'],
  },
  PDF: {
    description: 'Merge, split, extract text, metadata',
    popularSlugs: ['pdf-to-text', 'pdf-merge-split', 'pdf-to-markdown', 'pdf-metadata'],
  },
  Mockup: {
    description: 'Generate fake chats, posts, screenshots',
    popularSlugs: ['whatsapp-chat-mockup', 'imessage-chat-mockup', 'x-post-mockup', 'chatgpt-mockup'],
  },
  Marketing: {
    description: 'QR codes, UTM links, barcodes',
    popularSlugs: ['qr-code-generator', 'utm-builder', 'barcode-generator'],
  },
  Business: {
    description: 'Margin, break-even, tax, salary, ROI',
    popularSlugs: ['profit-margin-calculator', 'break-even-calculator', 'vat-calculator', 'salary-converter'],
  },
  Finance: {
    description: 'Mortgage, loans, compound interest, CAGR',
    popularSlugs: ['mortgage-calculator', 'loan-calculator', 'compound-interest-calculator', 'cagr-calculator'],
  },
  'E-commerce': {
    description: 'Amazon and Etsy seller fee calculators',
    popularSlugs: ['amazon-fee-calculator', 'etsy-fee-calculator'],
  },
}

const verticals = categoryOrder.map(cat => {
  const catTools = (toolsFlatByCategory[cat] ?? []).filter(t => t.live)
  const meta = verticalMeta[cat] ?? { description: '', popularSlugs: [] }
  const popularTools = meta.popularSlugs
    .map(slug => catTools.find(t => t.slug === slug))
    .filter((t): t is typeof tools[number] => !!t)
    .slice(0, 3)
  // Fallback to first 3 if not enough matches
  const display = popularTools.length >= 3
    ? popularTools
    : [...popularTools, ...catTools.filter(t => !popularTools.includes(t)).slice(0, 3 - popularTools.length)]
  return {
    name: cat,
    slug: cat.toLowerCase(),
    count: catTools.length,
    description: meta.description,
    popular: display,
  }
}).filter(v => v.count > 0).sort((a, b) => b.count - a.count) // largest verticals first

// Popular this week — deterministic heuristic ranking (see tools.ts popularityScore)
const popularThisWeek = getPopularTools(6)

// New tools — derived from tools.ts file position (last-added first)
const newTools = getRecentlyAddedTools(3)

// Hero query chips — pre-canned popular searches
const heroQueryChips = [
  { label: 'JSON formatter', slug: 'json-formatter' },
  { label: 'CHA2DS2-VASc', slug: 'cha2ds2-vasc' },
  { label: 'QR generator', slug: 'qr-code-generator' },
  { label: 'JWT decoder', slug: 'jwt-decoder' },
  { label: 'cron parser', slug: 'cron-parser' },
  { label: 'contrast checker', slug: 'contrast-checker' },
]

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: 'Are these tools really free?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Yes, every tool on maratool is completely free with no sign-up, no limits, and no hidden paywalls. The site is supported by ads.'
      }
    },
    {
      '@type': 'Question',
      name: 'Is my data safe?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Yes. Almost every tool on maratool runs entirely in your browser — your files and text stay on your device and nothing is uploaded to any server. The one exception is the Instagram video downloader, which has to proxy through a small server because Instagram blocks direct browser fetches. The privacy policy explains exactly what that one tool does.'
      }
    },
    {
      '@type': 'Question',
      name: 'Do I need to create an account?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'No. There are no accounts, no sign-ups, and no login walls. Just open a tool and start using it immediately.'
      }
    },
    {
      '@type': 'Question',
      name: 'What tools are available on maratool?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: `maratool offers ${liveTools.length}+ tools across 12 categories: converters, PDF, text, image, color, developer, marketing, business, finance, e-commerce, mockups, and medical calculators (Health). Almost every tool runs in your browser.`
      }
    }
  ]
}

const seo = {
  title: `maratool — ${liveTools.length}+ Free Browser-Based Tools | No Sign-Up`,
  description: 'Free browser-based tools — JSON formatter, color picker, JWT decoder, medical calculators, PDF tools, and 220+ more. No sign-up, no uploads, runs locally.',
  canonical: 'https://maratool.com/',
  schema: {
    '@context': 'https://schema.org',
    '@type': 'WebSite',
    name: 'maratool',
    url: 'https://maratool.com',
    description: 'Free browser-based tools for developers, designers, writers, and clinicians',
  }
}

const itemListSchema = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: 'Free Online Tools',
  description: 'A collection of free browser-based utilities',
  url: 'https://maratool.com',
  numberOfItems: liveTools.length,
  itemListElement: liveTools.map((t, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    name: t.name,
    url: `https://maratool.com/${t.slug}/`,
  })),
}
---
<Base {...seo} faqSchema={faqSchema} scope="home">
  <Layout scope="home">
    <!-- Hero -->
    <div class="hero">
      <h1>Free online tools</h1>
      <div class="hero-search-wrap">
        <svg class="hero-search-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
        </svg>
        <input
          id="hero-search-trigger"
          class="hero-search"
          type="search"
          placeholder="What do you need? Try 'CHA2DS2-VASc' or 'convert csv'…"
          aria-label="Search tools"
          autocomplete="off"
          readonly
        />
        <span class="hero-search-kbd" id="hero-search-kbd">⌘K</span>
      </div>
      <div class="home-query-chips">
        {heroQueryChips.map(chip => (
          <a href={`/${chip.slug}`} class="home-query-chip">{chip.label}</a>
        ))}
      </div>
      <p class="hero-tagline">No accounts. No installs. Nothing leaves your browser.</p>
    </div>

    <!-- Pinned (rendered by JS from localStorage) -->
    <div id="home-pinned" class="recently-used" hidden style="background: transparent; padding: 0; border: 0;">
      <div class="recently-used-title"><span style="color: var(--accent);">★</span> Pinned</div>
      <div id="home-pinned-grid" class="pinned-strip"></div>
    </div>

    <!-- Recently Used (rendered by JS from localStorage) -->
    <div id="recently-used" class="recently-used" hidden>
      <div class="recently-used-title">Pick up where you left off</div>
      <div id="recently-used-grid" class="recently-used-grid"></div>
    </div>

    <!-- Verticals grid -->
    <h2 class="home-section-h2">
      Browse by vertical
      <span class="h2-count">9 categories · {liveTools.length} tools</span>
    </h2>
    <div class="verticals-grid">
      {verticals.map(v => (
        <a href={`/${v.slug}`} class="vertical-card" data-cat={v.slug}>
          <div class="vertical-card-head">
            <span class="vertical-card-name">{v.name}</span>
            <span class="vertical-card-count">{v.count} {v.count === 1 ? 'tool' : 'tools'}</span>
          </div>
          <p class="vertical-card-desc">{v.description}</p>
          <div class="vertical-card-tools">
            {v.popular.map(tool => (
              <span>{tool.name}</span>
            ))}
          </div>
        </a>
      ))}
    </div>

    <!-- Popular this week -->
    {popularThisWeek.length > 0 && (
      <>
        <h2 class="home-section-h2">
          Popular this week
          <a href="/all" class="h2-see-all">All tools →</a>
        </h2>
        <div class="popular-grid">
          {popularThisWeek.map(tool => (
            <a href={`/${tool.slug}`} class="pop-card" data-cat={tool.category.toLowerCase()}>
              <span class="pop-card-emoji">{tool.emoji}</span>
              <div class="pop-card-body">
                <div class="pop-card-name">{tool.name}</div>
                <div class="pop-card-meta">
                  <span class="cat-dot" data-cat={tool.category.toLowerCase()}></span>
                  {tool.category} · {tool.subcategory}
                </div>
              </div>
            </a>
          ))}
        </div>
      </>
    )}

    <!-- New -->
    {newTools.length > 0 && (
      <>
        <h2 class="home-section-h2">
          ✨ New
        </h2>
        <div class="popular-grid">
          {newTools.map(tool => (
            <a href={`/${tool.slug}`} class="pop-card" data-cat={tool.category.toLowerCase()}>
              <span class="pop-card-emoji">{tool.emoji}</span>
              <div class="pop-card-body">
                <div class="pop-card-name">{tool.name}</div>
                <div class="pop-card-meta">
                  <span class="cat-dot" data-cat={tool.category.toLowerCase()}></span>
                  {tool.category} · {tool.subcategory}
                </div>
              </div>
            </a>
          ))}
        </div>
      </>
    )}

    <section style="margin-top: 3rem;">
      <h2>Why maratool?</h2>
      <p style="color: var(--text-2); line-height: 1.7; margin-top: 0.75rem; max-width: 560px;">
        No sign-ups. No "free tier" limits. maratool runs {liveTools.length}+ tools directly in your browser. Your files stay on your device. Results appear instantly. The one tool that needs a server is the <a href="/instagram-video-downloader" style="color: var(--accent);">Instagram video downloader</a>, because Instagram blocks direct browser fetches; the <a href="/privacy" style="color: var(--accent);">privacy page</a> explains exactly what it does.
      </p>
    </section>

    <section class="faq" style="margin-top: 2rem;">
      <h2>Frequently asked questions</h2>
      <div class="faq-item">
        <h3 class="faq-question">Are these tools really free?</h3>
        <p class="faq-answer">Yes, every tool on maratool is completely free with no sign-up, no limits, and no hidden paywalls. The site is supported by ads.</p>
      </div>
      <div class="faq-item">
        <h3 class="faq-question">Is my data safe?</h3>
        <p class="faq-answer">Yes. Almost every tool runs entirely in your browser using JavaScript. Your files and text stay on your device and nothing is uploaded. The one exception is the <a href="/instagram-video-downloader" class="about-link">Instagram video downloader</a>, which has to proxy through a small server because Instagram blocks direct browser fetches. The <a href="/privacy" class="about-link">privacy policy</a> documents it in detail.</p>
      </div>
      <div class="faq-item">
        <h3 class="faq-question">Do I need to create an account?</h3>
        <p class="faq-answer">No. There are no accounts, no sign-ups, and no login walls. Just open a tool and start using it immediately.</p>
      </div>
      <div class="faq-item">
        <h3 class="faq-question">What tools are available on maratool?</h3>
        <p class="faq-answer">maratool offers {liveTools.length}+ tools across 9 categories: converters, PDF, text, image, color, developer, marketing, mockups, and medical calculators (Health). Almost every tool runs in your browser.</p>
      </div>
    </section>

    <script type="application/ld+json" set:html={JSON.stringify(itemListSchema)} />
  </Layout>
</Base>

<script>
  ;(function () {
    // Hero search → open command palette (same fuzzy search, just centered modal)
    var trigger = document.getElementById('hero-search-trigger')
    var kbdEl = document.getElementById('hero-search-kbd')
    if (kbdEl) {
      var isMac = /Mac|iPod|iPhone|iPad/.test(navigator.platform)
      if (!isMac) kbdEl.textContent = 'Ctrl K'
    }
    if (trigger) {
      trigger.addEventListener('click', function () {
        if ((window as any).maratoolOpenCmdPalette) {
          ;(window as any).maratoolOpenCmdPalette()
        }
      })
      trigger.addEventListener('focus', function () {
        if ((window as any).maratoolOpenCmdPalette) {
          ;(trigger as HTMLInputElement).blur()
          ;(window as any).maratoolOpenCmdPalette()
        }
      })
    }
  })()

  ;(function () {
    var recentKey = 'maratool_recent'
    var pinnedKey = 'maratool_pinned'

    function load(key: string) {
      try {
        var raw = localStorage.getItem(key)
        if (!raw) return []
        var parsed = JSON.parse(raw)
        return Array.isArray(parsed) ? parsed : []
      } catch (e) { return [] }
    }

    function renderRecent() {
      var items = load(recentKey).slice(0, 8)
      var el = document.getElementById('recently-used')
      var grid = document.getElementById('recently-used-grid')
      if (!el || !grid) return
      if (items.length === 0) { el.hidden = true; return }
      el.hidden = false
      grid.innerHTML = items.map(function (item: any) {
        var emoji = item.emoji ? '<span>' + item.emoji + '</span>' : ''
        return '<a href="/' + item.slug + '" class="recently-used-chip">' + emoji + item.name + '</a>'
      }).join('')
    }

    function renderPinned() {
      var items = load(pinnedKey).slice(0, 8)
      var el = document.getElementById('home-pinned')
      var grid = document.getElementById('home-pinned-grid')
      if (!el || !grid) return
      if (items.length === 0) { el.hidden = true; return }
      el.hidden = false
      grid.innerHTML = items.map(function (item: any) {
        return '<a href="/' + item.slug + '" class="pinned-chip"><span class="pin-icon">★</span>' + item.name + '</a>'
      }).join('')
    }

    renderRecent()
    renderPinned()
  })()
</script>
