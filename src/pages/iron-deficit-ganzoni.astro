---
import HealthCalc from '../components/HealthCalc.astro'
const faq = [
  { q: 'Formula?', a: 'Total iron deficit (mg) = weight × (target Hb − current Hb) × 2.4 + iron stores. Iron stores = 500 mg if weight ≥ 35 kg; otherwise 15 × weight (mg).' },
  { q: 'Target hemoglobin?', a: 'Default 15 g/dL for adults. Pediatric target may be lower (12–14 g/dL depending on age).' },
  { q: 'Why 2.4?', a: 'Derived empirically from the iron content of hemoglobin (3.4 mg iron per g Hb) and assumed blood volume (~70 mL/kg).' },
  { q: 'Indications?', a: 'Calculating IV iron replacement dose in iron-deficiency anemia, particularly with intolerance to or failure of oral iron.' },
]
const references = [
  { citation: 'Ganzoni AM. Intravenous iron-dextran: therapeutic and experimental possibilities. <em>Schweiz Med Wochenschr</em>. 1970;100(7):301-303.' },
]
const relatedTools = [
  { slug: 'transferrin-saturation', name: 'Transferrin Saturation (TSAT)' },
  { slug: 'bicarbonate-deficit', name: 'Bicarbonate Deficit' },
  { slug: 'serum-osmolality', name: 'Serum Osmolality' },
]
---
<HealthCalc slug="iron-deficit-ganzoni" name="Total Iron Deficit (Ganzoni)" schemaName="Iron Deficit Ganzoni"
  shortDescription="Calculate total body iron deficit for IV iron replacement using the Ganzoni formula."
  metaTitle="Iron Deficit Calculator (Ganzoni Formula) | maratool"
  metaDescription="Calculate total body iron deficit for IV iron replacement (Ganzoni). Free, runs in your browser."
  subcategory="Electrolytes" subcategorySlug="electrolytes"
  howTo={[ 'Enter weight (kg), current Hb (g/dL), and target Hb (defaults to 15).', 'Total iron deficit (mg) appears instantly.', 'Divide by IV iron product unit to plan dosing schedule.' ]}
  faq={faq} relatedTools={relatedTools} references={references}>
  <div class="hcalc-inputs cols-3">
    <label class="hcalc-field"><span class="hcalc-label">Weight</span><div class="hcalc-input-wrap"><input type="number" id="iron-weight" placeholder="70" step="any" min="0"><span class="hcalc-unit">kg</span></div></label>
    <label class="hcalc-field"><span class="hcalc-label">Current Hb</span><div class="hcalc-input-wrap"><input type="number" id="iron-hb" placeholder="10" step="any" min="0"><span class="hcalc-unit">g/dL</span></div></label>
    <label class="hcalc-field"><span class="hcalc-label">Target Hb</span><div class="hcalc-input-wrap"><input type="number" id="iron-target" placeholder="15" step="any" min="0" value="15"><span class="hcalc-unit">g/dL</span></div></label>
  </div>
  <div class="hcalc-outputs">
    <div class="hcalc-output"><div class="hcalc-output-label">Total Iron Deficit</div><div class="hcalc-output-value" id="iron-value">—</div><button class="copy-btn" data-target="iron-value">Copy</button></div>
  </div>
</HealthCalc>
<script src="../tools/health/wave5-ui.js"></script>
