---
import Base from '../layouts/Base.astro'
import Layout from '../components/Layout.astro'
import HubPage from '../components/HubPage.astro'
import { toolsFlatByCategory, subcategoryOrderByCategory } from '../data/tools'

const categoryTools = toolsFlatByCategory.Converter ?? []
const subcategories = subcategoryOrderByCategory.Converter ?? []

const seo = {
  title: 'Converter Tools — maratool',
  description: 'Free browser-based converter tools. Convert CSV to JSON, HTML to Markdown, Base64 encode/decode, Unix timestamps, and more — no sign-up, runs in your browser.',
  canonical: 'https://maratool.com/converter',
  schema: {
    '@context': 'https://schema.org',
    '@type': 'CollectionPage',
    name: 'Converter Tools',
    url: 'https://maratool.com/converter',
    description: 'Free browser-based converter tools. Convert CSV to JSON, HTML to Markdown, Base64 encode/decode, Unix timestamps, and more — no sign-up, runs in your browser.',
    hasPart: categoryTools.filter(t => t.live).map(tool => ({
      '@type': 'SoftwareApplication',
      name: tool.name,
      url: `https://maratool.com/${tool.slug}`,
      applicationCategory: 'UtilitiesApplication',
    })),
  },
  breadcrumbSchema: {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://maratool.com' },
      { '@type': 'ListItem', position: 2, name: 'Converter', item: 'https://maratool.com/converter' },
    ],
  },
}

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: 'How to convert CSV to JSON online?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Paste your CSV data into the input field and get instant JSON output. maratool runs entirely in your browser — no file uploads, no server processing, and no data leaves your machine.'
      }
    },
    {
      '@type': 'Question',
      name: 'Can I convert files without uploading to a server?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Yes. All maratool converters run 100% client-side using JavaScript in your browser. Your data never leaves your device, making it safe for sensitive or proprietary content.'
      }
    },
    {
      '@type': 'Question',
      name: 'What formats can I convert between?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'maratool supports conversions between CSV and JSON, HTML and Markdown, Base64 encoding/decoding, Unix timestamps, and more. New converters are added regularly.'
      }
    },
    {
      '@type': 'Question',
      name: 'Are these converters free to use?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Yes, all converter tools on maratool are completely free with no sign-up required. There are no usage limits — convert as many files as you need.'
      }
    },
  ]
}
---
<Base {...seo} faqSchema={faqSchema}>
  <Layout scope="hub">
    <HubPage
      category="Converter"
      categorySlug="converter"
      title="Converter tools"
      subtitle="Transform between data formats, encodings, and units — all running locally in your browser."
      tools={categoryTools}
      subcategories={subcategories}
      basePath="/converter"
    />
  </Layout>
</Base>
