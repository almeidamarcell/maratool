---
import ScoreCalc from '../components/ScoreCalc.astro'

const spec = {
  items: [
    { id: 'exudate', label: 'Tonsillar exudate', options: [
      { label: 'No (0)', points: 0, default: true }, { label: 'Yes (1)', points: 1 },
    ]},
    { id: 'nodes', label: 'Tender anterior cervical lymphadenopathy', options: [
      { label: 'No (0)', points: 0, default: true }, { label: 'Yes (1)', points: 1 },
    ]},
    { id: 'fever', label: 'Fever (history of T > 38 °C)', options: [
      { label: 'No (0)', points: 0, default: true }, { label: 'Yes (1)', points: 1 },
    ]},
    { id: 'cough', label: 'Absence of cough', options: [
      { label: 'No (cough present) (0)', points: 0, default: true }, { label: 'Yes (no cough) (1)', points: 1 },
    ]},
    { id: 'age', label: 'Age (McIsaac modification)', options: [
      { label: '3–14 (+1)', points: 1 },
      { label: '15–44 (0)', points: 0, default: true },
      { label: '≥ 45 (−1)', points: -1 },
    ]},
  ],
  bands: [
    { min: -1, max: 0, label: 'Strep probability < 5% — no testing or antibiotics', cls: 'cls-normal' },
    { min: 1, max: 1, label: 'Probability 5–10%', cls: 'cls-normal' },
    { min: 2, max: 2, label: 'Probability ~ 15% — consider rapid antigen or culture', cls: 'cls-warn' },
    { min: 3, max: 3, label: 'Probability ~ 32% — test ± empiric treatment', cls: 'cls-warn' },
    { min: 4, max: 5, label: 'Probability ~ 50–80% — empiric treatment may be appropriate', cls: 'cls-danger' },
  ],
  max: 5,
}

const faq = [
  { q: 'What is the modified (McIsaac) Centor score?', a: 'A 5-criterion score for the clinical probability of group A streptococcal pharyngitis, adding age strata to the original 4-item Centor.' },
  { q: 'When should a rapid test be performed?', a: 'Scores 2–3 are the sweet spot for testing. Scores 0–1 do not need testing or antibiotics. Scores 4–5 may justify empiric therapy in some guidelines.' },
  { q: 'Is empiric therapy ever appropriate?', a: 'IDSA recommends confirmatory testing for nearly all adults to avoid unnecessary antibiotic use. ESCMID allows empiric therapy at score 4–5 in some settings.' },
  { q: 'Why is age included?', a: 'GAS pharyngitis incidence varies by age: highest in 3–14 (+1), baseline in 15–44, lowest ≥ 45 (−1).' },
]
const references = [
  { citation: 'McIsaac WJ, White D, Tannenbaum D, Low DE. A clinical score to reduce unnecessary antibiotic use in patients with sore throat. <em>CMAJ</em>. 1998;158(1):75-83.' },
  { citation: 'Centor RM, Witherspoon JM, Dalton HP, Brody CE, Link K. The diagnosis of strep throat in adults in the emergency room. <em>Med Decis Making</em>. 1981;1(3):239-246.' },
]
const relatedTools = [
  { slug: 'curb-65', name: 'CURB-65' },
  { slug: 'qsofa', name: 'qSOFA' },
  { slug: 'news-2', name: 'NEWS-2' },
]
---
<ScoreCalc
  slug="centor-modified"
  name="Modified Centor Score Calculator"
  schemaName="Modified Centor (McIsaac) Score"
  shortDescription="Modified Centor (McIsaac) score for streptococcal pharyngitis probability."
  metaTitle="Modified Centor (McIsaac) Score Calculator | maratool"
  metaDescription="Free modified Centor (McIsaac) score calculator for strep pharyngitis probability with testing and treatment guidance."
  subcategory="Score"
  subcategorySlug="score"
  howTo={[
    'Score each clinical feature and select the age category.',
    'The Centor score (−1 to 5) and strep probability update instantly.',
    'Use score 2–3 as the testing zone; avoid empiric antibiotics in 0–1.',
  ]}
  faq={faq}
  relatedTools={relatedTools}
  references={references}
  whatIs="The modified Centor (McIsaac) score is a clinical prediction rule that estimates the probability of group A streptococcal pharyngitis in patients presenting with a sore throat, guiding rational use of rapid antigen testing and antibiotics. The original Centor criteria were published in 1981 and modified by McIsaac et al. in 1998 to add age adjustment. One point each is awarded for tonsillar exudates, tender anterior cervical lymphadenopathy, fever >38°C, and absence of cough; ages 3–14 add one, 15–44 zero, and ≥45 subtract one. Scores of 0–1 do not require testing; 2–3 warrant rapid testing; 4–5 suggest empiric or test-then-treat antibiotics."
  spec={spec}
/>
