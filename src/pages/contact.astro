---
import Base from '../layouts/Base.astro'
import Layout from '../components/Layout.astro'

const seo = {
  title: 'Contact — maratool',
  description: 'Get in touch with the maratool team. We\'d love to hear from you — feedback, bugs, ideas, or just to say hi.',
  canonical: 'https://maratool.com/contact',
  schema: {
    '@context': 'https://schema.org',
    '@type': 'ContactPage',
    name: 'Contact maratool',
    url: 'https://maratool.com/contact',
  },
}
---
<Base {...seo}>
  <Layout>
    <div class="contact-page">
      <h1 class="contact-title">Contact</h1>
      <p class="contact-body">Have feedback, found a bug, or want to suggest a tool? Reach out — I read every email.</p>
      <a href="mailto:maratool@marcell.com.br" class="contact-email">maratool@marcell.com.br</a>
      <p class="contact-sig">— <a href="http://marcell.com.br/" target="_blank" rel="noopener">Marcell Almeida</a>, maratool</p>
    </div>
  </Layout>
</Base>
<style is:global>
  .contact-page {
    max-width: 480px;
    padding: 2.5rem 2rem;
  }
  .contact-title {
    font-size: 1.75rem;
    font-weight: 700;
    color: var(--text);
    margin: 0 0 1rem;
  }
  .contact-body {
    font-size: 15px;
    color: var(--text-2);
    line-height: 1.6;
    margin: 0 0 1.25rem;
  }
  .contact-email {
    display: inline-block;
    font-size: 16px;
    font-weight: 600;
    color: var(--accent);
    text-decoration: none;
    padding: 10px 18px;
    border: 1px solid var(--accent);
    border-radius: var(--radius);
    margin-bottom: 1.5rem;
    transition: background 0.1s, color 0.1s;
  }
  .contact-email:hover {
    background: var(--accent);
    color: #fff;
  }
  .contact-sig {
    font-size: 13px;
    color: var(--text-3);
    margin: 0;
  }
  .contact-sig a {
    color: var(--text-2);
    text-decoration: none;
  }
  .contact-sig a:hover { color: var(--accent); }
</style>
