---
import Base from '../layouts/Base.astro'
import Layout from '../components/Layout.astro'
import ToolShell from '../components/ToolShell.astro'

const seo = {
  title: 'CSV to JSON Converter — Convert CSV and JSON online | maratool',
  description: 'Convert CSV to JSON or JSON to CSV instantly. Auto-detects delimiters. Handles quoted fields, commas in values, and multi-line cells. Free, runs in your browser.',
  canonical: 'https://maratool.com/csv-to-json',
  schema: {
    '@context': 'https://schema.org',
    '@type': 'WebApplication',
    name: 'CSV to JSON Converter',
    url: 'https://maratool.com/csv-to-json',
    applicationCategory: 'DeveloperApplication',
    operatingSystem: 'Any',
    offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
    description: 'Convert between CSV and JSON formats instantly in the browser.',
  },
  breadcrumbSchema: {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://maratool.com' },
      { '@type': 'ListItem', position: 2, name: 'Converter', item: 'https://maratool.com/converter' },
      { '@type': 'ListItem', position: 3, name: 'Format', item: 'https://maratool.com/converter/format' },
      { '@type': 'ListItem', position: 4, name: 'CSV to JSON', item: 'https://maratool.com/csv-to-json' },
    ],
  },
  faqSchema: {
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: [
      {
        '@type': 'Question',
        name: 'How do I convert CSV to JSON?',
        acceptedAnswer: { '@type': 'Answer', text: 'Paste your CSV into the input box. The first row is treated as headers, and each subsequent row becomes a JSON object. The JSON array output appears instantly.' }
      },
      {
        '@type': 'Question',
        name: 'What delimiters are supported?',
        acceptedAnswer: { '@type': 'Answer', text: 'The tool auto-detects commas, semicolons, and tabs. You can also manually select a delimiter from the dropdown.' }
      },
      {
        '@type': 'Question',
        name: 'Does it handle quoted fields?',
        acceptedAnswer: { '@type': 'Answer', text: 'Yes. Fields wrapped in double quotes can contain commas, newlines, and escaped quotes (""). The parser follows RFC 4180 conventions.' }
      },
      {
        '@type': 'Question',
        name: 'Can I convert JSON back to CSV?',
        acceptedAnswer: { '@type': 'Answer', text: 'Yes. Switch to the "JSON to CSV" tab, paste a JSON array of objects, and the CSV output is generated instantly with proper escaping.' }
      }
    ]
  }
}

const howTo = [
  'Paste CSV into the input box — the delimiter is auto-detected.',
  'The JSON output appears instantly in the right panel.',
  'Switch to the "JSON → CSV" tab to convert in the other direction.',
]

const faq = [
  { q: 'How do I convert CSV to JSON?', a: 'Paste your CSV into the input box. The first row is treated as headers, and each subsequent row becomes a JSON object. The JSON array output appears instantly.' },
  { q: 'What delimiters are supported?', a: 'The tool auto-detects commas, semicolons, and tabs. You can also manually select a delimiter from the dropdown.' },
  { q: 'Does it handle quoted fields?', a: 'Yes. Fields wrapped in double quotes can contain commas, newlines, and escaped quotes (""). The parser follows RFC 4180 conventions.' },
  { q: 'Can I convert JSON back to CSV?', a: 'Yes. Switch to the "JSON → CSV" tab, paste a JSON array of objects, and the CSV output is generated instantly with proper escaping.' },
]

const relatedTools = [
  { slug: 'json-formatter', name: 'JSON Formatter' },
  { slug: 'json-to-markdown-table', name: 'JSON to Markdown Table' },
]

const breadcrumbs = [
  { label: 'Home', href: '/' },
  { label: 'Converter', href: '/converter' },
  { label: 'Format', href: '/converter/format' },
  { label: 'CSV to JSON' },
]
---
<Base {...seo}>
  <Layout>
    <ToolShell slug="csv-to-json" name="Convert CSV to JSON" description="Convert CSV to JSON or JSON to CSV instantly. Auto-detects delimiters and handles quoted fields." howTo={howTo} faq={faq} relatedTools={relatedTools} breadcrumbs={breadcrumbs}>
      <div class="tool-container">
        <div class="tool-tabs">
          <button class="tool-tab active" data-panel="tab-csv2json">CSV → JSON</button>
          <button class="tool-tab" data-panel="tab-json2csv">JSON → CSV</button>
        </div>

        <div id="tab-csv2json" class="tab-panel">
          <div class="c2j-delim-row">
            <label class="tool-label" for="c2j-delim">Delimiter</label>
            <select id="c2j-delim" class="tool-select">
              <option value="auto">Auto-detect</option>
              <option value=",">Comma (,)</option>
              <option value=";">Semicolon (;)</option>
              <option value="tab">Tab</option>
            </select>
          </div>
          <div class="tool-row">
            <div class="tool-panel">
              <label class="tool-label" for="c2j-csv">CSV input</label>
              <textarea id="c2j-csv" class="tool-textarea" rows="12" placeholder="name,age,city&#10;Alice,30,NYC&#10;Bob,25,LA" aria-label="CSV input"></textarea>
            </div>
            <div class="tool-panel">
              <label class="tool-label" for="c2j-json">JSON output</label>
              <textarea id="c2j-json" class="tool-textarea tool-output" rows="12" readonly aria-label="JSON output"></textarea>
            </div>
          </div>
          <button id="c2j-copy-json" class="copy-btn">Copy JSON</button>
        </div>

        <div id="tab-json2csv" class="tab-panel" style="display:none;">
          <div class="tool-row">
            <div class="tool-panel">
              <label class="tool-label" for="j2c-json">JSON input</label>
              <textarea id="j2c-json" class="tool-textarea" rows="12" placeholder='[{"name":"Alice","age":30},{"name":"Bob","age":25}]' aria-label="JSON input"></textarea>
            </div>
            <div class="tool-panel">
              <label class="tool-label" for="j2c-csv">CSV output</label>
              <textarea id="j2c-csv" class="tool-textarea tool-output" rows="12" readonly aria-label="CSV output"></textarea>
            </div>
          </div>
          <button id="j2c-copy-csv" class="copy-btn">Copy CSV</button>
        </div>
      </div>
    </ToolShell>
  </Layout>
</Base>

<style is:global>
  .c2j-delim-row {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 0.75rem;
  }
  .c2j-delim-row .tool-label {
    margin-bottom: 0;
  }
</style>

<script src="../tools/csv-to-json.js"></script>
