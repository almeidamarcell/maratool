const faq = [
  { q: 'What is the Padua Prediction Score?', a: 'A risk assessment model for venous thromboembolism in hospitalized medical patients. Score ≥ 4 identifies high-risk patients who benefit from pharmacologic prophylaxis.' },
  { q: 'Padua vs Caprini?', a: 'Padua is for medical inpatients; Caprini is for surgical patients. Both are recommended in respective populations by ACCP guidelines.' },
  { q: 'What prophylaxis is indicated at Padua ≥ 4?', a: 'LMWH (e.g., enoxaparin 40 mg SC daily), UFH 5 000 U SC q8–12h, or fondaparinux — duration typically until discharge.' },
  { q: 'When is Padua not applicable?', a: 'Patients with active bleeding, recent intracranial hemorrhage, or other absolute contraindications to anticoagulation — use mechanical prophylaxis instead.' },
]
const references = [
  { citation: 'Barbar S, Noventa F, Rossetto V, et al. A risk assessment model for the identification of hospitalized medical patients at risk for venous thromboembolism: the Padua Prediction Score. <em>J Thromb Haemost</em>. 2010;8(11):2450-2457.' },
]
