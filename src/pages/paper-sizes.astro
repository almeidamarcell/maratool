---
import Base from '../layouts/Base.astro'
import Layout from '../components/Layout.astro'
import ToolShell from '../components/ToolShell.astro'

const seo = {
  title: 'Paper Sizes Reference — A4, Letter, Legal & More | maratool',
  description: 'Complete reference for paper sizes — ISO A, B, C series, US Letter, Legal, Tabloid, and Japanese JIS. Search by name or dimensions.',
  canonical: 'https://maratool.com/paper-sizes',
  schema: {
    '@context': 'https://schema.org',
    '@type': 'WebApplication',
    name: 'Paper Sizes Reference',
    url: 'https://maratool.com/paper-sizes',
    applicationCategory: 'DeveloperApplication',
    operatingSystem: 'Any',
    offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
    description: 'Complete reference for paper sizes with search and filter.',
  },
  breadcrumbSchema: {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://maratool.com' },
      { '@type': 'ListItem', position: 2, name: 'Developer', item: 'https://maratool.com/developer' },
      { '@type': 'ListItem', position: 3, name: 'Reference', item: 'https://maratool.com/developer/reference' },
      { '@type': 'ListItem', position: 4, name: 'Paper Sizes Reference', item: 'https://maratool.com/paper-sizes' },
    ],
  },
  faqSchema: {
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: [
      {
        '@type': 'Question',
        name: 'What is A4 paper size in inches?',
        acceptedAnswer: { '@type': 'Answer', text: 'A4 paper is 210 x 297 mm, which equals 8.27 x 11.69 inches. It is the most commonly used paper size internationally and is slightly narrower and taller than US Letter.' }
      },
      {
        '@type': 'Question',
        name: 'What is the difference between A4 and US Letter?',
        acceptedAnswer: { '@type': 'Answer', text: 'A4 is 210 x 297 mm (8.27 x 11.69 in) while US Letter is 215.9 x 279.4 mm (8.5 x 11 in). Letter is slightly wider and shorter than A4. A4 is used internationally; Letter is standard in the US and Canada.' }
      },
      {
        '@type': 'Question',
        name: 'How does ISO paper sizing work?',
        acceptedAnswer: { '@type': 'Answer', text: 'ISO paper sizes follow a 1:sqrt(2) aspect ratio. Each size is half the area of the next larger size — A1 is half of A0, A2 is half of A1, and so on. This makes scaling between sizes seamless.' }
      },
      {
        '@type': 'Question',
        name: 'What paper size is best for printing?',
        acceptedAnswer: { '@type': 'Answer', text: 'For documents, A4 (international) or Letter (US) are standard. For posters, A3 or Tabloid work well. For envelopes, use the matching C-series size (e.g., C4 fits an unfolded A4 sheet).' }
      }
    ]
  }
}

const howTo = [
  'Browse paper sizes by series or use the search box to filter by name or dimensions.',
  'Click any series tab (ISO A, ISO B, US, etc.) to jump to that section.',
  'Click any row to copy its dimensions to your clipboard.'
]

const faq = [
  { q: 'What is A4 paper size in inches?', a: 'A4 is 210 &times; 297 mm, which equals 8.27 &times; 11.69 inches.' },
  { q: 'What is the difference between A4 and US Letter?', a: 'A4 is 210 &times; 297 mm while US Letter is 215.9 &times; 279.4 mm (8.5 &times; 11 in). Letter is wider and shorter.' },
  { q: 'How does ISO paper sizing work?', a: 'ISO sizes use a 1:&radic;2 aspect ratio. Each size is half the area of the next larger one, making scaling seamless.' },
  { q: 'What paper size is best for printing?', a: 'For documents, A4 (international) or Letter (US). For posters, A3 or Tabloid. For envelopes, use the matching C-series.' }
]

const relatedTools = [
  { slug: 'px-to-rem', name: 'PX to REM Converter' },
  { slug: 'unit-converter', name: 'Unit Converter' },
]

const breadcrumbs = [
  { label: 'Home', href: '/' },
  { label: 'Developer', href: '/developer' },
  { label: 'Reference', href: '/developer/reference' },
  { label: 'Paper Sizes Reference' },
]
---
<Base {...seo}>
  <Layout>
    <ToolShell slug="paper-sizes" name="Paper Sizes Reference" description="Complete reference for paper sizes — ISO A, B, C series, US, ANSI, Architectural, and Japanese JIS." howTo={howTo} faq={faq} relatedTools={relatedTools} breadcrumbs={breadcrumbs}>
      <div class="tool-container" style="min-height:300px;">
        <div class="ps-controls">
          <input type="text" id="ps-search" class="tool-input ps-search" placeholder="Search by name or dimensions (e.g. A4, 210x297)" />
          <div class="ps-tabs" id="ps-tabs"></div>
        </div>
        <div id="ps-content" class="ps-content"></div>
      </div>
    </ToolShell>
  </Layout>
</Base>
<style is:global>
  .ps-controls {
    margin-bottom: 1rem;
  }
  .ps-search {
    width: 100%;
    font-size: 16px;
    margin-bottom: 0.75rem;
  }
  .ps-tabs {
    display: flex;
    flex-wrap: wrap;
    gap: 0.375rem;
    margin-bottom: 0.5rem;
  }
  .ps-tab {
    padding: 6px 12px;
    font-size: 13px;
    font-weight: 500;
    border: 1px solid var(--border);
    border-radius: var(--radius);
    background: var(--bg);
    color: var(--text-2);
    cursor: pointer;
    transition: background 0.1s, color 0.1s;
  }
  .ps-tab:hover { background: var(--bg-soft); }
  .ps-tab.active {
    background: var(--accent);
    color: #fff;
    border-color: var(--accent);
  }

  .ps-section { margin-bottom: 1.5rem; }
  .ps-section-title {
    font-size: 15px;
    font-weight: 600;
    color: var(--text);
    margin-bottom: 0.5rem;
  }

  .ps-table {
    width: 100%;
    border-collapse: collapse;
  }
  .ps-table th {
    text-align: left;
    font-size: 11px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--text-3);
    padding: 6px 12px;
    border-bottom: 1px solid var(--border);
    position: sticky;
    top: 0;
    background: var(--bg);
  }
  .ps-table td {
    padding: 8px 12px;
    font-size: 13px;
    color: var(--text);
    border-bottom: 1px solid var(--border);
    cursor: pointer;
    transition: background 0.1s;
  }
  .ps-table td.ps-name {
    font-weight: 600;
  }
  .ps-table td.ps-dim {
    font-family: var(--font-mono);
  }
  .ps-table tr:hover td { background: var(--bg-soft); }
  .ps-table td.copied { color: var(--accent); }

  .ps-empty {
    text-align: center;
    color: var(--text-3);
    padding: 2rem 1rem;
    font-size: 14px;
  }

  @media (max-width: 640px) {
    .ps-table td, .ps-table th { padding: 6px 8px; font-size: 12px; }
  }
</style>
<script src="../tools/paper-sizes.js"></script>
