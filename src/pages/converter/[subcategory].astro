---
import Base from '../../layouts/Base.astro'
import Layout from '../../components/Layout.astro'
import HubPage from '../../components/HubPage.astro'
import { toolsByCategory, toolsFlatByCategory, subcategoryOrderByCategory } from '../../data/tools'

export function getStaticPaths() {
  const subs = subcategoryOrderByCategory.Converter ?? []
  const catTools = toolsByCategory.Converter ?? {}

  const descriptions: Record<string, { title: string; description: string; intro: string }> = {
    format: {
      title: 'Format Converter Tools — maratool',
      description: 'Free browser-based format converters. Convert CSV to JSON, HTML to Markdown, Base64 encode/decode, and text to binary — no sign-up, runs in your browser.',
      intro: 'Convert between data formats instantly — CSV, JSON, HTML, Markdown, Base64, and binary.',
    },
    unit: {
      title: 'Unit Converter Tools — maratool',
      description: 'Free browser-based unit converters. Convert Unix timestamps to dates, pixels to rem — no sign-up, runs entirely in your browser.',
      intro: 'Convert between units and representations quickly in your browser.',
    },
  }

  return subs.map(sub => {
    const slug = sub.toLowerCase()
    const meta = descriptions[slug] ?? {
      title: `${sub} Tools — maratool`,
      description: `Free browser-based ${sub.toLowerCase()} tools — no sign-up, runs entirely in your browser.`,
      intro: `${sub} tools that run locally in your browser.`,
    }
    return {
      params: { subcategory: slug },
      props: { sub, subTools: catTools[sub] ?? [], ...meta },
    }
  })
}

const { subcategory } = Astro.params
const { sub, subTools, title, description, intro } = Astro.props
const allTools = toolsFlatByCategory.Converter ?? []
const subcategories = subcategoryOrderByCategory.Converter ?? []

const seo = {
  title,
  description,
  canonical: `https://maratool.com/converter/${subcategory}`,
  schema: {
    '@context': 'https://schema.org',
    '@type': 'CollectionPage',
    name: `${sub} Converter Tools`,
    url: `https://maratool.com/converter/${subcategory}`,
    description,
    hasPart: subTools.filter((tool: { live: boolean }) => tool.live).map((tool: { name: string; slug: string }) => ({
      '@type': 'SoftwareApplication',
      name: tool.name,
      url: `https://maratool.com/${tool.slug}`,
      applicationCategory: 'DeveloperApplication',
    })),
  },
  breadcrumbSchema: {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://maratool.com' },
      { '@type': 'ListItem', position: 2, name: 'Converter', item: 'https://maratool.com/converter' },
      { '@type': 'ListItem', position: 3, name: sub, item: `https://maratool.com/converter/${subcategory}` },
    ],
  },
}
---
<Base {...seo}>
  <Layout scope="subcategory">
    <HubPage
      category="Converter"
      categorySlug="converter"
      title={`${sub} converter tools`}
      subtitle={intro}
      tools={allTools}
      subcategories={subcategories}
      activeSubcategory={sub}
      basePath="/converter"
    />
  </Layout>
</Base>
