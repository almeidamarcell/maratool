---
import Base from '../layouts/Base.astro'
import Layout from '../components/Layout.astro'
import ToolShell from '../components/ToolShell.astro'

const seo = {
  title: 'Password Strength Checker — How Strong Is My Password? | maratool',
  description: 'Check password strength with entropy scoring and crack-time estimates. See what makes a password weak or strong. Free, runs locally.',
  canonical: 'https://maratool.com/password-strength-checker',
  schema: {
    '@context': 'https://schema.org',
    '@type': 'WebApplication',
    name: 'Password Strength Checker',
    url: 'https://maratool.com/password-strength-checker',
    applicationCategory: 'DeveloperApplication',
    operatingSystem: 'Any',
    offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
    description: 'Check password strength with entropy scoring and crack-time estimates. See what makes a password weak or strong. Free, runs locally.',
  },
  breadcrumbSchema: {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://maratool.com' },
      { '@type': 'ListItem', position: 2, name: 'Developer', item: 'https://maratool.com/developer' },
      { '@type': 'ListItem', position: 3, name: 'Security', item: 'https://maratool.com/developer/security' },
      { '@type': 'ListItem', position: 4, name: 'Password Strength Checker', item: 'https://maratool.com/password-strength-checker' },
    ],
  },
  faqSchema: {
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: [
      { '@type': 'Question', name: 'Is my password sent to a server?', acceptedAnswer: { '@type': 'Answer', text: 'No. Strength checking runs entirely in your browser. Your password never leaves your device.' } },
      { '@type': 'Question', name: 'What makes a password strong?', acceptedAnswer: { '@type': 'Answer', text: 'Length (12+ chars), mixed case, numbers, special characters, and avoiding common passwords.' } },
      { '@type': 'Question', name: 'How is crack time estimated?', acceptedAnswer: { '@type': 'Answer', text: 'Based on password entropy — character set size and length — not actual breach data.' } },
      { '@type': 'Question', name: 'Should I use this instead of a password manager?', acceptedAnswer: { '@type': 'Answer', text: 'Use a password manager to generate and store passwords. Use this tool to evaluate passwords you create manually.' } }
    ]
  }
}

const howTo = [
  'Type or paste a password in the input field.',
  'See strength score and estimated crack time update instantly.',
  'Follow the tips to improve weak passwords.'
]

const faq = [
  { q: 'Is my password sent to a server?', a: 'No. Strength checking runs entirely in your browser. Your password never leaves your device.' },
  { q: 'What makes a password strong?', a: 'Length (12+ chars), mixed case, numbers, special characters, and avoiding common passwords.' },
  { q: 'How is crack time estimated?', a: 'Based on password entropy — character set size and length — not actual breach data.' },
  { q: 'Should I use this instead of a password manager?', a: 'Use a password manager to generate and store passwords. Use this tool to evaluate passwords you create manually.' }
]

const relatedTools = [
  { slug: 'password-generator', name: 'Password Generator' },
  { slug: 'bcrypt-generator', name: 'Bcrypt Generator' },
  { slug: 'hash-generator', name: 'Hash Generator' }
]

const breadcrumbs = [
  { label: 'Home', href: '/' },
  { label: 'Developer', href: '/developer' },
  { label: 'Security', href: '/developer/security' },
  { label: 'Password Strength Checker' }
]
---
<Base {...seo}>
  <Layout>
    <ToolShell slug="password-strength-checker" name="Password Strength Checker" description="Type a password to see strength score, estimated crack time, and improvement tips." howTo={howTo} faq={faq} relatedTools={relatedTools} breadcrumbs={breadcrumbs}>
      <div class="tool-container" style="min-height:280px;">
        <div class="calc-field"><label class="tool-label" for="pw-input">Password</label><input type="text" id="pw-input" class="tool-input" placeholder="Enter password to check" autocomplete="off" /></div>
        <div style="height:6px;background:var(--bg-soft);border-radius:3px;margin:1rem 0;overflow:hidden;"><div id="pw-bar" style="height:100%;width:0;transition:width 0.2s,background 0.2s;border-radius:3px;"></div></div>
        <p id="pw-label" style="font-weight:600;margin:0 0 0.25rem;">—</p>
        <p id="pw-crack" style="font-size:13px;color:var(--text-2);margin:0 0 1rem;">—</p>
        <ul id="pw-tips" style="font-size:13px;color:var(--text-2);padding-left:1.25rem;margin:0;"></ul>
      </div>
    </ToolShell>
  </Layout>
</Base>

<script src="../tools/password-strength-checker.js"></script>
