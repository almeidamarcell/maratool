---
import Base from '../layouts/Base.astro'
import Layout from '../components/Layout.astro'
import ToolShell from '../components/ToolShell.astro'

const seo = {
  title: 'Halftone Effect for Images & GIFs Online | maratool',
  description: 'Apply halftone dot, line, or diamond patterns to images and GIFs. Black & white or colored halftone — preview and download.',
  canonical: 'https://maratool.com/halftone-effect',
  schema: {
    '@context': 'https://schema.org',
    '@type': 'WebApplication',
    name: 'Halftone Effect',
    url: 'https://maratool.com/halftone-effect',
    applicationCategory: 'MultimediaApplication',
    operatingSystem: 'Any',
    offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
    description: 'Apply halftone dot, line, or diamond patterns to images and GIFs. Black & white or colored halftone — preview and download.',
  },
  breadcrumbSchema: {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://maratool.com' },
      { '@type': 'ListItem', position: 2, name: 'Image', item: 'https://maratool.com/image' },
      { '@type': 'ListItem', position: 3, name: 'Transform', item: 'https://maratool.com/image/transform' },
      { '@type': 'ListItem', position: 4, name: 'Halftone Effect', item: 'https://maratool.com/halftone-effect' },
    ],
  },
  faqSchema: {
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: [
      {
        '@type': 'Question',
        name: 'Pattern types?',
        acceptedAnswer: { '@type': 'Answer', text: 'Dots, lines, and diamonds — classic halftone styles.' }
      },
      {
        '@type': 'Question',
        name: 'Colored halftone?',
        acceptedAnswer: { '@type': 'Answer', text: 'Yes — preserve original hues in the dot pattern, or use black & white.' }
      },
      {
        '@type': 'Question',
        name: 'GIF support?',
        acceptedAnswer: { '@type': 'Answer', text: 'Yes. The effect renders on every frame.' }
      },
      {
        '@type': 'Question',
        name: 'Browser-based?',
        acceptedAnswer: { '@type': 'Answer', text: 'Yes.' }
      }
    ]
  }
}

const howTo = [
  'Upload an image or GIF.',
  'Pick pattern type, dot size, and color mode.',
  'Preview and download.'
]
const faq = [
  {
    'q': 'Pattern types?',
    'a': 'Dots, lines, and diamonds — classic halftone styles.'
  },
  {
    'q': 'Colored halftone?',
    'a': 'Yes — preserve original hues in the dot pattern, or use black & white.'
  },
  {
    'q': 'GIF support?',
    'a': 'Yes. The effect renders on every frame.'
  },
  {
    'q': 'Browser-based?',
    'a': 'Yes.'
  }
]
const relatedTools = [
  { slug: 'invert-colors', name: 'Invert Colors' },
  { slug: 'round-corners', name: 'Round Corners' },
  { slug: 'censor-image', name: 'Censor Image' },
]
const breadcrumbs = [
  { label: 'Home', href: '/' },
  { label: 'Image', href: '/image' },
  { label: 'Transform', href: '/image/transform' },
  { label: 'Halftone Effect' },
]
---
<Base {...seo}>
  <Layout>
    <ToolShell slug="halftone-effect" name="Halftone Effect for Images & GIFs" description="Apply halftone dot, line, or diamond patterns to images and GIFs. Black & white or colored halftone — preview and download." howTo={howTo} faq={faq} relatedTools={relatedTools} breadcrumbs={breadcrumbs}>
      <div class="tool-container hlf-root" style="min-height:420px;">
        <div class="hlf-dropzone" id="hlf-dropzone">
          <input type="file" id="hlf-file" hidden />
          <p class="hlf-drop-title">Drop a file here</p>
          <p class="hlf-drop-sub">or click to select</p>
        </div>
        <div id="hlf-workspace" style="display:none;"></div>
        <div id="hlf-progress" class="hlf-progress" style="display:none;">
          <div id="hlf-progress-text">Processing...</div>
          <div class="hlf-progress-track"><div id="hlf-progress-fill" class="hlf-progress-fill"></div></div>
        </div>
        <div id="hlf-error" class="hlf-error" style="display:none;"><span id="hlf-error-text"></span></div>
        <div id="hlf-result" style="display:none;"></div>
      </div>
    </ToolShell>
  </Layout>
</Base>
<style is:global>
  .hlf-dropzone {
    border: 2px dashed var(--border); border-radius: var(--radius);
    padding: 3rem 2rem; text-align: center; cursor: pointer;
    transition: border-color 0.2s, background 0.2s;
  }
  .hlf-dropzone:hover, .hlf-dropzone.drag-over { border-color: var(--accent); background: var(--bg-soft); }
  .hlf-drop-title { font-size: 1.125rem; font-weight: 600; margin: 0; }
  .hlf-drop-sub { font-size: 0.875rem; color: var(--text-2); margin: 0.5rem 0 0; }
  .hlf-progress { text-align: center; padding: 2rem; }
  .hlf-progress-track { width: 100%; max-width: 400px; height: 8px; background: var(--bg-hover); border-radius: 4px; margin: 1rem auto; overflow: hidden; }
  .hlf-progress-fill { height: 100%; background: var(--accent); width: 0%; transition: width 0.3s; }
  .hlf-error { background: var(--error-bg); border: 1px solid var(--error-border); border-radius: var(--radius); padding: 1rem; color: #c53030; font-size: 0.875rem; }
  .hlf-preview-wrap {
    background: repeating-conic-gradient(#e0e0e0 0% 25%, #fff 0% 50%) 0 0 / 16px 16px;
    border: 1px solid var(--border); border-radius: var(--radius); padding: 0.5rem;
    display: flex; align-items: center; justify-content: center; margin-bottom: 1rem;
  }
  .hlf-preview-wrap canvas, .hlf-preview-wrap img { max-width: 100%; max-height: 360px; display: block; }
  .hlf-controls { display: flex; flex-direction: column; gap: 0.75rem; margin-bottom: 1rem; }
  .hlf-row { display: flex; flex-wrap: wrap; gap: 0.75rem; align-items: center; }
  .hlf-actions { display: flex; gap: 0.75rem; flex-wrap: wrap; margin-top: 0.5rem; }
</style>
<script src="../tools/halftone-effect.js"></script>
