---
import Base from '../layouts/Base.astro'
import Layout from '../components/Layout.astro'
import ToolShell from '../components/ToolShell.astro'

const seo = {
  title: 'CSS Minifier — Minify CSS Online | maratool',
  description: 'Minify CSS by removing comments and extra whitespace. Paste stylesheets and copy compact output. Paste-only, free, runs in your browser.',
  canonical: 'https://maratool.com/css-minifier',
  schema: {
    '@context': 'https://schema.org',
    '@type': 'WebApplication',
    name: 'CSS Minifier — Minify CSS Online',
    url: 'https://maratool.com/css-minifier',
    applicationCategory: 'DeveloperApplication',
    operatingSystem: 'Any',
    offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
    description: 'Minify CSS by removing comments and extra whitespace. Paste stylesheets and copy compact output. Paste-only, free, runs in your browser.',
  },
  breadcrumbSchema: {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://maratool.com' },
      { '@type': 'ListItem', position: 2, name: 'Developer', item: 'https://maratool.com/developer' },
      { '@type': 'ListItem', position: 3, name: 'Web', item: 'https://maratool.com/developer/web' },
      { '@type': 'ListItem', position: 4, name: 'CSS Minifier — Minify CSS Online', item: 'https://maratool.com/css-minifier' },
    ],
  },
  faqSchema: {
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: [
      { '@type': 'Question', name: 'What does CSS minification remove?', acceptedAnswer: { '@type': 'Answer', text: 'Comments and unnecessary whitespace outside of strings.' } },
      { '@type': 'Question', name: 'Can it minify linked stylesheets?', acceptedAnswer: { '@type': 'Answer', text: 'No. Copy CSS from your file or DevTools and paste it here.' } },
      { '@type': 'Question', name: 'Will minification change selectors?', acceptedAnswer: { '@type': 'Answer', text: 'No. Only whitespace and comments are removed — rules stay the same.' } },
      { '@type': 'Question', name: 'Is my CSS sent to a server?', acceptedAnswer: { '@type': 'Answer', text: 'No. Minification happens entirely in your browser.' } }
    ]
  }
}

const howTo = [
  'Paste your CSS in the input box.',
  'Minified output updates automatically.',
  'Click Copy to copy the compact CSS.'
]

const faq = [
  { q: 'What does CSS minification remove?', a: 'Comments and unnecessary whitespace outside of strings.' },
  { q: 'Can it minify linked stylesheets?', a: 'No. Copy CSS from your file or DevTools and paste it here.' },
  { q: 'Will minification change selectors?', a: 'No. Only whitespace and comments are removed — rules stay the same.' },
  { q: 'Is my CSS sent to a server?', a: 'No. Minification happens entirely in your browser.' }
]

const relatedTools = [
  { slug: 'html-minifier', name: 'HTML Minifier' },
  { slug: 'html-beautifier', name: 'HTML Beautifier' },
  { slug: 'px-to-rem', name: 'PX to REM Converter' }
]

const breadcrumbs = [
  { label: 'Home', href: '/' },
  { label: 'Developer', href: '/developer' },
  { label: 'Web', href: '/developer/web' },
  { label: 'CSS Minifier' }
]
---
<Base {...seo}>
  <Layout>
    <ToolShell slug="css-minifier" name="CSS Minifier — Minify CSS Online" description="Paste CSS to remove comments and collapse whitespace. Does not fetch external stylesheets — paste-only." howTo={howTo} faq={faq} relatedTools={relatedTools} breadcrumbs={breadcrumbs}>
      <div class="tool-container" style="min-height:480px;">
        <label class="tool-label" for="cssm-input">CSS input</label>
        <textarea id="cssm-input" class="tool-textarea" rows="8" placeholder=".card {&#10;  padding: 1rem;&#10;  /* comment */&#10;  color: #333;&#10;}"></textarea>
        <div style="display:flex;justify-content:space-between;align-items:center;margin:1rem 0 0.5rem;">
          <label class="tool-label" style="margin:0;">Minified output</label>
          <button type="button" id="cssm-copy" class="copy-btn">Copy</button>
        </div>
        <pre id="cssm-output" class="tool-output" style="min-height:120px;white-space:pre-wrap;"></pre>
      </div>
    </ToolShell>
  </Layout>
</Base>

<script src="../tools/css-minifier.js"></script>
