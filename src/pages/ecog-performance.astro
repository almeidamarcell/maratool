---
import ScoreCalc from '../components/ScoreCalc.astro'

const spec = {
  items: [
    {
      id: 'ecog',
      label: 'Performance status',
      options: [
        { label: '0 — Fully active, no restrictions', points: 0, default: true },
        { label: '1 — Restricted in strenuous activity, ambulatory', points: 1 },
        { label: '2 — Ambulatory, capable of self-care, unable to work; up >50% waking hours', points: 2 },
        { label: '3 — Limited self-care, confined to bed/chair >50% waking hours', points: 3 },
        { label: '4 — Completely disabled, no self-care, totally bedbound', points: 4 },
        { label: '5 — Dead', points: 5 },
      ],
    },
  ],
  bands: [
    { min: 0, max: 1, label: 'Good performance status', cls: 'cls-normal' },
    { min: 2, max: 2, label: 'Moderately impaired', cls: 'cls-warn' },
    { min: 3, max: 5, label: 'Severely impaired / end of life', cls: 'cls-danger' },
  ],
  max: 5,
}

const faq = [
  { q: 'What is the ECOG performance status used for?', a: 'It quantifies cancer patient functional status for treatment decisions, clinical trial eligibility, and prognosis estimation.' },
  { q: 'What is the difference between ECOG and Karnofsky scales?', a: 'ECOG uses a 6-point scale (0–5); Karnofsky uses an 11-point scale (0–100). Both measure functional status but the ECOG is simpler and more widely used in oncology trials.' },
  { q: 'Can ECOG be used outside oncology?', a: 'Yes — it is also used in palliative care, hospice eligibility, and clinical trials in non-oncologic populations.' },
  { q: 'Who assesses ECOG?', a: 'The treating clinician or oncologist; assessment is subjective but well-validated.' },
]
const references = [
  { citation: 'Oken MM, Creech RH, Tormey DC, et al. Toxicity and response criteria of the Eastern Cooperative Oncology Group. <em>Am J Clin Oncol</em>. 1982;5(6):649-655.' },
]
const relatedTools = [
  { slug: 'karnofsky-performance', name: 'Karnofsky Performance Scale' },
  { slug: 'palliative-performance-scale', name: 'Palliative Performance Scale (PPS)' },
  { slug: 'pap-palliative-prognostic', name: 'Palliative Prognostic Score (PaP)' },
]
---
<ScoreCalc
  slug="ecog-performance"
  name="ECOG Performance Status Calculator"
  schemaName="ECOG Performance Status"
  shortDescription="Eastern Cooperative Oncology Group (ECOG) performance status scale 0–5."
  metaTitle="ECOG Performance Status Calculator (0–5) | maratool"
  metaDescription="Free ECOG performance status calculator. Assess oncology functional status from 0 (fully active) to 5 (dead) with instant interpretation."
  subcategory="Prognosis"
  subcategorySlug="prognosis"
  howTo={[
    'Select the patient’s functional status (0–5).',
    'The score and interpretation update instantly.',
    'Re-assess at each clinical encounter; document changes over time.',
  ]}
  faq={faq}
  relatedTools={relatedTools}
  references={references}
  spec={spec}
/>
