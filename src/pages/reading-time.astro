---
import Base from '../layouts/Base.astro'
import Layout from '../components/Layout.astro'
import ToolShell from '../components/ToolShell.astro'

const seo = {
  title: 'Reading Time Calculator — Estimate article read time instantly | maratool',
  description: 'Paste any text to see reading time at slow, average, and fast pace. Shows word count, character count, and paragraph and sentence count. Free, no sign-up.',
  canonical: 'https://maratool.com/reading-time',
  schema: {
    '@context': 'https://schema.org',
    '@type': 'WebApplication',
    name: 'Reading Time Calculator',
    url: 'https://maratool.com/reading-time',
    applicationCategory: 'UtilitiesApplication',
    operatingSystem: 'Any',
    offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
    description: 'Estimate how long it takes to read any text at slow, average, and fast reading speeds.',
  },
  breadcrumbSchema: {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://maratool.com' },
      { '@type': 'ListItem', position: 2, name: 'Text', item: 'https://maratool.com/text' },
      { '@type': 'ListItem', position: 3, name: 'Analyze', item: 'https://maratool.com/text/analyze' },
      { '@type': 'ListItem', position: 4, name: 'Reading Time Calculator', item: 'https://maratool.com/reading-time' },
    ],
  },
  faqSchema: {
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: [
      {
        '@type': 'Question',
        name: 'What is the average reading speed?',
        acceptedAnswer: { '@type': 'Answer', text: 'The average adult reads about 238 words per minute. Slow readers average 150 WPM, while fast readers can exceed 350 WPM.' }
      },
      {
        '@type': 'Question',
        name: 'How is reading time calculated?',
        acceptedAnswer: { '@type': 'Answer', text: 'Reading time is calculated by dividing the total word count by the reading speed in words per minute (WPM). This tool uses 150 WPM (slow), 238 WPM (average), and 350 WPM (fast).' }
      },
      {
        '@type': 'Question',
        name: 'Does the reading time calculator work offline?',
        acceptedAnswer: { '@type': 'Answer', text: 'Yes. All calculations happen in your browser. No data is sent to a server.' }
      },
      {
        '@type': 'Question',
        name: 'How is word count calculated?',
        acceptedAnswer: { '@type': 'Answer', text: 'Words are counted by splitting on whitespace. Hyphenated words like "well-known" count as one word. Numbers and punctuation attached to words count as part of that word.' }
      }
    ]
  }
}

const howTo = [
  'Paste or type your text into the input box.',
  'Reading time and text statistics update instantly as you type.',
  'Use the slow / average / fast values to plan your content length.'
]

const faq = [
  { q: 'What is the average reading speed?', a: 'The average adult reads about 238 words per minute. Slow readers average 150 WPM, while fast readers can exceed 350 WPM.' },
  { q: 'How is reading time calculated?', a: 'Reading time is calculated by dividing the total word count by the reading speed in words per minute (WPM). This tool uses 150 WPM (slow), 238 WPM (average), and 350 WPM (fast).' },
  { q: 'Does the reading time calculator work offline?', a: 'Yes. All calculations happen in your browser. No data is sent to a server.' },
  { q: 'How is word count calculated?', a: 'Words are counted by splitting on whitespace. Hyphenated words like "well-known" count as one word. Numbers and punctuation attached to words count as part of that word.' }
]

const relatedTools = [
  { slug: 'text-to-binary', name: 'Text to Binary' },
  { slug: 'diff-checker', name: 'Compare Two Texts Online' },
  { slug: 'lorem-ipsum', name: 'Generate Lorem Ipsum Text' },
]

const breadcrumbs = [
  { label: 'Home', href: '/' },
  { label: 'Text', href: '/text' },
  { label: 'Analyze', href: '/text/analyze' },
  { label: 'Reading Time Calculator' },
]
---
<Base {...seo}>
  <Layout>
    <ToolShell slug="reading-time" name="Reading Time Calculator" description="Paste any text to instantly see how long it takes to read — slow, average, and fast — plus word count, character count, paragraphs, and sentences." howTo={howTo} faq={faq} relatedTools={relatedTools} breadcrumbs={breadcrumbs}>
      <div class="tool-container">
        <div class="tool-stats">
          <div class="tool-stat">
            <span class="tool-stat-value" id="stat-avg">—</span>
            <span class="tool-stat-label">Avg read (238 WPM)</span>
          </div>
          <div class="tool-stat">
            <span class="tool-stat-value" id="stat-slow">—</span>
            <span class="tool-stat-label">Slow read (150 WPM)</span>
          </div>
          <div class="tool-stat">
            <span class="tool-stat-value" id="stat-fast">—</span>
            <span class="tool-stat-label">Fast read (350 WPM)</span>
          </div>
          <div class="tool-stat">
            <span class="tool-stat-value" id="stat-words">0</span>
            <span class="tool-stat-label">Words</span>
          </div>
          <div class="tool-stat">
            <span class="tool-stat-value" id="stat-chars">0</span>
            <span class="tool-stat-label">Characters</span>
          </div>
          <div class="tool-stat">
            <span class="tool-stat-value" id="stat-paras">0</span>
            <span class="tool-stat-label">Paragraphs</span>
          </div>
          <div class="tool-stat">
            <span class="tool-stat-value" id="stat-sents">0</span>
            <span class="tool-stat-label">Sentences</span>
          </div>
        </div>

        <textarea
          id="reading-input"
          class="tool-textarea"
          rows="12"
          placeholder="Paste your article, blog post, or any text here..."
          aria-label="Text to analyze"
        ></textarea>
      </div>
    </ToolShell>
  </Layout>
</Base>
<script src="../tools/reading.js"></script>
