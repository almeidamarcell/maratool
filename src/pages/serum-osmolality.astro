---
import HealthCalc from '../components/HealthCalc.astro'
const faq = [
  { q: 'Formula?', a: 'Calculated osmolality = 2 × Na + Glucose/18 + BUN/2.8 (mOsm/kg).' },
  { q: 'Normal range?', a: 'Normal serum osmolality is 275–295 mOsm/kg.' },
  { q: 'What is the osmolar gap?', a: 'Osmolar gap = measured osmolality − calculated osmolality. A gap > 10 mOsm/kg suggests unmeasured solutes (e.g., ethanol, methanol, ethylene glycol).' },
  { q: 'When to use this calculator?', a: 'Useful in toxic ingestions, hyponatremia workup, and ICU/critical care assessment.' },
]
const references = [
  { citation: 'Worthley LI, Guerin M, Pain RW. For calculating osmolality, the simplest formula is the best. <em>Anaesth Intensive Care</em>. 1987;15(2):199-202.' },
]
const relatedTools = [
  { slug: 'sodium-correction-hyperglycemia', name: 'Sodium Correction (Hyperglycemia)' },
  { slug: 'calcium-correction-albumin', name: 'Calcium Correction (Albumin)' },
  { slug: 'ckd-epi-creatinine', name: 'CKD-EPI 2021' },
]
---
<HealthCalc slug="serum-osmolality" name="Serum Osmolality Calculator" schemaName="Serum Osmolality"
  shortDescription="Calculate serum osmolality from sodium, glucose, and BUN."
  metaTitle="Serum Osmolality Calculator (Calculated Osmolality) | maratool"
  metaDescription="Calculate serum osmolality: 2 × Na + Glucose/18 + BUN/2.8. Free, runs in your browser."
  subcategory="Electrolytes" subcategorySlug="electrolytes"
  howTo={[ 'Enter sodium (mEq/L), glucose (mg/dL), and BUN (mg/dL).', 'Calculated osmolality appears in mOsm/kg.', 'Compare against measured osmolality to get the osmolar gap.' ]}
  faq={faq} relatedTools={relatedTools} references={references}>
  <div class="hcalc-inputs cols-3">
    <label class="hcalc-field"><span class="hcalc-label">Sodium</span><div class="hcalc-input-wrap"><input type="number" id="osm-na" placeholder="140" step="any" min="0"><span class="hcalc-unit">mEq/L</span></div></label>
    <label class="hcalc-field"><span class="hcalc-label">Glucose</span><div class="hcalc-input-wrap"><input type="number" id="osm-glc" placeholder="90" step="any" min="0"><span class="hcalc-unit">mg/dL</span></div></label>
    <label class="hcalc-field"><span class="hcalc-label">BUN</span><div class="hcalc-input-wrap"><input type="number" id="osm-bun" placeholder="14" step="any" min="0"><span class="hcalc-unit">mg/dL</span></div></label>
  </div>
  <div class="hcalc-outputs">
    <div class="hcalc-output"><div class="hcalc-output-label">Calculated Osmolality</div><div class="hcalc-output-value" id="osm-value">—</div><button class="copy-btn" data-target="osm-value">Copy</button></div>
  </div>
</HealthCalc>
<script src="../tools/health/wave5-ui.js"></script>
