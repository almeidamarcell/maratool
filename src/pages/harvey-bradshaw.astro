---
import ScoreCalc from '../components/ScoreCalc.astro'

const stools = Array.from({ length: 11 }, (_, n) => ({
  label: n === 10 ? '≥ 10 (10)' : `${n} (${n})`,
  points: n,
  default: n === 0,
}))

const yn1 = [
  { label: 'No (0)', points: 0, default: true },
  { label: 'Yes (1)', points: 1 },
]

const spec = {
  items: [
    { id: 'wellbeing', label: 'General well-being', options: [
      { label: 'Very well (0)', points: 0, default: true },
      { label: 'Slightly below par (1)', points: 1 },
      { label: 'Poor (2)', points: 2 },
      { label: 'Very poor (3)', points: 3 },
      { label: 'Terrible (4)', points: 4 },
    ]},
    { id: 'pain', label: 'Abdominal pain', options: [
      { label: 'None (0)', points: 0, default: true },
      { label: 'Mild (1)', points: 1 },
      { label: 'Moderate (2)', points: 2 },
      { label: 'Severe (3)', points: 3 },
    ]},
    { id: 'stools', label: 'Number of liquid/soft stools per day', options: stools },
    { id: 'mass', label: 'Abdominal mass', options: [
      { label: 'None (0)', points: 0, default: true },
      { label: 'Dubious (1)', points: 1 },
      { label: 'Definite (2)', points: 2 },
      { label: 'Definite and tender (3)', points: 3 },
    ]},
    { id: 'arthralgia', label: 'Complication: arthralgia', options: yn1 },
    { id: 'uveitis', label: 'Complication: uveitis', options: yn1 },
    { id: 'erythema', label: 'Complication: erythema nodosum', options: yn1 },
    { id: 'aphthous', label: 'Complication: aphthous ulcers', options: yn1 },
    { id: 'pyoderma', label: 'Complication: pyoderma gangrenosum', options: yn1 },
    { id: 'fissure', label: 'Complication: anal fissure', options: yn1 },
    { id: 'fistula', label: 'Complication: new fistula', options: yn1 },
    { id: 'abscess', label: 'Complication: abscess', options: yn1 },
  ],
  bands: [
    { min: 0, max: 4, label: 'Score < 5 — clinical remission', cls: 'cls-normal' },
    { min: 5, max: 7, label: 'Score 5–7 — mild disease', cls: 'cls-warn' },
    { min: 8, max: 16, label: 'Score 8–16 — moderate disease', cls: 'cls-danger' },
    { min: 17, max: 100, label: 'Score > 16 — severe disease', cls: 'cls-danger' },
  ],
  cols: 2,
}

const faq = [
  { q: 'What is the Harvey-Bradshaw Index?', a: 'A simplified clinical activity index for Crohn’s disease using only clinical variables (well-being, pain, stools, abdominal mass, complications) — a practical alternative to the CDAI.' },
  { q: 'What HBI score means remission?', a: 'A score < 5 indicates clinical remission; 5–7 mild, 8–16 moderate, > 16 severe disease activity.' },
  { q: 'HBI vs CDAI?', a: 'The HBI correlates well with the CDAI but needs no diary or labs, so it is faster and more practical for routine clinic use.' },
  { q: 'What counts as a clinical response?', a: 'A decrease of ≥ 3 points from baseline is commonly used to define clinical response in trials.' },
]
const references = [
  { citation: 'Harvey RF, Bradshaw JM. A simple index of Crohn’s-disease activity. <em>Lancet</em>. 1980;1(8167):514.' },
]
const relatedTools = [
  { slug: 'cdai-crohns', name: 'CDAI (Crohn’s)' },
  { slug: 'mayo-uc', name: 'Mayo Score (UC)' },
  { slug: 'uceis-uc', name: 'UCEIS' },
]
---
<ScoreCalc
  slug="harvey-bradshaw"
  name="Harvey-Bradshaw Index Calculator"
  schemaName="Harvey-Bradshaw Index"
  shortDescription="Harvey-Bradshaw Index for Crohn’s disease clinical activity."
  metaTitle="Harvey-Bradshaw Index Calculator (Crohn's) | maratool"
  metaDescription="Free Harvey-Bradshaw Index calculator. Assess Crohn’s disease clinical activity (remission, mild, moderate, severe) without labs or diaries."
  subcategory="Score"
  subcategorySlug="score"
  howTo={[
    'Select well-being, abdominal pain, daily liquid stools, abdominal mass, and any complications.',
    'The total Harvey-Bradshaw Index and disease-activity band update instantly.',
    'A score < 5 indicates clinical remission.',
  ]}
  faq={faq}
  relatedTools={relatedTools}
  references={references}
  spec={spec}
/>
