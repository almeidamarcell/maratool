---
import Base from '../layouts/Base.astro'
import Layout from '../components/Layout.astro'
import ToolShell from '../components/ToolShell.astro'

const seo = {
  title: 'Unit Converter — Length, Weight, Temperature & More | maratool',
  description: 'Convert between units of length, weight, temperature, data, speed, and time instantly. Free, no sign-up required.',
  canonical: 'https://maratool.com/unit-converter',
  schema: {
    '@context': 'https://schema.org',
    '@type': 'WebApplication',
    name: 'Unit Converter',
    url: 'https://maratool.com/unit-converter',
    applicationCategory: 'UtilitiesApplication',
    operatingSystem: 'Any',
    offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
    description: 'Convert between units of length, weight, temperature, data, speed, and time instantly.',
  },
  breadcrumbSchema: {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://maratool.com' },
      { '@type': 'ListItem', position: 2, name: 'Converter', item: 'https://maratool.com/converter' },
      { '@type': 'ListItem', position: 3, name: 'Unit', item: 'https://maratool.com/converter/unit' },
      { '@type': 'ListItem', position: 4, name: 'Unit Converter', item: 'https://maratool.com/unit-converter' },
    ],
  },
  faqSchema: {
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: [
      {
        '@type': 'Question',
        name: 'How do I convert Celsius to Fahrenheit?',
        acceptedAnswer: { '@type': 'Answer', text: 'Select the Temperature tab, choose Celsius as the source unit and Fahrenheit as the target. Enter a value and the result appears instantly. The formula is F = C x 9/5 + 32.' }
      },
      {
        '@type': 'Question',
        name: 'How many meters are in a mile?',
        acceptedAnswer: { '@type': 'Answer', text: 'One mile equals 1,609.344 meters. Select the Length tab and convert between miles and meters to verify any value.' }
      },
      {
        '@type': 'Question',
        name: 'Is a kilobyte 1000 or 1024 bytes?',
        acceptedAnswer: { '@type': 'Answer', text: 'This tool uses binary units: 1 kilobyte = 1,024 bytes. This matches how most operating systems and programming languages measure file sizes.' }
      },
      {
        '@type': 'Question',
        name: 'How do I convert between speed units?',
        acceptedAnswer: { '@type': 'Answer', text: 'Select the Speed tab, then choose your source and target units (km/h, mph, m/s, knot). Enter a value and the conversion appears instantly.' }
      }
    ]
  }
}

const howTo = [
  'Select a category tab — Length, Weight, Temperature, Data, Speed, or Time.',
  'Choose "From" and "To" units, then enter a value.',
  'Click "Copy" to copy the result to your clipboard.'
]

const faq = [
  { q: 'How do I convert Celsius to Fahrenheit?', a: 'Select the Temperature tab, choose Celsius as the source and Fahrenheit as the target. The formula is F = C x 9/5 + 32.' },
  { q: 'How many meters are in a mile?', a: 'One mile equals 1,609.344 meters. Use the Length tab to convert between any length units.' },
  { q: 'Is a kilobyte 1000 or 1024 bytes?', a: 'This tool uses binary units: 1 kilobyte = 1,024 bytes, matching how most operating systems measure file sizes.' },
  { q: 'How do I convert between speed units?', a: 'Select the Speed tab, choose your source and target units (km/h, mph, m/s, knot), and enter a value.' }
]

const relatedTools = [
  { slug: 'px-to-rem', name: 'PX to REM Converter' },
  { slug: 'unix-timestamp', name: 'Unix Timestamp Converter' },
  { slug: 'typography-calculator', name: 'Typography Size Converter' },
]

const breadcrumbs = [
  { label: 'Home', href: '/' },
  { label: 'Converter', href: '/converter' },
  { label: 'Unit', href: '/converter/unit' },
  { label: 'Unit Converter' },
]
---
<Base {...seo}>
  <Layout>
    <ToolShell slug="unit-converter" name="Unit Converter — Length, Weight, Temperature & More" description="Convert between units of length, weight, temperature, data, speed, and time instantly." howTo={howTo} faq={faq} relatedTools={relatedTools} breadcrumbs={breadcrumbs}>
      <div class="tool-container" style="min-height:300px;">
        <div class="uc-tabs" id="uc-tabs">
          <button class="uc-tab active" data-uc-cat="length">Length</button>
          <button class="uc-tab" data-uc-cat="weight">Weight</button>
          <button class="uc-tab" data-uc-cat="temperature">Temperature</button>
          <button class="uc-tab" data-uc-cat="data">Data</button>
          <button class="uc-tab" data-uc-cat="speed">Speed</button>
          <button class="uc-tab" data-uc-cat="time">Time</button>
        </div>

        <div class="uc-converter">
          <div class="uc-col">
            <label class="tool-label" for="uc-from-unit">From</label>
            <select id="uc-from-unit" class="uc-select"></select>
            <input type="number" id="uc-from-value" class="tool-input uc-value" placeholder="1" step="any" />
          </div>

          <div class="uc-swap-col">
            <button class="uc-swap-btn" id="uc-swap" title="Swap units">&hArr;</button>
          </div>

          <div class="uc-col">
            <label class="tool-label" for="uc-to-unit">To</label>
            <select id="uc-to-unit" class="uc-select"></select>
            <div class="uc-result" id="uc-result">&mdash;</div>
            <button class="copy-btn" id="uc-copy">Copy</button>
          </div>
        </div>
      </div>
    </ToolShell>
  </Layout>
</Base>
<style>
  .uc-tabs {
    display: flex;
    gap: 0.25rem;
    margin-bottom: 1.5rem;
    flex-wrap: wrap;
  }
  .uc-tab {
    padding: 0.5rem 1rem;
    border: 1px solid var(--border);
    border-radius: var(--radius);
    background: var(--bg);
    color: var(--text-2);
    font-size: 14px;
    font-weight: 500;
    cursor: pointer;
    transition: background 0.1s, color 0.1s;
  }
  .uc-tab:hover { background: var(--bg-soft); }
  .uc-tab.active {
    background: var(--accent);
    color: #fff;
    border-color: var(--accent);
  }
  .uc-converter {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    gap: 1rem;
    align-items: start;
  }
  .uc-col {
    background: var(--bg-soft);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 1rem;
  }
  .uc-select {
    width: 100%;
    padding: 8px 10px;
    border: 1px solid var(--border);
    border-radius: var(--radius);
    background: var(--bg);
    color: var(--text);
    font-size: 14px;
    margin-bottom: 0.75rem;
    cursor: pointer;
  }
  .uc-value {
    width: 100%;
    font-size: 18px;
    font-family: var(--font-mono);
  }
  .uc-result {
    font-size: 24px;
    font-weight: 700;
    font-family: var(--font-mono);
    color: var(--text);
    margin-bottom: 0.5rem;
    min-height: 36px;
    word-break: break-all;
  }
  .uc-swap-col {
    display: flex;
    align-items: center;
    padding-top: 2rem;
  }
  .uc-swap-btn {
    width: 40px;
    height: 40px;
    border: 1px solid var(--border);
    border-radius: var(--radius);
    background: var(--bg);
    color: var(--text-2);
    font-size: 18px;
    cursor: pointer;
    transition: background 0.1s;
  }
  .uc-swap-btn:hover { background: var(--bg-soft); }

  @media (max-width: 600px) {
    .uc-converter {
      grid-template-columns: 1fr;
    }
    .uc-swap-col {
      justify-content: center;
      padding-top: 0;
    }
  }
</style>
<script src="../tools/unit-converter.js"></script>
