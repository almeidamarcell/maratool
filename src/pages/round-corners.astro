---
import Base from '../layouts/Base.astro'
import Layout from '../components/Layout.astro'
import ToolShell from '../components/ToolShell.astro'

const seo = {
  title: 'Round Corners for Images & GIFs Online | maratool',
  description: 'Add rounded corners or circle crop to images and animated GIFs. Pick radius and background color, then download.',
  canonical: 'https://maratool.com/round-corners',
  schema: {
    '@context': 'https://schema.org',
    '@type': 'WebApplication',
    name: 'Round Corners',
    url: 'https://maratool.com/round-corners',
    applicationCategory: 'MultimediaApplication',
    operatingSystem: 'Any',
    offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
    description: 'Add rounded corners or circle crop to images and animated GIFs. Pick radius and background color, then download.',
  },
  breadcrumbSchema: {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://maratool.com' },
      { '@type': 'ListItem', position: 2, name: 'Image', item: 'https://maratool.com/image' },
      { '@type': 'ListItem', position: 3, name: 'Transform', item: 'https://maratool.com/image/transform' },
      { '@type': 'ListItem', position: 4, name: 'Round Corners', item: 'https://maratool.com/round-corners' },
    ],
  },
  faqSchema: {
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: [
      {
        '@type': 'Question',
        name: 'Transparent corners?',
        acceptedAnswer: { '@type': 'Answer', text: 'Yes — leave background empty for PNG/GIF transparency outside the rounded shape.' }
      },
      {
        '@type': 'Question',
        name: 'Circle crop?',
        acceptedAnswer: { '@type': 'Answer', text: 'Enable circle mode to crop to a perfect circle inscribed in the image.' }
      },
      {
        '@type': 'Question',
        name: 'GIF support?',
        acceptedAnswer: { '@type': 'Answer', text: 'Yes. Rounded corners apply to every frame.' }
      },
      {
        '@type': 'Question',
        name: 'Free?',
        acceptedAnswer: { '@type': 'Answer', text: 'Yes. Runs in your browser.' }
      }
    ]
  }
}

const howTo = [
  'Upload an image or GIF.',
  'Set corner radius or enable circle crop.',
  'Download with transparent or colored corners.'
]
const faq = [
  {
    'q': 'Transparent corners?',
    'a': 'Yes — leave background empty for PNG/GIF transparency outside the rounded shape.'
  },
  {
    'q': 'Circle crop?',
    'a': 'Enable circle mode to crop to a perfect circle inscribed in the image.'
  },
  {
    'q': 'GIF support?',
    'a': 'Yes. Rounded corners apply to every frame.'
  },
  {
    'q': 'Free?',
    'a': 'Yes. Runs in your browser.'
  }
]
const relatedTools = [
  { slug: 'matte-generator', name: 'Matte Generator' },
  { slug: 'square-gif', name: 'Square Gif' },
  { slug: 'image-compressor', name: 'Image Compressor' },
]
const breadcrumbs = [
  { label: 'Home', href: '/' },
  { label: 'Image', href: '/image' },
  { label: 'Transform', href: '/image/transform' },
  { label: 'Round Corners' },
]
---
<Base {...seo}>
  <Layout>
    <ToolShell slug="round-corners" name="Round Corners for Images & GIFs" description="Add rounded corners or circle crop to images and animated GIFs. Pick radius and background color, then download." howTo={howTo} faq={faq} relatedTools={relatedTools} breadcrumbs={breadcrumbs}>
      <div class="tool-container rcr-root" style="min-height:420px;">
        <div class="rcr-dropzone" id="rcr-dropzone">
          <input type="file" id="rcr-file" hidden />
          <p class="rcr-drop-title">Drop a file here</p>
          <p class="rcr-drop-sub">or click to select</p>
        </div>
        <div id="rcr-workspace" style="display:none;"></div>
        <div id="rcr-progress" class="rcr-progress" style="display:none;">
          <div id="rcr-progress-text">Processing...</div>
          <div class="rcr-progress-track"><div id="rcr-progress-fill" class="rcr-progress-fill"></div></div>
        </div>
        <div id="rcr-error" class="rcr-error" style="display:none;"><span id="rcr-error-text"></span></div>
        <div id="rcr-result" style="display:none;"></div>
      </div>
    </ToolShell>
  </Layout>
</Base>
<style is:global>
  .rcr-dropzone {
    border: 2px dashed var(--border); border-radius: var(--radius);
    padding: 3rem 2rem; text-align: center; cursor: pointer;
    transition: border-color 0.2s, background 0.2s;
  }
  .rcr-dropzone:hover, .rcr-dropzone.drag-over { border-color: var(--accent); background: var(--bg-soft); }
  .rcr-drop-title { font-size: 1.125rem; font-weight: 600; margin: 0; }
  .rcr-drop-sub { font-size: 0.875rem; color: var(--text-2); margin: 0.5rem 0 0; }
  .rcr-progress { text-align: center; padding: 2rem; }
  .rcr-progress-track { width: 100%; max-width: 400px; height: 8px; background: var(--bg-hover); border-radius: 4px; margin: 1rem auto; overflow: hidden; }
  .rcr-progress-fill { height: 100%; background: var(--accent); width: 0%; transition: width 0.3s; }
  .rcr-error { background: var(--error-bg); border: 1px solid var(--error-border); border-radius: var(--radius); padding: 1rem; color: #c53030; font-size: 0.875rem; }
  .rcr-preview-wrap {
    background: repeating-conic-gradient(#e0e0e0 0% 25%, #fff 0% 50%) 0 0 / 16px 16px;
    border: 1px solid var(--border); border-radius: var(--radius); padding: 0.5rem;
    display: flex; align-items: center; justify-content: center; margin-bottom: 1rem;
  }
  .rcr-preview-wrap canvas, .rcr-preview-wrap img { max-width: 100%; max-height: 360px; display: block; }
  .rcr-controls { display: flex; flex-direction: column; gap: 0.75rem; margin-bottom: 1rem; }
  .rcr-row { display: flex; flex-wrap: wrap; gap: 0.75rem; align-items: center; }
  .rcr-actions { display: flex; gap: 0.75rem; flex-wrap: wrap; margin-top: 0.5rem; }
</style>
<script src="../tools/round-corners.js"></script>
