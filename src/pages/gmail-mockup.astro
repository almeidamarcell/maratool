---
import Base from '../layouts/Base.astro'
import { styleHref } from '../lib/css-version'
import Layout from '../components/Layout.astro'
import ToolShell from '../components/ToolShell.astro'
import { gmail } from '../data/mockup-platforms'

const platformConfig = gmail

const seo = {
  title: 'Gmail Email Mockup Generator — Create Fake Emails | maratool',
  description: 'Create realistic Gmail email screenshots online. Edit sender, subject, body, and labels. Download as PNG. Free, no sign-up required.',
  canonical: 'https://maratool.com/gmail-mockup',
  schema: {
    '@context': 'https://schema.org',
    '@type': 'WebApplication',
    name: 'Gmail Email Mockup Generator',
    url: 'https://maratool.com/gmail-mockup',
    applicationCategory: 'DesignApplication',
    operatingSystem: 'Any',
    offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
    description: 'Create realistic Gmail email screenshots with editable sender, subject, body, labels, and PNG export.',
  },
  breadcrumbSchema: {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://maratool.com' },
      { '@type': 'ListItem', position: 2, name: 'Mockup', item: 'https://maratool.com/mockup' },
      { '@type': 'ListItem', position: 3, name: 'Email', item: 'https://maratool.com/mockup/email' },
      { '@type': 'ListItem', position: 4, name: 'Gmail Email Mockup Generator', item: 'https://maratool.com/gmail-mockup' },
    ],
  },
  faqSchema: {
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: [
      {
        '@type': 'Question',
        name: 'Is this Gmail mockup generator free?',
        acceptedAnswer: { '@type': 'Answer', text: 'Yes, completely free. No sign-up, no watermark. Create unlimited Gmail email mockups and download them as PNG.' }
      },
      {
        '@type': 'Question',
        name: 'Can I add Gmail labels like Inbox and Important?',
        acceptedAnswer: { '@type': 'Answer', text: 'Yes. Use the label checkboxes in the controls panel to add or remove Inbox, Important, Starred, and Social labels.' }
      },
      {
        '@type': 'Question',
        name: 'Does this tool send my email content anywhere?',
        acceptedAnswer: { '@type': 'Answer', text: 'No. Everything runs in your browser. Your email content never leaves your device. The PNG is generated locally.' }
      },
      {
        '@type': 'Question',
        name: 'Can I edit the email directly in the preview?',
        acceptedAnswer: { '@type': 'Answer', text: 'Yes. Click on the subject or email body in the phone preview to edit them inline, or use the controls panel on the left.' }
      }
    ]
  }
}

const howTo = [
  'Fill in the sender name, email, subject, and body using the controls panel on the left.',
  'Toggle labels (Inbox, Important, etc.) and edit the date.',
  'Toggle dark mode or hide the phone frame, then click Download PNG.'
]

const faq = [
  { q: 'Is this Gmail mockup generator free?', a: 'Yes, completely free. No sign-up, no watermark. Create unlimited mockups and download as PNG.' },
  { q: 'Can I add Gmail labels?', a: 'Yes. Use the label checkboxes in the controls panel to toggle Inbox, Important, Starred, and Social labels.' },
  { q: 'Does this tool send my email content anywhere?', a: 'No. Everything runs in your browser. Your content never leaves your device.' },
  { q: 'Can I edit the email directly in the preview?', a: 'Yes. Click on the subject or body in the phone preview to edit them inline.' }
]

const relatedTools = [
  { slug: 'whatsapp-chat-mockup', name: 'WhatsApp Chat Mockup' },
  { slug: 'x-post-mockup', name: 'X (Twitter) Post Mockup' },
  { slug: 'instagram-post-mockup', name: 'Instagram Post Mockup' },
]

const breadcrumbs = [
  { label: 'Home', href: '/' },
  { label: 'Mockup', href: '/mockup' },
  { label: 'Email', href: '/mockup/email' },
  { label: 'Gmail Email Mockup' },
]
---
<Base {...seo}>
  <Layout>
    <ToolShell slug="gmail-mockup" name="Gmail Email Mockup Generator" description="Create realistic Gmail email screenshots. Edit sender, subject, body, and labels. Download as PNG." howTo={howTo} faq={faq} relatedTools={relatedTools} breadcrumbs={breadcrumbs}>
      <div class="tool-container" style="min-height:600px;">
        <div class="mockup-workspace">
          <!-- Controls panel -->
          <div class="controls-panel">
            <div class="controls-section">
              <h3 class="controls-label">From</h3>
              <div class="ctrl-row">
                <input type="text" class="ctrl-input" id="from-name" placeholder="Sender name">
              </div>
              <div class="ctrl-row">
                <input type="text" class="ctrl-input" id="from-email" placeholder="sender@email.com">
              </div>
            </div>
            <div class="controls-section">
              <h3 class="controls-label">To</h3>
              <div class="ctrl-row">
                <input type="text" class="ctrl-input" id="to-email" placeholder="Recipient">
              </div>
            </div>
            <div class="controls-section">
              <h3 class="controls-label">Subject</h3>
              <div class="ctrl-row">
                <input type="text" class="ctrl-input" id="email-subject" placeholder="Email subject">
              </div>
            </div>
            <div class="controls-section">
              <h3 class="controls-label">Body</h3>
              <textarea class="ctrl-input" id="email-body" rows="6" placeholder="Email body..."></textarea>
            </div>
            <div class="controls-section">
              <h3 class="controls-label">Date</h3>
              <input type="text" class="ctrl-input" id="email-date" placeholder="Apr 9, 2026, 10:23 AM">
            </div>
            <div class="controls-section">
              <h3 class="controls-label">Labels</h3>
              <div class="ctrl-checkbox-group">
                <label class="ctrl-checkbox"><input type="checkbox" id="label-inbox" checked> Inbox</label>
                <label class="ctrl-checkbox"><input type="checkbox" id="label-important"> Important</label>
                <label class="ctrl-checkbox"><input type="checkbox" id="label-starred"> Starred</label>
                <label class="ctrl-checkbox"><input type="checkbox" id="label-social"> Social</label>
              </div>
            </div>
          </div>

          <!-- Preview -->
          <div class="mockup-preview">
            <div class="mockup-action-bar">
              <button class="mockup-btn mockup-btn-outline" id="toggle-dark">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 12.79A9 9 0 1111.21 3 7 7 0 0021 12.79z"/></svg>
                Dark mode
              </button>
              <button class="mockup-btn mockup-btn-outline" id="toggle-frame">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="5" y="2" width="14" height="20" rx="2" ry="2"/><line x1="12" y1="18" x2="12.01" y2="18"/></svg>
                Hide frame
              </button>
              <div style="flex:1"></div>
              <button class="mockup-btn mockup-btn-primary" id="download-btn">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
                Download PNG
              </button>
            </div>

            <div class="phone-frame" id="phone-frame">
              <div class="phone-notch"></div>
              <div class="phone-screen" id="phone-screen">
                <div class="gm-screen">
                  <div class="gm-statusbar">
                    <span class="gm-statusbar-time">15:08</span>
                    <span style="flex:1"></span>
                    <span class="gm-statusbar-icons">
                      <svg viewBox="0 0 18 12" fill="currentColor" width="16" height="11"><rect x="0" y="9" width="3" height="3" rx="1"/><rect x="5" y="6" width="3" height="6" rx="1"/><rect x="10" y="3" width="3" height="9" rx="1"/><rect x="15" y="0" width="3" height="12" rx="1"/></svg>
                      <svg viewBox="0 0 16 12" fill="currentColor" width="15" height="11"><path d="M8.5 1.5C10.4 1.5 12.1 2.3 13.3 3.5L14.7 2.1C13.1 0.5 10.9-0.5 8.5-0.5C6.1-0.5 3.9 0.5 2.3 2.1L3.7 3.5C4.9 2.3 6.6 1.5 8.5 1.5ZM5.1 5C5.9 4.2 7.1 3.7 8.5 3.7C9.9 3.7 11.1 4.2 11.9 5L8.5 8.5L5.1 5Z"/></svg>
                      <svg viewBox="0 0 25 12" fill="none" width="25" height="12"><rect x="0.5" y="0.5" width="21" height="11" rx="3.5" stroke="currentColor" stroke-width="1"/><rect x="2" y="2" width="18" height="8" rx="2" fill="currentColor"/><path d="M23 4.5C23.5523 4.5 24 4.94772 24 5.5V6.5C24 7.05228 23.5523 7.5 23 7.5" fill="currentColor"/></svg>
                    </span>
                  </div>
                  <div class="gm-content-area" id="email-content"></div>
                  <div class="gm-home-indicator"></div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </ToolShell>
  </Layout>
</Base>

<link rel="stylesheet" href={styleHref('mockup.css')} />

<script define:vars={{ platformConfig }}>
  window.__mockupPlatform = platformConfig
</script>
<script is:inline src="https://cdn.jsdelivr.net/npm/html2canvas@1.4.1/dist/html2canvas.min.js"></script>
<script src="../tools/mockup/mockup-common.js"></script>
<script src="../tools/mockup/email-engine.js"></script>

<style is:global>
.mockup-preview {
  display: flex;
  flex-direction: column;
  align-items: center;
}
</style>
