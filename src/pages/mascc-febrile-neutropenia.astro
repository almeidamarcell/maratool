---
import ScoreCalc from '../components/ScoreCalc.astro'

const spec = {
  items: [
    { id: 'burden', label: 'Burden of febrile neutropenia (clinical illness severity)', options: [
      { label: 'No or mild symptoms (5)', points: 5, default: true },
      { label: 'Moderate symptoms (3)', points: 3 },
      { label: 'Severe symptoms / moribund (0)', points: 0 },
    ]},
    { id: 'hypotension', label: 'No hypotension (systolic BP > 90 mmHg)', options: [
      { label: 'No — hypotensive (0)', points: 0 },
      { label: 'Yes — no hypotension (5)', points: 5, default: true },
    ]},
    { id: 'copd', label: 'No chronic obstructive pulmonary disease', options: [
      { label: 'No — has COPD (0)', points: 0 },
      { label: 'Yes — no COPD (4)', points: 4, default: true },
    ]},
    { id: 'tumor', label: 'Solid tumor, or hematologic malignancy with no previous fungal infection', options: [
      { label: 'No (0)', points: 0 },
      { label: 'Yes (4)', points: 4, default: true },
    ]},
    { id: 'dehydration', label: 'No dehydration requiring parenteral fluids', options: [
      { label: 'No — dehydrated (0)', points: 0 },
      { label: 'Yes — no dehydration (3)', points: 3, default: true },
    ]},
    { id: 'outpatient', label: 'Outpatient status at onset of fever', options: [
      { label: 'No — inpatient (0)', points: 0 },
      { label: 'Yes — outpatient (3)', points: 3, default: true },
    ]},
    { id: 'age', label: 'Age < 60 years', options: [
      { label: 'No (0)', points: 0 },
      { label: 'Yes (2)', points: 2, default: true },
    ]},
  ],
  bands: [
    { min: 0, max: 20, label: 'Score < 21 — high risk of complications; inpatient IV management', cls: 'cls-danger' },
    { min: 21, max: 26, label: 'Score ≥ 21 — low risk; consider oral / outpatient therapy', cls: 'cls-normal' },
  ],
  max: 26,
  cols: 2,
}

const faq = [
  { q: 'What is the MASCC risk index?', a: 'The Multinational Association for Supportive Care in Cancer index identifies low-risk febrile neutropenia patients who may be candidates for oral or outpatient antibiotic therapy.' },
  { q: 'What MASCC score is low risk?', a: 'A score ≥ 21 (maximum 26) predicts low risk of serious complications; < 21 is high risk and warrants inpatient intravenous management.' },
  { q: 'Note about the burden-of-illness item', a: 'Only one burden category is scored — “no/mild symptoms” (5) and “moderate symptoms” (3) are mutually exclusive options, not additive.' },
  { q: 'Does a low-risk MASCC mean home treatment is safe?', a: 'It identifies candidates, but outpatient management also requires clinical stability, reliable follow-up, access to care, and absence of profound prolonged neutropenia.' },
]
const references = [
  { citation: 'Klastersky J, Paesmans M, Rubenstein EB, et al. The MASCC risk-index: a multinational scoring system for identifying low-risk febrile neutropenic cancer patients. <em>J Clin Oncol</em>. 2000;18(16):3038-3051.' },
]
const relatedTools = [
  { slug: 'qsofa', name: 'qSOFA' },
  { slug: 'news-2', name: 'NEWS-2' },
  { slug: 'curb-65', name: 'CURB-65' },
]
---
<ScoreCalc
  slug="mascc-febrile-neutropenia"
  name="MASCC Risk Index Calculator"
  schemaName="MASCC Risk Index"
  shortDescription="MASCC risk index for identifying low-risk febrile neutropenia (max 26)."
  metaTitle="MASCC Risk Index Calculator (Febrile Neutropenia) | maratool"
  metaDescription="Free MASCC risk index calculator. Identify low-risk febrile neutropenia patients eligible for oral or outpatient antibiotic therapy."
  subcategory="Score"
  subcategorySlug="score"
  howTo={[
    'Select the burden-of-illness category and each other criterion.',
    'The total MASCC score (max 26) and risk band update instantly.',
    'A score ≥ 21 identifies low-risk patients who may be eligible for outpatient therapy.',
  ]}
  faq={faq}
  relatedTools={relatedTools}
  references={references}
  spec={spec}
/>
