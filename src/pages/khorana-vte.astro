---
import ScoreCalc from '../components/ScoreCalc.astro'

const spec = {
  items: [
    { id: 'site', label: 'Site of primary cancer', options: [
      { label: 'Other / not listed (0)', points: 0, default: true },
      { label: 'High risk — lung, lymphoma, gynecologic, bladder, testicular (1)', points: 1 },
      { label: 'Very high risk — stomach or pancreas (2)', points: 2 },
    ]},
    { id: 'platelets', label: 'Pre-chemotherapy platelet count ≥ 350 × 10⁹/L', options: [
      { label: 'No (0)', points: 0, default: true }, { label: 'Yes (1)', points: 1 },
    ]},
    { id: 'hgb', label: 'Hemoglobin < 10 g/dL or use of erythropoiesis-stimulating agent', options: [
      { label: 'No (0)', points: 0, default: true }, { label: 'Yes (1)', points: 1 },
    ]},
    { id: 'wbc', label: 'Pre-chemotherapy leukocyte count > 11 × 10⁹/L', options: [
      { label: 'No (0)', points: 0, default: true }, { label: 'Yes (1)', points: 1 },
    ]},
    { id: 'bmi', label: 'BMI ≥ 35 kg/m²', options: [
      { label: 'No (0)', points: 0, default: true }, { label: 'Yes (1)', points: 1 },
    ]},
  ],
  bands: [
    { min: 0, max: 0, label: 'Score 0 — low risk (≈ 0.3–0.8% VTE at 2.5 months)', cls: 'cls-normal' },
    { min: 1, max: 2, label: 'Score 1–2 — intermediate risk (≈ 1.8–2%)', cls: 'cls-warn' },
    { min: 3, max: 6, label: 'Score ≥ 3 — high risk (≈ 6.7–11%); consider thromboprophylaxis', cls: 'cls-danger' },
  ],
  max: 6,
  cols: 2,
}

const faq = [
  { q: 'What is the Khorana score?', a: 'A 6-point score that predicts the risk of venous thromboembolism (VTE) in ambulatory cancer patients starting chemotherapy.' },
  { q: 'What Khorana score warrants prophylaxis?', a: 'A score ≥ 2 (and especially ≥ 3) is the usual threshold for considering ambulatory thromboprophylaxis, per ASCO/ITAC guidance, after weighing bleeding risk.' },
  { q: 'Does Khorana apply to all cancers?', a: 'It was derived in solid tumours and lymphoma; it performs less well in some cancers (e.g., it underperforms in lung and certain hematologic malignancies) — clinical judgment is still needed.' },
  { q: 'When is the score calculated?', a: 'Before initiating a new systemic chemotherapy regimen, using the pre-chemotherapy blood counts.' },
]
const references = [
  { citation: 'Khorana AA, Kuderer NM, Culakova E, et al. Development and validation of a predictive model for chemotherapy-associated thrombosis. <em>Blood</em>. 2008;111(10):4902-4907.' },
]
const relatedTools = [
  { slug: 'caprini-dvt-risk', name: 'Caprini VTE Risk' },
  { slug: 'padua-prediction', name: 'Padua Prediction Score' },
  { slug: 'wells-dvt', name: 'Wells Score (DVT)' },
]
---
<ScoreCalc
  slug="khorana-vte"
  name="Khorana Score for Cancer VTE Calculator"
  schemaName="Khorana Score"
  shortDescription="Khorana score for chemotherapy-associated VTE risk in ambulatory cancer patients (0–6)."
  metaTitle="Khorana Score Calculator (Cancer VTE Risk) | maratool"
  metaDescription="Free Khorana score calculator. Predict venous thromboembolism risk in ambulatory cancer patients starting chemotherapy and guide thromboprophylaxis."
  subcategory="Score"
  subcategorySlug="score"
  howTo={[
    'Select the cancer site category and the pre-chemotherapy lab/BMI criteria.',
    'The total score (0–6) and VTE risk band update instantly.',
    'Consider ambulatory thromboprophylaxis when the score is ≥ 2 and bleeding risk is acceptable.',
  ]}
  faq={faq}
  relatedTools={relatedTools}
  references={references}
  spec={spec}
/>
