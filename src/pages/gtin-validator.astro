---
import Base from '../layouts/Base.astro'
import Layout from '../components/Layout.astro'
import ToolShell from '../components/ToolShell.astro'

const seo = {
  title: 'GTIN Validator — EAN-13 & UPC Check Digit | maratool',
  description: 'Validate GTIN, EAN-13, and UPC barcodes. Verify check digits and format. Free GTIN validator, runs in your browser.',
  canonical: 'https://maratool.com/gtin-validator',
  schema: {
    '@context': 'https://schema.org',
    '@type': 'WebApplication',
    name: 'GTIN Validator — EAN-13 & UPC Check Digit',
    url: 'https://maratool.com/gtin-validator',
    applicationCategory: 'BusinessApplication',
    operatingSystem: 'Any',
    offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
    description: 'Validate GTIN, EAN-13, and UPC barcodes. Verify check digits and format. Free GTIN validator, runs in your browser.',
  },
  breadcrumbSchema: {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://maratool.com' },
      { '@type': 'ListItem', position: 2, name: 'Business', item: 'https://maratool.com/business' },
      { '@type': 'ListItem', position: 3, name: 'Pricing', item: 'https://maratool.com/business/pricing' },
      { '@type': 'ListItem', position: 4, name: 'GTIN Validator — EAN-13 & UPC Check Digit', item: 'https://maratool.com/gtin-validator' },
    ],
  },
  faqSchema: {
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: [
      { '@type': 'Question', name: 'What GTIN formats are supported?', acceptedAnswer: { '@type': 'Answer', text: 'GTIN-8, GTIN-12 (UPC-A), GTIN-13 (EAN-13), and GTIN-14 with check digit validation.' } },
      { '@type': 'Question', name: 'How is the check digit calculated?', acceptedAnswer: { '@type': 'Answer', text: 'Modulo-10 algorithm: alternating weights of 3 and 1 on digits, sum mod 10, complement to 10.' } },
      { '@type': 'Question', name: 'Can I validate barcodes without check digits?', acceptedAnswer: { '@type': 'Answer', text: 'Enter the full code including check digit. The validator confirms the last digit is correct.' } },
      { '@type': 'Question', name: 'Is my data sent to a server?', acceptedAnswer: { '@type': 'Answer', text: 'No. Validation happens entirely in your browser.' } }
    ]
  }
}

const howTo = [
  'Enter a GTIN, EAN-13, or UPC barcode number.',
  'See validation status, barcode type, and check digit result.',
  'Fix any check digit errors before printing labels.'
]

const faq = [
  { q: 'What GTIN formats are supported?', a: 'GTIN-8, GTIN-12 (UPC-A), GTIN-13 (EAN-13), and GTIN-14 with check digit validation.' },
  { q: 'How is the check digit calculated?', a: 'Modulo-10 algorithm: alternating weights of 3 and 1 on digits, sum mod 10, complement to 10.' },
  { q: 'Can I validate barcodes without check digits?', a: 'Enter the full code including check digit. The validator confirms the last digit is correct.' },
  { q: 'Is my data sent to a server?', a: 'No. Validation happens entirely in your browser.' }
]

const relatedTools = [
  { slug: 'barcode-generator', name: 'Barcode Generator' },
  { slug: 'amazon-fee-calculator', name: 'Amazon Seller Fee Calculator' },
  { slug: 'shopify-discount-calculator', name: 'Shopify Discount Calculator' }
]

const breadcrumbs = [
  { label: 'Home', href: '/' },
  { label: 'Business', href: '/business' },
  { label: 'Pricing', href: '/business/pricing' },
  { label: 'GTIN Validator' }
]
---
<Base {...seo}>
  <Layout>
    <ToolShell slug="gtin-validator" name="GTIN Validator — EAN-13 & UPC Check Digit" description="Enter a GTIN, EAN-13, or UPC barcode to validate check digit, detect type, and see validation message." howTo={howTo} faq={faq} relatedTools={relatedTools} breadcrumbs={breadcrumbs}>
      <div class="tool-container" style="min-height:260px;">
        <div class="calc-field"><label class="tool-label" for="gtin-input">GTIN / barcode</label><input type="text" id="gtin-input" class="tool-input" placeholder="5901234123457" inputmode="numeric" style="max-width:280px;" /></div>
        <div class="tool-stats">
          <div class="tool-stat"><span class="tool-stat-value" id="gtin-valid">—</span><span class="tool-stat-label">Valid</span></div>
          <div class="tool-stat"><span class="tool-stat-value" id="gtin-type">—</span><span class="tool-stat-label">Type</span></div>
        </div>
        <p id="gtin-msg" style="font-size:13px;color:var(--text-2);margin:1rem 0 0;">—</p>
      </div>
    </ToolShell>
  </Layout>
</Base>

<style is:global>
  .calc-row { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; margin-bottom: 1rem; }
  .calc-field { margin-bottom: 0.75rem; }
  .calc-select { max-width: 100%; }
  @media (max-width: 600px) { .calc-row { grid-template-columns: 1fr; } }
</style>
<script src="../tools/gtin-validator.js"></script>
