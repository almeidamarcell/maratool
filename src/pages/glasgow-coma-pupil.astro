---
import ScoreCalc from '../components/ScoreCalc.astro'

const spec = {
  items: [
    {
      id: 'eye',
      label: 'Eye opening',
      options: [
        { label: '4 — Spontaneous', points: 4, default: true },
        { label: '3 — To sound', points: 3 },
        { label: '2 — To pressure', points: 2 },
        { label: '1 — None', points: 1 },
        { label: 'NT — Not testable', points: 0 },
      ],
    },
    {
      id: 'verbal',
      label: 'Verbal response',
      options: [
        { label: '5 — Oriented', points: 5, default: true },
        { label: '4 — Confused', points: 4 },
        { label: '3 — Words', points: 3 },
        { label: '2 — Sounds', points: 2 },
        { label: '1 — None (or intubated)', points: 1 },
      ],
    },
    {
      id: 'motor',
      label: 'Best motor response',
      options: [
        { label: '6 — Obeys commands', points: 6, default: true },
        { label: '5 — Localizing', points: 5 },
        { label: '4 — Normal flexion (withdrawal)', points: 4 },
        { label: '3 — Abnormal flexion (decorticate)', points: 3 },
        { label: '2 — Extension (decerebrate)', points: 2 },
        { label: '1 — None', points: 1 },
      ],
    },
    {
      id: 'pupil',
      label: 'Pupil reactivity (subtracted)',
      options: [
        { label: '0 — Both pupils reactive', points: 0, default: true },
        { label: '−1 — One pupil unreactive', points: -1 },
        { label: '−2 — Both pupils unreactive', points: -2 },
      ],
    },
  ],
  bands: [
    { min: 13, max: 15, label: 'Mild brain injury', cls: 'cls-normal' },
    { min: 9, max: 12, label: 'Moderate brain injury', cls: 'cls-warn' },
    { min: -2, max: 8, label: 'Severe brain injury', cls: 'cls-danger' },
  ],
  max: 15,
}

const faq = [
  { q: 'What is GCS-P?', a: 'The Glasgow Coma Scale-Pupils score combines the GCS (3–15) with a pupil reactivity score (0, −1, or −2). GCS-P = GCS − Pupil Reactivity Score.' },
  { q: 'Why subtract pupil reactivity?', a: 'Unreactive pupils correlate with worse outcomes in traumatic brain injury, especially at the severe end of the GCS scale. GCS-P preserves the prognostic information of pupil reactivity.' },
  { q: 'GCS-P range?', a: '1 (worst) to 15 (best). A GCS of 3 with both pupils unreactive yields GCS-P = 1.' },
  { q: 'Does GCS-P replace GCS?', a: 'GCS remains the cornerstone for tracking neurologic exam over time. GCS-P augments it for prognostication, particularly in TBI.' },
]
const references = [
  { citation: 'Brennan PM, Murray GD, Teasdale GM. Simplifying the use of prognostic information in traumatic brain injury. Part 1: The GCS-Pupils score. <em>J Neurosurg</em>. 2018;128(6):1612-1620.' },
  { citation: 'Teasdale G, Jennett B. Assessment of coma and impaired consciousness. <em>Lancet</em>. 1974;2(7872):81-84.' },
]
const relatedTools = [
  { slug: 'four-coma-scale', name: 'FOUR Score Coma Scale' },
  { slug: 'fisher-scale', name: 'Fisher Scale (SAH)' },
  { slug: 'nihss-stroke', name: 'NIHSS Stroke Scale' },
]
---
<ScoreCalc
  slug="glasgow-coma-pupil"
  name="Glasgow Coma Scale with Pupil Response (GCS-P)"
  schemaName="Glasgow Coma Scale-Pupils (GCS-P)"
  shortDescription="Glasgow Coma Scale combined with pupil reactivity (GCS-P, 1–15)."
  metaTitle="Glasgow Coma Scale + Pupils (GCS-P) Calculator | maratool"
  metaDescription="Free GCS-P calculator. Glasgow Coma Scale combined with pupil reactivity for traumatic brain injury prognostication."
  subcategory="Scale"
  subcategorySlug="scale"
  howTo={[
    'Assess eye opening (E), verbal response (V), motor response (M).',
    'Subtract the pupil reactivity score (0 / 1 / 2).',
    'Total GCS-P (1–15) and interpretation update instantly.',
  ]}
  faq={faq}
  relatedTools={relatedTools}
  references={references}
  spec={spec}
/>
