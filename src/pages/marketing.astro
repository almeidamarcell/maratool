---
import Base from '../layouts/Base.astro'
import Layout from '../components/Layout.astro'
import Breadcrumb from '../components/Breadcrumb.astro'
import { toolsFlatByCategory } from '../data/tools'

const tools = toolsFlatByCategory.Marketing ?? []

const seo = {
  title: 'Marketing Tools — maratool',
  description: 'Free browser-based marketing tools. Build UTM-tagged URLs for campaign tracking — no sign-up, runs entirely in your browser.',
  canonical: 'https://maratool.com/marketing',
  schema: {
    '@context': 'https://schema.org',
    '@type': 'CollectionPage',
    name: 'Marketing Tools',
    url: 'https://maratool.com/marketing',
    description: 'Free browser-based marketing tools. Build UTM-tagged URLs for campaign tracking — no sign-up, runs entirely in your browser.',
    hasPart: tools.map(tool => ({
      '@type': 'SoftwareApplication',
      name: tool.name,
      url: `https://maratool.com/${tool.slug}`,
      applicationCategory: 'BusinessApplication',
    })),
  },
  breadcrumbSchema: {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://maratool.com' },
      { '@type': 'ListItem', position: 2, name: 'Marketing', item: 'https://maratool.com/marketing' },
    ],
  },
}

const breadcrumbs = [
  { label: 'Home', href: '/' },
  { label: 'Marketing' },
]
---
<Base {...seo}>
  <Layout>
    <Breadcrumb crumbs={breadcrumbs} />
    <div class="hero">
      <h1>Marketing Tools</h1>
      <p>Free, browser-based marketing tools — UTM builders and campaign helpers, all running locally in your browser.</p>
    </div>

    <div class="tools-grid">
      {tools.map(tool => (
        tool.live
          ? (
            <a href={`/${tool.slug}`} class="tool-card">
              <span class="tool-card-emoji">{tool.emoji}</span>
              <div class="tool-card-name">{tool.name}</div>
              <div class="tool-card-desc">{tool.description}</div>
            </a>
          )
          : (
            <div class="tool-card" style="opacity:0.5;cursor:default;">
              <span class="tool-card-emoji">{tool.emoji}</span>
              <div class="tool-card-name">{tool.name}</div>
              <div class="tool-card-desc">{tool.description}</div>
              <span class="tool-card-badge">Coming Soon</span>
            </div>
          )
      ))}
    </div>
  </Layout>
</Base>
