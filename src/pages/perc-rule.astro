---
import ScoreCalc from '../components/ScoreCalc.astro'

const spec = {
  items: [
    { id: 'age', label: 'Age ≥ 50 years', options: [
      { label: 'No (0)', points: 0, default: true }, { label: 'Yes (1)', points: 1 },
    ]},
    { id: 'hr', label: 'Heart rate ≥ 100 bpm', options: [
      { label: 'No (0)', points: 0, default: true }, { label: 'Yes (1)', points: 1 },
    ]},
    { id: 'sao2', label: 'SaO₂ < 95% on room air', options: [
      { label: 'No (0)', points: 0, default: true }, { label: 'Yes (1)', points: 1 },
    ]},
    { id: 'leg', label: 'Unilateral leg swelling', options: [
      { label: 'No (0)', points: 0, default: true }, { label: 'Yes (1)', points: 1 },
    ]},
    { id: 'hemoptysis', label: 'Hemoptysis', options: [
      { label: 'No (0)', points: 0, default: true }, { label: 'Yes (1)', points: 1 },
    ]},
    { id: 'surgery', label: 'Recent surgery or trauma (≤ 4 weeks, requiring hospitalization)', options: [
      { label: 'No (0)', points: 0, default: true }, { label: 'Yes (1)', points: 1 },
    ]},
    { id: 'priorvte', label: 'Prior DVT or PE', options: [
      { label: 'No (0)', points: 0, default: true }, { label: 'Yes (1)', points: 1 },
    ]},
    { id: 'hormone', label: 'Hormone use (oral contraceptives, HRT, estrogen)', options: [
      { label: 'No (0)', points: 0, default: true }, { label: 'Yes (1)', points: 1 },
    ]},
  ],
  bands: [
    { min: 0, max: 0, label: 'PERC negative — in a low pretest-probability patient, PE can be excluded without D-dimer', cls: 'cls-normal' },
    { min: 1, max: 8, label: 'PERC positive — cannot exclude PE on PERC; proceed to D-dimer / imaging', cls: 'cls-warn' },
  ],
  max: 8,
  cols: 2,
}

const faq = [
  { q: 'What is the PERC rule?', a: 'The Pulmonary Embolism Rule-out Criteria: 8 bedside criteria that, when all negative in a patient with low pretest probability, allow PE to be excluded without D-dimer testing.' },
  { q: 'When can PERC be applied?', a: 'Only when the clinical gestalt pretest probability for PE is already low (< 15%). PERC should not be used in moderate- or high-risk patients.' },
  { q: 'What is the missed-PE rate if PERC negative?', a: 'In appropriately low-risk patients, a negative PERC carries a < 2% probability of PE — below the testing threshold.' },
  { q: 'Does any positive criterion mean the patient has a PE?', a: 'No. A positive PERC simply means PE cannot be excluded by the rule alone — continue the standard work-up (D-dimer, then imaging if indicated).' },
]
const references = [
  { citation: 'Kline JA, Mitchell AM, Kabrhel C, et al. Clinical criteria to prevent unnecessary diagnostic testing in emergency department patients with suspected pulmonary embolism. <em>J Thromb Haemost</em>. 2004;2(8):1247-1255.' },
]
const relatedTools = [
  { slug: 'wells-pe', name: 'Wells Score (PE)' },
  { slug: 'pesi-pe-severity', name: 'PESI Score' },
  { slug: 'wells-dvt', name: 'Wells Score (DVT)' },
]
---
<ScoreCalc
  slug="perc-rule"
  name="PERC Rule for Pulmonary Embolism Calculator"
  schemaName="PERC Rule"
  shortDescription="Pulmonary Embolism Rule-out Criteria (PERC) — 8 criteria to exclude PE in low-risk patients."
  metaTitle="PERC Rule Calculator (Pulmonary Embolism) | maratool"
  metaDescription="Free PERC rule calculator. Determine whether PE can be excluded without D-dimer in low pretest-probability patients using the 8 PERC criteria."
  subcategory="Score"
  subcategorySlug="score"
  howTo={[
    'Confirm the pretest probability of PE is low before applying PERC.',
    'Select any of the 8 criteria that are present.',
    'If all 8 are absent (PERC negative), PE can be excluded without further testing.',
  ]}
  faq={faq}
  relatedTools={relatedTools}
  references={references}
  spec={spec}
/>
