---
import ScoreCalc from '../components/ScoreCalc.astro'

const spec = {
  items: [
    { id: 'dyspnea', label: 'Dyspnea', options: [
      { label: 'No (0)', points: 0, default: true },
      { label: 'Yes (1)', points: 1 },
    ]},
    { id: 'anorexia', label: 'Anorexia', options: [
      { label: 'No (0)', points: 0, default: true },
      { label: 'Yes (1.5)', points: 1.5 },
    ]},
    { id: 'kps', label: 'Karnofsky Performance Status', options: [
      { label: '≥ 30 (0)', points: 0, default: true },
      { label: '10–20 (2.5)', points: 2.5 },
    ]},
    { id: 'cps', label: 'Clinical Prediction of Survival (weeks)', options: [
      { label: '> 12 weeks (0)', points: 0, default: true },
      { label: '11–12 weeks (2.0)', points: 2.0 },
      { label: '7–10 weeks (2.5)', points: 2.5 },
      { label: '5–6 weeks (4.5)', points: 4.5 },
      { label: '3–4 weeks (6.0)', points: 6.0 },
      { label: '1–2 weeks (8.5)', points: 8.5 },
    ]},
    { id: 'wbc', label: 'Total white blood cells (cells/mm³)', options: [
      { label: 'Normal 4 800–8 500 (0)', points: 0, default: true },
      { label: 'High 8 501–11 000 (0.5)', points: 0.5 },
      { label: 'Very high > 11 000 (1.5)', points: 1.5 },
    ]},
    { id: 'lymph', label: 'Lymphocyte percentage', options: [
      { label: 'Normal 20–40% (0)', points: 0, default: true },
      { label: 'Low 12–19.9% (1.0)', points: 1.0 },
      { label: 'Very low 0–11.9% (2.5)', points: 2.5 },
    ]},
  ],
  bands: [
    { min: 0, max: 5.5, label: 'Group A — > 70% 30-day survival', cls: 'cls-normal' },
    { min: 5.6, max: 11, label: 'Group B — 30–70% 30-day survival', cls: 'cls-warn' },
    { min: 11.1, max: 17.5, label: 'Group C — < 30% 30-day survival', cls: 'cls-danger' },
  ],
  max: 17.5,
  cols: 2,
}

const faq = [
  { q: 'What is the PaP score?', a: 'The Palliative Prognostic (PaP) score predicts 30-day survival in advanced cancer patients based on 6 clinical and laboratory variables.' },
  { q: 'When is PaP used?', a: 'In oncology and palliative care to support decisions about hospice referral, aggressiveness of treatment, and family discussions about prognosis.' },
  { q: 'Does PaP work without lab data?', a: 'PaP requires WBC and lymphocyte percent. If labs are unavailable, consider the PPI (Palliative Prognostic Index) which is purely clinical.' },
  { q: 'How is the clinical prediction of survival (CPS) estimated?', a: 'CPS is the treating clinician’s gestalt estimate of weeks of remaining life. It is one of the strongest single predictors but is often overestimated.' },
]
const references = [
  { citation: 'Pirovano M, Maltoni M, Nanni O, et al. A new palliative prognostic score: a first step for the staging of terminally ill cancer patients. <em>J Pain Symptom Manage</em>. 1999;17(4):231-239.' },
]
const relatedTools = [
  { slug: 'ppi-palliative-prognostic', name: 'Palliative Prognostic Index (PPI)' },
  { slug: 'palliative-performance-scale', name: 'Palliative Performance Scale (PPS)' },
  { slug: 'karnofsky-performance', name: 'Karnofsky Performance Scale' },
]
---
<ScoreCalc
  slug="pap-palliative-prognostic"
  name="Palliative Prognostic Score (PaP) Calculator"
  schemaName="Palliative Prognostic Score (PaP)"
  shortDescription="PaP score for 30-day survival probability in palliative cancer patients."
  metaTitle="Palliative Prognostic Score (PaP) Calculator | maratool"
  metaDescription="Free PaP (Palliative Prognostic) score calculator. Predicts 30-day survival in advanced cancer patients using 6 clinical/lab variables."
  subcategory="Prognosis"
  subcategorySlug="prognosis"
  howTo={[
    'Enter dyspnea, anorexia, KPS, clinical prediction of survival, WBC, and lymphocyte percentage.',
    'The total PaP score (0–17.5) and survival group update instantly.',
    'Use to support communication and care planning, not as the sole prognostic input.',
  ]}
  faq={faq}
  relatedTools={relatedTools}
  references={references}
  spec={spec}
/>
