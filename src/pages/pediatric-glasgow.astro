---
import ScoreCalc from '../components/ScoreCalc.astro'

const spec = {
  items: [
    { id: 'eye', label: 'Eye opening', options: [
      { label: '4 — Spontaneous', points: 4, default: true },
      { label: '3 — To sound / voice', points: 3 },
      { label: '2 — To pain', points: 2 },
      { label: '1 — None', points: 1 },
    ]},
    { id: 'verbal', label: 'Verbal response (pediatric)', options: [
      { label: '5 — Coos / babbles (infant) or oriented (child)', points: 5, default: true },
      { label: '4 — Irritable cry / consolable (infant) or confused (child)', points: 4 },
      { label: '3 — Cries to pain (infant) or inappropriate words (child)', points: 3 },
      { label: '2 — Moans to pain (infant) or incomprehensible sounds (child)', points: 2 },
      { label: '1 — None', points: 1 },
    ]},
    { id: 'motor', label: 'Best motor response (pediatric)', options: [
      { label: '6 — Spontaneous purposeful movement (infant) or obeys (child)', points: 6, default: true },
      { label: '5 — Withdraws to touch (infant) or localizes pain (child)', points: 5 },
      { label: '4 — Withdraws to pain', points: 4 },
      { label: '3 — Abnormal flexion (decorticate)', points: 3 },
      { label: '2 — Abnormal extension (decerebrate)', points: 2 },
      { label: '1 — None', points: 1 },
    ]},
  ],
  bands: [
    { min: 13, max: 15, label: 'Mild brain injury', cls: 'cls-normal' },
    { min: 9, max: 12, label: 'Moderate brain injury', cls: 'cls-warn' },
    { min: 3, max: 8, label: 'Severe brain injury — consider airway protection', cls: 'cls-danger' },
  ],
  max: 15,
}

const faq = [
  { q: 'When should the Pediatric GCS be used?', a: 'In children up to ~ 5 years, where the standard verbal scale (oriented, confused, etc.) is developmentally inappropriate.' },
  { q: 'Is the score range the same as adult GCS?', a: 'Yes — 3 (worst) to 15 (best). Only the descriptors within each component differ for age-appropriate assessment.' },
  { q: 'Pediatric GCS or Raimondi?', a: 'Pediatric GCS is the standard worldwide in trauma; Raimondi is a simpler 3-item alternative occasionally used in neurosurgery.' },
  { q: 'When does GCS ≤ 8 prompt intubation?', a: 'In pediatric TBI, GCS ≤ 8 typically prompts consideration of airway protection, but airway, ventilation, and exam stability must be assessed together.' },
]
const references = [
  { citation: 'Holmes JF, Palchak MJ, MacFarlane T, Kuppermann N. Performance of the pediatric Glasgow coma scale in children with blunt head trauma. <em>Acad Emerg Med</em>. 2005;12(9):814-819.' },
  { citation: 'James HE. Neurologic evaluation and support in the child with an acute brain insult. <em>Pediatr Ann</em>. 1986;15(1):16-22.' },
]
const relatedTools = [
  { slug: 'raimondi-coma-scale', name: 'Raimondi Coma Scale' },
  { slug: 'glasgow-coma-pupil', name: 'Adult GCS-P' },
  { slug: 'apgar-score', name: 'APGAR Score' },
]
---
<ScoreCalc
  slug="pediatric-glasgow"
  name="Pediatric Glasgow Coma Scale Calculator"
  schemaName="Pediatric Glasgow Coma Scale"
  shortDescription="Pediatric-adapted Glasgow Coma Scale for infants and young children (3–15)."
  metaTitle="Pediatric Glasgow Coma Scale Calculator (3–15) | maratool"
  metaDescription="Free pediatric Glasgow Coma Scale calculator. Age-appropriate descriptors for infants and young children."
  subcategory="Pediatric"
  subcategorySlug="pediatric"
  howTo={[
    'Assess eye opening, age-appropriate verbal response, and motor response.',
    'The total GCS (3–15) and severity interpretation update instantly.',
    'Re-assess frequently in head injury — trend changes drive management.',
  ]}
  faq={faq}
  relatedTools={relatedTools}
  references={references}
  spec={spec}
/>
