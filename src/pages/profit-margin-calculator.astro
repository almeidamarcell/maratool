---
import Base from '../layouts/Base.astro'
import Layout from '../components/Layout.astro'
import ToolShell from '../components/ToolShell.astro'

const seo = {
  title: 'Profit Margin Calculator — Gross & Net Margin | maratool',
  description: 'Calculate gross profit, net profit, and margin percentage from revenue and costs. Free business calculator, instant results.',
  canonical: 'https://maratool.com/profit-margin-calculator',
  schema: {
    '@context': 'https://schema.org',
    '@type': 'WebApplication',
    name: 'Profit Margin Calculator',
    url: 'https://maratool.com/profit-margin-calculator',
    applicationCategory: 'BusinessApplication',
    operatingSystem: 'Any',
    offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
    description: 'Calculate gross profit, net profit, and margin percentage from revenue and costs. Free business calculator, instant results.',
  },
  breadcrumbSchema: {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://maratool.com' },
      { '@type': 'ListItem', position: 2, name: 'Business', item: 'https://maratool.com/business' },
      { '@type': 'ListItem', position: 3, name: 'Calculator', item: 'https://maratool.com/business/calculator' },
      { '@type': 'ListItem', position: 4, name: 'Profit Margin Calculator', item: 'https://maratool.com/profit-margin-calculator' },
    ],
  },
  faqSchema: {
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: [
      { '@type': 'Question', name: 'What is gross margin?', acceptedAnswer: { '@type': 'Answer', text: 'Gross margin = (Revenue − COGS) / Revenue × 100. It measures profitability before operating expenses.' } },
      { '@type': 'Question', name: 'What is net margin?', acceptedAnswer: { '@type': 'Answer', text: 'Net margin = (Revenue − COGS − Expenses) / Revenue × 100. It is the bottom-line profit percentage.' } },
      { '@type': 'Question', name: 'What is a good profit margin?', acceptedAnswer: { '@type': 'Answer', text: 'Varies by industry. Software often targets 20%+ net margin; retail may be 2–5%.' } },
      { '@type': 'Question', name: 'Is my data sent to a server?', acceptedAnswer: { '@type': 'Answer', text: 'No. All calculations happen in your browser.' } }
    ]
  }
}

const howTo = [
  'Enter total revenue.',
  'Enter cost of goods sold (COGS) and operating expenses.',
  'See gross profit, net profit, and margin percentages.'
]

const faq = [
  { q: 'What is gross margin?', a: 'Gross margin = (Revenue − COGS) / Revenue × 100. It measures profitability before operating expenses.' },
  { q: 'What is net margin?', a: 'Net margin = (Revenue − COGS − Expenses) / Revenue × 100. It is the bottom-line profit percentage.' },
  { q: 'What is a good profit margin?', a: 'Varies by industry. Software often targets 20%+ net margin; retail may be 2–5%.' },
  { q: 'Is my data sent to a server?', a: 'No. All calculations happen in your browser.' }
]

const relatedTools = [
  { slug: 'break-even-calculator', name: 'Break-even Calculator' },
  { slug: 'roi-calculator', name: 'ROI Calculator' },
  { slug: 'vat-calculator', name: 'VAT Calculator' }
]

const breadcrumbs = [
  { label: 'Home', href: '/' },
  { label: 'Business', href: '/business' },
  { label: 'Calculator', href: '/business/calculator' },
  { label: 'Profit Margin Calculator' }
]
---
<Base {...seo}>
  <Layout>
    <ToolShell slug="profit-margin-calculator" name="Profit Margin Calculator" description="Enter revenue, cost of goods sold, and operating expenses to see gross and net profit margins." howTo={howTo} faq={faq} relatedTools={relatedTools} breadcrumbs={breadcrumbs}>
      <div class="tool-container" style="min-height:300px;">
        <div class="calc-field"><label class="tool-label" for="pm-revenue">Revenue ($)</label><input type="number" id="pm-revenue" class="tool-input" placeholder="100000" min="0" /></div>
        <div class="calc-row">
          <div class="calc-field"><label class="tool-label" for="pm-cogs">Cost of goods sold ($)</label><input type="number" id="pm-cogs" class="tool-input" placeholder="40000" min="0" /></div>
          <div class="calc-field"><label class="tool-label" for="pm-expenses">Operating expenses ($)</label><input type="number" id="pm-expenses" class="tool-input" placeholder="30000" min="0" /></div>
        </div>
        <div class="tool-stats">
          <div class="tool-stat"><span class="tool-stat-value" id="pm-gross-profit">—</span><span class="tool-stat-label">Gross profit</span></div>
          <div class="tool-stat"><span class="tool-stat-value" id="pm-net-profit">—</span><span class="tool-stat-label">Net profit</span></div>
          <div class="tool-stat"><span class="tool-stat-value" id="pm-gross-margin">—</span><span class="tool-stat-label">Gross margin</span></div>
          <div class="tool-stat"><span class="tool-stat-value" id="pm-net-margin">—</span><span class="tool-stat-label">Net margin</span></div>
        </div>
      </div>
    </ToolShell>
  </Layout>
</Base>

<style is:global>
  .calc-row { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; margin-bottom: 1rem; }
  .calc-field { margin-bottom: 0.75rem; }
  .calc-select { max-width: 100%; }
  @media (max-width: 600px) { .calc-row { grid-template-columns: 1fr; } }
</style>
<script src="../tools/profit-margin-calculator.js"></script>
