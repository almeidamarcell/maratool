---
import Base from '../layouts/Base.astro'
import Layout from '../components/Layout.astro'
import ToolShell from '../components/ToolShell.astro'

const seo = {
  title: 'Favicon Generator — Create favicons from any image | maratool',
  description: 'Generate favicons in all sizes from a single image. Download as ICO, individual PNGs, or a complete ZIP. Free, no sign-up, runs in your browser.',
  canonical: 'https://maratool.com/favicon-generator',
  schema: {
    '@context': 'https://schema.org',
    '@type': 'WebApplication',
    name: 'Favicon Generator',
    url: 'https://maratool.com/favicon-generator',
    applicationCategory: 'MultimediaApplication',
    operatingSystem: 'Any',
    offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
    description: 'Generate favicons in all sizes from a single image.',
  },
  breadcrumbSchema: {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://maratool.com' },
      { '@type': 'ListItem', position: 2, name: 'Image', item: 'https://maratool.com/image' },
      { '@type': 'ListItem', position: 3, name: 'Transform', item: 'https://maratool.com/image/transform' },
      { '@type': 'ListItem', position: 4, name: 'Favicon Generator', item: 'https://maratool.com/favicon-generator' },
    ],
  },
  faqSchema: {
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: [
      {
        '@type': 'Question',
        name: 'What sizes do I need for a favicon?',
        acceptedAnswer: { '@type': 'Answer', text: 'The most common sizes are 16x16 and 32x32 for browsers, 48x48 for Windows, 180x180 for Apple Touch Icon, and 192x192 and 512x512 for Android and PWAs. This tool generates all of them.' }
      },
      {
        '@type': 'Question',
        name: 'What is an ICO file?',
        acceptedAnswer: { '@type': 'Answer', text: 'ICO is the traditional favicon format that can contain multiple sizes in a single file. Browsers pick the best size automatically. This tool creates an ICO containing 16x16, 32x32, and 48x48 PNG images.' }
      },
      {
        '@type': 'Question',
        name: 'What image format should I use as a source?',
        acceptedAnswer: { '@type': 'Answer', text: 'Use a square PNG or SVG at least 512x512 pixels. SVGs scale perfectly to any size. JPGs work too but may have compression artifacts. Avoid non-square images as they will be stretched.' }
      },
      {
        '@type': 'Question',
        name: 'Does this tool upload my image to a server?',
        acceptedAnswer: { '@type': 'Answer', text: 'No. All image processing happens in your browser using the Canvas API. Your image never leaves your device.' }
      }
    ]
  }
}

const howTo = [
  'Upload or drop a square image (PNG, JPG, or SVG).',
  'Preview all generated sizes in the grid below.',
  'Download the ICO file, individual PNGs, or everything as a ZIP.'
]

const faq = [
  { q: 'What sizes do I need for a favicon?', a: '16x16 and 32x32 for browsers, 48x48 for Windows, 180x180 for Apple Touch Icon, and 192x192 and 512x512 for PWAs.' },
  { q: 'What is an ICO file?', a: 'ICO is the traditional favicon format containing multiple sizes. Browsers pick the best one. This tool creates an ICO with 16, 32, and 48px PNGs inside.' },
  { q: 'What image format should I use as a source?', a: 'Use a square PNG or SVG at least 512x512. SVGs scale perfectly. JPGs work but may have artifacts.' },
  { q: 'Does this tool upload my image to a server?', a: 'No. All processing uses the Canvas API in your browser. Your image never leaves your device.' }
]

const relatedTools = [
  { slug: 'svg-optimizer', name: 'SVG Optimizer' },
  { slug: 'color-shades', name: 'Color Shades Generator' },
  { slug: 'image-converter', name: 'Image Format Converter — PNG, JPEG, WebP' },
]

const breadcrumbs = [
  { label: 'Home', href: '/' },
  { label: 'Image', href: '/image' },
  { label: 'Transform', href: '/image/transform' },
  { label: 'Favicon Generator' },
]
---
<Base {...seo}>
  <Layout>
    <ToolShell slug="favicon-generator" name="Favicon Generator" description="Generate favicons in all sizes from a single image. Download as ICO, PNG, or ZIP." howTo={howTo} faq={faq} relatedTools={relatedTools} breadcrumbs={breadcrumbs}>
      <div class="tool-container">
        <div class="fg-upload" id="fg-upload">
          <input type="file" id="fg-file" accept="image/png,image/jpeg,image/svg+xml" hidden />
          <div class="fg-upload-content" id="fg-upload-content">
            <div class="fg-upload-icon">🖼️</div>
            <p class="fg-upload-text">Drop an image here or <button type="button" class="fg-upload-btn" id="fg-browse">browse</button></p>
            <p class="fg-upload-hint">PNG, JPG, or SVG — square recommended</p>
          </div>
        </div>

        <div class="fg-source" id="fg-source" style="display:none;">
          <div class="fg-source-preview">
            <img id="fg-source-img" alt="Source image" />
            <span class="fg-source-info" id="fg-source-info"></span>
          </div>
          <button class="fg-change-btn" id="fg-change" type="button">Change image</button>
        </div>

        <div class="fg-sizes" id="fg-sizes" style="display:none;">
          <span class="tool-label">Generated sizes</span>
          <div class="fg-sizes-grid" id="fg-sizes-grid"></div>
        </div>

        <div class="fg-downloads" id="fg-downloads" style="display:none;">
          <button class="fg-download-btn" id="fg-download-ico" type="button">Download .ico (16+32+48)</button>
          <button class="fg-download-btn fg-download-primary" id="fg-download-zip" type="button">Download All (ZIP)</button>
        </div>
      </div>
    </ToolShell>
  </Layout>
</Base>
<style>
  .fg-upload {
    border: 2px dashed var(--border);
    border-radius: var(--radius);
    padding: 3rem 2rem;
    text-align: center;
    cursor: pointer;
    transition: border-color 0.15s, background 0.15s;
    margin-bottom: 1.25rem;
  }
  .fg-upload:hover, .fg-upload.dragover {
    border-color: var(--accent);
    background: var(--bg-soft);
  }
  .fg-upload-icon { font-size: 36px; margin-bottom: 0.75rem; }
  .fg-upload-text { color: var(--text-2); font-size: 14px; }
  .fg-upload-btn {
    background: none;
    border: none;
    color: var(--accent);
    font-weight: 600;
    cursor: pointer;
    font-size: 14px;
    text-decoration: underline;
    padding: 0;
  }
  .fg-upload-hint { color: var(--text-3); font-size: 12px; margin-top: 0.375rem; }

  .fg-source {
    display: flex;
    align-items: center;
    gap: 1rem;
    background: var(--bg-soft);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 1rem;
    margin-bottom: 1.25rem;
  }
  .fg-source-preview {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    flex: 1;
  }
  .fg-source-preview img {
    width: 64px;
    height: 64px;
    object-fit: contain;
    border: 1px solid var(--border);
    border-radius: 6px;
    background: #fff;
  }
  .fg-source-info { font-size: 13px; color: var(--text-2); }
  .fg-change-btn {
    font-size: 13px;
    color: var(--accent);
    background: none;
    border: 1px solid var(--accent);
    border-radius: var(--radius);
    padding: 6px 12px;
    cursor: pointer;
    flex-shrink: 0;
  }
  .fg-change-btn:hover { background: var(--accent); color: #fff; }

  .fg-sizes { margin-bottom: 1.25rem; }
  .fg-sizes-grid {
    display: grid;
    grid-template-columns: repeat(6, 1fr);
    gap: 0.75rem;
    margin-top: 0.5rem;
  }
  .fg-size-card {
    text-align: center;
    background: var(--bg-soft);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 0.75rem 0.5rem;
  }
  .fg-size-card canvas {
    display: block;
    margin: 0 auto 0.5rem;
    image-rendering: pixelated;
    border: 1px solid var(--border);
    background: #fff;
  }
  .fg-size-label {
    font-size: 11px;
    font-weight: 600;
    color: var(--text);
    margin-bottom: 0.25rem;
  }
  .fg-size-download {
    font-size: 11px;
    color: var(--accent);
    cursor: pointer;
    background: none;
    border: none;
    padding: 0;
  }
  .fg-size-download:hover { text-decoration: underline; }

  .fg-downloads {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
  }
  .fg-download-btn {
    padding: 10px 20px;
    font-size: 14px;
    font-weight: 600;
    border: 1px solid var(--border);
    border-radius: var(--radius);
    background: var(--bg);
    color: var(--text);
    cursor: pointer;
    transition: background 0.15s;
  }
  .fg-download-btn:hover { background: var(--bg-soft); }
  .fg-download-primary {
    background: var(--accent);
    color: #fff;
    border-color: var(--accent);
  }
  .fg-download-primary:hover { background: var(--accent-hover); }

  @media (max-width: 768px) {
    .fg-sizes-grid { grid-template-columns: repeat(3, 1fr); }
    .fg-source { flex-direction: column; }
  }
</style>
<script src="../tools/favicon-generator.js"></script>
