---
import ScoreCalc from '../components/ScoreCalc.astro'

const spec = {
  items: [
    { id: 'confusion', label: 'Confusion (new)', options: [
      { label: 'No (0)', points: 0, default: true }, { label: 'Yes (1)', points: 1 },
    ]},
    { id: 'urea', label: 'Urea > 7 mmol/L (BUN > 19 mg/dL)', options: [
      { label: 'No (0)', points: 0, default: true }, { label: 'Yes (1)', points: 1 },
    ]},
    { id: 'rr', label: 'Respiratory rate ≥ 30/min', options: [
      { label: 'No (0)', points: 0, default: true }, { label: 'Yes (1)', points: 1 },
    ]},
    { id: 'bp', label: 'Low blood pressure (SBP < 90 or DBP ≤ 60)', options: [
      { label: 'No (0)', points: 0, default: true }, { label: 'Yes (1)', points: 1 },
    ]},
    { id: 'age', label: 'Age ≥ 65', options: [
      { label: 'No (0)', points: 0, default: true }, { label: 'Yes (1)', points: 1 },
    ]},
  ],
  bands: [
    { min: 0, max: 1, label: '0–1 — Low mortality (< 3%) — outpatient', cls: 'cls-normal' },
    { min: 2, max: 2, label: '2 — Moderate (~ 9%) — short admission or supervised outpatient', cls: 'cls-warn' },
    { min: 3, max: 5, label: '3–5 — Severe (~ 15–40%) — admit, consider ICU if 4–5', cls: 'cls-danger' },
  ],
  max: 5,
}

const faq = [
  { q: 'What is CURB-65?', a: 'Confusion, Urea, Respiratory rate, Blood pressure, age ≥ 65 — a 5-point bedside score for severity of community-acquired pneumonia.' },
  { q: 'CURB-65 vs PSI?', a: 'PSI (Pneumonia Severity Index) is more accurate but requires 20 variables. CURB-65 is simpler and a reasonable first pass at the bedside.' },
  { q: 'When should a patient be admitted?', a: 'CURB-65 = 0–1 generally outpatient; = 2 short admission or supervised outpatient therapy; ≥ 3 hospital admission; 4–5 strongly consider ICU.' },
  { q: 'Is CRB-65 also valid?', a: 'Yes — CRB-65 (no urea) is useful when labs are not immediately available, often in primary care. Same thresholds apply.' },
]
const references = [
  { citation: 'Lim WS, van der Eerden MM, Laing R, et al. Defining community acquired pneumonia severity on presentation to hospital: an international derivation and validation study. <em>Thorax</em>. 2003;58(5):377-382.' },
]
const relatedTools = [
  { slug: 'psi-port', name: 'Pneumonia Severity Index (PSI)' },
  { slug: 'qsofa', name: 'qSOFA' },
  { slug: 'news-2', name: 'NEWS-2' },
]
---
<ScoreCalc
  slug="curb-65"
  name="CURB-65 Pneumonia Severity Calculator"
  schemaName="CURB-65"
  shortDescription="CURB-65 score for community-acquired pneumonia severity (0–5)."
  metaTitle="CURB-65 Calculator (Pneumonia Severity) | maratool"
  metaDescription="Free CURB-65 calculator for community-acquired pneumonia. 5 bedside criteria with mortality and disposition guidance."
  subcategory="Score"
  subcategorySlug="score"
  howTo={[
    'Check each of the 5 criteria.',
    'The score (0–5) and disposition guidance update instantly.',
    'For full risk stratification consider PSI or NEWS-2 alongside.',
  ]}
  faq={faq}
  relatedTools={relatedTools}
  references={references}
  spec={spec}
/>
