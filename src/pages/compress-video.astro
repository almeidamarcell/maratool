---
import Base from '../layouts/Base.astro'
import Layout from '../components/Layout.astro'
import ToolShell from '../components/ToolShell.astro'

const seo = {
  title: 'Compress Video Online — Reduce MP4 Size Free | maratool',
  description: 'Compress video files in your browser for free. Reduce MP4, WebM, MOV file size with one click. No upload, no watermark, runs entirely on your device.',
  canonical: 'https://maratool.com/compress-video',
  schema: {
    '@context': 'https://schema.org',
    '@type': 'WebApplication',
    name: 'Compress Video Online',
    url: 'https://maratool.com/compress-video',
    applicationCategory: 'UtilitiesApplication',
    operatingSystem: 'Any',
    offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
    description: 'Compress MP4, WebM, and MOV video files directly in your browser. No upload, no watermark, no signup.',
  },
  breadcrumbSchema: {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://maratool.com' },
      { '@type': 'ListItem', position: 2, name: 'Converter', item: 'https://maratool.com/converter' },
      { '@type': 'ListItem', position: 3, name: 'Video', item: 'https://maratool.com/converter/video' },
      { '@type': 'ListItem', position: 4, name: 'Compress Video', item: 'https://maratool.com/compress-video' },
    ],
  },
  faqSchema: {
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: [
      {
        '@type': 'Question',
        name: 'How much can I compress a video?',
        acceptedAnswer: { '@type': 'Answer', text: 'It depends on the source. Videos recorded on phones are often already compressed — you might save 20–50%. Screen recordings or raw footage can shrink 60–80%. The "Small file" preset uses CRF 32, which gives the most aggressive compression; "Balanced" (CRF 26) is a good middle ground for most use cases.' }
      },
      {
        '@type': 'Question',
        name: 'Will the quality drop a lot?',
        acceptedAnswer: { '@type': 'Answer', text: 'The "High quality" preset (CRF 20) is near-visually lossless — most people cannot tell the difference from the original. "Balanced" (CRF 26) is the libx264 default and looks great for web sharing. "Small file" (CRF 32) is noticeably softer but dramatically smaller — good for previews or messaging.' }
      },
      {
        '@type': 'Question',
        name: 'What is CRF and how does it work?',
        acceptedAnswer: { '@type': 'Answer', text: 'CRF stands for Constant Rate Factor. It tells the encoder how much quality to preserve: lower = better quality + larger file, higher = smaller file + lower quality. CRF 18 is visually lossless, 23 is the encoder default, and 28+ is visibly compressed. This tool maps the three presets to CRF 20, 26, and 32.' }
      },
      {
        '@type': 'Question',
        name: 'What is the maximum file size?',
        acceptedAnswer: { '@type': 'Answer', text: 'Up to 2 GB on desktop; mobile browsers may struggle above 500 MB. Everything runs locally in your browser — nothing is uploaded to any server — so the practical limit is your device memory, not a server quota.' }
      }
    ]
  }
}

const howTo = [
  'Drop a video file or click to select an MP4, WebM, or MOV.',
  'Choose a quality preset — Balanced is recommended for most videos.',
  'Click "Compress video" and download the smaller result.'
]

const faq = [
  { q: 'How much can I compress a video?', a: 'It depends on the source. Videos recorded on phones are often already compressed — you might save 20–50%. Screen recordings or raw footage can shrink 60–80%. The "Small file" preset uses CRF 32 for the most aggressive compression; "Balanced" (CRF 26) is a good middle ground.' },
  { q: 'Will the quality drop a lot?', a: '"High quality" (CRF 20) is near-visually lossless. "Balanced" (CRF 26) is the libx264 default and looks great for web sharing. "Small file" (CRF 32) is noticeably softer but dramatically smaller — good for previews or messaging.' },
  { q: 'What is CRF and how does it work?', a: 'CRF stands for Constant Rate Factor. Lower = better quality + larger file; higher = smaller file + lower quality. CRF 18 is visually lossless, 23 is the encoder default, 28+ is visibly compressed. This tool uses CRF 20, 26, and 32 for the three presets.' },
  { q: 'What is the maximum file size?', a: 'Up to 2 GB on desktop; mobile browsers may struggle above 500 MB. Everything runs locally — nothing is uploaded to any server — so the limit is your device memory.' },
]

const relatedTools = [
  { slug: 'trim-video', name: 'Trim Video Online' },
  { slug: 'video-to-gif', name: 'Video to GIF Converter' },
  { slug: 'fps-converter', name: 'FPS Converter' },
]

const breadcrumbs = [
  { label: 'Home', href: '/' },
  { label: 'Converter', href: '/converter' },
  { label: 'Video', href: '/converter/video' },
  { label: 'Compress Video' },
]
---
<Base {...seo}>
  <Layout>
    <ToolShell slug="compress-video" name="Compress Video Online" description="Reduce MP4, WebM, and MOV file size in your browser. Choose a quality preset — no upload, no watermark, no signup." howTo={howTo} faq={faq} relatedTools={relatedTools} breadcrumbs={breadcrumbs}>
      <div class="tool-container" style="min-height:400px;">
        <!-- Mobile banner -->
        <div class="cv-mobile-banner" id="cv-mobile-banner" style="display:none;">
          <span>This works on mobile but is faster on desktop. Files above 500 MB may fail on phones.</span>
          <button type="button" class="cv-mobile-banner-dismiss" id="cv-mobile-banner-dismiss" aria-label="Dismiss">&times;</button>
        </div>

        <!-- Drop zone -->
        <div class="cv-dropzone" id="cv-dropzone">
          <input type="file" id="cv-file-input" accept="video/mp4,video/webm,video/quicktime" hidden />
          <div class="cv-dropzone-inner">
            <svg class="cv-upload-icon" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
              <polyline points="17 8 12 3 7 8"/>
              <line x1="12" y1="3" x2="12" y2="15"/>
            </svg>
            <p class="cv-dropzone-title">Drop a video here</p>
            <p class="cv-dropzone-sub">or click to select a file</p>
            <p class="cv-dropzone-formats">MP4, WebM, MOV — up to 2 GB</p>
          </div>
        </div>

        <div class="cv-info" id="cv-info">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="16" x2="12" y2="12"/><line x1="12" y1="8" x2="12.01" y2="8"/></svg>
          <span>The FFmpeg engine (~25 MB) downloads on first use and is cached by your browser. Compression re-encodes with libx264 — your file never leaves your device.</span>
        </div>

        <!-- Settings / editor -->
        <div class="cv-settings" id="cv-settings" style="display:none;">
          <div class="cv-preview-row">
            <div class="cv-video-wrap">
              <video id="cv-video" controls preload="metadata"></video>
            </div>
            <div class="cv-metadata">
              <div class="cv-stat">
                <span class="cv-stat-value" id="cv-duration">—</span>
                <span class="cv-stat-label">Duration</span>
              </div>
              <div class="cv-stat">
                <span class="cv-stat-value" id="cv-dimensions">—</span>
                <span class="cv-stat-label">Resolution</span>
              </div>
              <div class="cv-stat">
                <span class="cv-stat-value" id="cv-filesize">—</span>
                <span class="cv-stat-label">File size</span>
              </div>
            </div>
          </div>

          <!-- Quality preset -->
          <div class="cv-section">
            <span class="cv-section-label">Quality preset</span>
            <div class="cv-quality-group">
              <label class="cv-quality-radio">
                <input type="radio" name="cv-quality" value="high" />
                <div class="cv-quality-card">
                  <span class="cv-quality-name">High quality</span>
                  <span class="cv-quality-desc">Larger file — near-lossless (CRF 20)</span>
                </div>
              </label>
              <label class="cv-quality-radio">
                <input type="radio" name="cv-quality" value="balanced" checked />
                <div class="cv-quality-card">
                  <span class="cv-quality-name">Balanced <span class="cv-quality-badge">Recommended</span></span>
                  <span class="cv-quality-desc">Good quality, noticeably smaller (CRF 26)</span>
                </div>
              </label>
              <label class="cv-quality-radio">
                <input type="radio" name="cv-quality" value="small" />
                <div class="cv-quality-card">
                  <span class="cv-quality-name">Small file</span>
                  <span class="cv-quality-desc">Smallest size, lower quality (CRF 32)</span>
                </div>
              </label>
            </div>
          </div>

          <div class="cv-actions">
            <button class="tool-button" id="cv-compress">Compress video</button>
            <button class="copy-btn" id="cv-change">Change video</button>
          </div>
        </div>

        <!-- Progress -->
        <div class="cv-progress" id="cv-progress" style="display:none;">
          <div class="cv-progress-text" id="cv-progress-text">Loading FFmpeg...</div>
          <div class="cv-progress-track">
            <div class="cv-progress-fill" id="cv-progress-fill"></div>
          </div>
          <div class="cv-progress-detail" id="cv-progress-detail"></div>
        </div>

        <!-- Error -->
        <div class="cv-error" id="cv-error" style="display:none;">
          <span class="cv-error-text" id="cv-error-text"></span>
          <button class="cv-error-retry" id="cv-error-retry">Try again</button>
        </div>

        <!-- Result -->
        <div class="cv-result" id="cv-result" style="display:none;">
          <div class="cv-result-preview">
            <video id="cv-result-video" controls></video>
          </div>
          <div class="cv-result-stats" id="cv-result-stats"></div>
          <div class="cv-result-actions">
            <button class="tool-button" id="cv-download">Download compressed video</button>
            <button class="copy-btn" id="cv-new">Compress another</button>
          </div>
        </div>
      </div>
    </ToolShell>
  </Layout>
</Base>
<style is:global>
  /* Mobile banner */
  .cv-mobile-banner {
    display: flex; align-items: center; justify-content: space-between; gap: 0.75rem;
    padding: 0.625rem 0.875rem; margin-bottom: 1rem;
    background: var(--bg-soft); border: 1px solid var(--border); border-radius: var(--radius);
    font-size: 0.8125rem; color: var(--text-2);
  }
  .cv-mobile-banner-dismiss {
    background: none; border: none; font-size: 1.25rem; line-height: 1; cursor: pointer;
    color: var(--text-3); padding: 0 0.25rem;
  }
  .cv-mobile-banner-dismiss:hover { color: var(--text); }

  /* Dropzone */
  .cv-dropzone {
    border: 2px dashed var(--border);
    border-radius: var(--radius);
    padding: 3rem 2rem;
    text-align: center;
    cursor: pointer;
    transition: border-color 0.2s, background 0.2s;
  }
  .cv-dropzone:hover, .cv-dropzone.drag-over {
    border-color: var(--accent);
    background: var(--bg-soft);
  }
  .cv-dropzone-inner {
    display: flex; flex-direction: column; align-items: center; gap: 0.5rem;
  }
  .cv-upload-icon { color: var(--text-3); margin-bottom: 0.5rem; }
  .cv-dropzone-title { font-size: 1.125rem; font-weight: 600; color: var(--text); margin: 0; }
  .cv-dropzone-sub { font-size: 0.875rem; color: var(--text-2); margin: 0; }
  .cv-dropzone-formats { font-size: 0.75rem; color: var(--text-3); margin: 0.25rem 0 0; }

  .cv-info {
    display: flex; align-items: flex-start; gap: 0.5rem;
    padding: 0.75rem 1rem; background: var(--bg-soft);
    border: 1px solid var(--border); border-radius: var(--radius);
    margin-top: 1rem; font-size: 0.8125rem; color: var(--text-2); line-height: 1.5;
  }
  .cv-info svg { flex-shrink: 0; margin-top: 1px; color: var(--text-3); }

  /* Editor */
  .cv-preview-row {
    display: flex; gap: 1.5rem; margin-bottom: 1.25rem;
  }
  .cv-video-wrap { flex: 1; min-width: 0; }
  .cv-video-wrap video {
    width: 100%; border-radius: var(--radius);
    border: 1px solid var(--border); background: #000;
  }
  .cv-metadata {
    display: flex; flex-direction: column; gap: 1rem; min-width: 130px;
  }
  .cv-stat { display: flex; flex-direction: column; gap: 0.125rem; }
  .cv-stat-value {
    font-size: 1.125rem; font-weight: 600; color: var(--text);
    font-family: var(--font-mono);
  }
  .cv-stat-label {
    font-size: 0.75rem; color: var(--text-3);
    text-transform: uppercase; letter-spacing: 0.05em;
  }

  .cv-section {
    background: var(--bg-soft); border: 1px solid var(--border);
    border-radius: var(--radius); padding: 1rem; margin-bottom: 1rem;
  }
  .cv-section-label {
    display: block; font-size: 0.8125rem; font-weight: 600;
    color: var(--text-2); text-transform: uppercase;
    letter-spacing: 0.05em; margin-bottom: 0.75rem;
  }

  /* Quality preset radios */
  .cv-quality-group {
    display: flex; flex-direction: column; gap: 0.5rem;
  }
  .cv-quality-radio {
    display: flex; align-items: flex-start; gap: 0.75rem;
    padding: 0.75rem; border: 1px solid var(--border);
    border-radius: var(--radius); cursor: pointer;
    background: var(--bg); transition: border-color 0.15s, background 0.15s;
  }
  .cv-quality-radio:hover { border-color: var(--accent); background: var(--bg-soft); }
  .cv-quality-radio input[type="radio"] {
    margin-top: 3px; flex-shrink: 0; accent-color: var(--accent);
  }
  .cv-quality-radio input[type="radio"]:checked ~ .cv-quality-card { color: var(--text); }
  .cv-quality-radio:has(input:checked) { border-color: var(--accent); background: var(--bg-soft); }
  .cv-quality-card {
    display: flex; flex-direction: column; gap: 0.125rem;
  }
  .cv-quality-name {
    font-size: 0.9375rem; font-weight: 600; color: var(--text);
    display: flex; align-items: center; gap: 0.5rem;
  }
  .cv-quality-desc {
    font-size: 0.8125rem; color: var(--text-2);
  }
  .cv-quality-badge {
    font-size: 0.6875rem; font-weight: 600; letter-spacing: 0.04em;
    text-transform: uppercase; color: var(--accent);
    background: color-mix(in srgb, var(--accent) 10%, transparent);
    padding: 2px 6px; border-radius: 4px;
  }

  .cv-actions {
    display: flex; gap: 0.75rem; align-items: center; margin-top: 0.25rem;
  }

  /* Progress */
  .cv-progress { text-align: center; padding: 2rem; }
  .cv-progress-text {
    font-size: 0.9375rem; font-weight: 600; color: var(--text); margin-bottom: 1rem;
  }
  .cv-progress-track {
    width: 100%; max-width: 400px; height: 8px; background: var(--bg-hover);
    border-radius: 4px; margin: 0 auto; overflow: hidden;
  }
  .cv-progress-fill {
    height: 100%; background: var(--accent); border-radius: 4px;
    width: 0%; transition: width 0.3s;
  }
  .cv-progress-detail {
    font-size: 0.75rem; color: var(--text-3); margin-top: 0.5rem;
  }

  /* Error */
  .cv-error {
    background: var(--error-bg); border: 1px solid var(--error-border);
    border-radius: var(--radius); padding: 1rem;
    display: flex; align-items: center; justify-content: space-between; gap: 1rem;
  }
  .cv-error-text { color: #c53030; font-size: 0.875rem; }
  .cv-error-retry {
    padding: 6px 14px; background: var(--bg); border: 1px solid var(--border);
    border-radius: 6px; font-size: 0.8125rem; cursor: pointer; white-space: nowrap;
    color: var(--text);
  }
  .cv-error-retry:hover { background: var(--bg-hover); }

  /* Result */
  .cv-result-preview {
    text-align: center; margin-bottom: 0.75rem;
    border: 1px solid var(--border); border-radius: var(--radius);
    padding: 0.5rem; min-height: 100px;
    display: flex; align-items: center; justify-content: center;
    background: var(--bg-soft);
  }
  .cv-result-preview video { max-width: 100%; max-height: 500px; border-radius: 6px; background: #000; }
  .cv-result-stats {
    font-size: 0.875rem; color: var(--text-2); margin-bottom: 0.75rem;
    text-align: center; line-height: 1.6;
  }
  .cv-result-actions {
    display: flex; gap: 0.75rem; align-items: center; justify-content: center;
  }

  @media (max-width: 768px) {
    .cv-preview-row { flex-direction: column; }
    .cv-metadata { flex-direction: row; min-width: 0; flex-wrap: wrap; }
    .cv-quality-group { gap: 0.375rem; }
  }
</style>
<script src="../tools/compress-video.js"></script>
