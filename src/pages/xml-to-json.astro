---
import Base from '../layouts/Base.astro'
import Layout from '../components/Layout.astro'
import ToolShell from '../components/ToolShell.astro'

const seo = {
  title: 'XML to JSON Converter — Convert XML to JSON online | maratool',
  description: 'Convert XML to JSON instantly in your browser. Paste your XML and get a clean JSON object. Handles attributes, nested elements, and repeated tags. Free.',
  canonical: 'https://maratool.com/xml-to-json',
  schema: {
    '@context': 'https://schema.org',
    '@type': 'WebApplication',
    name: 'XML to JSON Converter',
    url: 'https://maratool.com/xml-to-json',
    applicationCategory: 'DeveloperApplication',
    operatingSystem: 'Any',
    offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
    description: 'Convert XML to JSON online.',
  },
  breadcrumbSchema: {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://maratool.com' },
      { '@type': 'ListItem', position: 2, name: 'Converter', item: 'https://maratool.com/converter' },
      { '@type': 'ListItem', position: 3, name: 'XML to JSON', item: 'https://maratool.com/xml-to-json' },
    ],
  },
  faqSchema: {
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: [
      {
        '@type': 'Question',
        name: 'How are XML attributes converted to JSON?',
        acceptedAnswer: { '@type': 'Answer', text: 'XML attributes are converted to JSON keys prefixed with "@". For example, <item id="1"> becomes { "item": { "@id": "1" } }. This is a common convention for XML-to-JSON mapping that preserves the distinction between attributes and child elements.' }
      },
      {
        '@type': 'Question',
        name: 'How are repeated XML elements handled?',
        acceptedAnswer: { '@type': 'Answer', text: 'When the same element name appears multiple times under a parent, they are automatically combined into a JSON array. For example, multiple <item> elements become { "items": { "item": ["a", "b", "c"] } }.' }
      },
      {
        '@type': 'Question',
        name: 'Does this handle XML namespaces?',
        acceptedAnswer: { '@type': 'Answer', text: 'Basic namespace prefixes are preserved as part of the element name in the JSON output (e.g., <ns:element> becomes "ns:element"). Full XML namespace resolution is not performed.' }
      },
      {
        '@type': 'Question',
        name: 'Does this converter send data to a server?',
        acceptedAnswer: { '@type': 'Answer', text: 'No. The conversion uses the browser\'s built-in DOMParser API, which runs entirely locally. No data is sent to any server. The converter works offline once the page has loaded.' }
      }
    ]
  }
}

const howTo = [
  'Paste your XML into the input panel on the left.',
  'The JSON output appears on the right instantly as you type.',
  'Click Copy to copy the JSON to your clipboard.'
]

const faq = [
  { q: 'How are XML attributes converted to JSON?', a: 'Attributes become keys prefixed with "@". For example, <item id="1"> becomes { "item": { "@id": "1" } }.' },
  { q: 'How are repeated XML elements handled?', a: 'Repeated sibling elements with the same name are combined into a JSON array automatically.' },
  { q: 'Does this handle XML namespaces?', a: 'Namespace prefixes are preserved as part of the key name (e.g., "ns:element"). Full namespace resolution is not performed.' },
  { q: 'Does this converter send data to a server?', a: 'No. Conversion uses the browser\'s built-in DOMParser. No data leaves your device.' }
]

const relatedTools = [
  { slug: 'yaml-to-json', name: 'YAML to JSON Converter' },
  { slug: 'json-formatter', name: 'JSON Formatter' },
]

const breadcrumbs = [
  { label: 'Home', href: '/' },
  { label: 'Converter', href: '/converter' },
  { label: 'XML to JSON' },
]
---
<Base {...seo}>
  <Layout>
    <ToolShell slug="xml-to-json" name="XML to JSON Converter" description="Convert XML to JSON instantly in your browser. Paste your XML and get a clean JSON object — handles attributes, nested elements, and repeated tags." howTo={howTo} faq={faq} relatedTools={relatedTools} breadcrumbs={breadcrumbs}>
      <div class="tool-container" style="min-height: 420px;">
        <div class="xtj-grid">
          <div class="xtj-panel">
            <div class="xtj-header">
              <span class="tool-label">XML Input</span>
            </div>
            <textarea id="xtj-xml-input" class="tool-input xtj-textarea" spellcheck="false" placeholder="<root>&#10;  <name>Alice</name>&#10;  <age>30</age>&#10;</root>"></textarea>
            <div id="xtj-error" class="xtj-error" style="display:none;"></div>
          </div>
          <div class="xtj-panel">
            <div class="xtj-header">
              <span class="tool-label">JSON Output</span>
              <button class="sg-copy-btn" id="xtj-copy" type="button">Copy</button>
            </div>
            <textarea id="xtj-json-output" class="tool-input xtj-textarea" readonly spellcheck="false"></textarea>
          </div>
        </div>
      </div>
    </ToolShell>
  </Layout>
</Base>
<style is:global>
  .xtj-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
  }
  .xtj-panel { display: flex; flex-direction: column; gap: 0.375rem; }
  .xtj-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }
  .xtj-header .tool-label { margin-bottom: 0; }
  .xtj-textarea {
    font-family: var(--font-mono, monospace);
    font-size: 12px;
    min-height: 300px;
    resize: vertical;
  }
  .xtj-error {
    font-size: 12px;
    color: #dc2626;
    padding: 4px 0;
  }
  @media (max-width: 600px) { .xtj-grid { grid-template-columns: 1fr; } }
</style>
<script src="../tools/xml-to-json.js"></script>
