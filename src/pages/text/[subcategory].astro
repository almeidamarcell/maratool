---
import Base from '../../layouts/Base.astro'
import Layout from '../../components/Layout.astro'
import HubPage from '../../components/HubPage.astro'
import { toolsByCategory, toolsFlatByCategory, subcategoryOrderByCategory } from '../../data/tools'

export function getStaticPaths() {
  const subs = subcategoryOrderByCategory.Text ?? []
  const catTools = toolsByCategory.Text ?? {}

  const descriptions: Record<string, { title: string; description: string; intro: string }> = {
    analyze: {
      title: 'Text Analysis Tools — maratool',
      description: 'Free browser-based text analysis tools. Compare text diffs, test regex patterns, calculate reading time — no sign-up, runs in your browser.',
      intro: 'Analyze, compare, and inspect text with fast, privacy-friendly tools that run locally.',
    },
    edit: {
      title: 'Text Editing Tools — maratool',
      description: 'Free browser-based text editing tools. Edit Markdown, generate Markdown tables, format JSON — no sign-up, runs in your browser.',
      intro: 'Edit, format, and structure text and data directly in your browser.',
    },
    generate: {
      title: 'Text Generator Tools — maratool',
      description: 'Free browser-based placeholder text generators. Lorem Ipsum, Mussum Ipsum, and Dilmes Ipsum — no sign-up, runs in your browser.',
      intro: 'Generate placeholder text in multiple styles for mockups and prototypes.',
    },
  }

  return subs.map(sub => {
    const slug = sub.toLowerCase()
    const meta = descriptions[slug] ?? {
      title: `${sub} Text Tools — maratool`,
      description: `Free browser-based text ${sub.toLowerCase()} tools — no sign-up, runs entirely in your browser.`,
      intro: `Text ${sub.toLowerCase()} tools that run locally in your browser.`,
    }
    return {
      params: { subcategory: slug },
      props: { sub, subTools: catTools[sub] ?? [], ...meta },
    }
  })
}

const { subcategory } = Astro.params
const { sub, subTools, title, description, intro } = Astro.props
const allTools = toolsFlatByCategory.Text ?? []
const subcategories = subcategoryOrderByCategory.Text ?? []

const seo = {
  title,
  description,
  canonical: `https://maratool.com/text/${subcategory}`,
  schema: {
    '@context': 'https://schema.org',
    '@type': 'CollectionPage',
    name: `Text ${sub} Tools`,
    url: `https://maratool.com/text/${subcategory}`,
    description,
    hasPart: subTools.filter((tool: { live: boolean }) => tool.live).map((tool: { name: string; slug: string }) => ({
      '@type': 'SoftwareApplication',
      name: tool.name,
      url: `https://maratool.com/${tool.slug}`,
      applicationCategory: 'UtilitiesApplication',
    })),
  },
  breadcrumbSchema: {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://maratool.com' },
      { '@type': 'ListItem', position: 2, name: 'Text', item: 'https://maratool.com/text' },
      { '@type': 'ListItem', position: 3, name: sub, item: `https://maratool.com/text/${subcategory}` },
    ],
  },
}
---
<Base {...seo}>
  <Layout scope="subcategory">
    <HubPage
      category="Text"
      categorySlug="text"
      title={`Text ${sub} tools`}
      subtitle={intro}
      tools={allTools}
      subcategories={subcategories}
      activeSubcategory={sub}
      basePath="/text"
    />
  </Layout>
</Base>
