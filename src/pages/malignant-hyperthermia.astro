---
import ScoreCalc from '../components/ScoreCalc.astro'

const none = { label: 'None / not applicable (0)', points: 0, default: true }

const spec = {
  items: [
    { id: 'rigidity', label: 'Process I — Muscular rigidity', options: [
      none,
      { label: 'Masseter rigidity after succinylcholine (15)', points: 15 },
      { label: 'Generalized muscular rigidity (15)', points: 15 },
    ]},
    { id: 'breakdown', label: 'Process II — Muscle breakdown (highest applicable)', options: [
      none,
      { label: 'K⁺ > 6 mEq/L without renal failure (3)', points: 3 },
      { label: 'Cola-colored urine (10)', points: 10 },
      { label: 'CK > 20,000 IU (with succinylcholine) (15)', points: 15 },
    ]},
    { id: 'acidosis', label: 'Process III — Respiratory acidosis (highest applicable)', options: [
      none,
      { label: 'Inappropriate tachypnea (10)', points: 10 },
      { label: 'ETCO₂ > 55 / PaCO₂ > 60 mmHg, or inappropriate hypercarbia (15)', points: 15 },
    ]},
    { id: 'temperature', label: 'Process IV — Temperature increase (highest applicable)', options: [
      none,
      { label: 'Inappropriately increased temperature > 38.8 °C (10)', points: 10 },
      { label: 'Rapid inappropriate increase in temperature (15)', points: 15 },
    ]},
    { id: 'cardiac', label: 'Process V — Cardiac involvement', options: [
      none,
      { label: 'Inappropriate sinus tachycardia (3)', points: 3 },
      { label: 'Ventricular tachycardia or fibrillation (3)', points: 3 },
    ]},
    { id: 'family', label: 'Process VI — Family history of MH', options: [
      none,
      { label: 'In a non–first-degree relative (5)', points: 5 },
      { label: 'In a first-degree relative (15)', points: 15 },
    ]},
    { id: 'other', label: 'Other indicators (highest applicable)', options: [
      none,
      { label: 'Rapid reversal of MH signs with dantrolene (5)', points: 5 },
      { label: 'Arterial pH < 7.25 (10)', points: 10 },
      { label: 'Arterial base excess more negative than −8 mEq/L (10)', points: 10 },
    ]},
  ],
  bands: [
    { min: 0, max: 9, label: 'Rank 1 — almost never MH', cls: 'cls-normal' },
    { min: 10, max: 19, label: 'Rank 2 — unlikely', cls: 'cls-normal' },
    { min: 20, max: 34, label: 'Rank 3 — somewhat less than likely', cls: 'cls-warn' },
    { min: 35, max: 49, label: 'Rank 4 — somewhat greater than likely', cls: 'cls-warn' },
    { min: 50, max: 64, label: 'Rank 5 — very likely MH', cls: 'cls-danger' },
    { min: 65, max: 200, label: 'Rank 6 — almost certain MH', cls: 'cls-danger' },
  ],
  cols: 2,
}

const faq = [
  { q: 'What is the MH Clinical Grading Scale?', a: 'The Larach Clinical Grading Scale estimates the qualitative likelihood that an event was malignant hyperthermia by summing the highest indicator within each clinical process.' },
  { q: 'How is the raw score ranked?', a: '< 9 = rank 1 (almost never), 10–19 rank 2, 20–34 rank 3, 35–49 rank 4, 50–64 rank 5, ≥ 65 rank 6 (almost certain).' },
  { q: 'Why pick only the highest indicator per process?', a: 'The CGS scores each process once (its highest applicable indicator) to avoid double-counting correlated findings; the process scores are then summed.' },
  { q: 'Is the CGS diagnostic?', a: 'No — it grades clinical likelihood retrospectively. Definitive diagnosis uses caffeine-halothane contracture testing or genetic testing.' },
]
const references = [
  { citation: 'Larach MG, Localio AR, Allen GC, et al. A clinical grading scale to predict malignant hyperthermia susceptibility. <em>Anesthesiology</em>. 1994;80(4):771-779.' },
]
const relatedTools = [
  { slug: 'rass-scale', name: 'RASS' },
  { slug: 'aldrete-recovery', name: 'Aldrete Recovery Score' },
  { slug: 'ramsay-sedation', name: 'Ramsay Sedation Scale' },
]
---
<ScoreCalc
  slug="malignant-hyperthermia"
  name="Malignant Hyperthermia Clinical Grading Scale Calculator"
  schemaName="MH Clinical Grading Scale"
  shortDescription="Larach Clinical Grading Scale for malignant hyperthermia likelihood (MH rank 1–6)."
  metaTitle="Malignant Hyperthermia Score Calculator (CGS) | maratool"
  metaDescription="Free Malignant Hyperthermia Clinical Grading Scale calculator. Estimate the likelihood of an MH event using the Larach process indicators."
  subcategory="Score"
  subcategorySlug="score"
  howTo={[
    'For each clinical process, select the single highest applicable indicator.',
    'The raw CGS score and MH likelihood rank update instantly.',
    'Use retrospectively to grade likelihood — confirm susceptibility with formal testing.',
  ]}
  faq={faq}
  relatedTools={relatedTools}
  references={references}
  spec={spec}
/>
