---
import Base from '../layouts/Base.astro'
import Layout from '../components/Layout.astro'
import ToolShell from '../components/ToolShell.astro'

const seo = {
  title: 'BMI Calculator — Body Mass Index & BSA | maratool',
  description: 'Free BMI calculator. Compute Body Mass Index, classification (WHO), and body surface area (Mosteller) from weight and height. Runs in your browser.',
  canonical: 'https://maratool.com/bmi-calculator',
  schema: {
    '@context': 'https://schema.org',
    '@type': 'WebApplication',
    name: 'BMI Calculator',
    url: 'https://maratool.com/bmi-calculator',
    applicationCategory: 'HealthApplication',
    operatingSystem: 'Any',
    offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
    description: 'Calculate Body Mass Index (BMI), BMI classification, and body surface area from weight and height.',
  },
  breadcrumbSchema: {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://maratool.com' },
      { '@type': 'ListItem', position: 2, name: 'Health', item: 'https://maratool.com/health' },
      { '@type': 'ListItem', position: 3, name: 'Anthropometric', item: 'https://maratool.com/health/anthropometric' },
      { '@type': 'ListItem', position: 4, name: 'BMI Calculator', item: 'https://maratool.com/bmi-calculator' },
    ],
  },
  faqSchema: {
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: [
      {
        '@type': 'Question',
        name: 'How is BMI calculated?',
        acceptedAnswer: { '@type': 'Answer', text: 'BMI is weight (kg) divided by height squared (m²). For example, a person weighing 70 kg at 1.75 m has a BMI of 70 / (1.75 × 1.75) = 22.9 kg/m².' }
      },
      {
        '@type': 'Question',
        name: 'What are the WHO BMI categories?',
        acceptedAnswer: { '@type': 'Answer', text: 'Underweight: < 18.5; Normal weight: 18.5–24.9; Overweight: 25.0–29.9; Obesity class I: 30.0–34.9; Obesity class II: 35.0–39.9; Obesity class III: ≥ 40.' }
      },
      {
        '@type': 'Question',
        name: 'What is body surface area (BSA) used for?',
        acceptedAnswer: { '@type': 'Answer', text: 'BSA is commonly used to dose medications (especially chemotherapy), calculate cardiac index, and estimate metabolic requirements. This calculator uses the Mosteller formula: BSA = √((height in cm × weight in kg) / 3600).' }
      },
      {
        '@type': 'Question',
        name: 'Is this tool a substitute for medical evaluation?',
        acceptedAnswer: { '@type': 'Answer', text: 'No. This calculator is intended for educational use by healthcare professionals and informed individuals. It does not replace clinical judgment or formal medical assessment.' }
      }
    ]
  }
}

const howTo = [
  'Enter weight in kilograms and height in centimeters (or meters).',
  'BMI, classification, and body surface area update as you type.',
  'Use the copy button to copy any result to your clipboard.'
]

const faq = [
  { q: 'How is BMI calculated?', a: 'BMI = weight (kg) / height² (m²). For example, 70 kg at 1.75 m → 70 / (1.75 × 1.75) = <strong>22.9 kg/m²</strong>.' },
  { q: 'What are the WHO BMI categories?', a: 'Underweight: &lt; 18.5 • Normal weight: 18.5–24.9 • Overweight: 25.0–29.9 • Obesity class I: 30.0–34.9 • Obesity class II: 35.0–39.9 • Obesity class III: ≥ 40.' },
  { q: 'What is body surface area (BSA) used for?', a: 'BSA is commonly used for chemotherapy dosing, cardiac index, and other body-size-adjusted calculations. This tool uses the <strong>Mosteller formula</strong>: BSA = √((H<sub>cm</sub> × W<sub>kg</sub>) / 3600).' },
  { q: 'Is this a substitute for medical evaluation?', a: 'No. This calculator is for educational use and does not replace clinical judgment. Always consult a healthcare professional for medical decisions.' }
]

const relatedTools = [
  { slug: 'mean-arterial-pressure', name: 'Mean Arterial Pressure (MAP)' },
  { slug: 'ideal-body-weight', name: 'Ideal Body Weight' },
  { slug: 'pediatric-bmi', name: 'Pediatric BMI Calculator' },
]

const breadcrumbs = [
  { label: 'Home', href: '/' },
  { label: 'Health', href: '/health' },
  { label: 'Anthropometric', href: '/health/anthropometric' },
  { label: 'BMI Calculator' },
]
---
<Base {...seo}>
  <Layout>
    <ToolShell slug="bmi-calculator" name="BMI Calculator" description="Calculate Body Mass Index (BMI), classification, and body surface area from weight and height. Uses the WHO BMI categories and the Mosteller BSA formula." howTo={howTo} faq={faq} relatedTools={relatedTools} breadcrumbs={breadcrumbs}>
      <div class="tool-container bmi-container">
        <div class="bmi-disclaimer">
          For educational and clinical reference. Not a substitute for medical judgment.
        </div>

        <div class="bmi-inputs">
          <label class="bmi-field">
            <span class="bmi-label">Weight</span>
            <div class="bmi-input-wrap">
              <input type="number" id="bmi-weight" placeholder="70" step="any" min="0" aria-label="Weight in kilograms">
              <span class="bmi-unit">kg</span>
            </div>
          </label>

          <label class="bmi-field">
            <span class="bmi-label">Height</span>
            <div class="bmi-input-wrap">
              <input type="number" id="bmi-height" placeholder="175" step="any" min="0" aria-label="Height in centimeters or meters">
              <span class="bmi-unit">cm or m</span>
            </div>
          </label>
        </div>

        <div class="bmi-outputs">
          <div class="bmi-output">
            <div class="bmi-output-label">BMI</div>
            <div class="bmi-output-value" id="bmi-value">—</div>
            <button class="copy-btn" data-target="bmi-value">Copy</button>
          </div>

          <div class="bmi-output">
            <div class="bmi-output-label">Classification</div>
            <div class="bmi-output-value" id="bmi-class">—</div>
            <button class="copy-btn" data-target="bmi-class">Copy</button>
          </div>

          <div class="bmi-output">
            <div class="bmi-output-label">Body Surface Area (Mosteller)</div>
            <div class="bmi-output-value" id="bmi-bsa">—</div>
            <button class="copy-btn" data-target="bmi-bsa">Copy</button>
          </div>
        </div>

        <details class="bmi-reference">
          <summary>WHO BMI classification reference</summary>
          <table class="bmi-table">
            <thead><tr><th>Category</th><th>BMI (kg/m²)</th></tr></thead>
            <tbody>
              <tr><td>Underweight</td><td>&lt; 18.5</td></tr>
              <tr><td>Normal weight</td><td>18.5 – 24.9</td></tr>
              <tr><td>Overweight</td><td>25.0 – 29.9</td></tr>
              <tr><td>Obesity class I</td><td>30.0 – 34.9</td></tr>
              <tr><td>Obesity class II</td><td>35.0 – 39.9</td></tr>
              <tr><td>Obesity class III</td><td>≥ 40.0</td></tr>
            </tbody>
          </table>
        </details>
      </div>
    </ToolShell>
  </Layout>
</Base>

<script src="../tools/health/bmi-ui.js"></script>

<style is:global>
  .bmi-container {
    min-height: 380px;
  }

  .bmi-disclaimer {
    padding: 0.5rem 0.75rem;
    background: var(--bg-soft);
    border-left: 3px solid var(--text-3);
    color: var(--text-2);
    font-size: 0.8125rem;
    margin-bottom: 1.5rem;
    border-radius: 4px;
  }

  .bmi-inputs {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
    margin-bottom: 1.5rem;
  }

  @media (max-width: 520px) {
    .bmi-inputs { grid-template-columns: 1fr; }
  }

  .bmi-field {
    display: flex;
    flex-direction: column;
    gap: 0.375rem;
  }

  .bmi-label {
    font-size: 0.8125rem;
    color: var(--text-2);
    font-weight: 500;
  }

  .bmi-input-wrap {
    display: flex;
    align-items: center;
    border: 1px solid var(--border);
    border-radius: var(--radius);
    background: var(--bg);
    transition: border-color 0.15s;
  }

  .bmi-input-wrap:focus-within {
    border-color: var(--accent);
  }

  .bmi-input-wrap input {
    flex: 1;
    padding: 10px 12px;
    border: none;
    background: transparent;
    font-family: var(--font-mono);
    font-size: 16px;
    color: var(--text);
    outline: none;
    min-width: 0;
  }

  .bmi-unit {
    padding: 0 12px;
    color: var(--text-3);
    font-size: 0.875rem;
    font-weight: 500;
  }

  .bmi-outputs {
    display: grid;
    gap: 0.75rem;
    margin-bottom: 1.5rem;
  }

  .bmi-output {
    display: grid;
    grid-template-columns: 1fr auto auto;
    align-items: center;
    gap: 1rem;
    padding: 0.875rem 1rem;
    background: var(--bg-soft);
    border-radius: var(--radius);
  }

  .bmi-output-label {
    font-size: 0.8125rem;
    color: var(--text-2);
    font-weight: 500;
  }

  .bmi-output-value {
    font-family: var(--font-mono);
    font-size: 1.0625rem;
    font-weight: 600;
    color: var(--text);
    text-align: right;
  }

  .bmi-output-value.cls-under { color: #b45309; }
  .bmi-output-value.cls-normal { color: #047857; }
  .bmi-output-value.cls-over { color: #b45309; }
  .bmi-output-value.cls-obese { color: #c53030; }

  .bmi-reference {
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 0;
  }

  .bmi-reference summary {
    cursor: pointer;
    padding: 0.75rem 1rem;
    font-size: 0.875rem;
    color: var(--text-2);
    user-select: none;
  }

  .bmi-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.875rem;
  }

  .bmi-table th, .bmi-table td {
    text-align: left;
    padding: 0.5rem 1rem;
    border-top: 1px solid var(--border);
  }

  .bmi-table th {
    background: var(--bg-soft);
    font-weight: 600;
    color: var(--text-2);
  }
</style>
