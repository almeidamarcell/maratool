---
import Base from '../layouts/Base.astro'
import Layout from '../components/Layout.astro'
import ToolShell from '../components/ToolShell.astro'

const seo = {
  title: 'AI Token Counter — Count tokens for GPT, Claude & Gemini | maratool',
  description: 'Count AI tokens for GPT-4o, Claude, and Gemini instantly. Paste text and see estimated token count, word count, and character count. Free, runs in your browser.',
  canonical: 'https://maratool.com/ai-token-calculator',
  schema: {
    '@context': 'https://schema.org',
    '@type': 'WebApplication',
    name: 'AI Token Counter',
    url: 'https://maratool.com/ai-token-calculator',
    applicationCategory: 'UtilitiesApplication',
    operatingSystem: 'Any',
    offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
    description: 'Count AI tokens for popular language models instantly in your browser.',
  },
  breadcrumbSchema: {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://maratool.com' },
      { '@type': 'ListItem', position: 2, name: 'Text', item: 'https://maratool.com/text' },
      { '@type': 'ListItem', position: 3, name: 'Analyze', item: 'https://maratool.com/text/analyze' },
      { '@type': 'ListItem', position: 4, name: 'AI Token Counter', item: 'https://maratool.com/ai-token-calculator' },
    ],
  },
  faqSchema: {
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: [
      { '@type': 'Question', name: 'How are AI tokens counted?', acceptedAnswer: { '@type': 'Answer', text: 'This tool estimates tokens using character and word counts calibrated per model. GPT models average ~4 characters per token; Claude models use a slightly different ratio. For exact counts, use the provider API tokenizer.' } },
      { '@type': 'Question', name: 'Why does token count matter?', acceptedAnswer: { '@type': 'Answer', text: 'LLM APIs charge per token. Knowing your prompt size helps you stay within context limits and estimate costs before sending a request.' } },
      { '@type': 'Question', name: 'Which models are supported?', acceptedAnswer: { '@type': 'Answer', text: 'GPT-4o, GPT-4o mini, GPT-4, GPT-3.5 Turbo, Claude Sonnet, Claude Opus, Gemini Pro, and Llama 3. Select a model to apply its tokenization estimate.' } },
      { '@type': 'Question', name: 'Is my text sent to a server?', acceptedAnswer: { '@type': 'Answer', text: 'No. Token counting runs entirely in your browser. Your text never leaves your device.' } },
    ]
  }
}

const howTo = ['Select the AI model you plan to use.', 'Paste or type your prompt or text into the box.', 'Token count, word count, and character count update instantly.']
const faq = [
  { q: 'How are AI tokens counted?', a: 'This tool estimates tokens using character and word counts calibrated per model. GPT models average ~4 characters per token. For exact counts, use the provider API tokenizer.' },
  { q: 'Why does token count matter?', a: 'LLM APIs charge per token. Knowing your prompt size helps you stay within context limits and estimate costs.' },
  { q: 'Which models are supported?', a: 'GPT-4o, GPT-4o mini, GPT-4, GPT-3.5 Turbo, Claude Sonnet, Claude Opus, Gemini Pro, and Llama 3.' },
  { q: 'Is my text sent to a server?', a: 'No. Token counting runs entirely in your browser.' },
]
const relatedTools = [
  { slug: 'ai-cost-calculator', name: 'AI API Cost Calculator' },
  { slug: 'reading-time', name: 'Reading Time Calculator' },
  { slug: 'json-formatter', name: 'Format and Validate JSON Online' },
]
const breadcrumbs = [
  { label: 'Home', href: '/' },
  { label: 'Text', href: '/text' },
  { label: 'Analyze', href: '/text/analyze' },
  { label: 'AI Token Counter' },
]
---
<Base {...seo}>
  <Layout>
    <ToolShell slug="ai-token-calculator" name="Count AI Tokens Online" description="Paste text and instantly see estimated token count for GPT-4o, Claude, Gemini, and more. Shows words and characters too." howTo={howTo} faq={faq} relatedTools={relatedTools} breadcrumbs={breadcrumbs}>
      <div class="tool-container" style="min-height:420px;">
        <div class="calc-field">
          <label class="tool-label" for="atc-model">Model</label>
          <select id="atc-model" class="tool-input calc-select"></select>
        </div>
        <div class="tool-stats">
          <div class="tool-stat"><span class="tool-stat-value" id="atc-tokens">0</span><span class="tool-stat-label">Tokens</span></div>
          <div class="tool-stat"><span class="tool-stat-value" id="atc-words">0</span><span class="tool-stat-label">Words</span></div>
          <div class="tool-stat"><span class="tool-stat-value" id="atc-chars">0</span><span class="tool-stat-label">Characters</span></div>
        </div>
        <textarea id="atc-input" class="tool-textarea" rows="12" placeholder="Paste your prompt, document, or code here..." aria-label="Text to count tokens"></textarea>
        <button id="atc-copy" class="copy-btn">Copy token count</button>
      </div>
    </ToolShell>
  </Layout>
</Base>
<script src="../tools/ai-token-calculator.js"></script>
