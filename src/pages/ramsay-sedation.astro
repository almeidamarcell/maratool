---
import ScoreCalc from '../components/ScoreCalc.astro'

const spec = {
  items: [
    {
      id: 'ramsay',
      label: 'Level of sedation',
      options: [
        { label: '1 — Anxious, agitated, or restless', points: 1 },
        { label: '2 — Cooperative, oriented, tranquil', points: 2, default: true },
        { label: '3 — Responds to commands only', points: 3 },
        { label: '4 — Brisk response to light glabellar tap or loud auditory stimulus', points: 4 },
        { label: '5 — Sluggish response to light glabellar tap or loud auditory stimulus', points: 5 },
        { label: '6 — No response to stimuli', points: 6 },
      ],
    },
  ],
  bands: [
    { min: 1, max: 1, label: 'Under-sedated / agitated', cls: 'cls-warn' },
    { min: 2, max: 4, label: 'Adequate sedation', cls: 'cls-normal' },
    { min: 5, max: 6, label: 'Over-sedated', cls: 'cls-danger' },
  ],
  max: 6,
}

const faq = [
  { q: 'What is the Ramsay Sedation Scale?', a: 'A 6-level scale for assessing depth of sedation in ICU patients, ranging from agitated (1) to unresponsive (6).' },
  { q: 'What target Ramsay is appropriate?', a: 'Typical ICU targets are 2–4 (cooperative to brisk response). Levels 5–6 are excessive for most patients and increase the risk of delirium and prolonged ventilation.' },
  { q: 'Should I use Ramsay or RASS?', a: 'RASS (Richmond Agitation-Sedation Scale) is preferred in most modern ICUs because it has better inter-rater reliability and finer agitation discrimination.' },
  { q: 'How often should sedation be assessed?', a: 'At least every 4 hours, with re-assessment after any change in sedative dose.' },
]
const references = [
  { citation: 'Ramsay MA, Savege TM, Simpson BR, Goodwin R. Controlled sedation with alphaxalone-alphadolone. <em>BMJ</em>. 1974;2(5920):656-659.' },
]
const relatedTools = [
  { slug: 'rass-scale', name: 'RASS Scale' },
  { slug: 'sas-scale', name: 'SAS Sedation Scale (Riker)' },
  { slug: 'four-coma-scale', name: 'FOUR Score Coma Scale' },
]
---
<ScoreCalc
  slug="ramsay-sedation"
  name="Ramsay Sedation Scale Calculator"
  schemaName="Ramsay Sedation Scale"
  shortDescription="Ramsay Sedation Scale (1–6) for ICU level of sedation."
  metaTitle="Ramsay Sedation Scale Calculator (1–6) | maratool"
  metaDescription="Free Ramsay sedation scale calculator. 6 levels from agitated (1) to unresponsive (6) for ICU sedation assessment."
  subcategory="Scale"
  subcategorySlug="scale"
  howTo={[
    'Select the level that best describes the patient.',
    'The score and adequacy interpretation update instantly.',
    'Document score with each dose adjustment; target 2–4 for most ICU patients.',
  ]}
  faq={faq}
  relatedTools={relatedTools}
  references={references}
  spec={spec}
/>
