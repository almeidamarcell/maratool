---
import Base from '../layouts/Base.astro'
import Layout from '../components/Layout.astro'
import ToolShell from '../components/ToolShell.astro'

const seo = {
  title: 'Loan Calculator — Monthly Payment & Interest | maratool',
  description: 'Calculate monthly loan payments and total interest for personal, auto, or business loans. Free, instant, runs in your browser.',
  canonical: 'https://maratool.com/loan-calculator',
  schema: {
    '@context': 'https://schema.org',
    '@type': 'WebApplication',
    name: 'Loan Calculator — Monthly Payment & Interest',
    url: 'https://maratool.com/loan-calculator',
    applicationCategory: 'FinanceApplication',
    operatingSystem: 'Any',
    offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
    description: 'Calculate monthly loan payments and total interest for personal, auto, or business loans. Free, instant, runs in your browser.',
  },
  breadcrumbSchema: {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://maratool.com' },
      { '@type': 'ListItem', position: 2, name: 'Finance', item: 'https://maratool.com/finance' },
      { '@type': 'ListItem', position: 3, name: 'Loan', item: 'https://maratool.com/finance/loan' },
      { '@type': 'ListItem', position: 4, name: 'Loan Calculator — Monthly Payment & Interest', item: 'https://maratool.com/loan-calculator' },
    ],
  },
  faqSchema: {
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: [
      { '@type': 'Question', name: 'What types of loans does this work for?', acceptedAnswer: { '@type': 'Answer', text: 'Any fixed-rate installment loan — personal, auto, student, or business loans with equal monthly payments.' } },
      { '@type': 'Question', name: 'How do I convert years to months?', acceptedAnswer: { '@type': 'Answer', text: 'Multiply years by 12. A 5-year loan = 60 months, a 3-year loan = 36 months.' } },
      { '@type': 'Question', name: 'What if my interest rate is 0%?', acceptedAnswer: { '@type': 'Answer', text: 'The calculator divides principal by months for zero-interest loans.' } },
      { '@type': 'Question', name: 'Is my data sent to a server?', acceptedAnswer: { '@type': 'Answer', text: 'No. All calculations happen in your browser.' } }
    ]
  }
}

const howTo = [
  'Enter the loan principal amount.',
  'Set the annual interest rate and term in months.',
  'See monthly payment and total interest instantly.'
]

const faq = [
  { q: 'What types of loans does this work for?', a: 'Any fixed-rate installment loan — personal, auto, student, or business loans with equal monthly payments.' },
  { q: 'How do I convert years to months?', a: 'Multiply years by 12. A 5-year loan = 60 months, a 3-year loan = 36 months.' },
  { q: 'What if my interest rate is 0%?', a: 'The calculator divides principal by months for zero-interest loans.' },
  { q: 'Is my data sent to a server?', a: 'No. All calculations happen in your browser.' }
]

const relatedTools = [
  { slug: 'mortgage-calculator', name: 'Mortgage Calculator' },
  { slug: 'compound-interest-calculator', name: 'Compound Interest Calculator' },
  { slug: 'roi-calculator', name: 'ROI Calculator' }
]

const breadcrumbs = [
  { label: 'Home', href: '/' },
  { label: 'Finance', href: '/finance' },
  { label: 'Loan', href: '/finance/loan' },
  { label: 'Loan Calculator' }
]
---
<Base {...seo}>
  <Layout>
    <ToolShell slug="loan-calculator" name="Loan Calculator — Monthly Payment & Interest" description="Enter loan amount, annual interest rate, and term in months to see payment and total interest." howTo={howTo} faq={faq} relatedTools={relatedTools} breadcrumbs={breadcrumbs}>
      <div class="tool-container" style="min-height:300px;">
        <div class="calc-row">
          <div class="calc-field"><label class="tool-label" for="lc-amount">Loan amount ($)</label><input type="number" id="lc-amount" class="tool-input" placeholder="20000" min="0" /></div>
          <div class="calc-field"><label class="tool-label" for="lc-rate">Interest rate (%)</label><input type="number" id="lc-rate" class="tool-input" placeholder="7.5" step="any" min="0" /></div>
        </div>
        <div class="calc-field"><label class="tool-label" for="lc-months">Term (months)</label><input type="number" id="lc-months" class="tool-input" placeholder="60" min="1" style="max-width:200px;" /></div>
        <div class="tool-stats">
          <div class="tool-stat"><span class="tool-stat-value" id="lc-payment">—</span><span class="tool-stat-label">Monthly payment</span></div>
          <div class="tool-stat"><span class="tool-stat-value" id="lc-interest">—</span><span class="tool-stat-label">Total interest</span></div>
          <div class="tool-stat"><span class="tool-stat-value" id="lc-total">—</span><span class="tool-stat-label">Total payment</span></div>
        </div>
      </div>
    </ToolShell>
  </Layout>
</Base>

<style is:global>
  .calc-row { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; margin-bottom: 1rem; }
  .calc-field { margin-bottom: 0.75rem; }
  .calc-select { max-width: 100%; }
  @media (max-width: 600px) { .calc-row { grid-template-columns: 1fr; } }
</style>
<script src="../tools/loan-calculator.js"></script>
