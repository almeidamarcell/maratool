---
import Base from '../../layouts/Base.astro'
import Layout from '../../components/Layout.astro'
import HubPage from '../../components/HubPage.astro'
import { toolsByCategory, toolsFlatByCategory, subcategoryOrderByCategory, buildToolItemList } from '../../data/tools'

export function getStaticPaths() {
  const subs = subcategoryOrderByCategory.Finance ?? []
  const catTools = toolsByCategory.Finance ?? {}
  return subs.map(sub => ({
    params: { subcategory: sub.toLowerCase() },
    props: { sub, subTools: catTools[sub] ?? [] },
  }))
}

const { subcategory } = Astro.params
const { sub, subTools } = Astro.props
const allTools = toolsFlatByCategory.Finance ?? []
const subcategories = subcategoryOrderByCategory.Finance ?? []
const liveSubTools = subTools.filter((tool: { live: boolean }) => tool.live)

const seo = {
  title: `${sub} Calculators — maratool`,
  description: `Free browser-based ${sub.toLowerCase()} finance calculators — no sign-up, runs entirely in your browser.`,
  canonical: `https://maratool.com/finance/${subcategory}`,
  schema: {
    '@context': 'https://schema.org',
    '@type': 'CollectionPage',
    name: `${sub} Calculators`,
    url: `https://maratool.com/finance/${subcategory}`,
    hasPart: liveSubTools.map((tool: { name: string; slug: string }) => ({
      '@type': 'SoftwareApplication',
      name: tool.name,
      url: `https://maratool.com/${tool.slug}`,
    })),
    mainEntity: buildToolItemList(liveSubTools, `${sub} Calculators`),
  },
  breadcrumbSchema: {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://maratool.com' },
      { '@type': 'ListItem', position: 2, name: 'Finance', item: 'https://maratool.com/finance' },
      { '@type': 'ListItem', position: 3, name: sub, item: `https://maratool.com/finance/${subcategory}` },
    ],
  },
}
---
<Base {...seo} scope="subcategory">
  <Layout scope="subcategory">
    <HubPage
      category="Finance"
      categorySlug="finance"
      title={`${sub} calculators`}
      subtitle={`${sub} finance tools that run locally in your browser.`}
      tools={allTools}
      subcategories={subcategories}
      activeSubcategory={sub}
      basePath="/finance"
    />
  </Layout>
</Base>
