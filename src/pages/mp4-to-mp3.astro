---
import Base from '../layouts/Base.astro'
import Layout from '../components/Layout.astro'
import ToolShell from '../components/ToolShell.astro'

const seo = {
  title: 'Convert MP4 to MP3 — Extract Audio from Video Online | maratool',
  description: 'Extract audio from MP4, WebM, and MOV videos and download as MP3 instantly. Choose 128, 192, or 320 kbps. Runs in your browser — no upload, no signup.',
  canonical: 'https://maratool.com/mp4-to-mp3',
  schema: {
    '@context': 'https://schema.org',
    '@type': 'WebApplication',
    name: 'Convert MP4 to MP3',
    url: 'https://maratool.com/mp4-to-mp3',
    applicationCategory: 'UtilitiesApplication',
    operatingSystem: 'Any',
    offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
    description: 'Extract audio from MP4, WebM, and MOV videos and download as MP3. Runs entirely in your browser — no upload, no signup, no watermark.',
  },
  breadcrumbSchema: {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://maratool.com' },
      { '@type': 'ListItem', position: 2, name: 'Converter', item: 'https://maratool.com/converter' },
      { '@type': 'ListItem', position: 3, name: 'Video', item: 'https://maratool.com/converter/video' },
      { '@type': 'ListItem', position: 4, name: 'Convert MP4 to MP3', item: 'https://maratool.com/mp4-to-mp3' },
    ],
  },
  faqSchema: {
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: [
      {
        '@type': 'Question',
        name: 'Is this MP4 to MP3 converter free?',
        acceptedAnswer: { '@type': 'Answer', text: '100% free, no signup, no watermark, no server upload. The entire conversion runs in your browser using WebAssembly — your video file never leaves your device.' }
      },
      {
        '@type': 'Question',
        name: 'What bitrate should I choose?',
        acceptedAnswer: { '@type': 'Answer', text: '192 kbps is the sweet spot for most uses — it is indistinguishable from CD quality for voice and music. Choose 128 kbps for podcasts or voice recordings to keep the file smaller. Use 320 kbps only if you need the absolute highest quality for music production or archiving.' }
      },
      {
        '@type': 'Question',
        name: 'Can I extract audio from WebM and MOV too?',
        acceptedAnswer: { '@type': 'Answer', text: 'Yes. The tool accepts MP4, WebM, and MOV (QuickTime) video files. The output is always an MP3 file regardless of the input format.' }
      },
      {
        '@type': 'Question',
        name: 'What is the maximum file size?',
        acceptedAnswer: { '@type': 'Answer', text: 'Up to 2 GB on desktop. Mobile browsers may struggle above 500 MB because the video is loaded into browser memory for processing. Since nothing is uploaded, the limit is your device RAM, not a server quota.' }
      }
    ]
  }
}

const howTo = [
  'Drop a video file or click to select an MP4, WebM, or MOV.',
  'Choose the MP3 bitrate — 192 kbps is recommended for most uses.',
  'Click "Extract MP3" and download the audio file.'
]

const faq = [
  { q: 'Is this MP4 to MP3 converter free?', a: '100% free, no signup, no watermark, no server upload. The entire conversion runs in your browser using WebAssembly — your video file never leaves your device.' },
  { q: 'What bitrate should I choose?', a: '192 kbps is the sweet spot for most uses — it is indistinguishable from CD quality for voice and music. Choose 128 kbps for podcasts or voice recordings to keep the file smaller. Use 320 kbps only if you need the absolute highest quality for music production or archiving.' },
  { q: 'Can I extract audio from WebM and MOV too?', a: 'Yes. The tool accepts MP4, WebM, and MOV (QuickTime) video files. The output is always an MP3 file regardless of the input format.' },
  { q: 'What is the maximum file size?', a: 'Up to 2 GB on desktop. Mobile browsers may struggle above 500 MB because the video is loaded into browser memory for processing. Since nothing is uploaded, the limit is your device RAM, not a server quota.' },
]

const relatedTools = [
  { slug: 'video-to-gif', name: 'Video to GIF Converter' },
  { slug: 'trim-video', name: 'Trim Video Online' },
  { slug: 'fps-converter', name: 'FPS Converter' },
]

const breadcrumbs = [
  { label: 'Home', href: '/' },
  { label: 'Converter', href: '/converter' },
  { label: 'Video', href: '/converter/video' },
  { label: 'Convert MP4 to MP3' },
]
---
<Base {...seo}>
  <Layout>
    <ToolShell slug="mp4-to-mp3" name="Convert MP4 to MP3" description="Extract audio from MP4, WebM, and MOV videos. Download as MP3 — no upload, no signup, no watermark." howTo={howTo} faq={faq} relatedTools={relatedTools} breadcrumbs={breadcrumbs}>
      <div class="tool-container" style="min-height:400px;">
        <!-- Mobile banner -->
        <div class="m3-mobile-banner" id="m3-mobile-banner" style="display:none;">
          <span>This works on mobile but is faster on desktop. Files above 500 MB may fail on phones.</span>
          <button type="button" class="m3-mobile-banner-dismiss" id="m3-mobile-banner-dismiss" aria-label="Dismiss">&times;</button>
        </div>

        <!-- Drop zone -->
        <div class="m3-dropzone" id="m3-dropzone">
          <input type="file" id="m3-file-input" accept="video/mp4,video/webm,video/quicktime" hidden />
          <div class="m3-dropzone-inner">
            <svg class="m3-upload-icon" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
              <polyline points="17 8 12 3 7 8"/>
              <line x1="12" y1="3" x2="12" y2="15"/>
            </svg>
            <p class="m3-dropzone-title">Drop a video here</p>
            <p class="m3-dropzone-sub">or click to select a file</p>
            <p class="m3-dropzone-formats">MP4, WebM, MOV — up to 2 GB</p>
          </div>
        </div>

        <div class="m3-info" id="m3-info">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="16" x2="12" y2="12"/><line x1="12" y1="8" x2="12.01" y2="8"/></svg>
          <span>The FFmpeg engine (~25 MB) downloads on first use and is cached by your browser. Audio is extracted entirely in-browser — nothing is uploaded.</span>
        </div>

        <!-- Settings / editor -->
        <div class="m3-settings" id="m3-settings" style="display:none;">
          <div class="m3-preview-row">
            <div class="m3-video-wrap">
              <video id="m3-video" controls preload="metadata"></video>
            </div>
            <div class="m3-metadata">
              <div class="m3-stat">
                <span class="m3-stat-value" id="m3-duration">—</span>
                <span class="m3-stat-label">Duration</span>
              </div>
              <div class="m3-stat">
                <span class="m3-stat-value" id="m3-dimensions">—</span>
                <span class="m3-stat-label">Resolution</span>
              </div>
              <div class="m3-stat">
                <span class="m3-stat-value" id="m3-filesize">—</span>
                <span class="m3-stat-label">File size</span>
              </div>
            </div>
          </div>

          <div class="m3-section">
            <span class="m3-section-label">Output quality</span>
            <div class="m3-bitrate-row">
              <label class="m3-label" for="m3-bitrate">MP3 bitrate</label>
              <select id="m3-bitrate" class="m3-select">
                <option value="128">128 kbps — smaller file, good for voice</option>
                <option value="192" selected>192 kbps — recommended</option>
                <option value="320">320 kbps — highest quality</option>
              </select>
            </div>
          </div>

          <div class="m3-actions">
            <button class="tool-button" id="m3-extract">Extract MP3</button>
            <button class="copy-btn" id="m3-change">Change video</button>
          </div>
        </div>

        <!-- Progress -->
        <div class="m3-progress" id="m3-progress" style="display:none;">
          <div class="m3-progress-text" id="m3-progress-text">Loading FFmpeg...</div>
          <div class="m3-progress-track">
            <div class="m3-progress-fill" id="m3-progress-fill"></div>
          </div>
          <div class="m3-progress-detail" id="m3-progress-detail"></div>
        </div>

        <!-- Error -->
        <div class="m3-error" id="m3-error" style="display:none;">
          <span class="m3-error-text" id="m3-error-text"></span>
          <button class="m3-error-retry" id="m3-error-retry">Try again</button>
        </div>

        <!-- Result -->
        <div class="m3-result" id="m3-result" style="display:none;">
          <div class="m3-result-preview">
            <audio id="m3-result-audio" controls></audio>
          </div>
          <div class="m3-result-stats" id="m3-result-stats"></div>
          <div class="m3-result-actions">
            <button class="tool-button" id="m3-download">Download MP3</button>
            <button class="copy-btn" id="m3-new">Extract another</button>
          </div>
        </div>
      </div>
    </ToolShell>
  </Layout>
</Base>
<style is:global>
  /* Mobile banner */
  .m3-mobile-banner {
    display: flex; align-items: center; justify-content: space-between; gap: 0.75rem;
    padding: 0.625rem 0.875rem; margin-bottom: 1rem;
    background: var(--bg-soft); border: 1px solid var(--border); border-radius: var(--radius);
    font-size: 0.8125rem; color: var(--text-2);
  }
  .m3-mobile-banner-dismiss {
    background: none; border: none; font-size: 1.25rem; line-height: 1; cursor: pointer;
    color: var(--text-3); padding: 0 0.25rem;
  }
  .m3-mobile-banner-dismiss:hover { color: var(--text); }

  /* Dropzone */
  .m3-dropzone {
    border: 2px dashed var(--border);
    border-radius: var(--radius);
    padding: 3rem 2rem;
    text-align: center;
    cursor: pointer;
    transition: border-color 0.2s, background 0.2s;
  }
  .m3-dropzone:hover, .m3-dropzone.drag-over {
    border-color: var(--accent);
    background: var(--bg-soft);
  }
  .m3-dropzone-inner {
    display: flex; flex-direction: column; align-items: center; gap: 0.5rem;
  }
  .m3-upload-icon { color: var(--text-3); margin-bottom: 0.5rem; }
  .m3-dropzone-title { font-size: 1.125rem; font-weight: 600; color: var(--text); margin: 0; }
  .m3-dropzone-sub { font-size: 0.875rem; color: var(--text-2); margin: 0; }
  .m3-dropzone-formats { font-size: 0.75rem; color: var(--text-3); margin: 0.25rem 0 0; }

  .m3-info {
    display: flex; align-items: flex-start; gap: 0.5rem;
    padding: 0.75rem 1rem; background: var(--bg-soft);
    border: 1px solid var(--border); border-radius: var(--radius);
    margin-top: 1rem; font-size: 0.8125rem; color: var(--text-2); line-height: 1.5;
  }
  .m3-info svg { flex-shrink: 0; margin-top: 1px; color: var(--text-3); }

  /* Editor */
  .m3-preview-row {
    display: flex; gap: 1.5rem; margin-bottom: 1.25rem;
  }
  .m3-video-wrap { flex: 1; min-width: 0; }
  .m3-video-wrap video {
    width: 100%; border-radius: var(--radius);
    border: 1px solid var(--border); background: #000;
  }
  .m3-metadata {
    display: flex; flex-direction: column; gap: 1rem; min-width: 130px;
  }
  .m3-stat { display: flex; flex-direction: column; gap: 0.125rem; }
  .m3-stat-value {
    font-size: 1.125rem; font-weight: 600; color: var(--text);
    font-family: var(--font-mono);
  }
  .m3-stat-label {
    font-size: 0.75rem; color: var(--text-3);
    text-transform: uppercase; letter-spacing: 0.05em;
  }

  .m3-section {
    background: var(--bg-soft); border: 1px solid var(--border);
    border-radius: var(--radius); padding: 1rem; margin-bottom: 1rem;
  }
  .m3-section-label {
    display: block; font-size: 0.8125rem; font-weight: 600;
    color: var(--text-2); text-transform: uppercase;
    letter-spacing: 0.05em; margin-bottom: 0.75rem;
  }
  .m3-bitrate-row { display: flex; align-items: center; gap: 0.75rem; flex-wrap: wrap; }
  .m3-label { font-size: 0.75rem; color: var(--text-3); white-space: nowrap; }
  .m3-select {
    flex: 1; min-width: 200px; padding: 7px 10px; font-size: 0.875rem;
    border: 1px solid var(--border); border-radius: var(--radius);
    background: var(--bg); color: var(--text); cursor: pointer;
  }
  .m3-select:focus { outline: 2px solid var(--accent); outline-offset: 1px; }

  .m3-actions {
    display: flex; gap: 0.75rem; align-items: center; margin-top: 0.25rem;
  }

  /* Progress */
  .m3-progress { text-align: center; padding: 2rem; }
  .m3-progress-text {
    font-size: 0.9375rem; font-weight: 600; color: var(--text); margin-bottom: 1rem;
  }
  .m3-progress-track {
    width: 100%; max-width: 400px; height: 8px; background: var(--bg-hover);
    border-radius: 4px; margin: 0 auto; overflow: hidden;
  }
  .m3-progress-fill {
    height: 100%; background: var(--accent); border-radius: 4px;
    width: 0%; transition: width 0.3s;
  }
  .m3-progress-detail {
    font-size: 0.75rem; color: var(--text-3); margin-top: 0.5rem;
  }

  /* Error */
  .m3-error {
    background: var(--error-bg); border: 1px solid var(--error-border);
    border-radius: var(--radius); padding: 1rem;
    display: flex; align-items: center; justify-content: space-between; gap: 1rem;
  }
  .m3-error-text { color: #c53030; font-size: 0.875rem; }
  .m3-error-retry {
    padding: 6px 14px; background: var(--bg); border: 1px solid var(--border);
    border-radius: 6px; font-size: 0.8125rem; cursor: pointer; white-space: nowrap;
    color: var(--text);
  }
  .m3-error-retry:hover { background: var(--bg-hover); }

  /* Result */
  .m3-result-preview {
    text-align: center; margin-bottom: 0.75rem;
    border: 1px solid var(--border); border-radius: var(--radius);
    padding: 1.25rem 1rem; min-height: 80px;
    display: flex; align-items: center; justify-content: center;
    background: var(--bg-soft);
  }
  .m3-result-preview audio { width: 100%; max-width: 480px; }
  .m3-result-stats {
    font-size: 0.875rem; color: var(--text-2); margin-bottom: 0.75rem;
    text-align: center; line-height: 1.6;
  }
  .m3-result-actions {
    display: flex; gap: 0.75rem; align-items: center; justify-content: center;
  }

  @media (max-width: 768px) {
    .m3-preview-row { flex-direction: column; }
    .m3-metadata { flex-direction: row; min-width: 0; flex-wrap: wrap; }
    .m3-bitrate-row { flex-direction: column; align-items: stretch; }
    .m3-select { min-width: 0; }
  }
</style>
<script src="../tools/mp4-to-mp3.js"></script>
