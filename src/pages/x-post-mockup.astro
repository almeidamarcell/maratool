---
import Base from '../layouts/Base.astro'
import { styleHref } from '../lib/css-version'
import Layout from '../components/Layout.astro'
import ToolShell from '../components/ToolShell.astro'
import { xPost } from '../data/mockup-platforms'

const platformConfig = xPost

const seo = {
  title: 'X (Twitter) Post Mockup Generator — Create Fake Tweets | maratool',
  description: 'Create realistic X/Twitter post screenshots online. Edit tweet text, likes, retweets, and profile. Download as PNG. Free, no sign-up.',
  canonical: 'https://maratool.com/x-post-mockup',
  schema: {
    '@context': 'https://schema.org',
    '@type': 'WebApplication',
    name: 'X (Twitter) Post Mockup Generator',
    url: 'https://maratool.com/x-post-mockup',
    applicationCategory: 'DesignApplication',
    operatingSystem: 'Any',
    offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
    description: 'Create realistic X/Twitter post screenshots with editable text, metrics, and PNG export.',
  },
  breadcrumbSchema: {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://maratool.com' },
      { '@type': 'ListItem', position: 2, name: 'Mockup', item: 'https://maratool.com/mockup' },
      { '@type': 'ListItem', position: 3, name: 'Posts', item: 'https://maratool.com/mockup/posts' },
      { '@type': 'ListItem', position: 4, name: 'X (Twitter) Post Mockup Generator', item: 'https://maratool.com/x-post-mockup' },
    ],
  },
  faqSchema: {
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: [
      {
        '@type': 'Question',
        name: 'Is this X/Twitter post mockup generator free?',
        acceptedAnswer: { '@type': 'Answer', text: 'Yes, completely free. No sign-up, no watermark. Create unlimited X post mockups and download them as PNG.' }
      },
      {
        '@type': 'Question',
        name: 'Can I add the verified badge to the profile?',
        acceptedAnswer: { '@type': 'Answer', text: 'Yes. Check the "Verified badge" checkbox in the Author controls to add the blue verification checkmark.' }
      },
      {
        '@type': 'Question',
        name: 'Does this tool store my data?',
        acceptedAnswer: { '@type': 'Answer', text: 'No. Everything runs in your browser. Your text and images never leave your device. The PNG is generated locally.' }
      },
      {
        '@type': 'Question',
        name: 'Can I edit the tweet text directly in the preview?',
        acceptedAnswer: { '@type': 'Answer', text: 'Yes. Click on the tweet text in the phone preview to edit it inline, or use the text area in the controls panel.' }
      }
    ]
  }
}

const howTo = [
  'Edit the display name, handle, and tweet text using the controls panel on the left.',
  'Adjust likes, retweets, replies, and bookmarks to match your mockup needs.',
  'Toggle dark mode or hide the phone frame, then click Download PNG.'
]

const faq = [
  { q: 'Is this X/Twitter post mockup generator free?', a: 'Yes, completely free. No sign-up, no watermark. Create unlimited mockups and download as PNG.' },
  { q: 'Can I add the verified badge?', a: 'Yes. Check the "Verified badge" checkbox in the Author controls to add the blue checkmark.' },
  { q: 'Does this tool store my data?', a: 'No. Everything runs in your browser. Your text never leaves your device.' },
  { q: 'Can I edit the tweet directly in the preview?', a: 'Yes. Click on the tweet text in the phone preview to edit it inline.' }
]

const relatedTools = [
  { slug: 'instagram-post-mockup', name: 'Instagram Post Mockup' },
  { slug: 'whatsapp-chat-mockup', name: 'WhatsApp Chat Mockup' },
  { slug: 'gmail-mockup', name: 'Gmail Email Mockup' },
]

const breadcrumbs = [
  { label: 'Home', href: '/' },
  { label: 'Mockup', href: '/mockup' },
  { label: 'Posts', href: '/mockup/posts' },
  { label: 'X Post Mockup' },
]
---
<Base {...seo}>
  <Layout>
    <ToolShell slug="x-post-mockup" name="X (Twitter) Post Mockup Generator" description="Create realistic X/Twitter post screenshots. Edit tweet text, likes, retweets, and profile. Download as PNG." howTo={howTo} faq={faq} relatedTools={relatedTools} breadcrumbs={breadcrumbs}>
      <div class="tool-container" style="min-height:600px;">
        <div class="mockup-workspace">
          <!-- Controls panel -->
          <div class="controls-panel">
            <div class="controls-section">
              <h3 class="controls-label">Author</h3>
              <div class="ctrl-row">
                <input type="text" class="ctrl-input" id="author-name" placeholder="Display name">
              </div>
              <div class="ctrl-row">
                <input type="text" class="ctrl-input" id="author-handle" placeholder="Handle (without @)">
              </div>
              <label class="ctrl-checkbox">
                <input type="checkbox" id="author-verified"> Verified badge
              </label>
            </div>
            <div class="controls-section">
              <h3 class="controls-label">Tweet</h3>
              <textarea class="ctrl-input" id="content-text" rows="3" placeholder="What's happening?"></textarea>
            </div>
            <div class="controls-section">
              <h3 class="controls-label">Image</h3>
              <input type="file" id="image-upload" accept="image/*" style="display:none">
              <button class="mockup-btn mockup-btn-outline" id="image-upload-btn" style="width:100%">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><path d="M21 15l-5-5L5 21"/></svg>
                Upload Image
              </button>
            </div>
            <div class="controls-section">
              <h3 class="controls-label">Metrics</h3>
              <div class="ctrl-row">
                <label class="ctrl-label-sm">Replies</label>
                <input type="number" class="ctrl-input" id="metric-comments" min="0">
              </div>
              <div class="ctrl-row">
                <label class="ctrl-label-sm">Reposts</label>
                <input type="number" class="ctrl-input" id="metric-shares" min="0">
              </div>
              <div class="ctrl-row">
                <label class="ctrl-label-sm">Likes</label>
                <input type="number" class="ctrl-input" id="metric-likes" min="0">
              </div>
              <div class="ctrl-row">
                <label class="ctrl-label-sm">Bookmarks</label>
                <input type="number" class="ctrl-input" id="metric-bookmarks" min="0">
              </div>
            </div>
            <div class="controls-section">
              <h3 class="controls-label">Timestamp</h3>
              <input type="text" class="ctrl-input" id="post-timestamp" placeholder="10:30 AM · Apr 9, 2026">
            </div>
          </div>

          <!-- Preview -->
          <div class="mockup-preview">
            <div class="mockup-action-bar">
              <button class="mockup-btn mockup-btn-outline" id="toggle-dark">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 12.79A9 9 0 1111.21 3 7 7 0 0021 12.79z"/></svg>
                Dark mode
              </button>
              <button class="mockup-btn mockup-btn-outline" id="toggle-frame">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="5" y="2" width="14" height="20" rx="2" ry="2"/><line x1="12" y1="18" x2="12.01" y2="18"/></svg>
                Hide frame
              </button>
              <div style="flex:1"></div>
              <button class="mockup-btn mockup-btn-primary" id="download-btn">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
                Download PNG
              </button>
            </div>

            <div class="phone-frame" id="phone-frame">
              <div class="phone-notch"></div>
              <div class="phone-screen" id="phone-screen">
                <div class="xp-screen">
                  <div class="xp-statusbar">
                    <span class="xp-statusbar-time">15:08</span>
                    <span style="flex:1"></span>
                    <span class="xp-statusbar-icons">
                      <svg viewBox="0 0 18 12" fill="currentColor" width="16" height="11"><rect x="0" y="9" width="3" height="3" rx="1"/><rect x="5" y="6" width="3" height="6" rx="1"/><rect x="10" y="3" width="3" height="9" rx="1"/><rect x="15" y="0" width="3" height="12" rx="1"/></svg>
                      <svg viewBox="0 0 16 12" fill="currentColor" width="15" height="11"><path d="M8.5 1.5C10.4 1.5 12.1 2.3 13.3 3.5L14.7 2.1C13.1 0.5 10.9-0.5 8.5-0.5C6.1-0.5 3.9 0.5 2.3 2.1L3.7 3.5C4.9 2.3 6.6 1.5 8.5 1.5ZM5.1 5C5.9 4.2 7.1 3.7 8.5 3.7C9.9 3.7 11.1 4.2 11.9 5L8.5 8.5L5.1 5Z"/></svg>
                      <svg viewBox="0 0 25 12" fill="none" width="25" height="12"><rect x="0.5" y="0.5" width="21" height="11" rx="3.5" stroke="currentColor" stroke-width="1"/><rect x="2" y="2" width="18" height="8" rx="2" fill="currentColor"/><path d="M23 4.5C23.5523 4.5 24 4.94772 24 5.5V6.5C24 7.05228 23.5523 7.5 23 7.5" fill="currentColor"/></svg>
                    </span>
                  </div>
                  <div class="xp-topbar">
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
                    <span class="xp-topbar-title">Post</span>
                    <div style="flex:1"></div>
                  </div>
                  <div class="xp-content-area" id="post-content"></div>
                  <div class="xp-home-indicator"></div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </ToolShell>
  </Layout>
</Base>

<link rel="stylesheet" href={styleHref('mockup.css')} />

<script define:vars={{ platformConfig }}>
  window.__mockupPlatform = platformConfig
</script>
<script is:inline src="https://cdn.jsdelivr.net/npm/html2canvas@1.4.1/dist/html2canvas.min.js"></script>
<script src="../tools/mockup/mockup-common.js"></script>
<script src="../tools/mockup/post-engine.js"></script>

<style is:global>
.mockup-preview {
  display: flex;
  flex-direction: column;
  align-items: center;
}
</style>
