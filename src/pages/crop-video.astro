---
import Base from '../layouts/Base.astro'
import Layout from '../components/Layout.astro'
import ToolShell from '../components/ToolShell.astro'

const seo = {
  title: 'Crop Video Online — Free Video Cropper | maratool',
  description: 'Crop videos online for free — drag a crop box on any MP4, WebM, or MOV. Aspect ratio presets for Instagram, TikTok, YouTube. Runs in your browser.',
  canonical: 'https://maratool.com/crop-video',
  schema: {
    '@context': 'https://schema.org',
    '@type': 'WebApplication',
    name: 'Crop Video Online',
    url: 'https://maratool.com/crop-video',
    applicationCategory: 'UtilitiesApplication',
    operatingSystem: 'Any',
    offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
    description: 'Crop MP4, WebM, and MOV videos in your browser. Drag a crop box, pick an aspect ratio — no upload, no watermark.',
  },
  breadcrumbSchema: {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://maratool.com' },
      { '@type': 'ListItem', position: 2, name: 'Converter', item: 'https://maratool.com/converter' },
      { '@type': 'ListItem', position: 3, name: 'Video', item: 'https://maratool.com/converter/video' },
      { '@type': 'ListItem', position: 4, name: 'Crop Video', item: 'https://maratool.com/crop-video' },
    ],
  },
  faqSchema: {
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: [
      {
        '@type': 'Question',
        name: 'Is this video cropper free?',
        acceptedAnswer: { '@type': 'Answer', text: '100% free, no signup, no watermark, no file-size limits beyond what your browser can handle. Everything runs in your browser — your videos never leave your device.' }
      },
      {
        '@type': 'Question',
        name: 'Will cropping reduce video quality?',
        acceptedAnswer: { '@type': 'Answer', text: 'The video is re-encoded only for the crop operation itself, which is unavoidable. We use libx264 with a high-quality preset so the quality loss is minimal and invisible in most cases. Audio is always copied losslessly.' }
      },
      {
        '@type': 'Question',
        name: 'How do I crop a video for Instagram or TikTok?',
        acceptedAnswer: { '@type': 'Answer', text: 'Click the "9:16" aspect ratio button to lock the crop box to vertical format, drag the box to frame your subject, then click "Crop video". For a square Instagram post, use the "1:1" preset instead.' }
      },
      {
        '@type': 'Question',
        name: 'What is the maximum file size?',
        acceptedAnswer: { '@type': 'Answer', text: 'Up to 2 GB on desktop; mobile browsers may struggle above 500 MB. The whole video stays on your device — nothing is uploaded — so the limit is your device memory, not a server quota.' }
      }
    ]
  }
}

const howTo = [
  'Drop a video file or click to select an MP4, WebM, or MOV.',
  'Drag the crop box handles to frame your desired region, or pick an aspect ratio preset.',
  'Click "Crop video" and download the result.'
]

const faq = [
  { q: 'Is this video cropper free?', a: '100% free, no signup, no watermark, no file-size limits beyond what your browser can handle. Everything runs in your browser — your videos never leave your device.' },
  { q: 'Will cropping reduce video quality?', a: 'The video is re-encoded only for the crop operation itself, which is unavoidable. We use libx264 with a high-quality preset so quality loss is minimal. Audio is always copied losslessly.' },
  { q: 'How do I crop a video for Instagram or TikTok?', a: 'Click the "9:16" aspect ratio button to lock the crop box to vertical format, drag the box to frame your subject, then click "Crop video". For a square Instagram post, use the "1:1" preset instead.' },
  { q: 'What is the maximum file size?', a: 'Up to 2 GB on desktop; mobile browsers may struggle above 500 MB. The whole video stays on your device — nothing is uploaded — so the limit is your device memory, not a server quota.' },
]

const relatedTools = [
  { slug: 'resize-video', name: 'Resize Video Online' },
  { slug: 'trim-video', name: 'Trim Video Online' },
  { slug: 'rotate-video', name: 'Rotate Video Online' },
]

const breadcrumbs = [
  { label: 'Home', href: '/' },
  { label: 'Converter', href: '/converter' },
  { label: 'Video', href: '/converter/video' },
  { label: 'Crop Video' },
]
---
<Base {...seo}>
  <Layout>
    <ToolShell slug="crop-video" name="Crop Video Online" description="Crop MP4, WebM, and MOV videos in your browser. Drag a crop box, pick an aspect ratio — no upload, no watermark." howTo={howTo} faq={faq} relatedTools={relatedTools} breadcrumbs={breadcrumbs}>
      <div class="tool-container" style="min-height:400px;">
        <!-- Mobile banner -->
        <div class="cp-mobile-banner" id="cp-mobile-banner" style="display:none;">
          <span>This works on mobile but is faster on desktop. Files above 500 MB may fail on phones.</span>
          <button type="button" class="cp-mobile-banner-dismiss" id="cp-mobile-banner-dismiss" aria-label="Dismiss">&times;</button>
        </div>

        <!-- Drop zone -->
        <div class="cp-dropzone" id="cp-dropzone">
          <input type="file" id="cp-file-input" accept="video/mp4,video/webm,video/quicktime" hidden />
          <div class="cp-dropzone-inner">
            <svg class="cp-upload-icon" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
              <polyline points="17 8 12 3 7 8"/>
              <line x1="12" y1="3" x2="12" y2="15"/>
            </svg>
            <p class="cp-dropzone-title">Drop a video here</p>
            <p class="cp-dropzone-sub">or click to select a file</p>
            <p class="cp-dropzone-formats">MP4, WebM, MOV — up to 2 GB</p>
          </div>
        </div>

        <div class="cp-info" id="cp-info">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="16" x2="12" y2="12"/><line x1="12" y1="8" x2="12.01" y2="8"/></svg>
          <span>The FFmpeg engine (~25 MB) downloads on first use and is cached by your browser. Your video never leaves your device.</span>
        </div>

        <!-- Editor -->
        <div class="cp-editor" id="cp-editor" style="display:none;">
          <!-- Aspect ratio presets -->
          <div class="cp-ratio-row">
            <span class="cp-ratio-label">Aspect ratio:</span>
            <button type="button" class="cp-ratio-btn cp-ratio-btn--active" data-ratio="free">Free</button>
            <button type="button" class="cp-ratio-btn" data-ratio="16:9">16:9</button>
            <button type="button" class="cp-ratio-btn" data-ratio="9:16">9:16</button>
            <button type="button" class="cp-ratio-btn" data-ratio="1:1">1:1</button>
            <button type="button" class="cp-ratio-btn" data-ratio="4:3">4:3</button>
            <button type="button" class="cp-ratio-btn" data-ratio="3:4">3:4</button>
          </div>

          <!-- Video + crop overlay -->
          <div class="cp-video-wrap">
            <video id="cp-video" controls preload="metadata"></video>
            <div class="cp-crop-overlay" id="cp-crop-overlay">
              <div class="cp-shade cp-shade-top" id="cp-shade-top"></div>
              <div class="cp-shade cp-shade-bottom" id="cp-shade-bottom"></div>
              <div class="cp-shade cp-shade-left" id="cp-shade-left"></div>
              <div class="cp-shade cp-shade-right" id="cp-shade-right"></div>
              <div class="cp-crop-box" id="cp-crop-box">
                <div class="cp-handle cp-handle-tl" data-handle="tl"></div>
                <div class="cp-handle cp-handle-tr" data-handle="tr"></div>
                <div class="cp-handle cp-handle-bl" data-handle="bl"></div>
                <div class="cp-handle cp-handle-br" data-handle="br"></div>
              </div>
            </div>
          </div>

          <!-- Live readout -->
          <div class="cp-readout" id="cp-crop-readout"></div>

          <div class="cp-actions">
            <button class="tool-button" id="cp-crop-btn">Crop video</button>
            <button class="copy-btn" id="cp-change-btn">Change video</button>
          </div>
        </div>

        <!-- Progress -->
        <div class="cp-progress" id="cp-progress" style="display:none;">
          <div class="cp-progress-text" id="cp-progress-text">Loading FFmpeg...</div>
          <div class="cp-progress-track">
            <div class="cp-progress-fill" id="cp-progress-fill"></div>
          </div>
          <div class="cp-progress-detail" id="cp-progress-detail"></div>
        </div>

        <!-- Error -->
        <div class="cp-error" id="cp-error" style="display:none;">
          <span class="cp-error-text" id="cp-error-text"></span>
          <button class="cp-error-retry" id="cp-error-retry">Try again</button>
        </div>

        <!-- Result -->
        <div class="cp-result" id="cp-result" style="display:none;">
          <div class="cp-result-preview">
            <video id="cp-result-video" controls></video>
          </div>
          <div class="cp-result-stats" id="cp-result-stats"></div>
          <div class="cp-result-actions">
            <button class="tool-button" id="cp-download">Download cropped video</button>
            <button class="copy-btn" id="cp-new">Crop another</button>
          </div>
        </div>
      </div>
    </ToolShell>
  </Layout>
</Base>
<style is:global>
  /* Mobile banner */
  .cp-mobile-banner {
    display: flex; align-items: center; justify-content: space-between; gap: 0.75rem;
    padding: 0.625rem 0.875rem; margin-bottom: 1rem;
    background: var(--bg-soft); border: 1px solid var(--border); border-radius: var(--radius);
    font-size: 0.8125rem; color: var(--text-2);
  }
  .cp-mobile-banner-dismiss {
    background: none; border: none; font-size: 1.25rem; line-height: 1; cursor: pointer;
    color: var(--text-3); padding: 0 0.25rem;
  }
  .cp-mobile-banner-dismiss:hover { color: var(--text); }

  /* Dropzone */
  .cp-dropzone {
    border: 2px dashed var(--border);
    border-radius: var(--radius);
    padding: 3rem 2rem;
    text-align: center;
    cursor: pointer;
    transition: border-color 0.2s, background 0.2s;
  }
  .cp-dropzone:hover, .cp-dropzone.drag-over {
    border-color: var(--accent);
    background: var(--bg-soft);
  }
  .cp-dropzone-inner {
    display: flex; flex-direction: column; align-items: center; gap: 0.5rem;
  }
  .cp-upload-icon { color: var(--text-3); margin-bottom: 0.5rem; }
  .cp-dropzone-title { font-size: 1.125rem; font-weight: 600; color: var(--text); margin: 0; }
  .cp-dropzone-sub { font-size: 0.875rem; color: var(--text-2); margin: 0; }
  .cp-dropzone-formats { font-size: 0.75rem; color: var(--text-3); margin: 0.25rem 0 0; }

  .cp-info {
    display: flex; align-items: flex-start; gap: 0.5rem;
    padding: 0.75rem 1rem; background: var(--bg-soft);
    border: 1px solid var(--border); border-radius: var(--radius);
    margin-top: 1rem; font-size: 0.8125rem; color: var(--text-2); line-height: 1.5;
  }
  .cp-info svg { flex-shrink: 0; margin-top: 1px; color: var(--text-3); }

  /* Aspect ratio buttons */
  .cp-ratio-row {
    display: flex; align-items: center; gap: 0.5rem; flex-wrap: wrap;
    margin-bottom: 0.875rem;
  }
  .cp-ratio-label {
    font-size: 0.8125rem; color: var(--text-2); font-weight: 500; margin-right: 0.25rem;
  }
  .cp-ratio-btn {
    padding: 5px 12px; border: 1px solid var(--border); border-radius: 6px;
    background: var(--bg); color: var(--text-2); font-size: 0.8125rem;
    cursor: pointer; transition: border-color 0.15s, background 0.15s, color 0.15s;
  }
  .cp-ratio-btn:hover { border-color: var(--accent); color: var(--accent); }
  .cp-ratio-btn--active {
    border-color: var(--accent); background: var(--accent); color: #fff;
  }
  .cp-ratio-btn--active:hover { color: #fff; }

  /* Video wrap + crop overlay */
  .cp-video-wrap {
    position: relative; display: inline-block; max-width: 100%;
    margin-bottom: 0.75rem;
  }
  .cp-video-wrap video {
    display: block; max-width: 100%; height: auto;
    border-radius: var(--radius); border: 1px solid var(--border); background: #000;
  }
  .cp-crop-overlay {
    position: absolute; inset: 0; pointer-events: none;
  }
  .cp-shade { pointer-events: none; }
  .cp-crop-box {
    position: absolute;
    border: 2px solid #fff;
    box-shadow: 0 0 0 1px rgba(0,0,0,0.5);
    cursor: move;
    pointer-events: auto;
    touch-action: none;
    box-sizing: border-box;
  }
  .cp-handle {
    position: absolute; width: 14px; height: 14px;
    background: #fff; border: 1px solid #000;
    pointer-events: auto; touch-action: none;
    box-sizing: border-box;
  }
  .cp-handle-tl { top: -7px; left: -7px; cursor: nwse-resize; }
  .cp-handle-tr { top: -7px; right: -7px; cursor: nesw-resize; }
  .cp-handle-bl { bottom: -7px; left: -7px; cursor: nesw-resize; }
  .cp-handle-br { bottom: -7px; right: -7px; cursor: nwse-resize; }

  /* Live readout */
  .cp-readout {
    font-size: 0.875rem; font-weight: 600; color: var(--text-2);
    font-family: var(--font-mono); margin-bottom: 0.875rem;
    min-height: 1.25rem;
  }

  .cp-actions {
    display: flex; gap: 0.75rem; align-items: center; margin-top: 0.25rem;
  }

  /* Progress */
  .cp-progress { text-align: center; padding: 2rem; }
  .cp-progress-text {
    font-size: 0.9375rem; font-weight: 600; color: var(--text); margin-bottom: 1rem;
  }
  .cp-progress-track {
    width: 100%; max-width: 400px; height: 8px; background: var(--bg-hover);
    border-radius: 4px; margin: 0 auto; overflow: hidden;
  }
  .cp-progress-fill {
    height: 100%; background: var(--accent); border-radius: 4px;
    width: 0%; transition: width 0.3s;
  }
  .cp-progress-detail {
    font-size: 0.75rem; color: var(--text-3); margin-top: 0.5rem;
  }

  /* Error */
  .cp-error {
    background: var(--error-bg); border: 1px solid var(--error-border);
    border-radius: var(--radius); padding: 1rem;
    display: flex; align-items: center; justify-content: space-between; gap: 1rem;
  }
  .cp-error-text { color: #c53030; font-size: 0.875rem; }
  .cp-error-retry {
    padding: 6px 14px; background: var(--bg); border: 1px solid var(--border);
    border-radius: 6px; font-size: 0.8125rem; cursor: pointer; white-space: nowrap;
    color: var(--text);
  }
  .cp-error-retry:hover { background: var(--bg-hover); }

  /* Result */
  .cp-result-preview {
    text-align: center; margin-bottom: 0.75rem;
    border: 1px solid var(--border); border-radius: var(--radius);
    padding: 0.5rem; min-height: 100px;
    display: flex; align-items: center; justify-content: center;
    background: var(--bg-soft);
  }
  .cp-result-preview video { max-width: 100%; max-height: 500px; border-radius: 6px; background: #000; }
  .cp-result-stats {
    font-size: 0.875rem; color: var(--text-2); margin-bottom: 0.75rem;
    text-align: center; line-height: 1.6;
  }
  .cp-result-actions {
    display: flex; gap: 0.75rem; align-items: center; justify-content: center;
  }

  @media (max-width: 768px) {
    .cp-ratio-row { gap: 0.375rem; }
    .cp-ratio-btn { padding: 4px 8px; font-size: 0.75rem; }
  }
</style>
<script src="../tools/crop-video.js"></script>
