---
import Base from '../layouts/Base.astro'
import Layout from '../components/Layout.astro'
import ToolShell from '../components/ToolShell.astro'

const seo = {
  title: 'Convert MNG to APNG — Free Online MNG Converter | maratool',
  description: 'Convert MNG (Multiple-image Network Graphics) to APNG online. Preserves frames and timing — runs in your browser, no upload, no watermark.',
  canonical: 'https://maratool.com/mng-to-apng',
  schema: {
    '@context': 'https://schema.org',
    '@type': 'WebApplication',
    name: 'Convert MNG to APNG',
    url: 'https://maratool.com/mng-to-apng',
    applicationCategory: 'UtilitiesApplication',
    operatingSystem: 'Any',
    offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
    description: 'Convert legacy MNG animations to modern APNG format in your browser. Preserves frames and frame timing.',
  },
  breadcrumbSchema: {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://maratool.com' },
      { '@type': 'ListItem', position: 2, name: 'Converter', item: 'https://maratool.com/converter' },
      { '@type': 'ListItem', position: 3, name: 'Format', item: 'https://maratool.com/converter/format' },
      { '@type': 'ListItem', position: 4, name: 'Convert MNG to APNG', item: 'https://maratool.com/mng-to-apng' },
    ],
  },
  faqSchema: {
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: [
      {
        '@type': 'Question',
        name: 'What is the difference between MNG and APNG?',
        acceptedAnswer: { '@type': 'Answer', text: 'Both are animated PNG-based formats. MNG (Multiple-image Network Graphics) is a legacy format not supported by any mainstream browser. APNG (Animated PNG) works in Chrome, Firefox, Safari, and Edge, and falls back to the first frame in older software.' }
      },
      {
        '@type': 'Question',
        name: 'Does this converter preserve frame timing?',
        acceptedAnswer: { '@type': 'Answer', text: 'Yes. FFmpeg decodes each MNG frame and muxes them into APNG with the original per-frame delays. Loop count and timing from the source animation are preserved.' }
      },
      {
        '@type': 'Question',
        name: 'Is my MNG file uploaded to a server?',
        acceptedAnswer: { '@type': 'Answer', text: 'No. Conversion runs entirely in your browser using FFmpeg compiled to WebAssembly. Your file never leaves your device.' }
      },
      {
        '@type': 'Question',
        name: 'What is the maximum MNG file size?',
        acceptedAnswer: { '@type': 'Answer', text: 'Up to 200 MB. Large animations may take longer and use significant browser memory because the entire file is processed locally.' }
      }
    ]
  }
}

const howTo = [
  'Drop a .mng file or click to browse — up to 200 MB.',
  'Click "Convert to APNG" and wait for FFmpeg to process the animation.',
  'Preview the result and download your .apng file.'
]

const faq = [
  { q: 'What is the difference between MNG and APNG?', a: 'Both are animated PNG-based formats. MNG is a legacy format not supported by browsers. APNG works in all modern browsers and falls back to the first frame in older software.' },
  { q: 'Does this converter preserve frame timing?', a: 'Yes. FFmpeg decodes each MNG frame and muxes them into APNG with the original per-frame delays.' },
  { q: 'Is my MNG file uploaded to a server?', a: 'No. Conversion runs in your browser via WebAssembly. Your file never leaves your device.' },
  { q: 'What is the maximum MNG file size?', a: 'Up to 200 MB. Large animations use significant browser memory because processing is entirely local.' },
]

const relatedTools = [
  { slug: 'gif-compressor', name: 'GIF Compressor' },
  { slug: 'image-converter', name: 'Image Format Converter' },
  { slug: 'video-to-gif', name: 'Video to GIF Converter' },
]

const breadcrumbs = [
  { label: 'Home', href: '/' },
  { label: 'Converter', href: '/converter' },
  { label: 'Format', href: '/converter/format' },
  { label: 'Convert MNG to APNG' },
]
---
<Base {...seo}>
  <Layout>
    <ToolShell slug="mng-to-apng" name="Convert MNG to APNG Online" description="Convert legacy MNG animations to modern APNG in your browser. Preserves frames and timing — no upload, no watermark." howTo={howTo} faq={faq} relatedTools={relatedTools} breadcrumbs={breadcrumbs}>
      <div class="tool-container" style="min-height:400px;">
        <div class="m2a-mobile-banner" id="m2a-mobile-banner" style="display:none;">
          <span>Works on mobile but is faster on desktop. Files above 50 MB may be slow on phones.</span>
          <button type="button" class="m2a-mobile-banner-dismiss" id="m2a-mobile-banner-dismiss" aria-label="Dismiss">&times;</button>
        </div>

        <div class="m2a-dropzone" id="m2a-dropzone">
          <input type="file" id="m2a-file-input" accept=".mng,video/x-mng,image/x-mng" hidden />
          <div class="m2a-dropzone-inner">
            <svg class="m2a-upload-icon" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <rect x="3" y="3" width="18" height="18" rx="2" ry="2"/>
              <circle cx="8.5" cy="8.5" r="1.5"/>
              <polyline points="21 15 16 10 5 21"/>
            </svg>
            <p class="m2a-dropzone-title">Drop an MNG file here</p>
            <p class="m2a-dropzone-sub">or click to select a file</p>
            <p class="m2a-dropzone-formats">MNG (Multiple-image Network Graphics) — up to 200 MB</p>
          </div>
        </div>

        <div class="m2a-info" id="m2a-info">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="16" x2="12" y2="12"/><line x1="12" y1="8" x2="12.01" y2="8"/></svg>
          <span>MNG is not supported by browsers. This tool converts to APNG with FFmpeg (~25 MB download on first use, then cached). Frames and timing are preserved.</span>
        </div>

        <div class="m2a-settings" id="m2a-settings" style="display:none;">
          <div class="m2a-file-meta">
            <div class="m2a-stat">
              <span class="m2a-stat-value" id="m2a-filename">—</span>
              <span class="m2a-stat-label">File name</span>
            </div>
            <div class="m2a-stat">
              <span class="m2a-stat-value" id="m2a-filesize">—</span>
              <span class="m2a-stat-label">File size</span>
            </div>
          </div>
          <p class="m2a-note">Browsers cannot preview MNG files. Click convert to generate a browser-compatible APNG.</p>
          <div class="m2a-actions">
            <button class="tool-button" id="m2a-convert">Convert to APNG</button>
            <button class="copy-btn" id="m2a-change">Change file</button>
          </div>
        </div>

        <div class="m2a-progress" id="m2a-progress" style="display:none;">
          <div class="m2a-progress-text" id="m2a-progress-text">Loading FFmpeg...</div>
          <div class="m2a-progress-track">
            <div class="m2a-progress-fill" id="m2a-progress-fill"></div>
          </div>
          <div class="m2a-progress-detail" id="m2a-progress-detail"></div>
        </div>

        <div class="m2a-error" id="m2a-error" style="display:none;">
          <span class="m2a-error-text" id="m2a-error-text"></span>
          <button class="m2a-error-retry" id="m2a-error-retry">Try again</button>
        </div>

        <div class="m2a-result" id="m2a-result" style="display:none;">
          <div class="m2a-result-preview">
            <img id="m2a-result-img" alt="Converted APNG animation preview" />
          </div>
          <div class="m2a-result-stats" id="m2a-result-stats"></div>
          <div class="m2a-result-actions">
            <button class="tool-button" id="m2a-download">Download APNG</button>
            <button class="copy-btn" id="m2a-new">Convert another</button>
          </div>
        </div>
      </div>
    </ToolShell>
  </Layout>
</Base>
<style is:global>
  .m2a-mobile-banner {
    display: flex; align-items: center; justify-content: space-between; gap: 0.75rem;
    padding: 0.625rem 0.875rem; margin-bottom: 1rem;
    background: var(--bg-soft); border: 1px solid var(--border); border-radius: var(--radius);
    font-size: 0.8125rem; color: var(--text-2);
  }
  .m2a-mobile-banner-dismiss {
    background: none; border: none; font-size: 1.25rem; line-height: 1; cursor: pointer;
    color: var(--text-3); padding: 0 0.25rem;
  }
  .m2a-mobile-banner-dismiss:hover { color: var(--text); }

  .m2a-dropzone {
    border: 2px dashed var(--border);
    border-radius: var(--radius);
    padding: 3rem 2rem;
    text-align: center;
    cursor: pointer;
    transition: border-color 0.2s, background 0.2s;
  }
  .m2a-dropzone:hover, .m2a-dropzone.drag-over {
    border-color: var(--accent);
    background: var(--bg-soft);
  }
  .m2a-dropzone-inner {
    display: flex; flex-direction: column; align-items: center; gap: 0.5rem;
  }
  .m2a-upload-icon { color: var(--text-3); margin-bottom: 0.5rem; }
  .m2a-dropzone-title { font-size: 1.125rem; font-weight: 600; color: var(--text); margin: 0; }
  .m2a-dropzone-sub { font-size: 0.875rem; color: var(--text-2); margin: 0; }
  .m2a-dropzone-formats { font-size: 0.75rem; color: var(--text-3); margin: 0.25rem 0 0; }

  .m2a-info {
    display: flex; align-items: flex-start; gap: 0.5rem;
    padding: 0.75rem 1rem; background: var(--bg-soft);
    border: 1px solid var(--border); border-radius: var(--radius);
    margin-top: 1rem; font-size: 0.8125rem; color: var(--text-2); line-height: 1.5;
  }
  .m2a-info svg { flex-shrink: 0; margin-top: 1px; color: var(--text-3); }

  .m2a-file-meta {
    display: flex; gap: 2rem; margin-bottom: 1rem; flex-wrap: wrap;
  }
  .m2a-stat { display: flex; flex-direction: column; gap: 0.125rem; min-width: 0; }
  .m2a-stat-value {
    font-size: 1rem; font-weight: 600; color: var(--text);
    font-family: var(--font-mono);
    word-break: break-all;
  }
  .m2a-stat-label {
    font-size: 0.75rem; color: var(--text-3);
    text-transform: uppercase; letter-spacing: 0.05em;
  }
  .m2a-note {
    font-size: 0.8125rem; color: var(--text-2); margin: 0 0 1rem; line-height: 1.5;
  }
  .m2a-actions {
    display: flex; gap: 0.75rem; align-items: center; flex-wrap: wrap;
  }

  .m2a-progress { text-align: center; padding: 2rem; }
  .m2a-progress-text {
    font-size: 0.9375rem; font-weight: 600; color: var(--text); margin-bottom: 1rem;
  }
  .m2a-progress-track {
    width: 100%; max-width: 400px; height: 8px; background: var(--bg-hover);
    border-radius: 4px; margin: 0 auto; overflow: hidden;
  }
  .m2a-progress-fill {
    height: 100%; background: var(--accent); border-radius: 4px;
    width: 0%; transition: width 0.3s;
  }
  .m2a-progress-detail {
    font-size: 0.75rem; color: var(--text-3); margin-top: 0.5rem;
  }

  .m2a-error {
    background: var(--error-bg); border: 1px solid var(--error-border);
    border-radius: var(--radius); padding: 1rem;
    display: flex; align-items: center; justify-content: space-between; gap: 1rem;
  }
  .m2a-error-text { color: #c53030; font-size: 0.875rem; }
  .m2a-error-retry {
    padding: 6px 14px; background: var(--bg); border: 1px solid var(--border);
    border-radius: 6px; font-size: 0.8125rem; cursor: pointer; white-space: nowrap;
    color: var(--text);
  }
  .m2a-error-retry:hover { background: var(--bg-hover); }

  .m2a-result-preview {
    text-align: center; margin-bottom: 0.75rem;
    border: 1px solid var(--border); border-radius: var(--radius);
    padding: 0.5rem; min-height: 120px;
    display: flex; align-items: center; justify-content: center;
    background: var(--bg-soft);
  }
  .m2a-result-preview img { max-width: 100%; max-height: 500px; border-radius: 6px; }
  .m2a-result-stats {
    font-size: 0.875rem; color: var(--text-2); margin-bottom: 0.75rem;
    text-align: center; line-height: 1.6;
  }
  .m2a-result-actions {
    display: flex; gap: 0.75rem; align-items: center; justify-content: center; flex-wrap: wrap;
  }
</style>
<script src="../tools/mng-to-apng.js"></script>
