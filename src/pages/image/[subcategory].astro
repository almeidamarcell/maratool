---
import Base from '../../layouts/Base.astro'
import Layout from '../../components/Layout.astro'
import HubPage from '../../components/HubPage.astro'
import { toolsByCategory, toolsFlatByCategory, subcategoryOrderByCategory, buildToolItemList } from '../../data/tools'

export function getStaticPaths() {
  const subs = subcategoryOrderByCategory.Image ?? []
  const catTools = toolsByCategory.Image ?? {}

  const descriptions: Record<string, { title: string; description: string; intro: string }> = {
    transform: {
      title: 'Image Transform Tools — maratool',
      description: 'Free browser-based image tools. Remove backgrounds, optimize SVGs, generate favicons — no upload, runs entirely in your browser.',
      intro: 'Transform, optimize, and convert images directly in your browser.',
    },
    inspect: {
      title: 'Image Inspect Tools — maratool',
      description: 'Free browser-based image inspection tools. Preview Base64 images, generate alt text with AI — no upload, runs in your browser.',
      intro: 'Inspect, preview, and analyze images locally in your browser.',
    },
  }

  return subs.map(sub => {
    const slug = sub.toLowerCase()
    const meta = descriptions[slug] ?? {
      title: `${sub} Image Tools — maratool`,
      description: `Free browser-based image ${sub.toLowerCase()} tools — no sign-up, runs entirely in your browser.`,
      intro: `Image ${sub.toLowerCase()} tools that run locally in your browser.`,
    }
    return {
      params: { subcategory: slug },
      props: { sub, subTools: catTools[sub] ?? [], ...meta },
    }
  })
}

const { subcategory } = Astro.params
const { sub, subTools, title, description, intro } = Astro.props
const allTools = toolsFlatByCategory.Image ?? []
const subcategories = subcategoryOrderByCategory.Image ?? []
const liveSubTools = subTools.filter((tool: { live: boolean }) => tool.live)

const seo = {
  title,
  description,
  canonical: `https://maratool.com/image/${subcategory}`,
  schema: {
    '@context': 'https://schema.org',
    '@type': 'CollectionPage',
    name: `Image ${sub} Tools`,
    url: `https://maratool.com/image/${subcategory}`,
    description,
    hasPart: liveSubTools.map((tool: { name: string; slug: string }) => ({
      '@type': 'SoftwareApplication',
      name: tool.name,
      url: `https://maratool.com/${tool.slug}`,
      applicationCategory: 'DesignApplication',
    })),
    mainEntity: buildToolItemList(liveSubTools, `Image ${sub} Tools`),
  },
  breadcrumbSchema: {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://maratool.com' },
      { '@type': 'ListItem', position: 2, name: 'Image', item: 'https://maratool.com/image' },
      { '@type': 'ListItem', position: 3, name: sub, item: `https://maratool.com/image/${subcategory}` },
    ],
  },
}
---
<Base {...seo} scope="subcategory">
  <Layout scope="subcategory">
    <HubPage
      category="Image"
      categorySlug="image"
      title={`Image ${sub} tools`}
      subtitle={intro}
      tools={allTools}
      subcategories={subcategories}
      activeSubcategory={sub}
      basePath="/image"
    />
  </Layout>
</Base>
