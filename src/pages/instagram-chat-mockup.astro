---
import Base from '../layouts/Base.astro'
import { styleHref } from '../lib/css-version'
import Layout from '../components/Layout.astro'
import ToolShell from '../components/ToolShell.astro'
import { instagramDm } from '../data/mockup-platforms'

const platformConfig = instagramDm

const seo = {
  title: 'Instagram DM Mockup Generator — Create Fake DMs | maratool',
  description: 'Create realistic Instagram DM screenshots online. Blue outgoing messages, rounded bubbles, dark mode toggle, download as PNG. Free, no sign-up.',
  canonical: 'https://maratool.com/instagram-chat-mockup',
  schema: {
    '@context': 'https://schema.org',
    '@type': 'WebApplication',
    name: 'Instagram DM Mockup Generator',
    url: 'https://maratool.com/instagram-chat-mockup',
    applicationCategory: 'DesignApplication',
    operatingSystem: 'Any',
    offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
    description: 'Create realistic Instagram DM screenshots with inline editing, dark mode, and PNG export.',
  },
  breadcrumbSchema: {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://maratool.com' },
      { '@type': 'ListItem', position: 2, name: 'Mockup', item: 'https://maratool.com/mockup' },
      { '@type': 'ListItem', position: 3, name: 'Chat', item: 'https://maratool.com/mockup/chat' },
      { '@type': 'ListItem', position: 4, name: 'Instagram DM Mockup Generator', item: 'https://maratool.com/instagram-chat-mockup' },
    ],
  },
  faqSchema: {
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: [
      {
        '@type': 'Question',
        name: 'Is this Instagram DM mockup generator free?',
        acceptedAnswer: { '@type': 'Answer', text: 'Yes, completely free. No sign-up, no watermark. Create unlimited Instagram DM mockups and download them as PNG.' }
      },
      {
        '@type': 'Question',
        name: 'Does this tool upload my messages?',
        acceptedAnswer: { '@type': 'Answer', text: 'No. Everything runs in your browser. Your messages never leave your device. The PNG is generated locally using html2canvas.' }
      },
      {
        '@type': 'Question',
        name: 'Can I use dark mode for the Instagram DM mockup?',
        acceptedAnswer: { '@type': 'Answer', text: 'Yes. Click the dark mode toggle above the phone preview to switch between light and dark Instagram themes.' }
      },
      {
        '@type': 'Question',
        name: 'Does the mockup look like real Instagram DMs?',
        acceptedAnswer: { '@type': 'Answer', text: 'Yes. The mockup uses Instagram\'s actual color scheme, rounded bubble style, and header layout to create authentic-looking screenshots.' }
      }
    ]
  }
}

const howTo = [
  'Add people and type messages using the controls panel on the left.',
  'Click any message bubble in the phone preview to edit it inline.',
  'Toggle dark mode or hide the phone frame, then click Download PNG.'
]

const faq = [
  { q: 'Is this Instagram DM mockup generator free?', a: 'Yes, completely free. No sign-up, no watermark. Create unlimited mockups and download as PNG.' },
  { q: 'Does this tool upload my messages?', a: 'No. Everything runs in your browser. Your messages never leave your device.' },
  { q: 'Can I use dark mode for the Instagram DM?', a: 'Yes. Click the dark mode toggle above the phone to switch Instagram themes.' },
  { q: 'Does the mockup look like real Instagram DMs?', a: 'Yes. It uses Instagram\'s actual colors, rounded bubbles, and header layout.' }
]

const relatedTools = [
  { slug: 'whatsapp-chat-mockup', name: 'WhatsApp Chat Mockup' },
  { slug: 'imessage-chat-mockup', name: 'iMessage Chat Mockup' },
  { slug: 'discord-chat-mockup', name: 'Discord Chat Mockup' },
]

const breadcrumbs = [
  { label: 'Home', href: '/' },
  { label: 'Mockup', href: '/mockup' },
  { label: 'Chat', href: '/mockup/chat' },
  { label: 'Instagram DM Mockup' },
]
---
<Base {...seo}>
  <Layout>
    <ToolShell slug="instagram-chat-mockup" name="Instagram DM Mockup Generator" description="Create realistic Instagram DM screenshots. Edit messages inline, toggle dark mode, download as PNG." howTo={howTo} faq={faq} relatedTools={relatedTools} breadcrumbs={breadcrumbs}>
      <div class="tool-container" style="min-height:600px;">
        <div class="mockup-workspace">
          <!-- Controls panel -->
          <div class="controls-panel">
            <div class="controls-section">
              <h3 class="controls-label">People</h3>
              <div id="people-list"></div>
              <div class="ctrl-row" style="margin-top:8px">
                <input type="text" class="ctrl-input" id="new-person-name" placeholder="Add person...">
                <button class="mockup-btn mockup-btn-primary" id="add-person-btn">Add</button>
              </div>
            </div>
            <div class="controls-section">
              <h3 class="controls-label">New Message</h3>
              <div class="dir-toggle">
                <button class="active" id="dir-outgoing">You</button>
                <button id="dir-incoming">Them</button>
              </div>
              <select class="ctrl-input" id="msg-sender-select" style="display:none;margin-bottom:6px"></select>
              <div class="ctrl-row">
                <input type="text" class="ctrl-input" id="new-msg-text" placeholder="Type a message...">
                <button class="mockup-btn mockup-btn-primary" id="add-msg-btn">Send</button>
              </div>
            </div>
            <div class="controls-section">
              <h3 class="controls-label">Messages</h3>
              <div id="msg-list" style="max-height:320px;overflow-y:auto"></div>
            </div>
          </div>

          <!-- Preview -->
          <div class="mockup-preview">
            <div class="mockup-action-bar">
              <button class="mockup-btn mockup-btn-outline" id="toggle-dark">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 12.79A9 9 0 1111.21 3 7 7 0 0021 12.79z"/></svg>
                Dark mode
              </button>
              <button class="mockup-btn mockup-btn-outline" id="toggle-frame">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="5" y="2" width="14" height="20" rx="2" ry="2"/><line x1="12" y1="18" x2="12.01" y2="18"/></svg>
                Hide frame
              </button>
              <div style="flex:1"></div>
              <button class="mockup-btn mockup-btn-primary" id="download-btn">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
                Download PNG
              </button>
            </div>

            <div class="phone-frame" id="phone-frame">
              <div class="phone-notch"></div>
              <div class="phone-screen" id="phone-screen">
                <div class="ig-screen">
                  <div class="ig-statusbar">
                    <span class="ig-statusbar-time">20:15</span>
                    <span style="flex:1"></span>
                    <span class="ig-statusbar-icons">
                      <svg viewBox="0 0 18 12" fill="#000" width="16" height="11"><rect x="0" y="9" width="3" height="3" rx="1"/><rect x="5" y="6" width="3" height="6" rx="1"/><rect x="10" y="3" width="3" height="9" rx="1"/><rect x="15" y="0" width="3" height="12" rx="1"/></svg>
                      <svg viewBox="0 0 16 12" fill="#000" width="15" height="11"><path d="M8.5 1.5C10.4 1.5 12.1 2.3 13.3 3.5L14.7 2.1C13.1 0.5 10.9 -0.5 8.5 -0.5C6.1 -0.5 3.9 0.5 2.3 2.1L3.7 3.5C4.9 2.3 6.6 1.5 8.5 1.5Z M5.1 5C5.9 4.2 7.1 3.7 8.5 3.7C9.9 3.7 11.1 4.2 11.9 5L8.5 8.5L5.1 5Z"/></svg>
                      <svg viewBox="0 0 25 12" fill="none" width="25" height="12"><rect x="0.5" y="0.5" width="21" height="11" rx="3.5" stroke="#000" stroke-width="1"/><rect x="2" y="2" width="18" height="8" rx="2" fill="#000"/><path d="M23 4.5C23.5523 4.5 24 4.94772 24 5.5V6.5C24 7.05228 23.5523 7.5 23 7.5" fill="#000"/></svg>
                    </span>
                  </div>
                  <div class="ig-header">
                    <span class="ig-header-back">
                      <svg viewBox="0 0 14 24" fill="none" stroke="#262626" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M11 4L2.5 12L11 20"/></svg>
                    </span>
                    <div class="ig-header-avatar" id="wa-avatar">J</div>
                    <div class="ig-header-info">
                      <div class="ig-header-name" id="wa-contact-name">Jordan</div>
                      <div class="ig-header-status">Active now</div>
                    </div>
                    <div class="ig-header-actions">
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M15.05 5A5 5 0 0119 8.95M15.05 1A9 9 0 0123 8.94M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/></svg>
                      <svg viewBox="0 0 34 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M3 8.5C3 7.12 4.12 6 5.5 6H15.5C16.88 6 18 7.12 18 8.5V15.5C18 16.88 16.88 18 15.5 18H5.5C4.12 18 3 16.88 3 15.5V8.5Z"/><polygon points="18 10.5 24 7.5 24 16.5 18 13.5" stroke-linejoin="round"/></svg>
                    </div>
                  </div>
                  <div class="ig-chat" id="wa-chat"></div>
                  <div class="ig-input-bar">
                    <span class="ig-input-icon">
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 19a2 2 0 01-2 2H4a2 2 0 01-2-2V8a2 2 0 012-2h3.5l1.5-2.5h6l1.5 2.5H20a2 2 0 012 2z"/><circle cx="12" cy="13" r="3.5"/></svg>
                    </span>
                    <div class="ig-input-wrap">
                      <input type="text" class="ig-input-field" placeholder="Message..." disabled>
                    </div>
                    <span class="ig-input-icons-right">
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2a3 3 0 00-3 3v7a3 3 0 006 0V5a3 3 0 00-3-3z"/><path d="M19 10v2a7 7 0 01-14 0v-2"/></svg>
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 19a2 2 0 01-2 2H4a2 2 0 01-2-2V8a2 2 0 012-2h3.5l1.5-2.5h6l1.5 2.5H20a2 2 0 012 2z"/><circle cx="12" cy="13" r="3.5"/></svg>
                    </span>
                  </div>
                  <div class="ig-home-indicator"></div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </ToolShell>
  </Layout>
</Base>

<link rel="stylesheet" href={styleHref('mockup.css')} />

<script define:vars={{ platformConfig }}>
  window.__mockupPlatform = platformConfig
</script>
<script is:inline src="https://cdn.jsdelivr.net/npm/html2canvas@1.4.1/dist/html2canvas.min.js"></script>
<script src="../tools/mockup/mockup-common.js"></script>
<script src="../tools/mockup/chat-engine.js"></script>

<style is:global>
/* Ensure the mockup phone is centered in the preview area */
.mockup-preview {
  display: flex;
  flex-direction: column;
  align-items: center;
}
</style>
