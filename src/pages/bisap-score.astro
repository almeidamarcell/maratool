---
import ScoreCalc from '../components/ScoreCalc.astro'

const spec = {
  items: [
    { id: 'bun', label: 'BUN > 25 mg/dL', options: [
      { label: 'No (0)', points: 0, default: true }, { label: 'Yes (1)', points: 1 },
    ]},
    { id: 'mental', label: 'Impaired mental status (GCS < 15)', options: [
      { label: 'No (0)', points: 0, default: true }, { label: 'Yes (1)', points: 1 },
    ]},
    { id: 'sirs', label: 'SIRS present (≥ 2 SIRS criteria)', options: [
      { label: 'No (0)', points: 0, default: true }, { label: 'Yes (1)', points: 1 },
    ]},
    { id: 'age', label: 'Age > 60 years', options: [
      { label: 'No (0)', points: 0, default: true }, { label: 'Yes (1)', points: 1 },
    ]},
    { id: 'effusion', label: 'Pleural effusion on imaging', options: [
      { label: 'No (0)', points: 0, default: true }, { label: 'Yes (1)', points: 1 },
    ]},
  ],
  bands: [
    { min: 0, max: 2, label: 'Score 0–2 — lower mortality (≈ 0.1–2%)', cls: 'cls-normal' },
    { min: 3, max: 3, label: 'Score 3 — mortality ≈ 5–8%', cls: 'cls-warn' },
    { min: 4, max: 5, label: 'Score ≥ 4 — high mortality (≈ 13–22%)', cls: 'cls-danger' },
  ],
  max: 5,
}

const faq = [
  { q: 'What is the BISAP score?', a: 'Bedside Index of Severity in Acute Pancreatitis — a 5-point score (BUN, Impaired mental status, SIRS, Age, Pleural effusion) that predicts in-hospital mortality within 24 hours of admission.' },
  { q: 'Why use BISAP over Ranson?', a: 'BISAP uses only data available within the first 24 hours, whereas Ranson requires 48 hours, allowing earlier risk stratification.' },
  { q: 'What BISAP score is severe?', a: 'A score ≥ 3 is associated with substantially higher mortality and risk of organ failure / pancreatic necrosis.' },
  { q: 'What are the SIRS criteria?', a: 'Temp < 36 °C or > 38 °C, HR > 90, RR > 20 or PaCO₂ < 32 mmHg, WBC < 4,000 or > 12,000/µL — ≥ 2 defines SIRS.' },
]
const references = [
  { citation: 'Wu BU, Johannes RS, Sun X, et al. The early prediction of mortality in acute pancreatitis: a large population-based study. <em>Gut</em>. 2008;57(12):1698-1703.' },
]
const relatedTools = [
  { slug: 'ranson-pancreatitis', name: 'Ranson Criteria' },
  { slug: 'qsofa', name: 'qSOFA' },
  { slug: 'apache-ii', name: 'APACHE II' },
]
---
<ScoreCalc
  slug="bisap-score"
  name="BISAP Score for Pancreatitis Calculator"
  schemaName="BISAP Score"
  shortDescription="BISAP score for predicting mortality in acute pancreatitis within 24 hours (0–5)."
  metaTitle="BISAP Score Calculator (Acute Pancreatitis) | maratool"
  metaDescription="Free BISAP score calculator. Predict in-hospital mortality in acute pancreatitis within 24 hours using BUN, mental status, SIRS, age, and pleural effusion."
  subcategory="Score"
  subcategorySlug="score"
  howTo={[
    'Select each of the five BISAP criteria present in the first 24 hours.',
    'The total score (0–5) and estimated mortality update instantly.',
    'A score ≥ 3 flags severe pancreatitis — escalate care.',
  ]}
  faq={faq}
  relatedTools={relatedTools}
  references={references}
  spec={spec}
/>
