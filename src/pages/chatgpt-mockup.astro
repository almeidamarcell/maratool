---
import Base from '../layouts/Base.astro'
import Layout from '../components/Layout.astro'
import ToolShell from '../components/ToolShell.astro'
import { chatgpt } from '../data/mockup-platforms'

const platformConfig = chatgpt

const seo = {
  title: 'ChatGPT Conversation Mockup Generator — Create Fake AI Chats | maratool',
  description: 'Create realistic ChatGPT conversation screenshots online. Edit messages inline, toggle dark mode, download as PNG. Free, no sign-up required.',
  canonical: 'https://maratool.com/chatgpt-mockup',
  schema: {
    '@context': 'https://schema.org',
    '@type': 'WebApplication',
    name: 'ChatGPT Conversation Mockup Generator',
    url: 'https://maratool.com/chatgpt-mockup',
    applicationCategory: 'DesignApplication',
    operatingSystem: 'Any',
    offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
    description: 'Create realistic ChatGPT conversation screenshots with inline editing, dark mode, and PNG export.',
  },
  breadcrumbSchema: {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://maratool.com' },
      { '@type': 'ListItem', position: 2, name: 'Mockup', item: 'https://maratool.com/mockup' },
      { '@type': 'ListItem', position: 3, name: 'AI Chat', item: 'https://maratool.com/mockup/ai-chat' },
      { '@type': 'ListItem', position: 4, name: 'ChatGPT Conversation Mockup Generator', item: 'https://maratool.com/chatgpt-mockup' },
    ],
  },
  faqSchema: {
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: [
      {
        '@type': 'Question',
        name: 'Is this ChatGPT mockup generator free?',
        acceptedAnswer: { '@type': 'Answer', text: 'Yes, completely free. No sign-up, no watermark. Create unlimited ChatGPT conversation mockups and download them as PNG.' }
      },
      {
        '@type': 'Question',
        name: 'Does this tool send my data anywhere?',
        acceptedAnswer: { '@type': 'Answer', text: 'No. Everything runs in your browser. Your messages never leave your device. The PNG is generated locally using html2canvas.' }
      },
      {
        '@type': 'Question',
        name: 'Can I make a dark mode ChatGPT screenshot?',
        acceptedAnswer: { '@type': 'Answer', text: 'Yes. Click the dark mode toggle above the phone preview to switch between light and dark ChatGPT themes.' }
      },
      {
        '@type': 'Question',
        name: 'Can I edit messages after adding them?',
        acceptedAnswer: { '@type': 'Answer', text: 'Yes. Click any message directly in the preview to edit its text inline. Changes are reflected immediately.' }
      }
    ]
  }
}

const howTo = [
  'Toggle between User and Assistant roles, type a message, and click Send.',
  'Click any message in the phone preview to edit it inline.',
  'Toggle dark mode or hide the phone frame, then click Download PNG.'
]

const faq = [
  { q: 'Is this ChatGPT mockup generator free?', a: 'Yes, completely free. No sign-up, no watermark. Create unlimited mockups and download as PNG.' },
  { q: 'Does this tool send my data anywhere?', a: 'No. Everything runs in your browser. Your messages never leave your device.' },
  { q: 'Can I make a dark mode ChatGPT screenshot?', a: 'Yes. Click the dark mode toggle above the phone preview to switch themes.' },
  { q: 'Can I edit messages after adding them?', a: 'Yes. Click any message in the preview to edit its text inline.' }
]

const relatedTools = [
  { slug: 'whatsapp-chat-mockup', name: 'WhatsApp Chat Mockup' },
  { slug: 'imessage-chat-mockup', name: 'iMessage Chat Mockup' },
  { slug: 'discord-chat-mockup', name: 'Discord Chat Mockup' },
]

const breadcrumbs = [
  { label: 'Home', href: '/' },
  { label: 'Mockup', href: '/mockup' },
  { label: 'AI Chat', href: '/mockup/ai-chat' },
  { label: 'ChatGPT Conversation Mockup' },
]
---
<Base {...seo}>
  <Layout>
    <ToolShell slug="chatgpt-mockup" name="ChatGPT Conversation Mockup Generator" description="Create realistic ChatGPT conversation screenshots. Edit messages inline, toggle dark mode, download as PNG." howTo={howTo} faq={faq} relatedTools={relatedTools} breadcrumbs={breadcrumbs}>
      <div class="tool-container" style="min-height:600px;">
        <div class="mockup-workspace">
          <!-- Controls panel -->
          <div class="controls-panel">
            <div class="controls-section">
              <h3 class="controls-label">New Message</h3>
              <div class="dir-toggle">
                <button class="active" id="dir-outgoing">User</button>
                <button id="dir-incoming">Assistant</button>
              </div>
              <div class="ctrl-row">
                <input type="text" class="ctrl-input" id="new-msg-text" placeholder="Type a message...">
                <button class="mockup-btn mockup-btn-primary" id="add-msg-btn">Send</button>
              </div>
            </div>
            <div class="controls-section">
              <h3 class="controls-label">Messages</h3>
              <div id="msg-list" style="max-height:420px;overflow-y:auto"></div>
            </div>
          </div>

          <!-- Preview -->
          <div class="mockup-preview">
            <div class="mockup-action-bar">
              <button class="mockup-btn mockup-btn-outline" id="toggle-dark">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 12.79A9 9 0 1111.21 3 7 7 0 0021 12.79z"/></svg>
                Dark mode
              </button>
              <button class="mockup-btn mockup-btn-outline" id="toggle-frame">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="5" y="2" width="14" height="20" rx="2" ry="2"/><line x1="12" y1="18" x2="12.01" y2="18"/></svg>
                Hide frame
              </button>
              <div style="flex:1"></div>
              <button class="mockup-btn mockup-btn-primary" id="download-btn">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
                Download PNG
              </button>
            </div>

            <div class="phone-frame" id="phone-frame">
              <div class="phone-notch"></div>
              <div class="phone-screen" id="phone-screen">
                <div class="gpt-screen">
                  <div class="gpt-statusbar">
                    <span class="gpt-statusbar-time">15:08</span>
                    <span style="flex:1"></span>
                    <span class="gpt-statusbar-icons">
                      <svg viewBox="0 0 18 12" fill="currentColor" width="16" height="11"><rect x="0" y="9" width="3" height="3" rx="1"/><rect x="5" y="6" width="3" height="6" rx="1"/><rect x="10" y="3" width="3" height="9" rx="1"/><rect x="15" y="0" width="3" height="12" rx="1"/></svg>
                      <svg viewBox="0 0 16 12" fill="currentColor" width="15" height="11"><path d="M8.5 1.5C10.4 1.5 12.1 2.3 13.3 3.5L14.7 2.1C13.1 0.5 10.9 -0.5 8.5 -0.5C6.1 -0.5 3.9 0.5 2.3 2.1L3.7 3.5C4.9 2.3 6.6 1.5 8.5 1.5Z M5.1 5C5.9 4.2 7.1 3.7 8.5 3.7C9.9 3.7 11.1 4.2 11.9 5L8.5 8.5L5.1 5Z"/></svg>
                      <svg viewBox="0 0 25 12" fill="none" width="25" height="12"><rect x="0.5" y="0.5" width="21" height="11" rx="3.5" stroke="currentColor" stroke-width="1"/><rect x="2" y="2" width="18" height="8" rx="2" fill="currentColor"/><path d="M23 4.5C23.5523 4.5 24 4.94772 24 5.5V6.5C24 7.05228 23.5523 7.5 23 7.5" fill="currentColor"/></svg>
                    </span>
                  </div>
                  <!-- Minimal header: model chip centered + sidebar icon -->
                  <div class="gpt-header">
                    <span class="gpt-header-sidebar">
                      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M21 18H9M21 12H3M21 6H9"/></svg>
                    </span>
                    <div class="gpt-model-chip" id="gpt-model-chip">
                      <span>ChatGPT 4o</span>
                      <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="6 9 12 15 18 9"/></svg>
                    </div>
                    <span class="gpt-header-new">
                      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 013 3L7 19l-4 1 1-4L16.5 3.5z"/></svg>
                    </span>
                  </div>
                  <!-- Chat area -->
                  <div class="gpt-chat" id="gpt-chat"></div>
                  <!-- Input bar -->
                  <div class="gpt-input-bar">
                    <div class="gpt-input-wrap">
                      <span class="gpt-input-attach">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21.44 11.05l-9.19 9.19a6 6 0 01-8.49-8.49l9.19-9.19a4 4 0 015.66 5.66l-9.2 9.19a2 2 0 01-2.83-2.83l8.49-8.49"/></svg>
                      </span>
                      <input type="text" class="gpt-input-field" placeholder="Message ChatGPT" disabled>
                      <span class="gpt-input-send">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2L12 22M12 2L5 9M12 2L19 9"/></svg>
                      </span>
                    </div>
                  </div>
                  <div class="gpt-disclaimer">ChatGPT can make mistakes. Check important info.</div>
                  <div class="gpt-home-indicator"></div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </ToolShell>
  </Layout>
</Base>

<link rel="stylesheet" href="/styles/mockup.css" />

<script define:vars={{ platformConfig }}>
  window.__mockupPlatform = platformConfig
</script>
<script is:inline src="https://cdn.jsdelivr.net/npm/html2canvas@1.4.1/dist/html2canvas.min.js"></script>
<script src="../tools/mockup/mockup-common.js"></script>
<script src="../tools/mockup/ai-chat-engine.js"></script>

<style is:global>
/* Ensure the mockup phone is centered in the preview area */
.mockup-preview {
  display: flex;
  flex-direction: column;
  align-items: center;
}
</style>
