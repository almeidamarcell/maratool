---
import Base from '../layouts/Base.astro'
import Layout from '../components/Layout.astro'
import HubPage from '../components/HubPage.astro'
import { toolsFlatByCategory, subcategoryOrderByCategory, buildToolItemList } from '../data/tools'

const categoryTools = toolsFlatByCategory['E-commerce'] ?? []
const subcategories = subcategoryOrderByCategory['E-commerce'] ?? []
const liveCategoryTools = categoryTools.filter(t => t.live)

const seo = {
  title: 'E-commerce Fee Calculators — Amazon & Etsy | maratool',
  description: 'Free e-commerce fee calculators for Amazon and Etsy sellers. Estimate referral fees, FBA costs, and net profit per sale — runs in your browser.',
  canonical: 'https://maratool.com/e-commerce',
  schema: {
    '@context': 'https://schema.org',
    '@type': 'CollectionPage',
    name: 'E-commerce Calculators',
    url: 'https://maratool.com/e-commerce',
    description: 'Free e-commerce fee calculators for Amazon and Etsy sellers.',
    hasPart: liveCategoryTools.map(tool => ({
      '@type': 'SoftwareApplication',
      name: tool.name,
      url: `https://maratool.com/${tool.slug}`,
      applicationCategory: 'BusinessApplication',
    })),
    mainEntity: buildToolItemList(liveCategoryTools, 'E-commerce Calculators'),
  },
  breadcrumbSchema: {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://maratool.com' },
      { '@type': 'ListItem', position: 2, name: 'E-commerce', item: 'https://maratool.com/e-commerce' },
    ],
  },
}

const editorial = `
<h2>About these e-commerce calculators</h2>
<p>Marketplace fees eat into margins fast. These calculators estimate platform fees so you can price products profitably before listing.</p>
<h3>What you can calculate</h3>
<p>The <a href="/amazon-fee-calculator">Amazon fee calculator</a> estimates referral and FBA fees by category. The <a href="/etsy-fee-calculator">Etsy fee calculator</a> breaks down listing, transaction, and payment processing costs.</p>
<h3>Privacy</h3>
<p>All calculations run in your browser. Pricing data never leaves your device.</p>
`
---
<Base {...seo} scope="hub">
  <Layout scope="hub">
    <HubPage
      category="E-commerce"
      categorySlug="e-commerce"
      title="E-commerce calculators"
      subtitle="Amazon and Etsy seller fee calculators — everything runs locally in your browser."
      tools={categoryTools}
      subcategories={subcategories}
      basePath="/e-commerce"
      editorial={editorial}
    />
  </Layout>
</Base>
