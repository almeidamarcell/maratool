---
import ScoreCalc from '../components/ScoreCalc.astro'

const spec = {
  items: [
    { id: 'albumin', label: 'Albumin < 3.0 g/dL', options: [
      { label: 'No (0)', points: 0, default: true }, { label: 'Yes (1)', points: 1 },
    ]},
    { id: 'inr', label: 'INR > 1.5', options: [
      { label: 'No (0)', points: 0, default: true }, { label: 'Yes (1)', points: 1 },
    ]},
    { id: 'mental', label: 'Altered mental status (GCS < 14)', options: [
      { label: 'No (0)', points: 0, default: true }, { label: 'Yes (1)', points: 1 },
    ]},
    { id: 'sbp', label: 'Systolic BP ≤ 90 mmHg', options: [
      { label: 'No (0)', points: 0, default: true }, { label: 'Yes (1)', points: 1 },
    ]},
    { id: 'age', label: 'Age > 65 years', options: [
      { label: 'No (0)', points: 0, default: true }, { label: 'Yes (1)', points: 1 },
    ]},
  ],
  bands: [
    { min: 0, max: 1, label: 'Score 0–1 — low in-hospital mortality (≈ 0.3–1%)', cls: 'cls-normal' },
    { min: 2, max: 2, label: 'Score 2 — intermediate mortality (≈ 3%)', cls: 'cls-warn' },
    { min: 3, max: 5, label: 'Score ≥ 3 — high mortality (≈ 9–25%)', cls: 'cls-danger' },
  ],
  max: 5,
}

const faq = [
  { q: 'What is the AIMS65 score?', a: 'A 5-point score (Albumin, INR, Mental status, Systolic BP, age 65) that predicts in-hospital mortality in acute upper gastrointestinal bleeding.' },
  { q: 'AIMS65 vs Glasgow-Blatchford?', a: 'AIMS65 best predicts mortality and is simple to calculate; Glasgow-Blatchford better identifies low-risk patients suitable for outpatient management.' },
  { q: 'What AIMS65 score is high risk?', a: 'Mortality rises with each point — a score ≥ 2 is generally considered high risk and ≥ 3 carries markedly increased mortality.' },
  { q: 'When is AIMS65 calculated?', a: 'At initial presentation with upper GI bleeding, using the first available labs and vital signs.' },
]
const references = [
  { citation: 'Saltzman JR, Tabak YP, Hyett BH, et al. A simple risk score accurately predicts in-hospital mortality, length of stay, and cost in acute upper GI bleeding. <em>Gastrointest Endosc</em>. 2011;74(6):1215-1224.' },
]
const relatedTools = [
  { slug: 'rockall-score', name: 'Rockall Score' },
  { slug: 'has-bled', name: 'HAS-BLED' },
  { slug: 'child-pugh', name: 'Child-Pugh' },
]
---
<ScoreCalc
  slug="aims65-score"
  name="AIMS65 Score Calculator"
  schemaName="AIMS65 Score"
  shortDescription="AIMS65 score for in-hospital mortality in acute upper GI bleeding (0–5)."
  metaTitle="AIMS65 Score Calculator (Upper GI Bleed) | maratool"
  metaDescription="Free AIMS65 calculator. Predict in-hospital mortality in acute upper gastrointestinal bleeding from albumin, INR, mental status, blood pressure, and age."
  subcategory="Score"
  subcategorySlug="score"
  howTo={[
    'Select each of the five AIMS65 criteria present at presentation.',
    'The total score (0–5) and estimated mortality update instantly.',
    'Use to triage upper GI bleeding — pair with Glasgow-Blatchford for discharge decisions.',
  ]}
  faq={faq}
  relatedTools={relatedTools}
  references={references}
  spec={spec}
/>
