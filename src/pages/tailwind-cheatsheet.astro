---
import Base from '../layouts/Base.astro'
import Layout from '../components/Layout.astro'
import ToolShell from '../components/ToolShell.astro'

const seo = {
  title: 'Tailwind CSS Cheat Sheet — All Classes with CSS Output | maratool',
  description: 'Quick reference for Tailwind CSS classes — spacing, typography, colors, flexbox, grid, and more. Search any class and see its CSS output. Click to copy.',
  canonical: 'https://maratool.com/tailwind-cheatsheet',
  schema: {
    '@context': 'https://schema.org',
    '@type': 'WebApplication',
    name: 'Tailwind CSS Cheat Sheet',
    url: 'https://maratool.com/tailwind-cheatsheet',
    applicationCategory: 'DeveloperApplication',
    operatingSystem: 'Any',
    offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
    description: 'Searchable Tailwind CSS cheat sheet with class names and CSS output.',
  },
  breadcrumbSchema: {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://maratool.com' },
      { '@type': 'ListItem', position: 2, name: 'Developer', item: 'https://maratool.com/developer' },
      { '@type': 'ListItem', position: 3, name: 'Reference', item: 'https://maratool.com/developer/reference' },
      { '@type': 'ListItem', position: 4, name: 'Tailwind CSS Cheat Sheet', item: 'https://maratool.com/tailwind-cheatsheet' },
    ],
  },
  faqSchema: {
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: [
      {
        '@type': 'Question',
        name: 'What CSS does a Tailwind class generate?',
        acceptedAnswer: { '@type': 'Answer', text: 'Each Tailwind class maps to one or more CSS properties. For example, "p-4" generates "padding: 1rem" and "flex" generates "display: flex". This cheat sheet shows the exact CSS output for every class.' }
      },
      {
        '@type': 'Question',
        name: 'How do I use arbitrary values in Tailwind?',
        acceptedAnswer: { '@type': 'Answer', text: 'Use square bracket notation for custom values: w-[200px], text-[#1a1a18], p-[13px]. This works with any utility that accepts a value.' }
      },
      {
        '@type': 'Question',
        name: 'What is the Tailwind spacing scale?',
        acceptedAnswer: { '@type': 'Answer', text: 'Tailwind uses a consistent spacing scale where 1 unit = 0.25rem (4px). So p-1 = 0.25rem, p-2 = 0.5rem, p-4 = 1rem, p-8 = 2rem, and so on up to p-96 = 24rem.' }
      },
      {
        '@type': 'Question',
        name: 'How do I find the right Tailwind class?',
        acceptedAnswer: { '@type': 'Answer', text: 'Use the search box on this page to filter by class name or CSS property. Type "flex" to see all flexbox utilities, "rounded" for border-radius classes, or "shadow" for box-shadow options.' }
      }
    ]
  }
}

const howTo = [
  'Use the search box to filter by class name or CSS property.',
  'Click any category to expand or collapse it.',
  'Click a class name to copy it to your clipboard.'
]

const faq = [
  { q: 'What CSS does a Tailwind class generate?', a: 'Each Tailwind class maps to one or more CSS properties. For example, "p-4" generates "padding: 1rem". This cheat sheet shows the exact CSS for every class.' },
  { q: 'How do I use arbitrary values in Tailwind?', a: 'Use square bracket notation: w-[200px], text-[#1a1a18], p-[13px]. This works with any utility that accepts a value.' },
  { q: 'What is the Tailwind spacing scale?', a: 'Tailwind uses a consistent spacing scale where 1 unit = 0.25rem (4px). So p-1 = 0.25rem, p-4 = 1rem, p-8 = 2rem.' },
  { q: 'How do I find the right Tailwind class?', a: 'Use the search box on this page to filter by class name or CSS property. Type "flex" for flexbox, "rounded" for border-radius, etc.' }
]

const relatedTools = [
  { slug: 'tailwind-shades', name: 'Tailwind Shade Generator' },
  { slug: 'css-gradient', name: 'CSS Gradient Generator with Live Preview' },
  { slug: 'color-converter', name: 'Color Converter' },
]

const breadcrumbs = [
  { label: 'Home', href: '/' },
  { label: 'Developer', href: '/developer' },
  { label: 'Reference', href: '/developer/reference' },
  { label: 'Tailwind CSS Cheat Sheet' },
]
---
<Base {...seo}>
  <Layout>
    <ToolShell slug="tailwind-cheatsheet" name="Tailwind CSS Cheat Sheet" description="Searchable reference for Tailwind CSS utility classes with their CSS output. Click any class to copy." howTo={howTo} faq={faq} relatedTools={relatedTools} breadcrumbs={breadcrumbs}>
      <div class="tool-container" style="min-height:300px;">
        <div class="tw-search-wrap">
          <input type="text" id="tw-search" class="tool-input tw-search" placeholder="Search classes or CSS properties (e.g. flex, padding, rounded)" />
          <span class="tw-count" id="tw-count"></span>
        </div>
        <div id="tw-content" class="tw-content"></div>
      </div>
    </ToolShell>
  </Layout>
</Base>
<style is:global>
  .tw-search-wrap {
    position: relative;
    margin-bottom: 1rem;
  }
  .tw-search {
    width: 100%;
    font-size: 16px;
    padding-right: 80px;
  }
  .tw-count {
    position: absolute;
    right: 12px;
    top: 50%;
    transform: translateY(-50%);
    font-size: 12px;
    color: var(--text-3);
  }

  .tw-category {
    margin-bottom: 0.75rem;
    border: 1px solid var(--border);
    border-radius: var(--radius);
    overflow: hidden;
  }
  .tw-category-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 10px 14px;
    background: var(--bg-soft);
    cursor: pointer;
    user-select: none;
    transition: background 0.1s;
  }
  .tw-category-header:hover { background: var(--bg-hover); }
  .tw-category-title {
    font-size: 14px;
    font-weight: 600;
    color: var(--text);
  }
  .tw-category-badge {
    font-size: 11px;
    color: var(--text-3);
    background: var(--bg);
    padding: 2px 8px;
    border-radius: 99px;
    border: 1px solid var(--border);
  }
  .tw-category-body {
    display: none;
  }
  .tw-category.open .tw-category-body {
    display: block;
  }

  .tw-table {
    width: 100%;
    border-collapse: collapse;
  }
  .tw-table th {
    text-align: left;
    font-size: 11px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--text-3);
    padding: 6px 14px;
    border-bottom: 1px solid var(--border);
    background: var(--bg);
  }
  .tw-table td {
    padding: 6px 14px;
    font-size: 13px;
    border-bottom: 1px solid var(--border);
    transition: background 0.1s;
  }
  .tw-table tr:hover td { background: var(--bg-soft); }
  .tw-table tr:last-child td { border-bottom: none; }
  .tw-class {
    font-family: var(--font-mono);
    font-weight: 500;
    color: var(--accent);
    cursor: pointer;
  }
  .tw-class.copied {
    color: var(--text);
  }
  .tw-css {
    font-family: var(--font-mono);
    color: var(--text-2);
    font-size: 12px;
  }

  .tw-empty {
    text-align: center;
    color: var(--text-3);
    padding: 2rem 1rem;
    font-size: 14px;
  }
  .tw-tip {
    font-size: 12px;
    color: var(--text-3);
    margin-top: 1rem;
    padding: 8px 12px;
    background: var(--bg-soft);
    border-radius: var(--radius);
  }
  .tw-tip code {
    font-family: var(--font-mono);
    background: var(--bg);
    padding: 1px 4px;
    border-radius: 3px;
    font-size: 11px;
  }
</style>
<script src="../tools/tailwind-cheatsheet.js"></script>
