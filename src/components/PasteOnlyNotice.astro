---
interface Props {
  toolName?: string
}
const { toolName = 'This tool' } = Astro.props
---
<div class="paste-only-notice" role="note">
  <strong>Paste only — cannot fetch live URLs.</strong>
  {toolName} analyzes content you paste into the box. Browsers block websites from loading other sites' HTML (CORS), so we cannot enter a URL and pull your page automatically. Copy HTML from <em>View Source</em> (Ctrl+U / Cmd+Option+U), your CMS, or a saved file.
</div>

<style is:global>
  .paste-only-notice {
    margin: 0 0 1.25rem;
    padding: 0.875rem 1rem;
    font-size: 13px;
    line-height: 1.55;
    color: var(--text);
    background: #fff8e6;
    border: 1px solid #e8d9a8;
    border-radius: var(--radius);
  }
  .paste-only-notice strong {
    display: block;
    margin-bottom: 0.25rem;
    color: #8a6d1d;
  }
</style>
