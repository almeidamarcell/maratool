---
interface Props {
  slug: string
  title?: string
  height?: number
}
const { slug, title, height = 520 } = Astro.props
const toolUrl = `/${slug}`
const embedUrl = `${toolUrl}?embed=1`
---
<figure class="blog-tool-embed">
  {title && <figcaption class="blog-tool-embed-caption">{title}</figcaption>}
  <iframe
    src={embedUrl}
    title={title ?? `Embedded ${slug} tool`}
    class="blog-tool-embed-frame"
    height={height}
    loading="lazy"
  ></iframe>
  <p class="blog-tool-embed-link">
    <a href={toolUrl}>Open full tool →</a>
  </p>
</figure>

<style is:global>
  .blog-tool-embed {
    margin: 1.5rem 0;
    padding: 0;
  }
  .blog-tool-embed-caption {
    font-size: 13px;
    color: var(--text-2);
    margin: 0 0 0.5rem;
  }
  .blog-tool-embed-frame {
    display: block;
    width: 100%;
    border: 1px solid var(--border);
    border-radius: var(--radius);
    background: var(--bg);
  }
  .blog-tool-embed-link {
    margin: 0.5rem 0 0;
    font-size: 13px;
    text-align: right;
  }
  .blog-tool-embed-link a {
    color: var(--accent);
    text-decoration: none;
  }
  .blog-tool-embed-link a:hover { text-decoration: underline; }
</style>
