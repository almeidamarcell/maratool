---
import { tools, toolsBySubcategory, subcategoryOrder } from '../data/tools'

const currentPath = Astro.url.pathname

// Determine active subcategory from path or from the active tool
const subcategoryMatch = currentPath.match(/^\/developer\/([^/]+)\/?$/)
const activeSubcategoryFromPath = subcategoryMatch ? subcategoryMatch[1] : null
const activeTool = tools.find(t => currentPath === `/${t.slug}` || currentPath === `/${t.slug}/`)
const activeSubcategory = activeSubcategoryFromPath ?? (activeTool?.subcategory?.toLowerCase() ?? null)
---
<nav class="sidebar" aria-label="Tools navigation">
  <details class="sidebar-group" open>
    <summary class="sidebar-category">
      <a href="/developer" class="sidebar-category-label">Developer</a>
      <svg class="sidebar-chevron" width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true">
        <path d="M3 4.5L6 7.5L9 4.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </summary>

    {subcategoryOrder.map(sub => (
      <div class="sidebar-subcategory-group">
        <a
          href={`/developer/${sub.toLowerCase()}`}
          class:list={['sidebar-subcategory', { active: activeSubcategory === sub.toLowerCase() }]}
        >{sub}</a>
        {(toolsBySubcategory[sub] ?? []).map(tool => (
          <a
            href={tool.live ? `/${tool.slug}` : undefined}
            class:list={[
              'sidebar-link',
              { active: currentPath === `/${tool.slug}` || currentPath === `/${tool.slug}/` },
              { 'coming-soon': !tool.live }
            ]}
            aria-current={currentPath === `/${tool.slug}` ? 'page' : undefined}
          >
            <span class="sidebar-link-emoji">{tool.emoji}</span>
            <span>{tool.name}</span>
          </a>
        ))}
      </div>
    ))}
  </details>
</nav>

<script>
  // Clicking the Developer label navigates without toggling <details>
  document.querySelectorAll('.sidebar-category-label').forEach(a => {
    a.addEventListener('click', e => e.stopPropagation())
  })
</script>
