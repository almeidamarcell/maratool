---
import {
  tools,
  toolsByCategory,
  toolsFlatByCategory,
  categoryOrder,
  subcategoryOrderByCategory,
} from '../data/tools'

interface Props {
  scope?: 'home' | 'hub' | 'subcategory' | 'tool' | 'all' | 'page'
}

const { scope = 'page' } = Astro.props

const currentPath = Astro.url.pathname

// Identify the active tool, category, subcategory from the URL
const activeTool = tools.find(t => currentPath === `/${t.slug}` || currentPath === `/${t.slug}/`)

const categorySlugMap: Record<string, string> = {}
for (const cat of categoryOrder) {
  categorySlugMap[cat.toLowerCase()] = cat
}

const categoryPageMatch = currentPath.match(/^\/([^/]+)\/?$/)
const subcategoryPageMatch = currentPath.match(/^\/([^/]+)\/([^/]+)\/?$/)
const activeCategoryFromPage = categoryPageMatch ? categorySlugMap[categoryPageMatch[1]] : null
const activeCategoryFromSubPage = subcategoryPageMatch ? categorySlugMap[subcategoryPageMatch[1]] : null
const activeCategory = activeTool?.category ?? activeCategoryFromPage ?? activeCategoryFromSubPage ?? null
const activeCategorySlug = activeCategory ? activeCategory.toLowerCase() : null

const activeSubcategorySlug = subcategoryPageMatch ? subcategoryPageMatch[2] : null
const activeSubcategoryFromTool = activeTool?.subcategory?.toLowerCase() ?? null
const activeSubcategory = activeSubcategorySlug ?? activeSubcategoryFromTool

// Counts
const catCounts: Record<string, number> = {}
for (const cat of categoryOrder) {
  catCounts[cat] = (toolsFlatByCategory[cat] ?? []).filter(t => t.live).length
}

// Auto-detect effective scope from URL when not provided explicitly
let effectiveScope: 'home' | 'hub' | 'subcategory' | 'tool' | 'all' | 'page' = scope
if (scope === 'page') {
  if (currentPath === '/' || currentPath === '/index') effectiveScope = 'home'
  else if (currentPath === '/all' || currentPath === '/all/') effectiveScope = 'all'
  else if (activeTool) effectiveScope = 'tool'
  else if (subcategoryPageMatch && activeCategory) effectiveScope = 'subcategory'
  else if (categoryPageMatch && activeCategory) effectiveScope = 'hub'
}

const isHubScope = effectiveScope === 'hub' || effectiveScope === 'subcategory'
const showVerticalsList = effectiveScope === 'home' || effectiveScope === 'all' || effectiveScope === 'page'

// For hub scope: subcategories of the active hub
const hubSubs = isHubScope && activeCategory
  ? (subcategoryOrderByCategory[activeCategory] ?? []).filter(sub => {
      const toolsInSub = (toolsByCategory[activeCategory]?.[sub] ?? []).filter(t => t.live)
      return toolsInSub.length > 0
    })
  : []

const hubSubCounts: Record<string, number> = {}
if (isHubScope && activeCategory) {
  for (const sub of hubSubs) {
    hubSubCounts[sub] = (toolsByCategory[activeCategory]?.[sub] ?? []).filter(t => t.live).length
  }
}

// For tool scope: sibling tools in same subcategory
const siblingTools = effectiveScope === 'tool' && activeTool
  ? (toolsByCategory[activeTool.category]?.[activeTool.subcategory] ?? [])
      .filter(t => t.live && t.slug !== activeTool.slug)
      .slice(0, 10)
  : []
---
<nav class="sidebar" id="site-sidebar" aria-label="Tools navigation">

  <!-- Pinned (rendered by JS from localStorage) -->
  <div id="sidebar-pinned" class="sidebar-pinned" hidden>
    <div class="sidebar-pinned-title"><span class="pin-mark">★</span> Pinned</div>
    <div id="sidebar-pinned-list"></div>
    <div class="sidebar-divider"></div>
  </div>

  <!-- Recently used (rendered by JS from localStorage) -->
  <div id="sidebar-recent" class="sidebar-recent" hidden>
    <div class="sidebar-recent-title">Recently used</div>
    <div id="sidebar-recent-list"></div>
    <div class="sidebar-divider" id="sidebar-recent-divider"></div>
  </div>

  {showVerticalsList && (
    <div class="sidebar-verticals">
      <div class="sidebar-pinned-title" style="color: var(--text-3); font-size: 0.875rem;">Verticals</div>
      {categoryOrder.map(cat => {
        const catSlug = cat.toLowerCase()
        return (
          <a
            href={`/${catSlug}`}
            class:list={['sidebar-vertical-link', { active: activeCategory === cat && !activeSubcategory && !activeTool }]}
          >
            <span class="cat-dot" data-cat={catSlug}></span>
            {cat}
            <span class="count">{catCounts[cat]}</span>
          </a>
        )
      })}
      <div class="sidebar-divider"></div>
      <a
        href="/all"
        class:list={['sidebar-vertical-link', { active: effectiveScope === 'all' }]}
      >
        All tools
        <span class="count">{tools.filter(t => t.live).length}</span>
      </a>
    </div>
  )}

  {isHubScope && activeCategory && (
    <div class="sidebar-hub-subs">
      <div class="sidebar-pinned-title" style="color: var(--text-3); font-size: 0.875rem;">{activeCategory} filters</div>
      <a
        href={`/${activeCategorySlug}`}
        class:list={['sidebar-hub-sub', { active: !activeSubcategory }]}
      >
        <span class="cat-dot" data-cat={activeCategorySlug}></span>
        All {activeCategory}
        <span class="count">{catCounts[activeCategory]}</span>
      </a>
      {hubSubs.map(sub => (
        <a
          href={`/${activeCategorySlug}/${sub.toLowerCase()}`}
          class:list={['sidebar-hub-sub', { active: activeSubcategory === sub.toLowerCase() }]}
        >
          {sub}
          <span class="count">{hubSubCounts[sub]}</span>
        </a>
      ))}
      <div class="sidebar-divider"></div>
      <a href="/" class="sidebar-back-link">← Back to maratool</a>
    </div>
  )}

  {effectiveScope === 'tool' && activeTool && (
    <div class="sidebar-hub-subs">
      <div class="sidebar-pinned-title" style="color: var(--text-3); font-size: 0.875rem;">
        In {activeTool.subcategory}
      </div>
      {siblingTools.map(tool => (
        <a
          href={`/${tool.slug}`}
          class="sidebar-hub-sub"
        >
          <span class="sidebar-link-emoji">{tool.emoji}</span>
          {tool.name}
        </a>
      ))}
      <div class="sidebar-divider"></div>
      <a href={`/${activeCategorySlug}`} class="sidebar-back-link">← All {activeCategory}</a>
      <a href="/" class="sidebar-back-link">← maratool home</a>
    </div>
  )}
</nav>

<script>
  ;(function () {
    var pinnedKey = 'maratool_pinned'
    var recentKey = 'maratool_recent'
    var maxRecent = 5
    var maxPinned = 8

    var pinnedEl = document.getElementById('sidebar-pinned')
    var pinnedList = document.getElementById('sidebar-pinned-list')
    var recentEl = document.getElementById('sidebar-recent')
    var recentList = document.getElementById('sidebar-recent-list')

    function load(key: string) {
      try {
        var raw = localStorage.getItem(key)
        if (!raw) return []
        var parsed = JSON.parse(raw)
        return Array.isArray(parsed) ? parsed : []
      } catch (e) { return [] }
    }

    function renderRow(item: any) {
      var emoji = item.emoji ? '<span class="sidebar-link-emoji">' + item.emoji + '</span>' : ''
      return '<a href="/' + item.slug + '" class="sidebar-hub-sub">' + emoji + item.name + '</a>'
    }

    var pinned = load(pinnedKey).slice(0, maxPinned)
    if (pinned.length > 0 && pinnedList && pinnedEl) {
      pinnedList.innerHTML = pinned.map(renderRow).join('')
      pinnedEl.hidden = false
    }

    var recent = load(recentKey).slice(0, maxRecent)
    if (recent.length > 0 && recentList && recentEl) {
      recentList.innerHTML = recent.map(renderRow).join('')
      recentEl.hidden = false
    }
  })()
</script>
