---
import Base from '../layouts/Base.astro'
import Layout from './Layout.astro'
import ToolShell from './ToolShell.astro'
import References from './References.astro'
import ReviewedBy from './ReviewedBy.astro'
import { tools, getSpecialty, MEDICAL_CONDITIONS } from '../data/tools'
import { lastmodBySlug } from '../data/lastmod-generated'

interface FAQItem { q: string; a: string }
interface Reference { citation: string; url?: string }
interface RelatedTool { slug: string; name: string }

interface Props {
  slug: string
  name: string
  shortDescription: string  // appears under H1
  metaTitle: string
  metaDescription: string
  subcategory: string       // 'General' | 'Renal' | etc.
  subcategorySlug: string   // lowercase slug
  schemaName: string        // for WebApplication JSON-LD
  howTo: string[]
  faq: FAQItem[]
  relatedTools: RelatedTool[]
  references: Reference[]
  // YMYL E-E-A-T fields (optional). When clinician reviewer is unknown,
  // ReviewedBy renders an explicit "not yet reviewed" notice.
  lastReviewed?: string | null
  reviewer?: string | null
  reviewerCredentials?: string | null
  // Optional "what is X" passage rendered above "How to use".
  whatIs?: string
}

const {
  slug, name, shortDescription, metaTitle, metaDescription,
  subcategory, subcategorySlug, schemaName, howTo, faq, relatedTools, references,
  lastReviewed = null, reviewer = null, reviewerCredentials = null,
  whatIs,
} = Astro.props

// Look up the tool registry entry so we can enrich JSON-LD with
// medicalAudience and relevantSpecialty (strong YMYL E-E-A-T signal).
const toolEntry = tools.find(t => t.slug === slug)
const specialty = toolEntry ? getSpecialty(toolEntry) : null

// Map maratool's internal specialty taxonomy → schema.org MedicalSpecialty
// enum names. Schema.org MedicalSpecialty values use suffixes like -ic / -al.
const SPECIALTY_TO_SCHEMA: Record<string, string> = {
  Cardiology: 'Cardiovascular',
  Renal: 'Renal',
  Hepatology: 'Hepatologic',
  Pediatric: 'Pediatric',
  Obstetric: 'Obstetric',
  Endocrine: 'Endocrine',
  Trauma: 'Emergency',
  Pulmonary: 'Pulmonary',
  Neurology: 'Neurologic',
  Oncology: 'Oncologic',
  GI: 'PrimaryCare',
  Hematology: 'Hematologic',
  Infectious: 'Infectious',
  Psych: 'Psychiatric',
  ICU: 'Emergency',
  Drug: 'PharmacySpecialty',
  Infusion: 'Anesthesia',
  Ventilation: 'Pulmonary',
  Anthropometric: 'PrimaryCare',
  Electrolytes: 'Renal',
  General: 'PrimaryCare',
  Scale: 'PrimaryCare',
  Screening: 'PrimaryCare',
  Score: 'PrimaryCare',
  Prognosis: 'PrimaryCare',
  Reference: 'PrimaryCare',
}
const schemaSpecialty = specialty ? (SPECIALTY_TO_SCHEMA[specialty] ?? 'PrimaryCare') : null

const calcSchema: Record<string, unknown> = {
  '@context': 'https://schema.org',
  '@type': ['MedicalRiskCalculator', 'WebApplication'],
  name: schemaName,
  url: `https://maratool.com/${slug}`,
  applicationCategory: 'HealthApplication',
  operatingSystem: 'Any',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
  description: metaDescription,
  medicalAudience: [
    { '@type': 'MedicalAudience', audienceType: 'Physician' },
    { '@type': 'MedicalAudience', audienceType: 'Nurse' },
  ],
}
if (schemaSpecialty && specialty) {
  calcSchema.relevantSpecialty = {
    '@type': 'MedicalSpecialty',
    name: schemaSpecialty,
    alternateName: specialty,
  }
}

const condition = MEDICAL_CONDITIONS[slug]
if (condition) {
  calcSchema.about = {
    '@type': 'MedicalCondition',
    name: condition.name,
    ...(condition.alternateName ? { alternateName: condition.alternateName } : {}),
  }
}

const lastmodDate = lastmodBySlug[slug]
if (lastmodDate) {
  calcSchema.dateModified = lastmodDate
}

const seo = {
  title: metaTitle,
  description: metaDescription,
  canonical: `https://maratool.com/${slug}`,
  schema: calcSchema,
  breadcrumbSchema: {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://maratool.com' },
      { '@type': 'ListItem', position: 2, name: 'Health', item: 'https://maratool.com/health' },
      { '@type': 'ListItem', position: 3, name: subcategory, item: `https://maratool.com/health/${subcategorySlug}` },
      { '@type': 'ListItem', position: 4, name: schemaName, item: `https://maratool.com/${slug}` },
    ],
  },
  faqSchema: {
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: faq.map(item => ({
      '@type': 'Question',
      name: item.q,
      acceptedAnswer: { '@type': 'Answer', text: item.a.replace(/<[^>]+>/g, '') },
    })),
  },
}

const breadcrumbs = [
  { label: 'Home', href: '/' },
  { label: 'Health', href: '/health' },
  { label: subcategory, href: `/health/${subcategorySlug}` },
  { label: name },
]
---
<Base {...seo}>
  <Layout>
    <ToolShell
      slug={slug}
      name={name}
      description={shortDescription}
      howTo={howTo}
      faq={faq}
      relatedTools={relatedTools}
      breadcrumbs={breadcrumbs}
      whatIs={whatIs}
    >
      <div class="tool-container hcalc-container">
        <div class="hcalc-disclaimer">For educational and clinical reference. Not a substitute for medical judgment. See the <a href="/medical-disclaimer/">medical disclaimer</a>.</div>
        <slot />
      </div>
      <ReviewedBy
        lastReviewed={lastReviewed}
        reviewer={reviewer}
        reviewerCredentials={reviewerCredentials}
      />
      <References references={references} />
    </ToolShell>
  </Layout>
</Base>
