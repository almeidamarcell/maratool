---
interface Props {
  name: string
}

const { name } = Astro.props
---
<div class="tool-container" style="display:flex;align-items:center;justify-content:center;flex-direction:column;gap:0.75rem;">
  <p style="font-size:1.125rem;font-weight:600;color:var(--text);">{name}</p>
  <span style="padding:4px 12px;background:var(--bg-soft);border:1px solid var(--border);border-radius:100px;font-size:12px;color:var(--text-3);font-weight:500;">Coming soon</span>
</div>
