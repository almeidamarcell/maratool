---
interface Props {
  title: string
  lead: string
  date: string
  dateIso: string
}
const { title, lead, date, dateIso } = Astro.props
---
<article class="blog-post">
  <header class="blog-post-header">
    <div class="blog-post-meta">
      <a href="/blog" class="blog-back">&larr; Blog</a>
      <time datetime={dateIso} class="blog-post-date">{date}</time>
      <span class="blog-post-author">by <a href="https://marcell.com.br/" target="_blank" rel="noopener">Marcell Almeida</a></span>
    </div>
    <h1 class="blog-post-title">{title}</h1>
    <p class="blog-post-lead">{lead}</p>
  </header>
  <div class="blog-body">
    <slot />
  </div>
</article>

<style is:global>
  .blog-post { max-width: 720px; margin: 0 auto; padding: 2rem 1rem 4rem; }
  .blog-post-meta { display: flex; flex-wrap: wrap; gap: 0.75rem; align-items: center; font-size: 14px; color: var(--text-2); margin-bottom: 1rem; }
  .blog-back { color: var(--accent); text-decoration: none; }
  .blog-post-title { font-size: 2rem; font-weight: 700; line-height: 1.2; margin: 0 0 0.75rem; }
  .blog-post-lead { font-size: 1.125rem; color: var(--text-2); margin: 0 0 1.5rem; }
  .blog-body { font-size: 1rem; line-height: 1.7; }
  .blog-body h2 { font-size: 1.35rem; margin: 2rem 0 0.75rem; }
  .blog-body ol { padding-left: 1.25rem; }
  .blog-divider { border: none; border-top: 1px solid var(--border); margin: 2rem 0; }
  .blog-footer-note { font-size: 14px; color: var(--text-2); }
</style>
