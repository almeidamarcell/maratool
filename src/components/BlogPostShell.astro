---
interface Props {
  title: string
  lead: string
  date: string
  dateIso: string
}
const { title, lead, date, dateIso } = Astro.props
---
<article class="blog-post">
  <header class="blog-post-header">
    <div class="blog-post-meta">
      <a href="/blog" class="blog-back">&larr; Blog</a>
      <time datetime={dateIso} class="blog-post-date">{date}</time>
      <span class="blog-post-author">by <a href="http://marcell.com.br/" target="_blank" rel="noopener">Marcell Almeida</a></span>
    </div>
    <h1 class="blog-post-title">{title}</h1>
    <p class="blog-post-lead">{lead}</p>
  </header>
  <div class="blog-body">
    <slot />
  </div>
</article>

<style is:global>
  .blog-post {
    max-width: 680px;
    padding: 2.5rem 2rem;
  }
  .blog-post-meta {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 1rem;
  }
  .blog-back {
    font-size: 13px;
    color: var(--text-2);
    text-decoration: none;
  }
  .blog-back:hover { color: var(--accent); }
  .blog-post-date {
    font-size: 12px;
    color: var(--text-3);
  }
  .blog-post-author {
    font-size: 12px;
    color: var(--text-3);
  }
  .blog-post-author a {
    color: var(--text-2);
    text-decoration: none;
  }
  .blog-post-author a:hover { color: var(--accent); }
  .blog-post-header { margin-bottom: 2rem; }
  .blog-post-title {
    font-size: 1.875rem;
    font-weight: 700;
    color: var(--text);
    line-height: 1.2;
    margin: 0 0 0.75rem;
    letter-spacing: -0.02em;
  }
  .blog-post-lead {
    font-size: 16px;
    color: var(--text-2);
    margin: 0;
    line-height: 1.5;
  }
  .blog-body {
    font-size: 15px;
    line-height: 1.7;
    color: var(--text);
  }
  .blog-body p { margin: 0 0 1rem; }
  .blog-body h2 {
    font-size: 1.125rem;
    font-weight: 700;
    color: var(--text);
    margin: 2rem 0 0.5rem;
    letter-spacing: -0.01em;
  }
  .blog-body ul, .blog-body ol {
    margin: 0.5rem 0 1rem 1.25rem;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.375rem;
  }
  .blog-body li { line-height: 1.6; }
  .blog-body code {
    font-family: var(--font-mono, monospace);
    font-size: 13px;
    background: var(--bg-soft);
    border: 1px solid var(--border);
    border-radius: 4px;
    padding: 1px 5px;
    color: var(--text);
  }
  .blog-body a {
    color: var(--accent);
    text-decoration: none;
  }
  .blog-body a:hover { text-decoration: underline; }
  .blog-divider {
    border: none;
    border-top: 1px solid var(--border);
    margin: 2rem 0;
  }
  .blog-footer-note {
    font-size: 14px;
    color: var(--text-2);
    padding: 1rem;
    background: var(--bg-soft);
    border-radius: var(--radius);
    border: 1px solid var(--border);
  }
  @media (max-width: 600px) {
    .blog-post { padding: 1.5rem 1rem; }
    .blog-post-title { font-size: 1.5rem; }
  }
</style>
