---
import Breadcrumb from './Breadcrumb.astro'
import EmbedBadge from './EmbedBadge.astro'
import EmbedButton from './EmbedButton.astro'
import { lastmodBySlug } from '../data/lastmod-generated'

interface FAQItem {
  q: string
  a: string
}

interface RelatedTool {
  slug: string
  name: string
}

interface Props {
  name: string
  slug: string
  description: string
  howTo: string[]
  faq: FAQItem[]
  relatedTools: RelatedTool[]
  breadcrumbs?: Array<{ label: string; href?: string }>
  // Optional self-contained passage answering "what is X?". Renders as a
  // bordered card before "How to use". Designed for LLM citability — one
  // paragraph, no jargon dump, includes the tool name early.
  whatIs?: string
}

const { name, slug, description, howTo, faq, relatedTools, breadcrumbs = [], whatIs } = Astro.props
const lastUpdated = lastmodBySlug[slug] ?? null
const lastUpdatedDisplay = lastUpdated
  ? new Date(lastUpdated + 'T00:00:00Z').toLocaleDateString('en-US', {
      year: 'numeric',
      month: 'long',
      day: 'numeric',
      timeZone: 'UTC',
    })
  : null
---
<article>
  {breadcrumbs.length > 0 && <Breadcrumb crumbs={breadcrumbs} />}
  <div class="tool-header" style="display:flex;align-items:center;justify-content:space-between;gap:1rem;flex-wrap:wrap;">
    <h1 style="margin: 0; flex: 1; min-width: 0;">{name}</h1>
    <div style="display: flex; align-items: center; gap: 0.5rem; flex-shrink: 0;">
      <button
        type="button"
        class="tool-pin"
        id="tool-pin-btn"
        data-tool-slug={slug}
        data-tool-name={name}
        aria-pressed="false"
        aria-label="Pin this tool"
      >
        <span class="star-icon" id="tool-pin-star">☆</span>
        <span id="tool-pin-label">Pin</span>
      </button>
      <EmbedButton slug={slug} />
    </div>
  </div>
  <p class="tool-description">{description}</p>

  <slot />

  {whatIs && (
    <section class="what-is" aria-labelledby="what-is-heading">
      <h2 id="what-is-heading">What is {name.replace(/\s*(Calculator|Generator|Converter|Score|Tool|Online)\s*$/i, '')}?</h2>
      <p set:html={whatIs} />
    </section>
  )}

  <section class="how-to" aria-labelledby="how-to-heading">
    <h2 id="how-to-heading">How to use</h2>
    <ol>
      {howTo.map(step => <li>{step}</li>)}
    </ol>
  </section>

  <section class="faq" aria-labelledby="faq-heading">
    <h2 id="faq-heading">Frequently asked questions</h2>
    {faq.map(item => (
      <div class="faq-item">
        <h3 class="faq-question">{item.q}</h3>
        <p class="faq-answer" set:html={item.a} />
      </div>
    ))}
  </section>

  {relatedTools.length > 0 && (
    <section class="related-tools" aria-labelledby="related-heading">
      <h2 id="related-heading">Related tools</h2>
      <ul class="related-tools-list">
        {relatedTools.map(tool => (
          <li><a href={`/${tool.slug}`}>{tool.name}</a></li>
        ))}
      </ul>
    </section>
  )}
  {lastUpdatedDisplay && (
    <p class="tool-lastmod">
      <span aria-hidden="true">⟳</span> Last updated <time datetime={lastUpdated}>{lastUpdatedDisplay}</time>
    </p>
  )}
  <EmbedBadge toolUrl={`https://maratool.com/${slug}`} />
</article>

<style is:global>
  .tool-lastmod {
    font-size: 12px;
    color: var(--text-3);
    margin: 1.5rem 0 0.5rem;
    font-family: var(--font-mono);
  }
  .tool-lastmod time {
    color: var(--text-2);
  }
  .what-is {
    margin: 2rem 0 1rem;
    padding: 1.25rem 1.5rem;
    background: var(--bg-soft);
    border: 1px solid var(--border);
    border-radius: var(--radius);
  }
  .what-is h2 {
    font-family: var(--font-heading);
    font-style: italic;
    font-weight: 400;
    font-size: 1.375rem;
    margin: 0 0 0.5rem;
    color: var(--text);
  }
  .what-is p {
    font-size: 15px;
    line-height: 1.65;
    color: var(--text);
    margin: 0;
  }
</style>

<script define:vars={{ slug, name }}>
// Track this tool visit in localStorage for "Recently Used"
(function () {
  var key = 'maratool_recent'
  var max = 8
  try {
    var raw = localStorage.getItem(key)
    var items = raw ? JSON.parse(raw) : []
    if (!Array.isArray(items)) items = []
    // Remove existing entry for this tool
    items = items.filter(function (item) { return item.slug !== slug })
    // Find emoji — first try sidebar, then a data attribute we could set
    var link = document.querySelector('a[href="/' + slug + '"] .sidebar-link-emoji')
    var emoji = link ? link.textContent.trim() : ''
    items.unshift({ slug: slug, name: name, emoji: emoji })
    if (items.length > max) items = items.slice(0, max)
    localStorage.setItem(key, JSON.stringify(items))
  } catch (e) {}
})()

// Pin toggle
;(function () {
  var pinnedKey = 'maratool_pinned'
  var maxPinned = 12
  var btn = document.getElementById('tool-pin-btn')
  var star = document.getElementById('tool-pin-star')
  var label = document.getElementById('tool-pin-label')
  if (!btn) return

  function load() {
    try {
      var raw = localStorage.getItem(pinnedKey)
      return raw ? JSON.parse(raw) : []
    } catch (e) { return [] }
  }

  function save(items) {
    try { localStorage.setItem(pinnedKey, JSON.stringify(items)) } catch (e) {}
  }

  function isPinned(items) {
    for (var i = 0; i < items.length; i++) {
      if (items[i].slug === slug) return true
    }
    return false
  }

  function sync() {
    var items = load()
    var pinned = isPinned(items)
    btn.classList.toggle('pinned', pinned)
    btn.setAttribute('aria-pressed', pinned ? 'true' : 'false')
    if (star) star.textContent = pinned ? '★' : '☆'
    if (label) label.textContent = pinned ? 'Pinned' : 'Pin'
  }

  btn.addEventListener('click', function () {
    var items = load()
    var idx = -1
    for (var i = 0; i < items.length; i++) {
      if (items[i].slug === slug) { idx = i; break }
    }
    if (idx >= 0) {
      items.splice(idx, 1)
    } else {
      items.unshift({ slug: slug, name: name })
      if (items.length > maxPinned) items = items.slice(0, maxPinned)
    }
    save(items)
    sync()
  })

  sync()
})()
</script>
